{
  "name": "proficiency-studio-desktop",
  "version": "1.0.0",
  "description": "Proficiency Studio - AI-Powered Proficiency Assessment Desktop Application",
  "main": "dist/main/electron-main.js",
  "author": "Proficiency Studio Team",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:renderer": "vite",
    "dev:electron": "electron .",
    "build": "npm run build:renderer && npm run build:main && npm run build:preload",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:win": "npm run build:backend && npm run build && electron-builder --win",
    "build:mac": "npm run build:backend && npm run build && electron-builder --mac",
    "build:linux": "npm run build:backend && npm run build && electron-builder --linux",
    "build:backend": "node scripts/build-backend.mjs",
    "build:all": "npm run build:backend && npm run build && electron-builder -mwl",
    "lint": "eslint --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.main.json",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.71.2",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-radio-group": "1.3.8",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-toast": "1.2.15",
    "@radix-ui/react-tooltip": "1.2.8",
    "@sentry/electron": "7.11.0",
    "axios": "1.14.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dotenv": "16.6.1",
    "electron-log": "5.4.3",
    "electron-store": "10.1.0",
    "electron-updater": "6.8.3",
    "form-data": "4.0.5",
    "i18next": "26.0.3",
    "lucide-react": "0.562.0",
    "motion": "12.38.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "17.0.2",
    "react-markdown": "10.1.0",
    "react-resizable-panels": "4.9.0",
    "remark-gfm": "4.0.1",
    "tailwind-merge": "3.5.0",
    "uuid": "13.0.0",
    "zod": "4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.10.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/uuid": "10.0.0",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "8.58.0",
    "@vitejs/plugin-react": "5.1.3",
    "@vitest/coverage-v8": "4.1.3",
    "autoprefixer": "10.4.27",
    "concurrently": "9.2.1",
    "electron": "41.1.1",
    "electron-builder": "26.8.1",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "husky": "9.1.7",
    "jsdom": "27.4.0",
    "lint-staged": "16.4.0",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "tailwindcss": "3.4.19",
    "tailwindcss-animate": "1.0.7",
    "terser": "5.46.1",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vitest": "4.1.3",
    "wait-on": "8.0.5"
  },
  "build": {
    "appId": "com.proficiencystudio.desktop",
    "productName": "Proficiency Studio",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend-dist/",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "build/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "profstudio",
      "repo": "profstudio-desktop"
    }
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --report-unused-disable-directives --max-warnings 0 --fix",
      "prettier --write"
    ],
    "src/**/*.{json,css}": [
      "prettier --write"
    ]
  }
}
