{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "allowImportingTsExtensions": false,
        "outDir": "dist/main",
        "module": "Node16",
        "moduleResolution": "node16",
        "rootDir": "./src/main",
        "noEmit": false,
        "lib": [
            "ES2020"
        ]
    },
    "include": [
        "src/main/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}