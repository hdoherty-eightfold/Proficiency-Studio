### **Async Processing Patterns**
```python
# Concurrent processing for integrations
class IntegrationProcessor:
    def __init__(self, max_concurrent=10):
        self.semaphore = asyncio.Semaphore(max_concurrent)
    
    async def process_integrations(self, integration_configs):
        """Process multiple integrations concurrently"""
        tasks = [
            self._process_integration(config)
            for config in integration_configs
        ]
        results = await asyncio.gather(*tasks, return_exceptions=True)
        
        # Separate successful results from exceptions
        successes = [r for r in results if not isinstance(r, Exception)]
        failures = [r for r in results if isinstance(r, Exception)]
        
        return successes, failures
    
    async def _process_integration(self, config):
        """Process single integration with resource limiting"""
        async with self.semaphore:
            try:
                adapter = self._create_adapter(config)
                data = await adapter.fetch_all_data()
                return await self._save_integration_data(data)
            except Exception as e:
                logger.exception(f"Integration {config.name} failed: {e}")
                raise
