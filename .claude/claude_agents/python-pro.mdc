### **Unit Testing with Mocking**
```python
import pytest
from unittest.mock import AsyncMock, patch, MagicMock
from integration_service import IntegrationService

class TestIntegrationService:
    @pytest.fixture
    async def service(self):
        return IntegrationService()
    
    @pytest.mark.asyncio
    async def test_process_candidate_success(self, service):
        """Test successful candidate processing"""
        candidate_data = {
            'id': '123',
            'name': 'John Doe',
            'email': 'john@example.com'
        }
        
        with patch.object(service, '_validate_candidate_data', return_value=True), \
             patch.object(service, '_transform_candidate_data', new_callable=AsyncMock) as mock_transform, \
             patch.object(service, '_save_candidate_data', new_callable=AsyncMock) as mock_save:
            
            mock_transform.return_value = {'transformed': True}
            
            result = await service.process_candidate_data(candidate_data)
            
            assert result.success is True
            assert result.data == {'transformed': True}
            mock_transform.assert_called_once_with(candidate_data)
            mock_save.assert_called_once_with({'transformed': True})
    
    @pytest.mark.asyncio
    async def test_process_candidate_validation_error(self, service):
        """Test handling of validation errors"""
        candidate_data = {'invalid': 'data'}
        
        with patch.object(service, '_validate_candidate_data', return_value=False):
            result = await service.process_candidate_data(candidate_data)
            
            assert result.success is False
            assert result.error_code == "VALIDATION_ERROR"
