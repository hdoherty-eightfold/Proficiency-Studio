# Efficient bulk operations
async def bulk_create_applications(applications_data):
    """Efficiently create multiple applications"""
    applications = [
        Application(**data) for data in applications_data
    ]
    
    # Use bulk_create for efficiency
    created_applications = await Application.objects.abulk_create(
