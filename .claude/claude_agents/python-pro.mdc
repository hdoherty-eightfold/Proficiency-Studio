## 🏗️ **Eightfold Python Architecture Patterns**

### **ATS Adapter Pattern**
```python
# Base adapter implementation
class BaseATSAdapter:
    def __init__(self, config):
        self.config = config
        self.session = self._create_session()
    
    async def fetch_data(self, endpoint, params=None):
        """Generic async data fetching with retry logic"""
        for attempt in range(self.config.max_retries):
            try:
                response = await self.session.get(endpoint, params=params)
                response.raise_for_status()
                return response.json()
            except aiohttp.ClientError as e:
                if attempt == self.config.max_retries - 1:
                    raise AdapterError(f"Failed after {attempt + 1} attempts: {e}")
                await asyncio.sleep(self.config.retry_delay)
    
    def transform_data(self, raw_data):
        """Override in subclasses for system-specific transformations"""
        raise NotImplementedError
```

### **Data Processing Pipeline**
```python
# Efficient data processing pattern
class DataProcessor:
    def __init__(self, batch_size=1000):
        self.batch_size = batch_size
    
    async def process_stream(self, data_source):
        """Process data in batches to manage memory"""
        async for batch in self._batch_generator(data_source):
            processed_batch = await self._process_batch(batch)
            await self._save_batch(processed_batch)
    
    async def _batch_generator(self, data_source):
        """Yield data in memory-efficient batches"""
        batch = []
        async for item in data_source:
            batch.append(item)
            if len(batch) >= self.batch_size:
                yield batch
                batch = []
        if batch:
            yield batch
    
    async def _process_batch(self, batch):
        """Process batch with error handling"""
        results = []
        for item in batch:
            try:
                processed = await self._process_item(item)
                results.append(processed)
            except ProcessingError as e:
                logger.error(f"Failed to process item {item.id}: {e}")
                # Continue processing other items
        return results
```

