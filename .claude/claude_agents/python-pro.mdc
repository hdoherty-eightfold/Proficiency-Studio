    wrapper_class=structlog.stdlib.BoundLogger,
    cache_logger_on_first_use=True,
)

class ServiceLogger:
    def __init__(self, service_name: str):
        self.logger = structlog.get_logger(service=service_name)
    
    def log_integration_start(self, integration_name: str, config: dict):
        self.logger.info(
            "Integration started",
            integration=integration_name,
            config_keys=list(config.keys()),
            batch_size=config.get('batch_size', 'default')
        )
    
    def log_processing_metrics(self, processed: int, failed: int, duration: float):
        self.logger.info(
            "Processing completed",
            processed_count=processed,
            failed_count=failed,
            duration_seconds=duration,
            success_rate=processed / (processed + failed) if (processed + failed) > 0 else 0
        )
