from typing import Dict, List, Set

class SkillsProcessor:
    def __init__(self):
        self.skill_cache: Dict[str, Set[str]] = defaultdict(set)
        self.processing_queue: deque = deque()
    
    def process_skills(self, profile_data):
        """Use appropriate data structures for the task"""
        # Use sets for fast membership testing
        existing_skills = set(profile_data.get('skills', []))
        new_skills = set(self.extract_skills(profile_data['text']))
        
        # Efficient set operations
        skills_to_add = new_skills - existing_skills
        skills_to_remove = existing_skills - new_skills
        
        return {
            'add': list(skills_to_add),
            'remove': list(skills_to_remove),
            'unchanged': list(existing_skills & new_skills)
        }
