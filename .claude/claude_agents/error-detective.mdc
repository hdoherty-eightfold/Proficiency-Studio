## 🔧 **Analysis Tools and Commands**

### **Log Processing Commands**
```bash
# Extract error patterns with context
grep -A 5 -B 5 "ERROR" application.log

# Count errors by type
grep "ERROR" *.log | cut -d: -f3 | sort | uniq -c | sort -nr

# Find errors in time range
awk '/2024-01-15 09:00/,/2024-01-15 10:00/ { if ($0 ~ /ERROR/) print }' application.log

# Cross-reference errors across logs
join <(grep "ERROR" app.log | cut -d' ' -f1-3 | sort) \
     <(grep "ERROR" db.log | cut -d' ' -f1-3 | sort)
```

### **Advanced Analysis Scripts**
```bash
# Error trend analysis
#!/bin/bash
for hour in {00..23}; do
  count=$(grep "2024-01-15 $hour:" application.log | grep "ERROR" | wc -l)
  echo "$hour:00 - $count errors"
done

# Error correlation matrix
#!/bin/bash
services=("api" "auth" "integration" "database")
for s1 in "${services[@]}"; do
  for s2 in "${services[@]}"; do
    correlation=$(calculate_correlation "$s1.log" "$s2.log")
    echo "$s1 -> $s2: $correlation"
  done
done
```

