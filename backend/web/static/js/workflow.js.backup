}

// API Request/Response Monitoring Functions
function copyRequestJson() {
    const requestDisplay = document.getElementById('api-request-preview');
    if (requestDisplay && requestDisplay.textContent && !requestDisplay.textContent.includes('Select an endpoint')) {
        navigator.clipboard.writeText(requestDisplay.textContent).then(() => {
            showNotification('Request JSON copied to clipboard', 'success');
        });
    } else {
        showNotification('No request data to copy', 'error');
    }
}

function downloadRequestJson() {
    const requestDisplay = document.getElementById('api-request-preview');
    if (requestDisplay && requestDisplay.textContent && !requestDisplay.textContent.includes('Select an endpoint')) {
        const blob = new Blob([requestDisplay.textContent], { type: 'application/json' });
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'api_request.json';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        window.URL.revokeObjectURL(url);
        showNotification('Request JSON downloaded', 'success');
    } else {
        showNotification('No request data to download', 'error');
    }
}

function copyResponseJson() {
    const responseDisplay = document.getElementById('api-response-preview');
    if (responseDisplay && responseDisplay.textContent && !responseDisplay.textContent.includes('responses will appear')) {
        navigator.clipboard.writeText(responseDisplay.textContent).then(() => {
            showNotification('Response JSON copied to clipboard', 'success');
        });
    } else {
        showNotification('No response data to copy', 'error');
    }
}

function downloadResponseJson() {
    const responseDisplay = document.getElementById('api-response-preview');
    if (responseDisplay && responseDisplay.textContent && !responseDisplay.textContent.includes('responses will appear')) {
        const blob = new Blob([responseDisplay.textContent], { type: 'application/json' });
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'api_response.json';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        window.URL.revokeObjectURL(url);
        showNotification('Response JSON downloaded', 'success');
    } else {
        showNotification('No response data to download', 'error');
    }
}

function clearApiHistory() {
    const historyList = document.getElementById('api-call-history');
    if (historyList) {
        historyList.innerHTML = '<div class="text-sm text-gray-500 dark:text-gray-400">No API calls made yet...</div>';
    }
    showNotification('API call history cleared', 'success');
}

function openStep6ConfigManager() {
    // Open configuration manager modal for Step 6
    // This would reuse the existing config manager or create a new one
    if (typeof openConfigManager === 'function') {
        openConfigManager();
    } else {
        showNotification('Configuration manager - Coming soon!', 'info');
    }
}

// Intercept API calls and display in Step 6 monitoring
function interceptApiCall(method, url, requestData, responseData) {
    // Display request in Step 6 monitoring
    const requestDisplay = document.getElementById('api-request-preview');
    const responseDisplay = document.getElementById('api-response-preview');
    const historyList = document.getElementById('api-call-history');
    
    if (requestDisplay) {
        requestDisplay.innerHTML = `<pre class="text-green-400">${JSON.stringify({
            method: method,
            url: url,
            data: requestData,
            timestamp: new Date().toISOString()
        }, null, 2)}</pre>`;
    }
    
    if (responseDisplay && responseData) {
        responseDisplay.innerHTML = `<pre class="text-green-400">${JSON.stringify(responseData, null, 2)}</pre>`;
    }
    
    // Add to history
    if (historyList) {
        const timestamp = new Date().toLocaleString();
        const historyItem = document.createElement('div');
        historyItem.className = 'border-b border-gray-200 dark:border-gray-600 pb-2 mb-2 last:border-b-0';
        historyItem.innerHTML = `
            <div class="flex justify-between items-center">
                <span class="text-sm font-medium">${method} ${url.split('/').pop()}</span>
                <span class="text-xs text-gray-500 dark:text-gray-400">${timestamp}</span>
            </div>
            <div class="text-xs text-gray-600 dark:text-gray-300 mt-1">
                Status: ${responseData?.status_code || responseData?.status || 'Pending'}
            </div>
        `;
        
        // Remove placeholder if it exists
        const placeholder = historyList.querySelector('.text-gray-500');
        if (placeholder && placeholder.textContent.includes('No API calls made yet')) {
            placeholder.remove();
        }
        
        historyList.insertBefore(historyItem, historyList.firstChild);
        
        // Keep only last 10 items
        while (historyList.children.length > 10) {
            historyList.removeChild(historyList.lastChild);
        }
    }
}

// Sandbox Configuration Functions
function loadSandboxCredentials() {
    const sandboxDropdown = document.getElementById('sandbox-selector');
    let selectedValue = sandboxDropdown ? sandboxDropdown.value : null;
    
    // If no value selected, default to adoherty-demo
    if (!selectedValue) {
        selectedValue = 'adoherty-demo';
        if (sandboxDropdown) sandboxDropdown.value = 'adoherty-demo';
    }
    
    
    let config = null;
    
    // Check predefined configs first
    if (sandboxConfigs[selectedValue]) {
        config = sandboxConfigs[selectedValue];
    } else if (selectedValue === 'custom') {
        // Show custom config modal
        openConfigManager();
        return;
    } else if (customConfigs[selectedValue]) {
        config = customConfigs[selectedValue];
    }
    
    // Always load TM sandbox credentials if nothing is selected or if tm-sandbox is selected
    if (!config && (selectedValue === 'tm-sandbox' || !selectedValue)) {
        config = sandboxConfigs['tm-sandbox'];
    }
    
    if (config) {
        const usernameField = document.getElementById('api-eightfold-username');
        const passwordField = document.getElementById('api-eightfold-password');
        
        
        if (usernameField) {
            usernameField.value = config.username || '';
            usernameField.placeholder = '';
        }
        if (passwordField) {
            passwordField.value = config.password || '';
            passwordField.placeholder = '';
        }
        
        // Also store in sessionStorage for the auth function to use
        if (config.username) {
            sessionStorage.setItem('eightfold_username', config.username);
        }
        if (config.password) {
            sessionStorage.setItem('eightfold_password', config.password);
        }
        
    } else {
        // No config found for selected value
    }
}

async function loadSandboxConfigurations() {
    try {
        // Load custom configurations from backend
        const response = await fetch('/api/sandbox-configs');
        if (response.ok) {
            const data = await response.json();
            customConfigs = data.configs || {};
            
            // Update Step 1 dropdown
            updateSandboxDropdown();
            
            // Update Step 6 dropdown to match
            populateStep6EnvironmentDropdown();
        }
    } catch (error) {
        // Error loading sandbox configurations
    }
}

function updateSandboxDropdown() {
    const dropdownElement = document.getElementById('sandbox-selector');
    if (!dropdownElement) return;
    
    const currentValue = dropdownElement.value;
    
    // Clear and rebuild options
    dropdownElement.innerHTML = '<option value="">-- Select a Sandbox --</option>';
    
    // Add predefined options
    Object.keys(sandboxConfigs).forEach(key => {
        const option = document.createElement('option');
        option.value = key;
        option.textContent = sandboxConfigs[key].name;
        dropdownElement.appendChild(option);
    });
    
    // Add custom configurations
    if (Object.keys(customConfigs).length > 0) {
        const separator = document.createElement('option');
        separator.disabled = true;
        separator.textContent = '── Custom Configurations ──';
        dropdownElement.appendChild(separator);
        
        Object.keys(customConfigs).forEach(key => {
            const option = document.createElement('option');
            option.value = key;
            option.textContent = customConfigs[key].name;
            dropdownElement.appendChild(option);
        });
    }
    
    // Add custom option at the end
    const customOption = document.createElement('option');
    customOption.value = 'custom';
    customOption.textContent = 'Custom Configuration...';
    dropdownElement.appendChild(customOption);
    
    // Restore selection if it still exists
    if (currentValue && dropdownElement.querySelector(`option[value="${currentValue}"]`)) {
        dropdownElement.value = currentValue;
    }
}

function updateConfigurationList() {
    const listContainer = document.getElementById('sandbox-configs-list');
    // This element was removed from main view, only exists in modal now
    if (!listContainer) return;
    
    listContainer.innerHTML = '';
    
    // Combine all configurations
    const allConfigs = { ...sandboxConfigs, ...customConfigs };
    
    Object.keys(allConfigs).forEach(key => {
        const config = allConfigs[key];
        const isPredefined = sandboxConfigs.hasOwnProperty(key);
        
        const configItem = document.createElement('div');
        configItem.className = 'flex items-center justify-between p-2 bg-white rounded border';
        
        configItem.innerHTML = `
            <div class="flex-1">
                <div class="font-medium ${isPredefined ? 'text-blue-700' : 'text-gray-900'}">
                    ${config.name}
                    ${isPredefined ? '<span class="ml-2 text-xs bg-blue-100 text-blue-600 px-2 py-1 rounded">Predefined</span>' : ''}
                </div>
                <div class="text-xs text-gray-500">${config.apiUrl || 'No URL specified'}</div>
            </div>
            <div class="flex gap-2">
                <button onclick="editSandboxConfig('${key}')" class="text-blue-600 hover:text-blue-800 text-sm">
                    <i class="fas fa-edit"></i>
                </button>
                ${!isPredefined ? `<button onclick="deleteSandboxConfig('${key}')" class="text-red-600 hover:text-red-800 text-sm">
                    <i class="fas fa-trash"></i>
                </button>` : ''}
            </div>
        `;
        
        listContainer.appendChild(configItem);
    });
}

function openConfigManager() {
    const modal = document.getElementById('config-manager-modal');
    if (modal) {
        modal.classList.remove('hidden');
    loadConfigurationTable();
    }
}

function closeConfigManager() {
    const modal = document.getElementById('config-manager-modal');
    if (modal) {
        modal.classList.add('hidden');
    }
}

function loadConfigurationTable() {
    const tableBody = document.getElementById('config-table-body');
    if (!tableBody) return;
    
    tableBody.innerHTML = '';
    
    // Combine all configurations
    const allConfigs = { ...sandboxConfigs, ...customConfigs };
    
    Object.keys(allConfigs).forEach(key => {
        const config = allConfigs[key];
        const isPredefined = sandboxConfigs.hasOwnProperty(key);
        
        const row = document.createElement('tr');
        row.innerHTML = `
            <td class="border p-2">
                ${config.name}
                ${isPredefined ? '<span class="ml-2 text-xs bg-blue-100 text-blue-600 px-2 py-1 rounded">Predefined</span>' : ''}
            </td>
            <td class="border p-2 text-sm">${config.apiUrl || 'Not specified'}</td>
            <td class="border p-2 text-sm">${config.username || 'Not specified'}</td>
            <td class="border p-2 text-center">
                <button onclick="editSandboxConfig('${key}')" class="text-blue-600 hover:text-blue-800 mr-2">
                    <i class="fas fa-edit"></i>
                </button>
                ${!isPredefined ? `<button onclick="deleteSandboxConfig('${key}')" class="text-red-600 hover:text-red-800">
                    <i class="fas fa-trash"></i>
                </button>` : ''}
            </td>
        `;
        
        tableBody.appendChild(row);
    });
}

function addNewSandbox() {
    closeConfigManager();
    
    // Clear form
    document.getElementById('config-id').value = '';
    document.getElementById('config-name').value = '';
    document.getElementById('config-api-url').value = 'https://apiv2.eightfold.ai';
    document.getElementById('config-username').value = '';
    document.getElementById('config-password').value = '';
    document.getElementById('config-description').value = '';
    
    document.getElementById('config-modal-title').textContent = 'Add New Configuration';
    const modal = document.getElementById('config-edit-modal');
    if (modal) {
        modal.classList.remove('hidden');
    }
}

function editSandboxConfig(key) {
    closeConfigManager();
    
    const config = sandboxConfigs[key] || customConfigs[key];
    if (!config) return;
    
    document.getElementById('config-id').value = key;
    document.getElementById('config-name').value = config.name || '';
    document.getElementById('config-api-url').value = config.apiUrl || 'https://apiv2.eightfold.ai';
    document.getElementById('config-username').value = config.username || '';
    document.getElementById('config-password').value = config.password || '';
    document.getElementById('config-description').value = config.description || '';
    
    document.getElementById('config-modal-title').textContent = 'Edit Configuration';
    document.getElementById('config-edit-modal').classList.remove('hidden');
}

function closeConfigEditModal() {
    document.getElementById('config-edit-modal').classList.add('hidden');
}

async function saveConfiguration(event) {
    event.preventDefault();
    
    const configId = document.getElementById('config-id').value;
    const isNew = !configId;
    
    const configData = {
        name: document.getElementById('config-name').value,
        apiUrl: document.getElementById('config-api-url').value,
        username: document.getElementById('config-username').value,
        password: document.getElementById('config-password').value,
        description: document.getElementById('config-description').value
    };
    
    try {
        const url = isNew ? '/api/sandbox-configs' : `/api/sandbox-configs/${configId}`;
        const method = isNew ? 'POST' : 'PUT';
        
        const response = await fetch(url, {
            method: method,
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(configData)
        });
        
        if (response.ok) {
            showNotification(`Configuration ${isNew ? 'created' : 'updated'} successfully`, 'success');
            closeConfigEditModal();
            await loadSandboxConfigurations();
        } else {
            const error = await response.json();
            showNotification(error.message || 'Error saving configuration', 'error');
        }
    } catch (error) {
        showNotification('Error saving configuration: ' + error.message, 'error');
    }
}

async function deleteSandboxConfig(key) {
    if (!confirm('Are you sure you want to delete this configuration?')) {
        return;
    }
    
    try {
        const response = await fetch(`/api/sandbox-configs/${key}`, {
            method: 'DELETE'
        });
        
        if (response.ok) {
            showNotification('Configuration deleted successfully', 'success');
            await loadSandboxConfigurations();
        } else {
            const error = await response.json();
            showNotification(error.message || 'Error deleting configuration', 'error');
        }
    } catch (error) {
        showNotification('Error deleting configuration: ' + error.message, 'error');
    }
}

// Step 1: Test Eightfold Authentication
async function testEightfoldAuth() {
    // Test Eightfold authentication

    // First check if required DOM elements exist
    const usernameField = document.getElementById('api-eightfold-username');
    const passwordField = document.getElementById('api-eightfold-password');

    if (!usernameField || !passwordField) {
        console.error('Username or password field not found in DOM');
        showNotification('Authentication fields not found. Please refresh the page.', 'error');
        return;
    }

    // Try session storage first, then fall back to form fields
    let username = sessionStorage.getItem('eightfold_username') || usernameField.value;
    let password = sessionStorage.getItem('eightfold_password') || passwordField.value;

    if (!username || !password) {
        showNotification('Please enter username and password', 'error');
        return;
    }

    // Store in session for persistence
    sessionStorage.setItem('eightfold_username', username);
    sessionStorage.setItem('eightfold_password', password);

    let statusDisplay = document.getElementById('auth-status-display');
    let statusIcon = document.getElementById('auth-status-icon');
    let statusText = document.getElementById('auth-status-text');
    let responseContainer = document.getElementById('auth-response-container');

    // Add safety checks for missing elements
    if (!statusDisplay || !statusIcon || !statusText) {
        console.error('Auth status elements not found:', {
            statusDisplay: !!statusDisplay,
            statusIcon: !!statusIcon,
            statusText: !!statusText
        });
        showNotification('Authentication UI elements not found. Please refresh the page.', 'error');
        return;
    }

    // Extra safety check for classList
    try {
        if (statusDisplay && statusDisplay.classList) {
            statusDisplay.classList.remove('hidden');
        } else {
            statusDisplay.style.display = 'block';
        }
        statusIcon.className = 'fas fa-spinner fa-spin text-blue-500 mr-2';
        statusText.textContent = 'Authenticating...';
    } catch (e) {
        console.error('Error updating UI elements:', e);
        showNotification('Error updating authentication UI. Please refresh the page.', 'error');
        return;
    }

    try {
        // Get the correct auth header based on selected sandbox
        const selector = document.getElementById('sandbox-selector');
        const selectedSandbox = selector?.value;
        const environment = selectedSandbox; // Define environment variable
        
        let authHeader = null;
        let grantType = 'password';
        
        // Check both predefined and custom configurations
        let config = null;
        if (selectedSandbox && sandboxConfigs[selectedSandbox]) {
            config = sandboxConfigs[selectedSandbox];
        } else if (selectedSandbox && customConfigs[selectedSandbox]) {
            config = customConfigs[selectedSandbox];
        }
        
        // Only use predefined auth if sandbox is selected AND credentials match
        if (config && username === config.username && password === config.password) {
            authHeader = config.authHeader;
            grantType = config.grantType || 'password';
        }
        
        // Generate Basic auth from entered credentials (default behavior)
        if (!authHeader) {
            const credentials = btoa(`${username}:${password}`);
            authHeader = `Basic ${credentials}`;
        }
        
        // Build auth request for proxy
        const authRequest = {
            endpoint: '/oauth/v1/authenticate',
            method: 'POST',
            headers: {
                'Authorization': authHeader,
                'Content-Type': 'application/x-www-form-urlencoded',
                'Accept': 'application/json'
            },
            body: {
                grant_type: grantType,
                username: username,
                password: password
            },
            base_url: 'https://apiv2.eightfold.ai'
        };
        
        workflowState.authRequest = authRequest;
        
        // Use backend proxy to avoid CORS issues
        const response = await fetch('/api/eightfold/proxy', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(authRequest)
        });
        
        workflowState.authStatusCode = response.status;
        const result = await response.json();
        workflowState.authResponse = result;
        
        // Check if authentication was successful (proxy response)
        if (response.ok && result.success && result.data) {
            const authData = result.data;
            workflowState.authenticated = true;
            workflowState.authToken = authData.access_token || authData.auth_token;
            
            // Store token in session storage for persistence
            sessionStorage.setItem('auth_token', workflowState.authToken);
            
            // Also update the auth modal if it's open
            const modalToken = document.getElementById('modal-auth-token');
            if (modalToken) {
                modalToken.textContent = workflowState.authToken;
            }
            
            statusIcon.className = 'fas fa-check-circle text-green-500 mr-2';
            statusText.textContent = 'Authentication successful';
            statusDisplay.className = 'mt-4 p-4 bg-green-50 dark:bg-gray-800 border border-green-500 dark:border-green-400 rounded-lg';
            
            // Show JSON response
            responseContainer.classList.remove('hidden');
            const authResponseElement = document.getElementById('auth-response-json');
            if (authResponseElement) {
                authResponseElement.textContent = JSON.stringify(result, null, 2);
            }
            
            showNotification('Authentication successful!', 'success');

            // Update workflow progress
            if (typeof updateWorkflowStep === 'function') {
                updateWorkflowStep(1, 'completed', 'Authentication successful');
            }

            // Update Step 6 environment to match Step 1 authentication
            populateStep6EnvironmentDropdown();
            
            // Update assessment status in Step 5
            const assessmentStatus = document.getElementById('assessment-status');
            if (assessmentStatus && !workflowState.skillsLoaded) {
                assessmentStatus.innerHTML = '<span class="text-blue-600"><i class="fas fa-arrow-right mr-1"></i>Step 2: Now fetch JIE roles to extract skills</span>';
            }
        } else {
            workflowState.authenticated = false;
            workflowState.authToken = null;
            
            // Update the auth modal if it's open
            const modalToken = document.getElementById('modal-auth-token');
            if (modalToken) {
                modalToken.textContent = 'Authentication failed - no token received';
            }
            
            statusIcon.className = 'fas fa-times-circle text-red-500 mr-2';
            statusText.textContent = 'Authentication failed: ' + (result.message || 'Invalid credentials');
            statusDisplay.className = 'mt-4 p-3 bg-red-50 dark:bg-red-900 dark:bg-opacity-20 rounded-lg';
            
            // Show JSON response even on failure
            responseContainer.classList.remove('hidden');
            const authResponseElement = document.getElementById('auth-response-json');
            if (authResponseElement) {
                authResponseElement.textContent = JSON.stringify(result, null, 2);
            }
            
            showNotification('Authentication failed', 'error');
        }
    } catch (error) {
        statusIcon.className = 'fas fa-exclamation-circle text-red-500 mr-2';
        statusText.textContent = 'Error: ' + error.message;
        statusDisplay.className = 'mt-4 p-3 bg-red-50 dark:bg-red-900 dark:bg-opacity-20 rounded-lg';
        
        showNotification('Authentication error: ' + error.message, 'error');
    }
    
}

// Step 2: Extract Skills
async function extractSkillsForAssessment() {
    // Update workflow progress
    if (typeof updateWorkflowStep === 'function') {
        updateWorkflowStep(2, 'in_progress', 'Extracting skills...');
    }

    // Check if we have authentication token in session storage as fallback
    let authToken = workflowState.authToken || sessionStorage.getItem('auth_token');
    
    if (!authToken) {
        showNotification('Please authenticate with Eightfold API first (Step 1)', 'error');
        // No auth token found
        return;
    }
    
    // Update workflow state with token if we got it from session
    if (!workflowState.authToken && authToken) {
        workflowState.authToken = authToken;
        workflowState.authenticated = true;
    }
    
    showNotification('Fetching JIE roles from Eightfold API...', 'info');
    
    try {
        // Build request for proxy
        const requestData = {
            endpoint: '/api/v2/JIE/roles',
            method: 'GET',
            headers: {
                'Authorization': `Bearer ${workflowState.authToken}`,
                'Content-Type': 'application/json',
                'Accept': 'application/json'
            },
            params: {
                limit: 100  // Fetch up to 100 roles
            },
            base_url: 'https://apiv2.eightfold.ai'
        };
        
        workflowState.skillsRequest = requestData;
        
        // Intercept API call for Step 6 monitoring
        interceptApiCall('GET', '/api/v2/JIE/roles', requestData, null);
        
        // Use backend proxy to avoid CORS
        const response = await fetch('/api/eightfold/proxy', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(requestData)
        });
        
        if (!response.ok) {
            // Fetch JIE roles failed
            const errorText = await response.text();
            showNotification(`Failed to fetch roles: ${response.status} ${response.statusText}`, 'error');
            return;
        }
        
        let result;
        try {
            result = await response.json();
        } catch (e) {
            // Failed to parse response as JSON
            const responseText = await response.text();
            showNotification('Failed to parse API response. Check console for details.', 'error');
            return;
        }
        
        workflowState.skillsResponse = result;
        
        // Update Step 6 monitoring with response
        interceptApiCall('GET', '/api/v2/JIE/roles', workflowState.skillsRequest, result);
        
        // Proxy response - check if we have data
        if (result.success && result.data && result.data.data) {
            // Store JIE roles for Step 6 role updates
            workflowState.jieRoles = result.data.data;
            
            // Populate role dropdown for Step 6
            populateRoleDropdown(result.data.data);
            
            // Also populate the role management dropdown
            populateRoleManagementDropdown(result.data.data);
            
            // Extract skills from JIE roles response
            const skills = [];
            if (result.data.data && Array.isArray(result.data.data)) {
                // JIE roles are in data.data array
                for (const role of result.data.data) {
                    if (role.skillProficiencies && Array.isArray(role.skillProficiencies)) {
                        for (const skill of role.skillProficiencies) {
                            if (skill.name) {
                                const existingSkill = skills.find(s => s.name === skill.name);
                                if (!existingSkill) {
                                    // Add new skill
                                    skills.push({
                                        name: skill.name,
                                        proficiency: skill.proficiency || null,  // Numeric value (1-5)
                                        skillGroupList: skill.skillGroupList || [],  // Group list (required for API)
                                        source_role: role.title  // Track which role this came from
                                    });
                                } else if (skill.proficiency && !existingSkill.proficiency) {
                                    // Update existing skill if this one has proficiency and existing doesn't
                                    existingSkill.proficiency = skill.proficiency;
                                    existingSkill.skillGroupList = skill.skillGroupList || [];
                                    existingSkill.source_role = role.title + " (has proficiency)";
                                }
                            }
                        }
                    }
                }
            }
            
            workflowState.extractedSkills = skills;
            workflowState.skillsLoaded = true;

            // Update chunking UI when skills are loaded
            updateChunkingUI();

            // Update skill count display and batch calculations
            updateSkillsCount();
            updateSkillCountDisplay();
            
            // Update skill limit slider to match extracted skills count
            const skillLimitSlider = document.getElementById('skill-limit-slider');
            if (skillLimitSlider && skills.length > 0) {
                // Update max value to total skills count
                skillLimitSlider.max = skills.length;
                // Set current value to total skills (assess all by default)
                skillLimitSlider.value = skills.length;
                // Update the display
                updateSkillLimitDisplay(skills.length);
                // Update workflow state
                workflowState.skillLimit = skills.length;
                // Update the text display
                const skillLimitValue = document.getElementById('skill-limit-value');
                if (skillLimitValue) {
                    skillLimitValue.textContent = skills.length;
                }
                // Update the max value display
                const maxDisplay = document.getElementById('skill-limit-max');
                if (maxDisplay) {
                    maxDisplay.textContent = skills.length;
                }
                // Update the skill limit display text
                const skillLimitDisplay = document.getElementById('skill-limit-display');
                if (skillLimitDisplay) {
                    skillLimitDisplay.innerHTML = `<i class="fas fa-list mr-1"></i>${skills.length} skills`;
                }
            }
            
            // Update display with proxy API details
            const rolesData = result.data?.data || [];
            const rolesCount = rolesData.length;
            const rolesWithSkills = rolesData.filter(r => r.skillProficiencies && r.skillProficiencies.length > 0);
            const totalSkillsInRoles = rolesWithSkills.reduce((sum, role) => sum + (role.skillProficiencies?.length || 0), 0);
            
            const statusText = `✅ Fetched ${rolesCount} JIE roles → Found ${totalSkillsInRoles} total skills → Extracted ${skills.length} unique skills`;
            
            const skillsCountDisplay = document.getElementById('skills-count-display');
            if (skillsCountDisplay) {
                skillsCountDisplay.innerHTML = `
                    <div class="text-green-600 font-semibold">
                        ${statusText}
                    </div>
                    <div class="text-xs text-gray-500 mt-1">
                        Eightfold API: ${result.eightfold_endpoint}<br>
                        Status Code: <span class="${result.status_code === 200 ? 'text-green-600' : 'text-red-600'}">${result.status_code}</span><br>
                        Request Limit: ${requestData.params.limit} roles<br>
                        Roles with skills: ${rolesWithSkills.length} of ${rolesCount}<br>
                        <span class="text-gray-500">Total skill instances: ${totalSkillsInRoles} (includes duplicates across roles)</span><br>
                        <span class="text-green-600 font-semibold">Unique skills for assessment: ${skills.length}</span><br>
                        <button onclick="viewRawRolesJSON()" class="mt-2 px-3 py-1 bg-purple-500 text-white rounded text-xs hover:bg-purple-600 mr-2">
                            <i class="fas fa-code mr-1"></i>View Raw JSON
                        </button>
                        <button onclick="replayLastSkillsRequest()" class="mt-2 px-3 py-1 bg-blue-500 text-white rounded text-xs hover:bg-blue-600">
                            <i class="fas fa-redo mr-1"></i>Replay Request
                        </button>
                    </div>
                `;
            }
            
            // Show export button now that we have roles
            const exportBtn = document.getElementById('export-jie-roles-btn');
            if (exportBtn) exportBtn.style.display = 'block';
            
            // Update JIE Roles Summary
            const rolesSummary = document.getElementById('jie-roles-summary');
            if (rolesSummary && rolesData.length > 0) {
                // Get top 5 roles with most skills
                const sortedRoles = [...rolesData]
                    .sort((a, b) => (b.skillProficiencies?.length || 0) - (a.skillProficiencies?.length || 0))
                    .slice(0, 5);
                
                let summaryHTML = `
                    <div class="grid grid-cols-2 gap-3 mb-3">
                        <div class="bg-white dark:bg-gray-800 rounded p-2">
                            <div class="text-2xl font-bold text-blue-600 dark:text-blue-400">${rolesCount}</div>
                            <div class="text-xs text-gray-600 dark:text-gray-400">Total Roles</div>
                        </div>
                        <div class="bg-white dark:bg-gray-800 rounded p-2">
                            <div class="text-2xl font-bold text-green-600 dark:text-green-400">${skills.length}</div>
                            <div class="text-xs text-gray-600 dark:text-gray-400">Unique Skills</div>
                        </div>
                    </div>
                    <div class="space-y-1">
                        <div class="text-xs font-semibold text-gray-700 dark:text-gray-300 mb-1">Top Roles by Skill Count:</div>
                `;
                
                sortedRoles.forEach(role => {
                    const skillCount = role.skillProficiencies?.length || 0;
                    summaryHTML += `
                        <div class="flex justify-between items-center text-xs py-1 border-b border-gray-200 dark:border-gray-600">
                            <span class="text-gray-700 dark:text-gray-300 truncate flex-1 mr-2" title="${role.title}">${role.title}</span>
                            <span class="text-gray-500 dark:text-gray-400 font-semibold">${skillCount} skills</span>
                        </div>
                    `;
                });
                
                if (rolesData.length > 5) {
                    summaryHTML += `
                        <div class="text-xs text-gray-500 dark:text-gray-400 italic mt-2">
                            ... and ${rolesData.length - 5} more roles
                        </div>
                    `;
                }
                
                summaryHTML += '</div>';
                rolesSummary.innerHTML = summaryHTML;
            }
            
            // Store curl command for replay
            workflowState.lastCurlCommand = result.curl_command;
            
            // AUTO-SAVE: Automatically save JIE roles to history every time they're fetched
            // This ensures the structured data is always available for Step 6 operations
            saveJIERolesToHistory(true); // Pass true to indicate auto-save
            
            // Show comprehensive notification and auto-load prompt
            setTimeout(() => {
                const skillCount = workflowState.extractedSkills.length;
                
            // Auto-insert skills and proficiencies into prompt
            autoInsertSkillsIntoPrompt();
            autoInsertProficiencyLevels();
            
            // Update the LangChain request preview
            updateLangChainRequestPreview();
            
            // Update the assessment status to show ready
            const statusElement = document.getElementById('overall-progress-details');
            if (statusElement) {
                statusElement.innerHTML = '<span class="text-green-600 font-semibold"><i class="fas fa-check-circle mr-1"></i>Ready! ' + skillCount + ' skills auto-loaded into prompt. Click "Run Skills Assessment" to begin.</span>';
            }
            }, 500);
            
            // Update debug JSON
            if (document.getElementById('skills-debug-json')) {
                document.getElementById('skills-debug-json').textContent = JSON.stringify(result, null, 2);
            }
            
            const skillCount = workflowState.extractedSkills?.length || 0;
            const source = result.source || 'Eightfold API';
            showNotification(`Loaded ${skillCount} skills from ${source}`, 'success');

            // Update workflow progress
            if (typeof updateWorkflowStep === 'function') {
                updateWorkflowStep(2, 'completed', `${skillCount} skills extracted`);
                // Auto-mark step 3 as complete (proficiency levels are auto-populated)
                updateWorkflowStep(3, 'completed', 'Proficiency levels configured');
                // Auto-mark step 4 as complete if LLM is configured
                if (document.getElementById('llm-provider')?.value) {
                    updateWorkflowStep(4, 'completed', 'LLM configured');
                }
            }
        } else {
            // Show error in debug
            const debugElement = document.getElementById('skills-debug-json');
            if (debugElement) {
                debugElement.textContent = JSON.stringify(result, null, 2);
            }
            showNotification('Failed to extract skills: ' + result.message, 'error');
        }
    } catch (error) {
        showNotification('Error extracting skills: ' + error.message, 'error');
    }
    
}

// No demo mode - authentication required
function useTestSkills() {
    showNotification('Demo mode has been removed. Please authenticate with Eightfold API to load real skills.', 'error');
}

// Save API Keys (simplified for selected provider)
async function saveApiKeys() {
    const provider = document.getElementById('llm-provider').value;
    let apiKey;

    // For Google, use the multiple key system
    if (provider === 'google') {
        apiKey = window.googleApiKeys.getActiveKey();
        if (!apiKey) {
            showNotification('Please add and select a Google API key', 'error');
            return;
        }
    } else {
        apiKey = document.getElementById('llm-api-key').value;
        if (!apiKey) {
            showNotification('Please enter an API key', 'error');
            return;
        }
    }

    const keys = {};
    keys[provider] = apiKey;

    // Log the API key being saved (masked for security)
    const maskedKey = apiKey.substring(0, 10) + '...' + apiKey.substring(apiKey.length - 4);
    console.log(`Saving ${provider} API key: ${maskedKey}`);

    try {
        const response = await fetch('/api/keys/update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(keys)
        });

        if (response.ok) {
            workflowState.llmConfigured = true;
            showNotification(`✅ ${provider.toUpperCase()} API key saved successfully`, 'success');
            console.log(`✅ ${provider} API key saved to session`);

            // Update status indicator
            const statusIcon = document.getElementById('api-key-status');
            if (statusIcon) {
                statusIcon.className = 'fas fa-check-circle text-green-500';
            }
        } else {
            const error = await response.text();
            showNotification(`Failed to save API key: ${error}`, 'error');
        }
    } catch (error) {
        showNotification(`Failed to save API key: ${error.message}`, 'error');
        console.error('Error saving API key:', error);
    }
}

// Store assessed skills without displaying them immediately
function displayAssessedSkills(assessedSkills) {
    // Store the results in workflow state for later viewing
    workflowState.lastAssessmentResults = assessedSkills;
    workflowState.assessedSkills = assessedSkills;  // Also store for validation
    
    // Remove any existing results section from the main page
    const existingResults = document.getElementById('assessment-results');
    if (existingResults) {
        existingResults.remove();
    }
    
    // DO NOT create a new results section on the main page
    // Results will only be shown when "View Assessment Results" is clicked
}

// Log chunk processing events
function logChunkEvent(message, type = 'info') {
    const logContainer = document.getElementById('chunk-processing-log');
    if (!logContainer) return;

    const timestamp = new Date().toLocaleTimeString();
    const entry = document.createElement('div');

    const typeColors = {
        'start': 'text-blue-600 dark:text-blue-400',
        'complete': 'text-green-600 dark:text-green-400',
        'error': 'text-red-600 dark:text-red-400',
        'info': 'text-gray-600 dark:text-gray-400',
        'warning': 'text-yellow-600 dark:text-yellow-400'
    };

    entry.className = `${typeColors[type] || typeColors.info}`;
    entry.innerHTML = `<span class="text-gray-500">[${timestamp}]</span> ${message}`;

    // Clear the initial "waiting" message if it exists
    const waitingMsg = logContainer.querySelector('.text-gray-500');
    if (waitingMsg && waitingMsg.textContent.includes('Waiting')) {
        waitingMsg.remove();
    }

    logContainer.appendChild(entry);
    logContainer.scrollTop = logContainer.scrollHeight;
}

// Track chunk processing times
let chunkStartTime = null;
let chunkTimings = [];

// Display accumulated results when all chunks are processed
function displayAccumulatedResults() {
    const accumulated = chunkingState.accumulatedResults || [];
    if (accumulated.length === 0) {
        console.log('No accumulated results to display');
        return;
    }

    console.log(`Displaying ${accumulated.length} accumulated assessment results`);

    // Display the results and update workflow state
    displayAssessedSkills(accumulated);
    workflowState.assessedSkills = accumulated;  // Ensure workflow state is updated

    // Update completion message with correct total
    const totalSkills = workflowState.extractedSkills?.length || accumulated.length;
    showNotification(`✅ Assessment complete! All ${totalSkills} skills have been assessed.`, 'success');
    updateProcessingLog(`🎉 Assessment complete: ${totalSkills} skills successfully assessed`, 'success');

    // Stop the progress timer when assessment is truly complete
    if (window.progressInterval) {
        clearInterval(window.progressInterval);
        window.progressInterval = null;
    }

    // Update Step 6 if available
    if (typeof updateStep6WithAssessmentResults === 'function') {
        updateStep6WithAssessmentResults();
    }

    // Save the complete results
    workflowState.assessmentResults = {
        skills: accumulated,
        timestamp: new Date().toISOString(),
        provider: document.getElementById('llm-provider-select')?.value || 'unknown',
        model: document.getElementById('llm-model-select')?.value || 'unknown',
        environment: document.getElementById('environmentSelect')?.value || document.getElementById('sandbox-selector')?.value || 'unknown'
    };

    // Mark workflow step as complete
    if (typeof updateWorkflowStep === 'function') {
        updateWorkflowStep(5, 'completed', `${accumulated.length} skills assessed`);
    }
}

// Run LangChain Assessment
async function runLangChainAssessment() {
    console.log('🚀 runLangChainAssessment: Function called');

    // Check if automatic mode is enabled
    if (window.automaticProcessingMode) {
        return runAutomaticAssessment();
    }

    // Running LangChain Assessment

    // Update workflow progress
    if (typeof updateWorkflowStep === 'function') {
        updateWorkflowStep(5, 'in_progress', 'Running assessment...');
    }

    // Check if already running
    if (isAssessmentRunning) {
        console.log('⚠️ Assessment already running');
        showNotification('Assessment is already running. Please wait or stop the current assessment.', 'warning');
        return;
    }

    // Check if button click is working

    if (!workflowState.skillsLoaded || !workflowState.extractedSkills || workflowState.extractedSkills.length === 0) {
        showNotification('Please load skills first (Step 2: Fetch JIE Roles)', 'error');
        return;
    }

    // Initialize AbortController
    assessmentController = new AbortController();
    isAssessmentRunning = true;

    // IMPORTANT: Clear any existing progress timer to prevent duplicate timers
    if (window.progressInterval) {
        console.log('⚠️ Clearing existing progress timer before starting new assessment');
        clearInterval(window.progressInterval);
        window.progressInterval = null;
    }

    // Reset chunking state if starting fresh (chunk-start-input is 1 and no accumulated results)
    const startPosition = parseInt(document.getElementById('chunk-start-input')?.value || 1);
    if (startPosition === 1 && chunkingState.accumulatedResults.length === 0) {
        // Fresh start - reset the chunking state completely
        console.log('🔄 Fresh start detected, resetting chunking state');
        chunkingState = {
            accumulatedResults: [],
            currentChunkStart: 1,
            processedChunks: 0,
            totalSkillsProcessed: 0,
            sessionStartTime: chunkingState.sessionStartTime || null,
            totalElapsedTime: chunkingState.totalElapsedTime || 0
        };
    }

    // Update UI buttons
    updateAssessmentButtonStates(true);
    
    // Check if API keys are configured on the server
    let provider = document.getElementById('llm-provider')?.value || 'google';
    let hasConfiguredKey = false;

    // Read batch configuration from UI ONCE at the beginning - HONOR USER'S SETTINGS
    // User has set 450 for both chunk and batch size
    const batchSizeFromUI = parseInt(document.getElementById('batch-size-input')?.value);
    const actualBatchSize = batchSizeFromUI || userBatchSize || 450;  // Use UI value, then userBatchSize, then default to 450
    const actualConcurrency = parseInt(document.getElementById('concurrent-batches-input')?.value || 1);
    const actualMode = document.getElementById('processing-mode-select')?.value || 'sequential';

    console.log(`📦 Batch configuration: size=${actualBatchSize}, concurrent=${actualConcurrency}, mode=${actualMode}`);

    // Log current settings for any provider
    const totalSkills = workflowState.extractedSkills.length;
    const batches = Math.ceil(totalSkills / actualBatchSize);
    console.log(`${provider} API: Processing ${totalSkills} skills in ${batches} batches of ${actualBatchSize}`);

    // Update UI with actual batch info
    updateBatchCalculations();
    updateProcessingLog(`📦 Using batch size: ${actualBatchSize} skills per batch`, 'info');
    updateProcessingLog(`🔄 Processing ${batches} batches in ${actualMode} mode`, 'info');

    // Show batch info in notification
    showNotification(
        `Processing ${totalSkills} skills: ${batches} batches × ${actualBatchSize} skills each`,
        'info'
    );
    
    // Only log the start for the first run, not for auto-continuation retries
    // Auto-continuation already logs "Starting chunk X/Y..." separately
    if (!window.isAutoContinuation) {
        const defaultChunkSize = parseInt(document.getElementById('chunk-size-input')?.value || 650);
        const currentChunk = Math.floor(chunkingState.accumulatedResults?.length / (chunkingState.chunkSize || defaultChunkSize)) + 1;
        const initialTotalChunks = Math.ceil(workflowState.extractedSkills.length / (chunkingState.chunkSize || defaultChunkSize));
        logChunkEvent(`🚀 Starting assessment: Chunk ${currentChunk}/${initialTotalChunks} (${totalSkills} skills total)`, 'start');
    }
    window.isAutoContinuation = false; // Reset flag for next time
    chunkStartTime = Date.now();

    // Check server-side API key configuration
    try {
        const keyStatusResponse = await fetch('/api/keys/status');
        if (keyStatusResponse.ok) {
            const keyStatus = await keyStatusResponse.json();
            // Check API key status
            
            // Check if the selected provider has a key configured
            if (keyStatus[provider]) {
                hasConfiguredKey = true;
                // Using API key from server session
            } else {
                // Try to find any configured provider
                for (const [p, configured] of Object.entries(keyStatus)) {
                    if (configured && p !== 'eightfold') {
                        provider = p;
                        hasConfiguredKey = true;
                        // Using API key from server session
                        break;
                    }
                }
            }
        }
    } catch (error) {
        // Error checking API key status
    }
    
    // Also check local workflow state for API key
    if (!hasConfiguredKey && workflowState.currentApiKey && workflowState.currentProvider === provider) {
        hasConfiguredKey = true;
    }
    
    if (!hasConfiguredKey && provider !== 'mock') {
        console.log('❌ No API key configured and provider is not mock');
        // Show detailed error in Step 5 section
        const assessmentStatus = document.getElementById('langchain-status');
        if (assessmentStatus) {
            assessmentStatus.innerHTML = `
                <div class="bg-red-100 dark:bg-red-900/30 border border-red-300 dark:border-red-700 rounded-lg p-4">
                    <i class="fas fa-exclamation-triangle text-red-600 dark:text-red-400 mr-2"></i>
                    <span class="text-red-700 dark:text-red-300">
                        <strong>No API key configured!</strong><br>
                        <span class="text-sm">Please go to Step 4 and:</span><br>
                        <span class="text-sm">1. Enter your Google Gemini API key</span><br>
                        <span class="text-sm">2. Click "Test Gemini Connection" to validate</span><br>
                        <span class="text-sm">3. Once successful, try running the assessment again</span>
                    </span>
                </div>`;
        }

        showNotification('No API key found. Please configure Google Gemini API key in Step 4', 'error');

        // Reset button states
        isAssessmentRunning = false;
        updateAssessmentButtonStates(false);

        // Stop execution - don't continue without a key
        return;
    }
    
    
    const model = document.getElementById('llm-model-select')?.value || '';
    const promptTemplate = document.getElementById('assessment-prompt').value;
    
    // Get editable proficiency levels
    const proficiencyInputs = document.querySelectorAll('.proficiency-input');
    const proficiencyLevels = Array.from(proficiencyInputs).map(input => input.value).filter(v => v.trim());
    
    // Get the current environment
    const environmentElement = document.getElementById('environmentSelect') || document.getElementById('sandbox-selector');
    const environment = environmentElement?.value || 'unknown';
    
    // Check if we're processing a chunk or all skills
    // Get configuration from UI - HONOR USER'S SETTINGS (450 as shown in screenshot)
    const chunkStartInput = document.getElementById('chunk-start-input');
    const chunkSizeInput = document.getElementById('chunk-size-input');
    const batchSizeInput = document.getElementById('batch-size-input');

    // Get chunk persistence state to continue from where we left off
    const accumulatedCount = chunkingState.accumulatedResults?.length || 0;

    // Determine chunk start position
    let chunkStart;
    let chunkStartValue = parseInt(chunkStartInput?.value || 1);

    // If chunk start input is set and it's greater than 1, use it
    // This handles both manual input and when selectNextChunk() sets it
    if (chunkStartValue > 1) {
        // Use the input value (1-indexed) and convert to 0-indexed
        chunkStart = chunkStartValue - 1;
        console.log('📊 Using chunk start from input:', chunkStartValue, '(0-indexed:', chunkStart, ')');
    } else if (accumulatedCount > 0) {
        // Continue from accumulated position
        chunkStart = accumulatedCount;
        console.log('📊 Continuing from accumulated position:', accumulatedCount);
        // Update the UI to show the current position
        if (chunkStartInput) {
            chunkStartInput.value = chunkStart + 1; // Display as 1-indexed
        }
    } else {
        // Start from beginning
        chunkStart = 0;
        console.log('📊 Starting from beginning');
    }

    const chunkSize = parseInt(chunkSizeInput?.value || 450);  // Honor user's setting
    const userBatchSize = parseInt(batchSizeInput?.value || 450);  // Honor user's setting

    // Log the configuration being used
    console.log('📊 Configuration from UI:', {
        chunkStart: chunkStart + 1,  // Display as 1-indexed
        chunkSize: chunkSize,
        batchSize: userBatchSize,
        totalSkills: workflowState.extractedSkills.length,
        accumulatedCount: accumulatedCount
    });

    let skillsToProcess = workflowState.extractedSkills;
    let isChunkedProcessing = false;

    // Check if we have any skills left to process
    if (chunkStart >= workflowState.extractedSkills.length) {
        console.log('⚠️ No more skills to process. All skills have been assessed.');
        showNotification('All skills have been assessed. No more chunks to process.', 'info');

        // Reset button states
        isAssessmentRunning = false;
        updateAssessmentButtonStates(false);

        // Display final results if we have accumulated results
        if (accumulatedCount > 0) {
            displayAccumulatedResults();
        }
        return;
    }

    // Process chunk if chunk size is specified
    if (chunkSize > 0) {
        isChunkedProcessing = true;
        // IMPORTANT: Use the ORIGINAL chunk size from the input, not recalculated values
        const originalChunkSize = parseInt(document.getElementById('chunk-size-input')?.value || chunkSize);
        const chunkEnd = Math.min(chunkStart + originalChunkSize, workflowState.extractedSkills.length);
        skillsToProcess = workflowState.extractedSkills.slice(chunkStart, chunkEnd);

        // Validate that we have skills to process
        if (skillsToProcess.length === 0) {
            // No skills in chunk to process
            showNotification('Error: No skills found in the specified chunk range', 'error');

            // Reset button states
            isAssessmentRunning = false;
            updateAssessmentButtonStates(false);
            return;
        }

        // Set current chunk in state for progress tracking
        // Calculate the actual chunk number based on the start position
        // Use the originalChunkSize already declared above
        const currentChunkNumber = Math.floor(chunkStart / originalChunkSize) + 1;
        chunkingState.currentChunk = currentChunkNumber;
        chunkingState.currentChunkStart = chunkStart + 1; // Store as 1-indexed for display
        chunkingState.chunkSize = originalChunkSize; // CRITICAL: Store ORIGINAL chunk size in state
        chunkingState.currentChunkData = {
            start: chunkStart,
            end: chunkEnd,
            skillsToProcess: skillsToProcess
        }

        updateProcessingLog(`📦 Processing chunk ${currentChunkNumber}: Skills ${chunkStart + 1} to ${chunkEnd} (${skillsToProcess.length} skills)`, 'info');
        showNotification(`Processing chunk ${currentChunkNumber}: ${skillsToProcess.length} skills (${chunkStart + 1}-${chunkEnd})`, 'info');
    }

    // Create optimized request for LangChain (remove unnecessary data)
    const optimizedSkills = skillsToProcess.map(skill => ({
        name: skill.name || skill.skill_name,
        // Only include essential fields for assessment
    }));

    // actualBatchSize, actualConcurrency, and actualMode are already read at the beginning of this function

    const request = {
        skills: optimizedSkills,
        provider: provider,
        model: model,
        proficiency_levels: proficiencyLevels,
        prompt_template: promptTemplate,
        use_langchain: true,
        environment: environment,
        // Include batch configuration for processing
        batch_size: actualBatchSize,
        concurrent_batches: actualConcurrency,
        processing_mode: actualMode,
        // IMPORTANT: Since we're already sending sliced skills (optimizedSkills from skillsToProcess),
        // we should send chunk_start=0 to avoid double-slicing in the backend
        chunk_start: 0,  // Always 0 since skills array is already sliced
        chunk_size: isChunkedProcessing ? skillsToProcess.length : null,  // Use actual sliced array length
        total_skills_available: workflowState.extractedSkills.length,
        // jie_roles removed - not needed for LangChain, causes massive data bloat
        // resume_text not needed - just skills assessment
    };
    
    // Include API key if available locally (fallback when session storage fails)
    if (workflowState.currentApiKey && workflowState.currentProvider === provider) {
        request.api_key = workflowState.currentApiKey;
    }
    
    // Submit assessment request
    showNotification('Starting skills assessment...', 'info');

    // Initialize assessment history tracking
    try {
        if (window.assessmentHistory) {
            console.log('📜 Starting assessment history tracking');
            window.assessmentHistory.startNewRun(workflowState.extractedSkills.length, environment, provider);
        } else {
            console.log('📜 No assessmentHistory object found');
        }
    } catch (historyError) {
        console.error('❌ Error initializing assessment history:', historyError);
        // Don't let this stop the assessment
    }
    
    // Display request JSON with copy/download buttons
    const requestViewerElement = document.getElementById('langchain-request-viewer');
    if (requestViewerElement) {
        try {
            const requestJson = JSON.stringify(request, null, 2);
            const requestHtml = `
                <div class="relative">
                    <div class="absolute top-2 right-2 flex gap-2">
                        <span class="bg-green-600 text-white px-2 py-1 rounded text-xs">Executing</span>
                        <button onclick="copyJsonRequest()" class="bg-blue-600 text-white px-2 py-1 rounded text-xs hover:bg-blue-700">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                        <button onclick="downloadJsonRequest()" class="bg-green-600 text-white px-2 py-1 rounded text-xs hover:bg-green-700">
                            <i class="fas fa-download mr-1"></i>Download
                        </button>
                    </div>
                    <pre class="text-xs pt-8">${requestJson}</pre>
                </div>
            `;
            requestViewerElement.innerHTML = requestHtml;
            // Store for copy/download functions
            workflowState.lastAssessmentRequest = request;
        } catch (jsonError) {
            console.error('❌ Error displaying request JSON:', jsonError);
            requestViewerElement.innerHTML = '<div class="text-red-600">Error displaying request</div>';
        }
    } else {
        console.error('❌ langchain-request-viewer element not found!');
    }

    // Update status and progress bars
    const statusElement = document.getElementById('overall-progress-details');
    if (statusElement) {
        statusElement.innerHTML = '<span class="text-blue-600"><i class="fas fa-spinner fa-spin mr-1"></i>Sending assessment request to LLM...</span>';
    }
    
    // Initialize progress tracking
    console.log('📊 Initializing progress tracking...');
    console.log('Checking for DOM elements:');
    console.log('- processing-log:', document.getElementById('processing-log'));
    console.log('- elapsed-time:', document.getElementById('elapsed-time'));
    console.log('- assessment-progress:', document.getElementById('assessment-progress'));

    // Update progress with the current accumulated + current chunk
    const currentAccumulated = chunkingState.accumulatedResults?.length || 0;
    const totalExpected = workflowState.extractedSkills.length;
    const actualChunkSize = chunkingState.chunkSize || parseInt(document.getElementById('chunk-size-input')?.value || 650);
    const actualCurrentChunk = chunkingState.currentChunk || Math.floor(currentAccumulated / actualChunkSize) + 1;
    const totalChunks = Math.ceil(totalExpected / actualChunkSize);  // Calculate total chunks using TOTAL skills
    updateAssessmentProgress(currentAccumulated, totalExpected, 'Initializing Google Gemini assessment...');
    updateProcessingLog('🚀 Starting LangChain assessment...');
    updateProcessingLog(`📤 Sending ${skillsToProcess.length} skills for proficiency assessment (Chunk ${actualCurrentChunk}/${totalChunks})`)

    // Show batch configuration details - MUST match what we're actually sending!
    const totalSkillCount = workflowState.extractedSkills.length;

    // IMPORTANT: When chunking, ensure batch size equals chunk size to avoid internal batching
    let configBatchSize = actualBatchSize;  // Use the ACTUAL value from UI
    if (isChunkedProcessing) {
        // For chunked processing, set batch size to match the chunk to avoid sub-batching
        configBatchSize = skillsToProcess.length;
        // Also update the request to ensure backend uses the right batch size
        request.batch_size = configBatchSize;
    }

    const concurrentBatches = actualConcurrency;  // Use the ACTUAL value from UI
    const totalBatches = isChunkedProcessing ? 1 : Math.ceil(totalSkillCount / configBatchSize);  // Single batch for chunks
    const estimatedTime = Math.ceil((totalBatches / concurrentBatches) * 1.5);

    // Add initial configuration summary
    updateProcessingLog('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
    updateProcessingLog(`⚙️  Batch Configuration: ${configBatchSize} skills per batch, ${concurrentBatches} concurrent`);
    updateProcessingLog(`📊 Processing Plan: ${totalBatches} batch${totalBatches > 1 ? 'es' : ''} total, ~${estimatedTime} minute${estimatedTime > 1 ? 's' : ''} estimated`);

    // Show provider and model details
    const providerDisplay = provider === 'mock' ? 'Mock (Testing)' :
                           provider === 'google' ? 'Google Gemini' :
                           provider === 'openai' ? 'OpenAI GPT' : provider;
    updateProcessingLog(`🔄 Provider: ${providerDisplay}${model ? ` (${model})` : ''}`);
    updateProcessingLog(`📍 Environment: ${environment || 'Unknown'}`);
    updateProcessingLog('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━');

    // Log first batch start immediately
    updateProcessingLog(`🚀 Starting Batch 1/${totalBatches}`, 'progress');
    updateProcessingLog(`📋 Processing skills 1-${Math.min(configBatchSize, totalSkills)} (${Math.min(configBatchSize, totalSkills)} skills)`, 'info');
    updateProcessingLog(`📤 Sending to ${provider === 'google' ? 'Google Gemini' : provider.toUpperCase()} API...`, 'info');
    
    // Start progress simulation
    // Clear any existing intervals first
    if (window.progressInterval) {
        clearInterval(window.progressInterval);
        window.progressInterval = null;
    }

    let currentProgress = 0;
    const startTime = Date.now();

    // Store startTime globally for the interval to access
    window.assessmentStartTime = startTime;

    console.log('⏱️ Starting timer and progress interval...');

    // Simulate progress updates
    window.progressInterval = setInterval(() => {
        console.log('Timer tick - updating progress...');
        // Always update elapsed time, even after progress reaches 100%
        // Use the globally stored start time
        const currentStartTime = window.assessmentStartTime || startTime;

        if (!currentStartTime || isNaN(currentStartTime)) {
            console.warn('Invalid start time, skipping timer update');
            return;
        }

        const elapsedSeconds = Math.floor((Date.now() - currentStartTime) / 1000);
        const minutes = Math.floor(elapsedSeconds / 60);
        const seconds = elapsedSeconds % 60;

        // Check for NaN before updating
        if (isNaN(minutes) || isNaN(seconds)) {
            console.warn('NaN detected in timer calculation', { elapsedSeconds, minutes, seconds, currentStartTime });
            return;
        }

        const timeStr = `${minutes}:${seconds.toString().padStart(2, '0')}`;

        // Update elapsed time display
        const elapsedTimeEl = document.getElementById('elapsed-time');
        if (elapsedTimeEl) {
            elapsedTimeEl.textContent = timeStr;
        }

        // Update progress bars
        updateOverallProgress();
        updateChunkProgress();

        // Check for stalled progress (no update for 2 minutes)
        if (!window.progressInterval.lastProgressTime) {
            window.progressInterval.lastProgressTime = Date.now();
        }

        // If we haven't seen progress in 2 minutes, show warning
        if (Date.now() - window.progressInterval.lastProgressTime > 120000) {
            statusMessage = '⚠️ Assessment appears stalled. Consider stopping and retrying with smaller batch size.';
            updateProcessingLog('⚠️ No progress detected for 2 minutes', 'warning');
            window.progressInterval.lastProgressTime = Date.now(); // Reset to avoid spamming
        }

        // Provide detailed batch progress messages based on elapsed time
        let statusMessage;
        // Adjust batch time based on provider and batch size
        const estimatedBatchTime = provider === 'google' ?
            Math.max(30, Math.floor(configBatchSize / 10)) : // Google: ~10 skills/sec
            Math.max(20, Math.floor(configBatchSize / 15)); // Others: ~15 skills/sec

        // When using chunking, we need to show the actual chunk size
        const chunkSize = parseInt(document.getElementById('chunk-size-input')?.value || configBatchSize);
        const isChunking = chunkingState && (chunkingState.currentChunk || chunkingState.currentChunkData);

        // IMPORTANT: Get the TOTAL skills count from workflowState, not the current request
        const actualTotalSkills = workflowState.extractedSkills?.length || totalExpected;

        let currentBatch = Math.min(totalBatches, Math.floor(elapsedSeconds / estimatedBatchTime) + 1);
        let skillsToDisplay;
        let displayUnit = 'Batch';
        let displayCurrent = currentBatch;
        let displayTotal = totalBatches;

        if (isChunking) {
            // When chunking, always show chunk information consistently
            const totalChunksForDisplay = Math.ceil(actualTotalSkills / chunkSize);  // Use TOTAL skills for chunk calculation
            const currentChunkNum = chunkingState.currentChunk || (Math.floor(chunkingState.accumulatedResults.length / chunkSize) + 1);
            displayUnit = 'Chunk';
            displayCurrent = currentChunkNum;
            displayTotal = totalChunksForDisplay;

            // Calculate skills in current chunk (which may be less than chunkSize for the last chunk)
            const chunkStart = (currentChunkNum - 1) * chunkSize;
            skillsToDisplay = Math.min(chunkSize, actualTotalSkills - chunkStart);
        } else {
            // Regular batching - show skills in current batch
            skillsToDisplay = currentBatch === totalBatches ?
                totalSkills - ((totalBatches - 1) * configBatchSize) : configBatchSize;
        }

        if (elapsedSeconds < 10) {
            statusMessage = `🔗 Connecting to ${provider === 'google' ? 'Google Gemini' : provider.toUpperCase()} API...`;
        } else if (elapsedSeconds < 20) {
            statusMessage = `📤 Sending ${displayUnit} 1/${displayTotal} (${skillsToDisplay} skills) to ${provider} API...`;
        } else {
            // Don't show percentage as it's not accurate
            statusMessage = `🔄 Processing ${displayUnit} ${displayCurrent}/${displayTotal} (${skillsToDisplay} skills)`;
        }

        // Track batch transitions properly
        if (!window.progressInterval.lastLoggedBatch) {
            window.progressInterval.lastLoggedBatch = 0;
        }

        // Only log when we transition to a new batch
        if (currentBatch > window.progressInterval.lastLoggedBatch && currentBatch <= totalBatches) {
            if (window.progressInterval.lastLoggedBatch > 0) {
                const completedBatch = window.progressInterval.lastLoggedBatch;
                const completedPercent = Math.round((completedBatch / totalBatches) * 100);
                const skillsInCompletedBatch = completedBatch === totalBatches ?
                    totalSkills - ((totalBatches - 1) * configBatchSize) : configBatchSize;
                const completedSkills = (completedBatch - 1) * configBatchSize + skillsInCompletedBatch;

                updateProcessingLog(`✅ Batch ${completedBatch}/${totalBatches} completed - ${skillsInCompletedBatch} skills assessed`, 'success');
                updateProcessingLog(`📈 Overall progress: ${completedPercent}% (${completedSkills}/${totalSkills} skills done)`, 'info');

                // Mark batch as logged
                if (!window.progressInterval.batchesLogged) window.progressInterval.batchesLogged = [];
                window.progressInterval.batchesLogged.push(completedBatch);
            }

            // Show detailed info for new batch
            const batchStart = (currentBatch - 1) * configBatchSize + 1;
            const batchEnd = Math.min(currentBatch * configBatchSize, totalSkills);
            const actualSkillsInBatch = batchEnd - batchStart + 1;

            updateProcessingLog(`━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━`, 'separator');
            updateProcessingLog(`🚀 Starting Batch ${currentBatch}/${totalBatches}`, 'progress');
            updateProcessingLog(`📋 Processing skills ${batchStart}-${batchEnd} (${actualSkillsInBatch} skills)`, 'info');
            updateProcessingLog(`📤 Sending to ${provider === 'google' ? 'Google Gemini' : provider.toUpperCase()} API...`, 'info');
            updateProcessingLog(`⏱️ Estimated time: ~${Math.ceil(estimatedBatchTime)} seconds`, 'info');
            window.progressInterval.lastLoggedBatch = currentBatch;
        }

        // Add periodic progress updates every 15 seconds (but not when we just logged a batch transition)
        if (elapsedSeconds > 0 && elapsedSeconds % 15 === 0 && currentBatch <= totalBatches) {
            // Only show progress update if we didn't just log a batch transition
            if (currentBatch === window.progressInterval.lastLoggedBatch) {
                const estimatedRemaining = Math.max(0, (totalBatches - currentBatch + 1) * estimatedBatchTime - (elapsedSeconds % estimatedBatchTime));
                const remainingMinutes = Math.floor(estimatedRemaining / 60);
                const remainingSeconds = estimatedRemaining % 60;
                if (estimatedRemaining > 0 && currentBatch <= totalBatches) {
                    const batchProgress = Math.round(((elapsedSeconds % estimatedBatchTime) / estimatedBatchTime) * 100);
                    updateProcessingLog(`⏳ Batch ${currentBatch}/${totalBatches} - ${batchProgress}% complete (Est. ${remainingMinutes}:${remainingSeconds.toString().padStart(2, '0')} remaining)`);
                }
            }
        }
        
        updateAssessmentProgress(0, totalSkills, statusMessage);
    }, 500);  // Update every 500ms

    console.log('📤 Making API call to /api/skills/assess-proficiencies-simple');
    console.log('Request:', request);
    console.log('Request body size:', JSON.stringify(request).length, 'bytes');
    console.log('🔍 Critical values:', {
        'chunk_start': request.chunk_start,
        'chunk_size': request.chunk_size,
        'skills_array_length': request.skills.length,
        'first_skill': request.skills[0]?.name,
        'last_skill': request.skills[request.skills.length - 1]?.name
    });

    // Show in UI that we're waiting for response
    updateProcessingLog('⏳ Waiting for server response...', 'info');

    try {
        console.log('🕒 Fetch started at:', new Date().toLocaleTimeString());

        const response = await fetch('/api/skills/assess-proficiencies-simple', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(request),
            signal: assessmentController.signal
        });

        console.log('📥 Response received:', response.status, response.ok);
        console.log('🕒 Response received at:', new Date().toLocaleTimeString());
        updateProcessingLog('✅ Server response received', 'success');
        
        // Check response status
        
        if (!response.ok) {
            // Try to get the error details from the response body
            let errorDetail = `HTTP error! status: ${response.status}`;
            let errorResponse = null;
            try {
                errorResponse = await response.json();
                if (errorResponse.detail) {
                    errorDetail = errorResponse.detail;
                } else if (errorResponse.error) {
                    errorDetail = errorResponse.error;
                } else if (errorResponse.message) {
                    errorDetail = errorResponse.message;
                }
            } catch (e) {
                // If response is not JSON, use status text
                errorDetail = `HTTP ${response.status}: ${response.statusText || 'Request failed'}`;
            }

            // Check if this is a truncation error from backend
            if (errorResponse && errorResponse.error_type === 'truncated_response') {
                const currentBatchSize = parseInt(document.getElementById('batch-size-input')?.value || 306);
                const suggestedMatch = errorDetail.match(/Reduce to (\d+)/);
                const suggestedSize = suggestedMatch ? parseInt(suggestedMatch[1]) : Math.floor(currentBatchSize * 0.75);

                // Stop assessment and prepare for retry
                isAssessmentRunning = false;
                updateAssessmentButtonStates(false);

                // Clear progress interval
                if (window.progressInterval) {
                    clearInterval(window.progressInterval);
                    window.progressInterval = null;
                }

                // Log the truncation issue
                updateProcessingLog(`⚠️ Response truncated at ${errorResponse.response_length || 'unknown'} chars`, 'warning');
                updateProcessingLog(`📉 Current batch: ${currentBatchSize} skills`, 'info');
                updateProcessingLog(`💡 Auto-reducing to: ${suggestedSize} skills`, 'info');

                // Auto-retry with smaller batch
                showNotification(`Response truncated. Auto-retrying with ${suggestedSize} skills...`, 'warning');

                setTimeout(() => {
                    // Temporarily reduce batch size for retry (don't save to localStorage)
                    document.getElementById('batch-size-input').value = suggestedSize;

                    // Mark this as a temporary reduction
                    window.temporaryBatchReduction = true;

                    // Update calculations but don't save
                    updateBatchCalculations(false); // Pass false to skip saving
                    updateProcessingLog(`🔄 Retrying chunk with batch size: ${suggestedSize}`, 'info');
                    runLangChainAssessment();
                }, 2000);

                return; // Exit early, don't throw error
            }

            const error = new Error(errorDetail);
            error.status = response.status;
            throw error;
        }

        const result = await response.json();
        // Process assessment result

        // CRITICAL: Check if the result indicates complete failure OR partial success
        if (!result.success) {
            // Check if we have partial results (some batches succeeded)
            const hasPartialResults = result.assessed_skills && result.assessed_skills.length > 0;

            if (hasPartialResults) {
                // PARTIAL SUCCESS: Some batches worked, accumulate what we got
                console.warn('⚠️ Partial assessment failure - some batches succeeded');

                // Stop progress simulation
                if (window.progressInterval) {
                    clearInterval(window.progressInterval);
                    window.progressInterval = null;
                }

                // Accumulate successful skills
                const assessedSkills = result.assessed_skills;
                chunkingState.accumulatedResults.push(...assessedSkills);
                chunkingState.totalSkillsProcessed += assessedSkills.length;
                saveChunkingState();
                updateChunkingUI();
                updateOverallProgress();  // Update overall progress bar
                updateChunkProgress();     // Update current chunk progress

                // Show partial failure in UI
                const errorMessage = result.detail || result.error || result.message || 'Some batches failed';
                if (statusElement) {
                    statusElement.innerHTML = `<span class="text-yellow-600"><i class="fas fa-exclamation-triangle mr-1"></i>Partial failure: ${assessedSkills.length} skills saved</span>`;
                }

                updateProcessingLog('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━', 'warning');
                updateProcessingLog(`⚠️ PARTIAL ASSESSMENT FAILURE`, 'warning');
                updateProcessingLog(`  ✅ Saved: ${assessedSkills.length} skills successfully assessed`, 'success');
                updateProcessingLog(`  ❌ Error: ${errorMessage}`, 'error');
                updateProcessingLog(`  💾 Accumulated Total: ${chunkingState.accumulatedResults.length} skills`, 'info');
                updateProcessingLog(`  🔄 You can continue processing remaining skills`, 'info');
                updateProcessingLog('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━', 'warning');

                showNotification(`Partial failure: ${assessedSkills.length} skills saved. You can continue with remaining skills.`, 'warning');

                // Update workflow progress to partial
                if (typeof updateWorkflowStep === 'function') {
                    updateWorkflowStep(5, 'in_progress', 'Partial assessment - continue needed');
                }

                // Reset assessment state to allow retry
                isAssessmentRunning = false;
                updateAssessmentButtonStates(false);

                // Show continue/retry options
                showContinueChunkingOptions();

                return; // Exit but we've saved partial results
            } else {
                // COMPLETE FAILURE: No results at all
                // Stop progress simulation immediately
                if (window.progressInterval) {
                    clearInterval(window.progressInterval);
                    window.progressInterval = null;
                }

                // Show error in UI
                let errorMessage = result.detail || result.error || result.message || 'Assessment failed';
                const originalError = errorMessage; // Keep original for logging

                // Check for specific error types and provide better messages
                if (errorMessage.includes('429') || errorMessage.includes('quota')) {
                    errorMessage = '⚠️ API Quota Exceeded: Daily limit reached. Please wait 24 hours, switch providers, or upgrade your API plan.';

                    // If using Google with multiple keys, mark the current key as failed
                    const provider = document.getElementById('llm-provider')?.value;
                    if (provider === 'google') {
                        const currentKey = window.googleApiKeys.getActiveKey();
                        if (currentKey) {
                            window.googleApiKeys.markFailed(currentKey);

                            // Try to get next available key
                            const nextKeyIndex = window.googleApiKeys.getNextAvailableKey();
                            if (nextKeyIndex !== null) {
                                errorMessage += `\n\n✅ Automatically switched to ${window.googleApiKeys.keys[nextKeyIndex].name} API key. Retrying...`;
                                // Auto-retry with new key
                                setTimeout(() => {
                                    processSkillsWithRetry();
                                }, 2000);
                                return;
                            }
                        }
                    }
                } else if (errorMessage.includes('401') || errorMessage.includes('unauthorized')) {
                    errorMessage = '🔑 Authentication Error: Invalid API key. Please check your API key in Step 4.';
                } else if (errorMessage.includes('500') || errorMessage.includes('Internal Server Error')) {
                    errorMessage = '⚡ Server Error: The backend encountered an error. Please try again or check server logs.';
                } else if (errorMessage.includes('parse') || errorMessage.includes('JSON')) {
                    errorMessage = '📝 Response Parsing Error: The LLM response couldn\'t be parsed. Try reducing batch size.';
                }

                console.error('❌ Assessment failed:', originalError);
                console.error('❌ Full error details:', result);

                // Update the overall progress details
                const progressDetails = document.getElementById('overall-progress-details');
                if (progressDetails) {
                    progressDetails.innerHTML = `<span class="text-red-600"><i class="fas fa-times-circle mr-1"></i>${errorMessage}</span>`;
                }

                updateProcessingLog('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━', 'error');
                updateProcessingLog(`❌ ASSESSMENT FAILED`, 'error');
                updateProcessingLog(`  ${errorMessage}`, 'error');
                if (result.detail && result.detail !== errorMessage) {
                    updateProcessingLog(`  Details: ${result.detail}`, 'error');
                }
                updateProcessingLog('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━', 'error');

                showNotification(errorMessage, 'error');

                // Log the error details to the chunk processing log
                logChunkEvent(`❌ Assessment failed: ${errorMessage}`, 'error');

                // Show retry button for the failed chunk
                const currentChunkNum = typeof chunkingState.currentChunk === 'number' ? chunkingState.currentChunk : 1;
                const chunkSize = chunkingState.chunkSize || 387;
                const chunkStart = chunkingState.currentChunkStart ? chunkingState.currentChunkStart - 1 : (currentChunkNum - 1) * chunkSize;
                const failedSkills = workflowState.extractedSkills.slice(
                    chunkStart,
                    Math.min(chunkStart + chunkSize, workflowState.extractedSkills.length)
                );

                console.log(`Failed chunk details:`, {
                    currentChunkNum,
                    chunkSize,
                    chunkStart,
                    failedSkillsCount: failedSkills.length,
                    totalSkills: workflowState.extractedSkills.length
                });

                if (failedSkills.length > 0) {
                    workflowState.unassessedSkills = failedSkills;
                    showRetryUnassessedButton(failedSkills);
                    // Show retry options with error message
                    showChunkRetryOptions(currentChunkNum, failedSkills.length, errorMessage);
                } else {
                    // This is the "No skills provided" issue - chunk calculation was wrong
                    console.error('No skills found for failed chunk - chunk calculation error');
                    const detailedError = `No skills provided - Check chunk boundaries: Start=${chunkStart}, Size=${chunkSize}, Total=${workflowState.extractedSkills.length}`;
                    showNotification('Chunk calculation error. Click "Skip to Next Chunk" to continue.', 'error');
                    // Show options with detailed error
                    setTimeout(() => showChunkRetryOptions(currentChunkNum, 0, detailedError), 100);
                }

                // Update workflow progress
                if (typeof updateWorkflowStep === 'function') {
                    updateWorkflowStep(5, 'error', 'Assessment failed');
                }

                // Reset assessment state
                isAssessmentRunning = false;
                updateAssessmentButtonStates(false);

                return; // Exit early - don't process as success
            }
        }

        // Don't stop the interval yet - let it continue updating elapsed time

        // Check for partial failures (even if not chunking)
        if (result.llm_response?.batch_info?.failed_batches > 0) {
            handlePartialBatchFailure(result);
        }

        // Handle chunked processing accumulation
        if (isChunkedProcessing && result.success && result.assessed_skills) {
            // Add the assessed skills to accumulated results
            const assessedSkills = result.assessed_skills;
            chunkingState.accumulatedResults.push(...assessedSkills);
            chunkingState.processedChunks++;
            chunkingState.totalSkillsProcessed += assessedSkills.length;

            // Save state
            saveChunkingState();
            updateChunkingUI();
            updateOverallProgress();  // Update overall progress bar
            updateChunkProgress();     // Update current chunk progress

            // Enhanced logging with full details
            updateProcessingLog(`━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━`, 'separator');
            updateProcessingLog(`✅ CHUNK ${chunkingState.processedChunks} COMPLETED`, 'success');
            updateProcessingLog(`  📦 Chunk Range: Skills ${chunkStart + 1}-${chunkStart + assessedSkills.length}`, 'info');
            updateProcessingLog(`  🎯 Skills Assessed: ${assessedSkills.length}`, 'info');
            updateProcessingLog(`  📊 Total Accumulated: ${chunkingState.accumulatedResults.length} skills`, 'info');
            updateProcessingLog(`  💾 Results saved to local storage`, 'info');

            // Calculate remaining work
            const remainingSkills = workflowState.extractedSkills.length - chunkingState.totalSkillsProcessed;
            if (remainingSkills > 0) {
                updateProcessingLog(`  ⏳ Remaining: ${remainingSkills} skills to process`, 'warning');
                const chunksRemaining = Math.ceil(remainingSkills / parseInt(document.getElementById('chunk-size-input')?.value || 650));
                updateProcessingLog(`  📈 Estimated chunks remaining: ${chunksRemaining}`, 'info');
            } else {
                updateProcessingLog(`  🎉 All skills processed!`, 'success');
            }
            updateProcessingLog(`━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━`, 'separator');

            // Show a popup with accumulation status
            showNotification(
                `Chunk processed! ${chunkingState.accumulatedResults.length} total skills accumulated`,
                'success'
            );
        }

        // Check for rate limit warnings and display them
        if (result.llm_response?.batch_info?.rate_limit_warnings) {
            const warnings = result.llm_response.batch_info.rate_limit_warnings;
            console.warn('Rate limiting encountered during processing:', warnings);

            // Update processing log with warnings
            updateProcessingLog('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━', 'warning');
            updateProcessingLog(`⚠️ Rate Limiting Detected`, 'warning');
            warnings.forEach(warning => {
                console.warn(`  ⚠️ ${warning}`);
                updateProcessingLog(`  • ${warning}`, 'warning');
            });
            updateProcessingLog('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━', 'warning');

            showNotification(`Assessment completed with ${warnings.length} rate limit retries`, 'warning');
        }

        // Save to assessment history
        if (window.assessmentHistory) {
            // Calculate actual batch number based on skills processed
            const batchNumber = Math.ceil(workflowState.extractedSkills.length / 100);  // Updated to match backend batch size
            window.assessmentHistory.updateProgress(
                batchNumber, 
                workflowState.extractedSkills.length, 
                request, 
                result
            );
            window.assessmentHistory.completeRun('completed');
        }
        
        // Display response JSON - show ACCUMULATED results if chunking
        const responseViewerElement = document.getElementById('langchain-response-viewer');
        if (responseViewerElement) {
            // Determine what to display: accumulated results or current chunk
            let displayData = result;
            let headerText = 'Response';

            if (isChunkedProcessing && chunkingState.accumulatedResults.length > 0) {
                // Show accumulated results instead of just the current chunk
                displayData = {
                    success: true,
                    total_skills: chunkingState.accumulatedResults.length,
                    assessed_skills: chunkingState.accumulatedResults,
                    chunks_processed: chunkingState.processedChunks,
                    current_chunk: result.assessed_skills ? result.assessed_skills.length : 0
                };
                headerText = `Accumulated Results (${chunkingState.accumulatedResults.length} skills from ${chunkingState.processedChunks} chunks)`;
            }

            const responseHtml = `
                <div class="relative">
                    <div class="absolute top-2 right-2 flex gap-2">
                        <span class="bg-purple-600 text-white px-2 py-1 rounded text-xs">${headerText}</span>
                        <button onclick="copyJsonResponse()" class="bg-blue-600 text-white px-2 py-1 rounded text-xs hover:bg-blue-700">
                            <i class="fas fa-copy mr-1"></i>Copy
                        </button>
                        <button onclick="downloadJsonResponse()" class="bg-green-600 text-white px-2 py-1 rounded text-xs hover:bg-green-700">
                            <i class="fas fa-download mr-1"></i>Download
                        </button>
                    </div>
                    <pre class="text-xs pt-8">${JSON.stringify(displayData, null, 2)}</pre>
                </div>
            `;
            responseViewerElement.innerHTML = responseHtml;
            // Store for copy/download functions - use accumulated if available
            workflowState.lastAssessmentResponse = displayData;
        }
        
        // Check if we're in automatic mode and have more chunks to process
        const isAutomaticMode = chunkingState.intelligentMode || window.automaticProcessingMode;
        const hasMoreChunks = chunkingState.accumulatedResults.length < workflowState.extractedSkills.length;

        // Auto-continue when:
        // 1. Chunk size equals batch size (original condition), OR
        // 2. We're processing chunks and the batch was reduced due to truncation (batch < chunk)
        const chunkSizeValue = parseInt(document.getElementById('chunk-size-input')?.value || 650);
        const batchSizeValue = parseInt(document.getElementById('batch-size-input')?.value || 650);
        const isProcessingChunks = chunkSizeValue > 0 && chunkingState.processedChunks >= 0;
        const shouldAutoContinue = isProcessingChunks && hasMoreChunks &&
            (chunkSizeValue === batchSizeValue || batchSizeValue < chunkSizeValue);

        console.log('🔍 Auto-continuation check:', {
            chunkSize: chunkSizeValue,
            batchSize: batchSizeValue,
            sizesMatch: chunkSizeValue === batchSizeValue,
            batchReduced: batchSizeValue < chunkSizeValue,
            hasMoreChunks: hasMoreChunks,
            isProcessingChunks: isProcessingChunks,
            shouldAutoContinue: shouldAutoContinue,
            isAutomaticMode: isAutomaticMode,
            willContinue: (isAutomaticMode || shouldAutoContinue) && hasMoreChunks
        });

        if ((isAutomaticMode || shouldAutoContinue) && hasMoreChunks) {
            // Log chunk completion with timing
            const currentChunkNum = chunkingState.processedChunks + 1;
            if (chunkStartTime) {
                const chunkTime = Math.round((Date.now() - chunkStartTime) / 1000);
                const minutes = Math.floor(chunkTime / 60);
                const seconds = chunkTime % 60;
                logChunkEvent(`✅ Chunk ${currentChunkNum} completed in ${minutes}:${seconds.toString().padStart(2, '0')} (${result.total_skills} skills)`, 'complete');
                chunkTimings.push(chunkTime);
            }

            // Update progress for current chunk completion
            const processed = chunkingState.accumulatedResults.length;
            const total = workflowState.extractedSkills.length;
            updateAssessmentProgress(processed, total, `Chunk complete! Processing ${processed}/${total} skills...`);

            // Show notification about moving to next chunk
            const totalChunks = Math.ceil(total / parseInt(document.getElementById('chunk-size-input')?.value || 650));
            showNotification(`✅ Chunk ${currentChunkNum} complete! Moving to chunk ${currentChunkNum + 1}/${totalChunks}...`, 'info');

            updateProcessingLog(`━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━`, 'info');
            updateProcessingLog(`✅ Chunk ${currentChunkNum} Complete! (${result.total_skills} skills)`, 'success');
            updateProcessingLog(`🔄 Continuing to chunk ${currentChunkNum + 1}/${totalChunks}...`, 'info');

            // Log start of next chunk
            logChunkEvent(`🚀 Starting chunk ${currentChunkNum + 1}/${totalChunks}...`, 'start');
            chunkStartTime = Date.now();

            // ACTUALLY CONTINUE TO NEXT CHUNK IN AUTOMATIC MODE
            setTimeout(() => {
                console.log('🔄 Automatic mode check:', {
                    automaticMode: window.automaticProcessingMode,
                    intelligentMode: chunkingState.intelligentMode,
                    shouldAutoContinue: shouldAutoContinue,
                    remainingSkills: workflowState.extractedSkills.length - chunkingState.accumulatedResults.length
                });

                // Continue processing if in automatic mode or if chunk size equals batch size
                if (window.automaticProcessingMode || chunkingState.intelligentMode || shouldAutoContinue) {
                    console.log('✅ Continuing to next chunk automatically...');

                    // Increment the processed chunks counter
                    chunkingState.processedChunks = (chunkingState.processedChunks || 0) + 1;

                    // Log current state before continuing
                    console.log('📊 Pre-continuation state:', {
                        totalSkills: workflowState.extractedSkills?.length,
                        accumulated: chunkingState.accumulatedResults?.length,
                        currentChunkStart: chunkingState.currentChunkStart,
                        processedChunks: chunkingState.processedChunks,
                        isAssessmentRunning: isAssessmentRunning
                    });

                    selectNextChunk();  // Move to next chunk

                    // Check if selectNextChunk was successful (there are more skills)
                    const remainingSkills = workflowState.extractedSkills.length - chunkingState.accumulatedResults.length;
                    if (remainingSkills > 0) {
                        console.log(`📦 Starting next chunk with ${remainingSkills} remaining skills...`);

                        // Mark as auto-continuation to avoid duplicate logs
                        window.isAutoContinuation = true;

                        // Use appropriate function based on mode
                        if (window.automaticProcessingMode || chunkingState.intelligentMode) {
                            console.log('Using intelligent processing mode');
                            processSkillsWithRetry();  // Intelligent processing
                        } else {
                            console.log('Using normal chunk processing mode');
                            // Ensure assessment is not still running
                            if (isAssessmentRunning) {
                                console.error('⚠️ Assessment still running, waiting...');
                                setTimeout(() => runLangChainAssessment(), 1000);
                            } else {
                                runLangChainAssessment();  // Normal chunk processing
                            }
                        }
                    } else {
                        console.log('✅ All skills have been processed!');
                        showNotification('All skills have been processed!', 'success');

                        // CRITICAL: Stop the timer when all chunks are done
                        if (window.progressInterval) {
                            clearInterval(window.progressInterval);
                            window.progressInterval = null;
                            console.log('⏹️ Stopped timer - all chunks complete');
                        }

                        finalizeCombinedResults();
                    }
                } else {
                    console.log('❌ Auto-continuation conditions not met, checking for failures...');
                    checkAndRetryFailures();
                }
            }, 2000); // 2 second delay before continuing
        } else {
            // Final completion - all chunks done
            const totalAssessed = chunkingState.accumulatedResults.length;
            const totalExpected = workflowState.extractedSkills.length;
            updateAssessmentProgress(totalAssessed, totalExpected, `Assessment complete! ${totalExpected} skills assessed.`);

            // Stop the progress timer for final completion
            if (window.progressInterval) {
                clearInterval(window.progressInterval);
                window.progressInterval = null;
            }

            // Log final chunk completion
            if (chunkStartTime) {
                const chunkTime = Math.round((Date.now() - chunkStartTime) / 1000);
                const minutes = Math.floor(chunkTime / 60);
                const seconds = chunkTime % 60;
                const currentChunkNum = chunkingState.processedChunks + 1;
                logChunkEvent(`✅ Final chunk ${currentChunkNum} completed in ${minutes}:${seconds.toString().padStart(2, '0')}`, 'complete');
            }

            // Calculate and log total time
            if (chunkTimings.length > 0) {
                const totalTime = chunkTimings.reduce((a, b) => a + b, 0);
                const avgTime = Math.round(totalTime / chunkTimings.length);
                const totalMinutes = Math.floor(totalTime / 60);
                const totalSeconds = totalTime % 60;
                logChunkEvent(`🎉 All chunks complete! Total time: ${totalMinutes}:${totalSeconds.toString().padStart(2, '0')} (avg ${avgTime}s per chunk)`, 'complete');
            }

            // Check if truly complete or just chunk
            const actualComplete = chunkingState.accumulatedResults.length >= workflowState.extractedSkills.length;

            // Add detailed completion messages to processing log
            if (actualComplete) {
                updateProcessingLog(`━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━`, 'separator');
                updateProcessingLog(`🎉 Assessment Complete!`, 'success');
                const finalTotal = workflowState.extractedSkills.length;
                updateProcessingLog(`✅ Successfully assessed ${finalTotal} skills`, 'success');
            } else {
                const remaining = workflowState.extractedSkills.length - chunkingState.accumulatedResults.length;
                updateProcessingLog(`━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━`, 'separator');
                updateProcessingLog(`📦 Chunk Complete!`, 'info');
                updateProcessingLog(`✅ Assessed ${chunkingState.accumulatedResults.length}/${workflowState.extractedSkills.length} skills`, 'info');
                updateProcessingLog(`⏳ ${remaining} skills remaining`, 'warning');
            }
        }

        // Show batch completion summary if available
        if (result.llm_response?.batch_info) {
            const batchInfo = result.llm_response.batch_info;
            updateProcessingLog(`📊 Batch Processing Summary:`, 'info');
            updateProcessingLog(`  • Total batches executed: ${batchInfo.total_batches}`, 'info');
            updateProcessingLog(`  • Successful batches: ${batchInfo.successful_batches}`, 'success');
            if (batchInfo.failed_batches > 0) {
                updateProcessingLog(`  • Failed batches: ${batchInfo.failed_batches}`, 'warning');
            }
            updateProcessingLog(`  • Skills per batch: ${batchInfo.skills_per_batch}`, 'info');

            // Show individual batch status if we didn't log them during processing
            if (window.progressInterval && !window.progressInterval.batchesLogged) {
                for (let i = 1; i <= batchInfo.successful_batches; i++) {
                    const batchStart = (i - 1) * batchInfo.skills_per_batch + 1;
                    const batchEnd = Math.min(i * batchInfo.skills_per_batch, result.total_skills);
                    updateProcessingLog(`  ✅ Batch ${i}: Skills ${batchStart}-${batchEnd} completed`, 'success');
                }
            }
        }

        // Calculate final time immediately
        const finalElapsed = Math.floor((Date.now() - startTime) / 1000);
        const finalMinutes = Math.floor(finalElapsed / 60);
        const finalSeconds = finalElapsed % 60;
        const finalTimeStr = `${finalMinutes}:${finalSeconds.toString().padStart(2, '0')}`;
        
        // Stop progress interval after a delay
        setTimeout(() => {
            if (window.progressInterval) {
                clearInterval(window.progressInterval);
                window.progressInterval = null;
            }
            // Update elapsed time one more time
            const elapsedTimeEl = document.getElementById('elapsed-time');
            if (elapsedTimeEl && window.assessmentStartTime) {
                const latestElapsed = Math.floor((Date.now() - window.assessmentStartTime) / 1000);
                if (!isNaN(latestElapsed)) {
                    const latestMinutes = Math.floor(latestElapsed / 60);
                    const latestSeconds = latestElapsed % 60;
                    elapsedTimeEl.textContent = `${latestMinutes}:${latestSeconds.toString().padStart(2, '0')}`;
                }
            }
        }, 1000);  // Give it 1 more second to update
        
        if (result.success) {
            if (statusElement) {
                // Check if this is automatic mode with more chunks
                const isAutomaticMode = chunkingState.intelligentMode || window.automaticProcessingMode;
                const hasMoreChunks = chunkingState.accumulatedResults.length < workflowState.extractedSkills.length;

                if (isAutomaticMode && hasMoreChunks) {
                    const processed = chunkingState.accumulatedResults.length;
                    const total = workflowState.extractedSkills.length;
                    statusElement.innerHTML = `<span class="text-blue-600"><i class="fas fa-spinner fa-spin mr-1"></i>Chunk complete! Continuing... (${processed}/${total} skills)</span>`;
                } else {
                    const finalTotalSkills = workflowState.extractedSkills.length;
                    statusElement.innerHTML = `<span class="text-green-600"><i class="fas fa-check-circle mr-1"></i>LangChain assessment complete! ${finalTotalSkills} skills populated with proficiency values.</span>`;
                }
                
                // Log completion with batch details
                updateProcessingLog('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━', 'success');
                updateProcessingLog(`✅ All ${totalBatches} batch${totalBatches > 1 ? 'es' : ''} completed successfully!`, 'success');

                // Update workflow progress
                if (typeof updateWorkflowStep === 'function') {
                    updateWorkflowStep(5, 'completed', 'Assessment complete');
                }
                updateProcessingLog(`📊 Final Results:`, 'success');
                updateProcessingLog(`  • Skills Processed: ${totalSkills}`, 'success');
                updateProcessingLog(`  • Batches Completed: ${totalBatches}`, 'success');
                updateProcessingLog(`  • Total Time: ${finalTimeStr}`, 'success');


                // Check for warnings from backend about batch failures
                if (response.warning) {
                    updateProcessingLog(`⚠️  WARNING: ${response.warning}`, 'warning');
                    showNotification(`Assessment completed with warnings: ${response.warning}`, 'warning');
                } else {
                    updateProcessingLog('🎉 Assessment completed successfully!', 'success');
                }
                updateProcessingLog('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━', 'success');
            }
            
            // Update final metrics - use ACTUAL accumulated results count
            const actualAssessedCount = chunkingState.accumulatedResults.length;
            const totalAssessedEl = document.getElementById('total-assessed-skills');
            const totalTimeEl = document.getElementById('total-processing-time');
            const avgConfidenceEl = document.getElementById('average-confidence');

            console.log('Assessment Complete Metrics:', {
                accumulated: actualAssessedCount,
                total: workflowState.extractedSkills.length,
                time: finalTimeStr
            });

            if (totalAssessedEl) totalAssessedEl.textContent = actualAssessedCount.toString();
            if (totalTimeEl) totalTimeEl.textContent = finalTimeStr;
            if (avgConfidenceEl) {
                // Calculate actual average confidence from accumulated results
                const avgConf = chunkingState.accumulatedResults.length > 0
                    ? (chunkingState.accumulatedResults.reduce((sum, skill) => sum + (skill.confidence_score || 0.85), 0) / chunkingState.accumulatedResults.length * 100).toFixed(1)
                    : '0.0';
                avgConfidenceEl.textContent = avgConf;
            }
            
            // Show results summary
            const resultsSummary = document.getElementById('assessment-results-summary');
            if (resultsSummary) {
                resultsSummary.classList.remove('hidden');
            }
            
            // Show notification if assessment was saved
            if (result.saved_assessment_file) {
                showNotification(`Assessment saved to: ${result.saved_assessment_file}`, 'success');
                updateProcessingLog(`💾 Assessment saved to assessment_history/${result.saved_assessment_file}`);
            }
            
            // Store the assessment results
            workflowState.assessmentResults = {
                roles: workflowState.jieRoles || [],
                skills: result.assessed_skills || result.assessments || [],
                total_skills_sent: result.total_skills || workflowState.extractedSkills?.length || 0,
                proficiency_levels: {},
                langchain_response: result.langchain_response || null,
                model_used: document.getElementById('llm-provider')?.value || 'Unknown',
                processing_time: result.processing_time || finalElapsed
            };
            
            // Extract proficiency levels and confidence scores from assessed skills
            const assessedSkills = result.assessed_skills || result.assessments || [];
            assessedSkills.forEach(skill => {
                // Handle both skill_name and skill field names
                const skillName = skill.skill || skill.skill_name || skill.name;
                if (skillName && skill.proficiency) {
                    workflowState.assessmentResults.proficiency_levels[skillName] = skill.proficiency;
                }
                // Add confidence if available from LangChain response
                if (skill.confidence === undefined && result.langchain_response) {
                    // Try to extract confidence from the response
                    skill.confidence = extractConfidenceFromResponse(skill, result.langchain_response);
                }
            });
            
            // Store in assessment analytics if available
            if (window.assessmentAnalytics) {
                const assessmentId = window.assessmentAnalytics.addAssessment({
                    ...result,
                    assessed_skills: assessedSkills,
                    model_used: workflowState.assessmentResults.model_used,
                    processing_time: workflowState.assessmentResults.processing_time
                });
                // Assessment stored successfully
            }
            
            // Automatically save assessment to server and download
            const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, -5);
            const environment = document.getElementById('sandbox-selector')?.value || 'unknown';
            
            // Get the actual provider and model used
            const provider = document.getElementById('llm-provider')?.value || request.provider || 'unknown';
            const modelSelect = document.getElementById('llm-model-select');
            const model = modelSelect?.value || request.model || '';
            
            // Format model string with provider/model if model exists
            const modelString = model ? `${provider}/${model}` : provider;
            
            // NOTE: Assessment is already saved by the backend in /api/assess endpoint
            // Don't save again here - this was causing duplicates
            // The backend saves the correct assessment data structure
            
            const assessmentData = {
                timestamp: new Date().toISOString(),
                environment: environment,
                model: modelString,
                provider: provider,
                model_name: model,
                // Don't include roles - they're not part of assessment results
                skills: assessedSkills,
                proficiency_levels: workflowState.assessmentResults.proficiency_levels,
                langchain_response: result.langchain_response,
                statistics: {
                    total_skills: assessedSkills.length,
                    processing_time: workflowState.assessmentResults.processing_time,
                    confidence_scores: assessedSkills.filter(s => s.confidence).map(s => s.confidence)
                }
            };
            
            // Skip the duplicate save - backend already saved it
            // Just notify that assessment was saved
            showNotification('Assessment saved automatically', 'info');
            
            // Don't automatically download - user can download manually if needed
            
            // Display the assessed skills
            if (assessedSkills.length > 0) {
                displayAssessedSkills(assessedSkills);
                // Use total_skills from the response for accurate count
                const totalSkillsCount = result.total_skills || assessedSkills.length;
                const totalExpectedSkills = workflowState.extractedSkills?.length || totalSkillsCount;

                // Track unassessed skills
                const unassessedCount = totalSkillsCount - assessedSkills.length;
                if (unassessedCount > 0) {
                    // Find which skills were not assessed
                    const assessedSkillNames = new Set(assessedSkills.map(s => s.skill_name || s.skill || s.name));
                    const unassessedSkills = workflowState.extractedSkills.filter(s =>
                        !assessedSkillNames.has(s.name || s.skill_name || s.skill)
                    );

                    // Store unassessed skills for retry
                    workflowState.unassessedSkills = unassessedSkills;

                    // Show warning with retry option
                    showNotification(`⚠️ Only ${assessedSkills.length} of ${totalSkillsCount} skills were assessed. ${unassessedCount} skills need retry.`, 'warning');
                    // Check if this is a full chunk or just some skills
                    const chunkSize = parseInt(document.getElementById('chunk-size-input')?.value || 650);
                    const failedChunks = Math.ceil(unassessedCount / chunkSize);
                    const isFullChunk = unassessedCount >= chunkSize;

                    updateProcessingLog(`⚠️ Incomplete Assessment: ${assessedSkills.length}/${totalSkillsCount} skills assessed`, 'warning');

                    if (isFullChunk) {
                        updateProcessingLog(`❗ ${failedChunks} chunk(s) (${unassessedCount} skills) were not assessed and need retry`, 'warning');
                    } else {
                        updateProcessingLog(`❗ ${unassessedCount} skill${unassessedCount > 1 ? 's' : ''} from the current chunk failed and need${unassessedCount > 1 ? '' : 's'} retry`, 'warning');
                    }

                    // Log the error reason if available
                    if (result.error || result.detail) {
                        const errorReason = result.error || result.detail;
                        logChunkEvent(`❌ Failed: ${errorReason}`, 'error');
                        updateProcessingLog(`📝 Failure reason: ${errorReason}`, 'error');
                    }

                    // Show retry button
                    showRetryUnassessedButton(unassessedSkills);
                } else {
                    // Check if this is truly complete or just a chunk
                    const accumulated = chunkingState.accumulatedResults?.length || 0;
                    const totalExpected = workflowState.extractedSkills?.length || totalSkillsCount;

                    if (accumulated > 0 && accumulated < totalExpected) {
                        // This is a chunk completion, not full completion
                        const remainingSkills = totalExpected - accumulated;
                        const currentChunk = Math.floor(accumulated / (chunkingState.chunkSize || 650));
                        const totalChunks = Math.ceil(totalExpected / (chunkingState.chunkSize || 650));
                        showNotification(`✅ Chunk ${currentChunk}/${totalChunks} complete! ${accumulated}/${totalExpected} skills assessed. ${remainingSkills} remaining.`, 'info');
                        updateProcessingLog(`📦 Chunk ${currentChunk}/${totalChunks} complete: ${accumulated}/${totalExpected} skills assessed`);
                        updateProcessingLog(`⏳ ${remainingSkills} skills remaining to process`);
                    } else {
                        // This is full completion
                        showNotification(`✅ Successfully assessed all ${totalSkillsCount} skills`, 'success');
                        updateProcessingLog(`✅ Complete: All ${totalSkillsCount} skills successfully assessed`);
                    }
                }

                // Update Step 6 with the results
                updateStep6WithAssessmentResults();
            } else {
                showNotification('Assessment completed but no skills were returned', 'warning');
                updateProcessingLog('⚠️ Assessment completed but no skills data returned');
            }
        } else {
            // Add detailed failure logging
            let errorMsg = result.detail || result.error || 'Unknown error';

            // Check for specific error types
            if (errorMsg.includes('429') || errorMsg.includes('quota')) {
                errorMsg = '⚠️ API Quota Exceeded: Daily limit reached. Wait 24 hours or switch providers.';

                // If using Google with multiple keys, mark the current key as failed
                const provider = document.getElementById('llm-provider')?.value;
                if (provider === 'google') {
                    const currentKey = window.googleApiKeys.getActiveKey();
                    if (currentKey) {
                        window.googleApiKeys.markFailed(currentKey);

                        // Try to get next available key
                        const nextKeyIndex = window.googleApiKeys.getNextAvailableKey();
                        if (nextKeyIndex !== null) {
                            showNotification(`Switched to ${window.googleApiKeys.keys[nextKeyIndex].name} API key due to rate limit`, 'info');
                            // Auto-save the new key
                            await saveApiKeys();
                        }
                    }
                }
            } else if (errorMsg.includes('401')) {
                errorMsg = '🔑 Invalid API Key: Please check your API key configuration.';
            } else if (errorMsg.includes('parse')) {
                errorMsg = '📝 Response Parsing Error: Try reducing batch size.';
            }

            if (statusElement) {
                statusElement.innerHTML = `<span class="text-red-600"><i class="fas fa-times-circle mr-1"></i>${errorMsg}</span>`;
            }
            const skillCount = result.total_skills || 0;
            const assessedCount = result.assessed_skills ? result.assessed_skills.length : 0;

            updateProcessingLog('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━', 'error');
            updateProcessingLog(`❌ Assessment Failed`, 'error');
            updateProcessingLog(`  • Error: ${errorMsg}`, 'error');
            updateProcessingLog(`  • Skills Processed: ${assessedCount}/${skillCount}`, 'error');
            
            if (result.llm_response && result.llm_response.parsed_assessments === 0) {
                updateProcessingLog(`⚠️ LLM response parsing failed - 0 assessments extracted`);
                updateProcessingLog(`Raw response length: ${result.llm_response.raw_length || 0} characters`);
            }
            
            // Stop progress simulation on failure
            if (window.progressInterval) {
                clearInterval(window.progressInterval);
                window.progressInterval = null;
            }
            
            // Update final time on failure
            const elapsedTimeEl = document.getElementById('elapsed-time');
            const currentStartTime = window.assessmentStartTime || startTime;
            if (elapsedTimeEl && currentStartTime && !isNaN(currentStartTime)) {
                const finalElapsed = Math.floor((Date.now() - currentStartTime) / 1000);
                if (!isNaN(finalElapsed)) {
                    const finalMinutes = Math.floor(finalElapsed / 60);
                    const finalSeconds = finalElapsed % 60;
                    elapsedTimeEl.textContent = `${finalMinutes}:${finalSeconds.toString().padStart(2, '0')}`;
                }
            }
            
            showNotification('Assessment failed: ' + errorMsg, 'error');
        }
    } catch (error) {
        console.error('❌ Error in runLangChainAssessment:', error);
        console.error('Error type:', error.name);
        console.error('Error message:', error.message);
        console.error('Error stack:', error.stack);
        console.error('Full error object:', error);

        // Log to UI as well
        updateProcessingLog(`❌ Error: ${error.name}: ${error.message}`, 'error');

        // Check if this is an abort
        if (error.name === 'AbortError') {
            updateProcessingLog('🚫 Assessment was cancelled by user', 'warning');
        }

        // Assessment error occurred

        // Stop progress simulation
        if (window.progressInterval) {
            clearInterval(window.progressInterval);
            window.progressInterval = null;
        }

        if (statusElement) {
            statusElement.innerHTML = '<span class="text-red-600"><i class="fas fa-exclamation-triangle mr-1"></i>Assessment failed</span>';
        }

        // Determine the actual error message
        let detailedErrorMsg = 'Unknown error occurred';
        if (error.message === 'Failed to fetch') {
            // Network error - provide more specific message
            detailedErrorMsg = '🌐 Network Error: Unable to reach the server. Please check if the server is running on port 5000.';
        } else if (error.message && (error.message.includes('quota') || error.message.includes('429'))) {
            // API quota error
            detailedErrorMsg = '⚠️ API Quota Exceeded: Daily limit reached. Options: 1) Wait 24 hours for reset, 2) Switch to another provider in Step 4, 3) Upgrade your API plan';
        } else if (error.message && error.message.includes('401')) {
            detailedErrorMsg = '🔑 Authentication Failed: Invalid API key. Please verify your API key in Step 4.';
        } else if (error.message && error.message.includes('parse')) {
            detailedErrorMsg = '📝 Response Parsing Error: The LLM response format was invalid. Try reducing the batch size or switching providers.';
        } else if (error.message) {
            detailedErrorMsg = error.message;
        }

        // Check if this is a truncation error and offer auto-retry
        if (detailedErrorMsg.includes('truncated') || detailedErrorMsg.includes('Response appears truncated') ||
            detailedErrorMsg.includes('Reduce to') || detailedErrorMsg.includes('output limits')) {

            // Extract suggested batch size from error message
            const batchSizeMatch = detailedErrorMsg.match(/Reduce to (\d+)/);
            const currentBatchSize = parseInt(document.getElementById('batch-size-input')?.value || 306);
            const suggestedSize = batchSizeMatch ? parseInt(batchSizeMatch[1]) : Math.floor(currentBatchSize * 0.75);

            // Show truncation error with auto-retry option
            updateProcessingLog(`⚠️ Response truncated - batch size too large for this chunk`, 'warning');
            updateProcessingLog(`📉 Current batch size: ${currentBatchSize} skills`, 'info');
            updateProcessingLog(`💡 Suggested batch size: ${suggestedSize} skills`, 'info');

            // Auto-retry with smaller batch size
            showNotification(`Response truncated. Auto-retrying with batch size ${suggestedSize}...`, 'warning');

            // CRITICAL: Clear any existing progress timers before retry
            if (window.progressInterval) {
                clearInterval(window.progressInterval);
                window.progressInterval = null;
                console.log('⏹️ Cleared progress timer before retry');
            }

            // Clear assessment start time to reset timer
            window.assessmentStartTime = null;

            // Don't auto-retry - let user manually adjust and retry
            // Reset running state
            isAssessmentRunning = false;
            updateAssessmentButtonStates(false);

            updateProcessingLog(`❌ Chunk failed due to response truncation`, 'error');
            updateProcessingLog(`💡 Suggestion: Reduce batch size to ${suggestedSize} skills and try again`, 'info');
            updateProcessingLog(`━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━`, 'separator');

            return; // Don't show the regular error notification
        }

        // Show detailed error in notification
        showNotification('Assessment error: ' + detailedErrorMsg, 'error');

        // Update workflow progress
        if (typeof updateWorkflowStep === 'function') {
            updateWorkflowStep(5, 'error', 'Assessment failed');
        }
        
        // Display detailed error in response viewer
        const responseViewerElement = document.getElementById('langchain-response-viewer');
        if (responseViewerElement) {
            // Use the same detailed error message
            let displayError = detailedErrorMsg;

            // If the error contains response data, extract it
            if (error.response) {
                displayError = `HTTP ${error.response.status}: ${error.response.statusText || 'Request failed'}`;
            }

            // If there's a JSON response body with error details, parse it
            if (typeof result !== 'undefined' && result && !result.success) {
                if (result.detail) {
                    displayError = result.detail;
                } else if (result.error) {
                    displayError = result.error;
                } else if (result.message) {
                    displayError = result.message;
                }
            }

            const errorData = {
                error: displayError,
                status: error.status || (error.message === 'Failed to fetch' ? 'network_error' : 'unknown'),
                provider: typeof request !== 'undefined' ? (request.provider || 'unknown') : 'unknown',
                batch_size: typeof request !== 'undefined' ? (request.batch_size || batchConfig.batchSize) : batchConfig.batchSize,
                concurrent_batches: typeof request !== 'undefined' ? (request.concurrent_batches || batchConfig.concurrentBatches) : batchConfig.concurrentBatches,
                possible_causes: [
                    error.message === 'Failed to fetch' ? 'Server is not running or network issue' : null,
                    error.status === 429 ? 'API rate limit exceeded' : null,
                    error.status === 401 ? 'Invalid API key' : null,
                    error.status === 500 ? 'Server error - check server logs' : null
                ].filter(Boolean),
                timestamp: new Date().toISOString()
            };
            responseViewerElement.innerHTML = `<pre class="text-xs text-red-600">${JSON.stringify(errorData, null, 2)}</pre>`;
        }
        
        // Check if this was an abort operation
        if (error.name === 'AbortError') {
            updateProcessingLog('🛑 Assessment stopped by user');
            updateAssessmentProgress(0, workflowState.extractedSkills.length, 'Assessment stopped');
            showNotification('Assessment stopped successfully', 'info');
        } else {
            updateProcessingLog(`❌ Error: ${error.message}`);
            updateAssessmentProgress(0, workflowState.extractedSkills.length, 'Assessment failed');
            showNotification('Assessment failed: ' + error.message, 'error');
        }
    } finally {
        // Always clean up the assessment state
        isAssessmentRunning = false;
        assessmentController = null;
        updateAssessmentButtonStates(false);

        // Clear current chunk tracking
        chunkingState.currentChunk = null;
        chunkingState.currentChunkData = null;

        // Stop any running intervals
        if (window.progressInterval) {
            clearInterval(window.progressInterval);
            window.progressInterval = null;
        }
    }
}

// Update workflow status

// Update assessment progress
function updateAssessmentProgress(processed, total, message) {
    // Update status message
    const progressDetails = document.getElementById('overall-progress-details');

    if (progressDetails) {
        progressDetails.textContent = message || `Processing ${processed}/${total} skills`;
    }

    // Update overall progress bars
    updateOverallProgress();

    // Update failed skills count
    const failedSkillsEl = document.getElementById('failed-skills-count');
    if (failedSkillsEl) {
        failedSkillsEl.textContent = 'None';
    }
}

// Validate assessment completeness
function validateAssessmentCompleteness() {
    const resultsDiv = document.getElementById('validation-results');
    if (!resultsDiv) return;

    // Show the results div
    resultsDiv.classList.remove('hidden');

    // Check if we have assessment results
    if (!workflowState.assessedSkills || workflowState.assessedSkills.length === 0) {
        resultsDiv.innerHTML = `
            <div class="text-red-600 dark:text-red-400">
                <i class="fas fa-exclamation-triangle mr-2"></i>
                <strong>No Assessment Results Found</strong>
                <p class="mt-2">Please run an assessment first before validating.</p>
            </div>
        `;
        return;
    }

    const extractedSkills = workflowState.extractedSkills || [];
    const assessedSkills = workflowState.assessedSkills || [];

    // Create maps for efficient lookup
    const extractedMap = new Map(extractedSkills.map((s, idx) => [s.name || s, idx]));
    const assessedMap = new Map();
    const duplicates = [];

    // Check for duplicates and build assessed map
    assessedSkills.forEach((skill, idx) => {
        const name = skill.name || skill.skill_name;
        if (assessedMap.has(name)) {
            duplicates.push({ name, indices: [assessedMap.get(name), idx] });
        } else {
            assessedMap.set(name, idx);
        }
    });

    // Find missing skills
    const missingSkills = [];
    extractedMap.forEach((idx, name) => {
        if (!assessedMap.has(name)) {
            missingSkills.push(name);
        }
    });

    // Find extra skills (in assessed but not in extracted)
    const extraSkills = [];
    assessedMap.forEach((idx, name) => {
        if (!extractedMap.has(name)) {
            extraSkills.push(name);
        }
    });

    // Check for skills without proficiency
    const skillsWithoutProficiency = assessedSkills.filter(skill => {
        const prof = skill.proficiency || skill.proficiency_level;
        return !prof || prof === null || prof === undefined || prof === 0;
    }).map(s => s.name || s.skill_name);

    // Generate validation report
    const isValid = missingSkills.length === 0 && duplicates.length === 0 && skillsWithoutProficiency.length === 0;

    let html = `<div class="space-y-4">`;

    // Summary
    html += `
        <div class="${isValid ? 'text-green-600 dark:text-green-400' : 'text-yellow-600 dark:text-yellow-400'}">
            <i class="fas ${isValid ? 'fa-check-circle' : 'fa-exclamation-circle'} mr-2 text-2xl"></i>
            <strong class="text-xl">Validation ${isValid ? 'Passed' : 'Results'}</strong>
        </div>
    `;

    // Statistics
    html += `
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="bg-white dark:bg-gray-700 p-3 rounded">
                <div class="text-sm text-gray-600 dark:text-gray-400">Input Skills</div>
                <div class="text-2xl font-bold">${extractedSkills.length}</div>
            </div>
            <div class="bg-white dark:bg-gray-700 p-3 rounded">
                <div class="text-sm text-gray-600 dark:text-gray-400">Assessed Skills</div>
                <div class="text-2xl font-bold">${assessedSkills.length}</div>
            </div>
            <div class="bg-white dark:bg-gray-700 p-3 rounded">
                <div class="text-sm text-gray-600 dark:text-gray-400">Coverage</div>
                <div class="text-2xl font-bold">${Math.round((assessedSkills.length - extraSkills.length) / extractedSkills.length * 100)}%</div>
            </div>
            <div class="bg-white dark:bg-gray-700 p-3 rounded">
                <div class="text-sm text-gray-600 dark:text-gray-400">Duplicates</div>
                <div class="text-2xl font-bold ${duplicates.length > 0 ? 'text-red-600' : 'text-green-600'}">${duplicates.length}</div>
            </div>
        </div>
    `;

    // Issues
    if (!isValid) {
        html += `<div class="space-y-3">`;

        if (missingSkills.length > 0) {
            html += `
                <div class="bg-red-100 dark:bg-red-900 p-3 rounded">
                    <div class="font-semibold text-red-800 dark:text-red-200">
                        <i class="fas fa-times-circle mr-2"></i>Missing Skills (${missingSkills.length})
                    </div>
                    <div class="mt-2 text-sm text-red-700 dark:text-red-300 max-h-32 overflow-y-auto">
                        ${missingSkills.slice(0, 10).join(', ')}${missingSkills.length > 10 ? ` ... and ${missingSkills.length - 10} more` : ''}
                    </div>
                </div>
            `;
        }

        if (duplicates.length > 0) {
            html += `
                <div class="bg-yellow-100 dark:bg-yellow-900 p-3 rounded">
                    <div class="font-semibold text-yellow-800 dark:text-yellow-200">
                        <i class="fas fa-copy mr-2"></i>Duplicate Skills (${duplicates.length})
                    </div>
                    <div class="mt-2 text-sm text-yellow-700 dark:text-yellow-300 max-h-32 overflow-y-auto">
                        ${duplicates.slice(0, 5).map(d => `${d.name} (positions: ${d.indices.join(', ')})`).join('<br>')}
                        ${duplicates.length > 5 ? `<br>... and ${duplicates.length - 5} more` : ''}
                    </div>
                </div>
            `;
        }

        if (skillsWithoutProficiency.length > 0) {
            html += `
                <div class="bg-orange-100 dark:bg-orange-900 p-3 rounded">
                    <div class="font-semibold text-orange-800 dark:text-orange-200">
                        <i class="fas fa-question-circle mr-2"></i>Skills Without Proficiency (${skillsWithoutProficiency.length})
                    </div>
                    <div class="mt-2 text-sm text-orange-700 dark:text-orange-300 max-h-32 overflow-y-auto">
                        ${skillsWithoutProficiency.slice(0, 10).join(', ')}${skillsWithoutProficiency.length > 10 ? ` ... and ${skillsWithoutProficiency.length - 10} more` : ''}
                    </div>
                </div>
            `;
        }

        if (extraSkills.length > 0) {
            html += `
                <div class="bg-blue-100 dark:bg-blue-900 p-3 rounded">
                    <div class="font-semibold text-blue-800 dark:text-blue-200">
                        <i class="fas fa-plus-circle mr-2"></i>Extra Skills (${extraSkills.length})
                    </div>
                    <div class="mt-2 text-sm text-blue-700 dark:text-blue-300 max-h-32 overflow-y-auto">
                        ${extraSkills.slice(0, 10).join(', ')}${extraSkills.length > 10 ? ` ... and ${extraSkills.length - 10} more` : ''}
                    </div>
                </div>
            `;
        }

        html += `</div>`;
    } else {
        html += `
            <div class="bg-green-100 dark:bg-green-900 p-4 rounded">
                <div class="text-green-800 dark:text-green-200">
                    <i class="fas fa-check mr-2"></i>
                    <strong>Perfect!</strong> All ${extractedSkills.length} skills have been assessed with proficiency levels.
                    <ul class="mt-2 text-sm">
                        <li>✓ No missing skills</li>
                        <li>✓ No duplicate assessments</li>
                        <li>✓ All skills have proficiency values</li>
                    </ul>
                </div>
            </div>
        `;
    }

    html += `</div>`;
    resultsDiv.innerHTML = html;

    // Scroll to validation results
    resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

    // Log to console for debugging
    console.log('Validation Results:', {
        extractedCount: extractedSkills.length,
        assessedCount: assessedSkills.length,
        missingCount: missingSkills.length,
        duplicateCount: duplicates.length,
        noProficiencyCount: skillsWithoutProficiency.length,
        extraCount: extraSkills.length,
        isValid
    });
}

// Make the function globally available
window.validateAssessmentCompleteness = validateAssessmentCompleteness;

// Test current API key connection
async function testCurrentApiKey() {
    const provider = document.getElementById('llm-provider')?.value ||
                    document.getElementById('llm-provider-select')?.value || 'google';

    const statusIndicator = document.getElementById('connection-indicator');
    const statusMessage = document.getElementById('connection-message');

    // Show testing state
    if (statusIndicator) {
        statusIndicator.className = 'fas fa-circle-notch fa-spin text-blue-500 mr-1';
    }
    if (statusMessage) {
        statusMessage.textContent = 'Testing connection...';
    }

    try {
        const response = await fetch('/api/keys/test', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ provider })
        });

        const result = await response.json();

        if (result.valid) {
            // Success
            if (statusIndicator) {
                statusIndicator.className = 'fas fa-check-circle text-green-500 mr-1';
            }
            if (statusMessage) {
                statusMessage.textContent = `Connected to ${provider.toUpperCase()} API`;
                statusMessage.className = 'text-xs text-green-600 dark:text-green-400 flex items-center';
            }
            showNotification(`✅ ${provider.toUpperCase()} API connection successful!`, 'success');
        } else {
            // Failed
            if (statusIndicator) {
                statusIndicator.className = 'fas fa-times-circle text-red-500 mr-1';
            }
            if (statusMessage) {
                statusMessage.textContent = result.error || 'Connection failed';
                statusMessage.className = 'text-xs text-red-600 dark:text-red-400 flex items-center';
            }
            showNotification(`❌ ${provider.toUpperCase()} API test failed: ${result.error}`, 'error');
        }
    } catch (error) {
        // Network error
        if (statusIndicator) {
            statusIndicator.className = 'fas fa-exclamation-triangle text-yellow-500 mr-1';
        }
        if (statusMessage) {
            statusMessage.textContent = 'Network error - check server connection';
            statusMessage.className = 'text-xs text-yellow-600 dark:text-yellow-400 flex items-center';
        }
        showNotification(`⚠️ Network error: ${error.message}`, 'error');
    }
}

// Make test function globally available
window.testCurrentApiKey = testCurrentApiKey;

// Auto-split chunks functions
function updateChunkSplit(numChunks) {
    const totalSkills = workflowState.extractedSkills?.length || 1223;
    const chunkSize = Math.ceil(totalSkills / numChunks);

    // Update display
    const display = document.getElementById('chunk-split-display');
    if (display) {
        display.textContent = `${numChunks} chunks`;
    }

    // Update preview
    const preview = document.getElementById('chunk-split-preview');
    if (preview) {
        let previewText = `Split ${totalSkills} skills into ${numChunks} chunks of ~${chunkSize} skills each: `;
        const chunks = [];
        for (let i = 0; i < numChunks; i++) {
            const start = i * chunkSize + 1;
            const end = Math.min((i + 1) * chunkSize, totalSkills);
            const size = end - start + 1;
            chunks.push(`[${start}-${end}: ${size}]`);
        }
        previewText += chunks.join(', ');
        preview.textContent = previewText;
    }
}

function applyChunkSplit() {
    const numChunks = parseInt(document.getElementById('chunk-splitter-slider')?.value || 3);
    const totalSkills = workflowState.extractedSkills?.length || 1223;
    const chunkSize = Math.ceil(totalSkills / numChunks);

    // Apply the chunk size
    const chunkSizeInput = document.getElementById('chunk-size-input');
    if (chunkSizeInput) {
        chunkSizeInput.value = chunkSize;
    }

    // ALWAYS reset batch size to match chunk size when applying auto-split
    // This ensures any reduced batch sizes from previous runs are reset
    const batchSizeInput = document.getElementById('batch-size-input');
    if (batchSizeInput) {
        const currentBatchSize = parseInt(batchSizeInput.value);
        if (currentBatchSize !== chunkSize) {
            console.log(`📊 Resetting batch size from ${currentBatchSize} to ${chunkSize} to match chunk size`);
        }
        batchSizeInput.value = chunkSize;
    }

    // Update processing mode to sequential since we're doing one batch per chunk
    const processingMode = document.getElementById('processing-mode-select');
    if (processingMode) {
        processingMode.value = 'sequential';
    }

    // Update concurrent batches to 1
    const concurrentBatches = document.getElementById('concurrent-batches-input');
    if (concurrentBatches) {
        concurrentBatches.value = 1;
    }

    // Trigger updates - batch config should respect our chunk-based settings
    updateBatchConfig();  // This will now respect chunk-based processing
    updateProcessingEstimates();
    updateChunkingUI();

    // Also trigger the sync function to ensure batch = chunk
    if (typeof syncBatchSizeWithChunkSize === 'function') {
        syncBatchSizeWithChunkSize();
    }

    showNotification(`Applied: ${numChunks} chunks of ${chunkSize} skills each (batch size = chunk size)`, 'success');
}

// Make functions globally available
window.updateChunkSplit = updateChunkSplit;
window.applyChunkSplit = applyChunkSplit;
window.syncBatchSizeWithChunkSize = syncBatchSizeWithChunkSize;

// Initialize chunk splitter on page load
document.addEventListener('DOMContentLoaded', function() {
    // Initialize the chunk splitter preview
    const slider = document.getElementById('chunk-splitter-slider');
    if (slider) {
        updateChunkSplit(slider.value);
    }
});

// Clear processing log
function clearProcessingLog() {
    // Update the Assessment Overview status instead
    const statusElement = document.getElementById('overall-progress-details');
    if (statusElement) {
        statusElement.innerHTML = '<span class="text-gray-500 dark:text-gray-400">Ready for new assessment...</span>';
    }
}

// Apply No Batching configuration - send all skills in a single request
function applyNoBatching() {
    // Get the total number of skills
    const totalSkills = workflowState.extractedSkills?.length || 1223;

    // Set batch size to handle all skills in one batch
    document.getElementById('batch-size-input').value = Math.max(totalSkills, 2000);
    document.getElementById('concurrent-batches-input').value = 1;
    document.getElementById('processing-mode-select').value = 'sequential';

    // Update batch config
    updateBatchConfig();

    // Show notification and warning
    showNotification(`No Batching mode: All ${totalSkills} skills will be sent in a single request`, 'warning');

    // Show additional warning for large skill sets
    if (totalSkills > 500) {
        showNotification('⚠️ Warning: Sending many skills at once may hit token limits or timeout. Consider using batching for large skill sets.', 'warning');
    }

    // Update display
    const estimatedBatchesEl = document.getElementById('estimated-batches');
    const estimatedTimeEl = document.getElementById('estimated-time');
    if (estimatedBatchesEl) estimatedBatchesEl.textContent = '1';
    if (estimatedTimeEl) estimatedTimeEl.textContent = '1-3 min (single request)';

    // Add warning to processing log
    updateProcessingLog('⚠️ No Batching Mode: All skills in single request', 'warning');
    updateProcessingLog(`📊 Total skills to process: ${totalSkills}`, 'warning');
    updateProcessingLog('⏳ This may take longer or fail with token limits', 'warning');
}

// Apply Fast Mode configuration for 2-minute processing
function applyFastMode() {
    // Set optimal batch configuration based on provider limits
    const provider = document.getElementById('llm-provider')?.value || 'google';
    let batchSize, concurrentBatches, processingMode;

    if (provider === 'google') {
        // Google optimization: Use smaller batches to avoid response truncation
        const skillCount = workflowState.extractedSkills?.length || 1223;

        // Use chunk size for batch size (sequential processing)
        batchSize = chunkSize;
        concurrentBatches = 1;  // Sequential to avoid rate limits
        processingMode = 'sequential';

        // Show info for Google users
        const batchesNeeded = Math.ceil(skillCount / batchSize);
        showNotification(
            `Google Mode: Processing ${skillCount} skills in ${batchesNeeded} batches (${batchSize} skills each)`,
            'info'
        );
    } else {
        // Other providers with higher limits
        batchSize = 800;
        concurrentBatches = 1;
        processingMode = 'sequential';
    }

    document.getElementById('batch-size-input').value = batchSize;
    document.getElementById('concurrent-batches-input').value = concurrentBatches;
    document.getElementById('processing-mode-select').value = processingMode;

    // Use simplified prompt for faster processing
    const simplePrompt = `Assign proficiency levels to these skills.

Proficiency scale: 1=Novice, 2=Developing, 3=Intermediate, 4=Advanced, 5=Expert
Confidence score: 0.0 to 1.0 (decimal)

Return JSON format:
{{
    "assessments": [
        {{
            "skill_name": "exact skill name",
            "proficiency": 3,
            "confidence_score": 0.85,
            "reasoning": "brief explanation"
        }}
    ]
}}

Process ALL skills provided. Return ONLY valid JSON.`;

    document.getElementById('assessment-prompt').value = simplePrompt;

    // Update batch config
    updateBatchConfig();

    // Show notification with provider-specific message
    const skillCount = workflowState.extractedSkills?.length || 1223;
    const batchesNeeded = Math.ceil(skillCount / batchSize);
    const modeMessage = provider === 'google'
        ? `Google Optimized: ${batchesNeeded} batches × ${batchSize} skills (avoids output token limits)`
        : `Fast Mode: ${batchesNeeded} batches × ${batchSize} skills (2 parallel workers)`;
    showNotification(modeMessage, 'success');

    // Update display with actual calculated batches
    const actualBatches = Math.ceil(skillCount / batchSize);
    const estimatedBatchesEl = document.getElementById('estimated-batches');
    if (estimatedBatchesEl) estimatedBatchesEl.textContent = actualBatches;

    // Update time estimate based on provider and mode
    const timeEstimate = provider === 'google'
        ? `~${Math.ceil(actualBatches * 0.5)} min (sequential)`
        : '~2 min (parallel)';
    const estimatedTimeEl = document.getElementById('estimated-time');
    if (estimatedTimeEl) estimatedTimeEl.textContent = timeEstimate;

    // Update processing log with batch info
    updateProcessingLog(`📦 Batch configuration: ${batchSize} skills/batch × ${actualBatches} batches`, 'info');
    updateProcessingLog(`⚙️ Processing mode: ${processingMode} with ${concurrentBatches} worker(s)`, 'info');
}

// Update processing log with enhanced formatting
function updateProcessingLog(message, type = 'info') {
    // Update the Assessment Overview status instead of a separate log
    const statusElement = document.getElementById('overall-progress-details');

    if (statusElement) {
        // Don't update status for certain message types that should only go to console
        const skipStatusUpdate = message.includes('━━━') || message.includes('Processing Plan:') ||
                                message.includes('Batch') || message.includes('Skills:');
        // Skip separator lines
        if (type === 'separator' || message.includes('━━━')) {
            console.log(`[${type.toUpperCase()}] ${message}`);
            return;
        }

        if (skipStatusUpdate) {
            // Only log to console, not to UI status
            console.log(`[${type.toUpperCase()}] ${message}`);
            return;
        }

        // Extract the key information from the message
        let displayMessage = message;

        // Remove timestamps if present
        displayMessage = displayMessage.replace(/\[\d+:\d+:\d+\s*(AM|PM)?\]/, '').trim();

        // Determine icon and color based on type
        let icon = '';
        let colorClass = 'text-blue-600 dark:text-blue-400';

        if (type === 'error' || message.includes('❌') || message.includes('failed')) {
            icon = '<i class="fas fa-times-circle mr-1"></i>';
            colorClass = 'text-red-600 dark:text-red-400';
        } else if (type === 'warning' || message.includes('⚠️')) {
            icon = '<i class="fas fa-exclamation-triangle mr-1"></i>';
            colorClass = 'text-yellow-600 dark:text-yellow-400';
        } else if (type === 'success' || message.includes('✅') || message.includes('🎉')) {
            icon = '<i class="fas fa-check-circle mr-1"></i>';
            colorClass = 'text-green-600 dark:text-green-400';
        } else if (message.includes('🚀') || message.includes('🔄') || message.includes('📦')) {
            icon = '<i class="fas fa-spinner fa-pulse mr-1"></i>';
            colorClass = 'text-blue-600 dark:text-blue-400';
        }

        // Update the status with the formatted message
        statusElement.innerHTML = `<span class="${colorClass} font-medium">${icon}${displayMessage}</span>`;
    }

    // Also log to console for debugging
    console.log(`[${type.toUpperCase()}] ${message}`);
}

// Show notification (if not already defined)
if (typeof showNotification === 'undefined') {
    function showNotification(message, type) {
        // console.log(`[${type.toUpperCase()}] ${message}`);
        // You can add a toast notification here
    }
}

// Show a confirmation modal instead of using confirm()
function showConfirmModal(title, message, onConfirm, onCancel) {
    // Create modal overlay
    const overlay = document.createElement('div');
    overlay.className = 'fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center';
    overlay.id = 'confirm-modal-overlay';

    // Determine the button text based on the title
    let confirmButtonText = 'OK';
    let confirmButtonClass = 'bg-blue-600 hover:bg-blue-700';
    if (title.toLowerCase().includes('clear') || title.toLowerCase().includes('reset')) {
        confirmButtonText = 'Clear';
        confirmButtonClass = 'bg-red-600 hover:bg-red-700';
    } else if (title.toLowerCase().includes('stop')) {
        confirmButtonText = 'Stop';
        confirmButtonClass = 'bg-orange-600 hover:bg-orange-700';
    }

    // Create modal content
    const modal = document.createElement('div');
    modal.className = 'bg-white dark:bg-gray-800 rounded-lg shadow-xl max-w-md w-full mx-4 p-6';
    modal.innerHTML = `
        <h3 class="text-lg font-semibold mb-3 text-gray-900 dark:text-white">${title}</h3>
        <p class="text-gray-600 dark:text-gray-300 mb-6">${message}</p>
        <div class="flex justify-end gap-3">
            <button id="modal-cancel-btn" class="px-4 py-2 bg-gray-200 dark:bg-gray-700 text-gray-800 dark:text-gray-200 rounded-lg hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors">
                Cancel
            </button>
            <button id="modal-confirm-btn" class="px-4 py-2 ${confirmButtonClass} text-white rounded-lg transition-colors">
                ${confirmButtonText}
            </button>
        </div>
    `;

    overlay.appendChild(modal);
    document.body.appendChild(overlay);

    // Add event listeners
    document.getElementById('modal-cancel-btn').addEventListener('click', () => {
        document.body.removeChild(overlay);
        if (onCancel) onCancel();
    });

    document.getElementById('modal-confirm-btn').addEventListener('click', () => {
        document.body.removeChild(overlay);
        if (onConfirm) onConfirm();
    });

    // Close on overlay click
    overlay.addEventListener('click', (e) => {
        if (e.target === overlay) {
            document.body.removeChild(overlay);
            if (onCancel) onCancel();
        }
    });
}

// Show retry button for unassessed skills
function showRetryUnassessedButton(unassessedSkills) {
    // First add it to the processing log
    const processingLog = document.getElementById('processing-log');
    if (processingLog) {
        const retryDiv = document.createElement('div');
        retryDiv.className = 'mt-3 p-3 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-300 dark:border-yellow-700 rounded-lg';

        const chunkSize = parseInt(document.getElementById('chunk-size-input')?.value || 650);
        const failedChunks = Math.ceil(unassessedSkills.length / chunkSize);
        const isFullChunk = unassessedSkills.length >= chunkSize;

        retryDiv.innerHTML = `
            <div class="flex items-center justify-between">
                <div>
                    <div class="font-semibold text-yellow-800 dark:text-yellow-200">
                        <i class="fas fa-exclamation-triangle mr-2"></i>
                        ${isFullChunk ? `${failedChunks} Chunk(s)` : `${unassessedSkills.length} Skill${unassessedSkills.length > 1 ? 's' : ''}`} Not Assessed
                    </div>
                    <div class="text-sm text-yellow-600 dark:text-yellow-400 mt-1">
                        ${isFullChunk ? `Click retry to process the failed chunk(s)` : `Click retry to assess the remaining ${unassessedSkills.length} skill${unassessedSkills.length > 1 ? 's' : ''}`}
                    </div>
                </div>
                <button onclick="retryUnassessedSkills()" class="px-4 py-2 bg-yellow-600 text-white rounded-lg hover:bg-yellow-700 transition-colors">
                    <i class="fas fa-redo mr-2"></i>Retry Failed ${isFullChunk ? 'Chunk(s)' : 'Skills'}
                </button>
            </div>
        `;
        processingLog.appendChild(retryDiv);
    }

    // Also show a retry button in the main UI
    const retryButton = document.getElementById('retry-failed-btn');
    if (retryButton) {
        retryButton.classList.remove('hidden');
        retryButton.onclick = retryUnassessedSkills;
    }
}

// Retry unassessed skills with optimal batch size
async function retryUnassessedSkills() {
    if (!workflowState.unassessedSkills || workflowState.unassessedSkills.length === 0) {
        showNotification('No unassessed skills to retry', 'warning');
        return;
    }

    const unassessedSkills = workflowState.unassessedSkills;
    const unassessedCount = unassessedSkills.length;

    updateProcessingLog('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━', 'info');
    updateProcessingLog(`🔄 Retrying ${unassessedCount} unassessed skills`, 'info');

    // Calculate optimal batch size for 2 batches (Google rate limit)
    // If we have 422 unassessed skills, split into 2 batches of ~211 each
    const OPTIMAL_BATCHES = 2;
    const RETRY_BATCH_SIZE = Math.ceil(unassessedCount / OPTIMAL_BATCHES);

    updateProcessingLog(`📦 Using optimized batch size: ${RETRY_BATCH_SIZE} skills per batch (${OPTIMAL_BATCHES} total batches)`, 'info');
    updateProcessingLog(`⏱️ Will wait 60 seconds between batches to respect rate limits`, 'warning');

    // Replace the extracted skills with only unassessed ones
    const originalSkills = workflowState.extractedSkills;
    workflowState.extractedSkills = unassessedSkills;

    // Store retry configuration
    sessionStorage.setItem('retry_batch_size', RETRY_BATCH_SIZE);
    sessionStorage.setItem('is_retry_assessment', 'true');
    sessionStorage.setItem('rate_limit_delay', '60000'); // 60 second delay between batches

    // Trigger assessment with optimal batch size
    await assessSkillsWithSimpleLangChain();

    // Restore original skills list
    workflowState.extractedSkills = originalSkills;

    // Clear retry flags
    sessionStorage.removeItem('retry_batch_size');
    sessionStorage.removeItem('is_retry_assessment');
    sessionStorage.removeItem('rate_limit_delay');
}

// Make retry function globally available
window.retryUnassessedSkills = retryUnassessedSkills;

// Toggle auth response JSON display - Show Modal
window.toggleAuthResponse = function() {
    const modal = document.getElementById('auth-modal');
    const username = document.getElementById('api-eightfold-username').value;
    
    // Show the modal properly
    modal.classList.remove('hidden');
    modal.style.display = 'flex';
    
    // Update modal with auth data
    document.getElementById('modal-auth-username').textContent = username || 'N/A';
    document.getElementById('modal-auth-status').textContent = workflowState.authenticated ? 'Success' : 'Failed';
    
    // Update status code with color
    const statusCodeEl = document.getElementById('modal-auth-status-code');
    if (workflowState.authStatusCode) {
        statusCodeEl.textContent = workflowState.authStatusCode;
        statusCodeEl.className = workflowState.authStatusCode === 200 ? 'font-bold text-green-600' : 'font-bold text-red-600';
    }
    
    // Update bearer token
    if (workflowState.authResponse) {
        // Check multiple possible locations for the bearer token
        const token = workflowState.authToken || 
                     workflowState.authResponse.auth_response?.bearer_token || 
                     workflowState.authResponse.data?.data?.access_token || 
                     workflowState.authResponse.data?.access_token ||
                     'Not received';
        document.getElementById('modal-auth-token').textContent = token;
    } else if (workflowState.authToken) {
        // If we have auth token but no response object
        document.getElementById('modal-auth-token').textContent = workflowState.authToken;
    }
    
    // Initialize JSON viewers if not already done
    if (!workflowState.authRequestViewer) {
        workflowState.authRequestViewer = new JsonViewer('auth-request-json-viewer', {
            theme: 'dark',
            searchable: true,
            copyable: true,
            maxHeight: '300px'
        });
    }
    
    if (!workflowState.authJsonViewer) {
        workflowState.authJsonViewer = new JsonViewer('auth-response-json-viewer', {
            theme: 'dark',
            searchable: true,
            copyable: true,
            maxHeight: '400px'
        });
    }
    
    // Set request JSON
    if (workflowState.authRequest) {
        workflowState.authRequestViewer.setJson(workflowState.authRequest, {
            filename: 'auth_request'
        });
    }
    
    // Set response JSON
    if (workflowState.authResponse) {
        workflowState.authJsonViewer.setJson(workflowState.authResponse, {
            filename: 'auth_response'
        });
    }
    
    modal.classList.remove('hidden');
}

// Close auth modal
window.closeAuthModal = function() {
    const modal = document.getElementById('auth-modal');
    modal.classList.add('hidden');
    modal.style.display = 'none';
}

// Copy token to clipboard
window.copyToken = function() {
    const tokenText = document.getElementById('modal-auth-token').textContent;
    if (tokenText && tokenText !== 'Not received') {
        navigator.clipboard.writeText(tokenText).then(() => {
            showNotification('Token copied to clipboard', 'success');
        });
    } else {
        showNotification('No token available to copy', 'warning');
    }
}

// Toggle skills debug JSON display - Show Modal
window.toggleSkillsDebug = function() {
    try {
        const modal = document.getElementById('skills-modal');
        if (!modal) {
            // Skills debug modal not found
            showNotification('Debug modal not found', 'error');
            return;
        }
        
        if (!workflowState.skillsResponse) {
            showNotification('No API response to debug. Please fetch JIE roles first.', 'warning');
            return;
        }
        
        // Update modal with skills data
        const response = workflowState.skillsResponse;
        const isDemo = response.source === 'demo' || response.source === 'demo_fallback';
        
        const sourceEl = document.getElementById('modal-skills-source');
        if (sourceEl) {
            sourceEl.innerHTML = isDemo ? 
                '<span class="text-orange-600 font-bold">⚠️ DEMO MODE</span>' : 
                `<span class="text-green-600 font-bold">✅ ${response.source || 'Eightfold API'}</span>`;
        }
        
        const countEl = document.getElementById('modal-skills-count');
        if (countEl) {
            countEl.textContent = workflowState.extractedSkills ? workflowState.extractedSkills.length : '0';
        }
        
        // Update endpoint display with actual Eightfold API endpoint
        const endpointEl = document.getElementById('modal-skills-endpoint');
        if (endpointEl) {
            endpointEl.textContent = response.eightfold_endpoint || response.endpoint || '/api/v2/JIE/roles';
        }
        
        // Update status with color coding
        const statusEl = document.getElementById('modal-skills-status');
        if (response.status_code) {
            statusEl.innerHTML = `<span class="${response.status_code === 200 ? 'text-green-600' : 'text-red-600'} font-bold">HTTP ${response.status_code}</span>`;
        } else {
            statusEl.textContent = response.status || 'Unknown';
        }
        
        // Initialize JSON viewers if not already done
        if (!workflowState.skillsRequestViewer) {
            workflowState.skillsRequestViewer = new JsonViewer('skills-request-json-viewer', {
                theme: 'dark',
                searchable: true,
                copyable: true,
                maxHeight: '300px'
            });
        }
        
        if (!workflowState.skillsResponseViewer) {
            workflowState.skillsResponseViewer = new JsonViewer('skills-response-json-viewer', {
                theme: 'dark',
                searchable: true,
                copyable: true,
                maxHeight: '400px'
            });
        }
        
        // Set request JSON
        if (workflowState.skillsRequest) {
            const fullRequest = {
                url: workflowState.skillsRequest.url,
                method: workflowState.skillsRequest.method,
                headers: workflowState.skillsRequest.headers,
                timestamp: new Date().toISOString()
            };
            workflowState.skillsRequestViewer.setJson(fullRequest, {
                filename: 'skills_request'
            });
        }
        
        // Set response JSON
        if (workflowState.skillsResponse) {
            workflowState.skillsResponseViewer.setJson(workflowState.skillsResponse, {
                filename: 'skills_response'
            });
        }
        
        // Show the modal
        modal.classList.remove('hidden');
        modal.style.display = 'flex';
    
    // Add escape key listener
    document.addEventListener('keydown', handleSkillsModalEscape);
    
    // Add direct event listener to close button as backup
    const closeBtn = document.getElementById('skills-modal-close-btn');
    if (closeBtn) {
        closeBtn.addEventListener('click', closeSkillsModal);
    }
    } catch (error) {
        // Error showing skills debug
        showNotification('Error showing debug: ' + error.message, 'error');
    }
}

// Close skills modal
window.closeSkillsModal = function() {
    const modal = document.getElementById('skills-modal');
    if (modal) {
        modal.classList.add('hidden');
        modal.style.display = 'none';
        
        // Remove event listeners
        document.removeEventListener('keydown', handleSkillsModalEscape);
        const closeBtn = document.getElementById('skills-modal-close-btn');
        if (closeBtn) {
            closeBtn.removeEventListener('click', closeSkillsModal);
        }
    } else {
        // Skills modal not found
    }
}

// Handle escape key for skills modal
function handleSkillsModalEscape(event) {
    if (event.key === 'Escape') {
        const modal = document.getElementById('skills-modal');
        if (modal && !modal.classList.contains('hidden')) {
            closeSkillsModal();
        }
    }
}

// LangChain Config Popup Functions
window.showLangChainConfigPopup = function() {
    try {
        const modal = document.getElementById('langchain-config-popup');
        if (!modal) {
            // LangChain config popup not found
            showNotification('Config popup not found', 'error');
            return;
        }
        
        // Sync values from main UI
        syncPopupFromMainUI();
        
        // Refresh JSON display
        refreshConfigPopupJson();
        
        // Update model capabilities message immediately
        const currentModel = document.getElementById('popup-model')?.value;
        updatePopupJsonSupport(currentModel);
        
        // Show modal
        modal.classList.remove('hidden');
        modal.style.display = 'flex';
        
        // Add escape key listener
        document.addEventListener('keydown', handleConfigPopupEscape);
    } catch (error) {
        // Error showing LangChain config
        showNotification('Error showing config: ' + error.message, 'error');
    }
}

window.closeLangChainConfigPopup = function() {
    const modal = document.getElementById('langchain-config-popup');
    if (modal) {
        modal.classList.add('hidden');
        modal.style.display = 'none';
        
        // Remove escape key listener
        document.removeEventListener('keydown', handleConfigPopupEscape);
    }
}

function handleConfigPopupEscape(event) {
    if (event.key === 'Escape') {
        const modal = document.getElementById('langchain-config-popup');
        if (modal && !modal.classList.contains('hidden')) {
            closeLangChainConfigPopup();
        }
    }
}

function syncPopupFromMainUI() {
    // Sync provider and model from Step 4 LLM Provider Configuration
    const provider = document.getElementById('llm-provider')?.value || 'openai';
    const model = document.getElementById('llm-model-select')?.value || '';  // Fixed: using correct ID
    
    document.getElementById('popup-provider').value = provider;
    
    // Update model dropdown to match Step 4's available models
    updatePopupModelDropdown(provider);
    if (model) {
        document.getElementById('popup-model').value = model;
        // Update JSON support message for the current model
        updatePopupJsonSupport(model);
    } else {
        // If no model selected, check if there's a default in the dropdown
        const popupModel = document.getElementById('popup-model')?.value;
        if (popupModel) {
            updatePopupJsonSupport(popupModel);
        }
    }
}

// Get current LangChain configuration from popup - Keep legitimate LLM parameters
function getLangChainConfig() {
    return {
        provider: document.getElementById('popup-provider')?.value || 'openai',
        model: document.getElementById('popup-model')?.value || '',
        // Keep important LLM parameters that affect response quality
        temperature: parseFloat(document.getElementById('popup-temperature')?.value || '1.0'),
        max_tokens: parseInt(document.getElementById('popup-max-tokens')?.value || '2000'),
        top_p: parseFloat(document.getElementById('popup-top-p')?.value || '1.0'),
        // Keep these as they're used by LangChain service
        prompt_template: document.getElementById('assessment-prompt')?.value || '',
        proficiency_levels: workflowState.proficiencyLevels || [
            '1', '2', '3', '4', '5'
        ]
        // Real bloat is jie_roles (18,000+ lines) and massive prompts, not these configs
    };
}

// Handle provider change in popup
function onPopupProviderChange() {
    const provider = document.getElementById('popup-provider').value;
    
    // Update the main UI provider to stay in sync
    const mainProvider = document.getElementById('llm-provider');
    if (mainProvider) {
        mainProvider.value = provider;
        // Trigger the main provider change handler to load models
        testLLMKey();  // This will load the models for the new provider
    }
    
    // Update model dropdown for new provider
    setTimeout(() => {
        updatePopupModelDropdown(provider);
        onPopupSettingChange();
    }, 500);  // Wait for models to load
}

// Handle model change in popup
function onPopupModelChange() {
    const model = document.getElementById('popup-model').value;
    
    // Update the main UI model to stay in sync
    const mainModel = document.getElementById('llm-model-select');
    if (mainModel && model) {
        mainModel.value = model;
    }
    
    // Update JSON support message
    updatePopupJsonSupport(model);
    
    // Update configuration
    onPopupSettingChange();
}

// Handle real-time updates when popup settings change
function onPopupSettingChange() {
    // Update the JSON configuration immediately
    refreshConfigPopupJson();
    
    // Store the current settings in workflowState
    workflowState.langchainConfig = getLangChainConfig();
    
    // Show a subtle indicator that settings were updated
    const status = document.getElementById('pipeline-status');
    if (status) {
        status.textContent = 'Configuration updated';
        status.className = 'mt-2 text-xs text-green-600';
        setTimeout(() => {
            status.textContent = '';
        }, 2000);
    }
    
    // Update JSON support info for currently selected model
    const currentModel = document.getElementById('popup-model')?.value;
    if (currentModel) {
        updatePopupJsonSupport(currentModel);
    }
}

function updatePopupModelDropdown(provider) {
    const modelSelect = document.getElementById('popup-model');
    const mainModelSelect = document.getElementById('llm-model-select');  // Fixed: using correct ID
    
    if (mainModelSelect && mainModelSelect.options.length > 0) {
        // Copy options from main model dropdown in Step 4
        modelSelect.innerHTML = '';
        for (let option of mainModelSelect.options) {
            const newOption = document.createElement('option');
            newOption.value = option.value;
            newOption.textContent = option.textContent;
            modelSelect.appendChild(newOption);
        }
        
        // Update JSON support for the first/selected model
        if (modelSelect.value) {
            updatePopupJsonSupport(modelSelect.value);
        }
    }
}

function updatePopupProficiencyLevels() {
    const container = document.getElementById('popup-proficiency-levels');
    const proficiencyInputs = document.querySelectorAll('.proficiency-input');
    
    container.innerHTML = '';
    proficiencyInputs.forEach((input, index) => {
        const div = document.createElement('div');
        div.className = 'bg-white border rounded-lg p-2';
        div.innerHTML = `
            <input type="text" value="${input.value}" 
                   class="w-full text-xs text-center border-0 bg-transparent"
                   onchange="updateMainProficiencyLevel(${index}, this.value)">
        `;
        container.appendChild(div);
    });
}

function updateMainProficiencyLevel(index, value) {
    const proficiencyInputs = document.querySelectorAll('.proficiency-input');
    if (proficiencyInputs[index]) {
        proficiencyInputs[index].value = value;
        // Trigger change event to update prompt
        proficiencyInputs[index].dispatchEvent(new Event('change'));
    }
}

function updatePopupJsonSupport(model) {
    const supportDiv = document.getElementById('popup-json-support');
    
    // If no model is explicitly provided, try to get the current selected model
    if (!model) {
        model = document.getElementById('popup-model')?.value;
    }
    
    if (model && model !== '') {
        if (supportsJsonFormat(model)) {
            supportDiv.innerHTML = `
                <i class="fas fa-check-circle text-green-600 mr-1"></i>
                <span class="text-green-700">✓ ${model} supports structured JSON output</span>
            `;
        } else {
            supportDiv.innerHTML = `
                <i class="fas fa-exclamation-triangle text-orange-600 mr-1"></i>
                <span class="text-orange-700">⚠ ${model} does not support structured JSON output</span>
            `;
        }
    } else {
        supportDiv.innerHTML = `
            <i class="fas fa-info-circle text-gray-600 mr-1"></i>
            <span class="text-gray-700">No model selected</span>
        `;
    }
}

function refreshConfigPopupJson() {
    const config = {
        provider: document.getElementById('popup-provider').value,
        model: document.getElementById('popup-model').value || 'gpt-4',
        temperature: parseFloat(document.getElementById('popup-temperature').value),
        max_tokens: parseInt(document.getElementById('popup-max-tokens').value),
        top_p: parseFloat(document.getElementById('popup-top-p')?.value || '1.0'),
        chain_type: document.getElementById('popup-chain-type')?.value || 'llm',
        output_parser: document.getElementById('popup-output-parser')?.value || 'json',
        memory: document.getElementById('popup-memory')?.value || 'none',
        response_format: supportsJsonFormat(document.getElementById('popup-model').value) ? { type: "json_object" } : null,
        // Removed timestamp, json_format_supported, estimated_cost_per_1k_tokens
        // These are UI metadata, not needed for LangChain processing
    };
    
    const jsonContent = document.getElementById('config-popup-json-content');
    if (jsonContent) {
        jsonContent.textContent = JSON.stringify(config, null, 2);
    }
    
    // Update last updated timestamp
    document.getElementById('config-last-updated').textContent = new Date().toLocaleTimeString();
}

function resetConfigPopup() {
    // Reset to defaults
    document.getElementById('popup-provider').value = 'openai';
    document.getElementById('popup-model').value = '';
    document.getElementById('popup-temperature').value = '1.0';
    document.getElementById('popup-temp-value').textContent = '1.0';
    document.getElementById('popup-max-tokens').value = '2000';
    
    updatePopupModelDropdown('openai');
    updatePopupJsonSupport('');
    refreshConfigPopupJson();
}

function applyConfigPopup() {
    // Get values from popup
    const temperature = document.getElementById('popup-temperature')?.value || '1.0';
    const maxTokens = document.getElementById('popup-max-tokens')?.value || '2000';
    const chainType = document.getElementById('popup-chain-type')?.value || 'map_reduce';
    const outputParser = document.getElementById('popup-output-parser')?.value || 'json';
    
    // Update main UI LangChain settings
    if (document.getElementById('langchain-temperature')) {
        document.getElementById('langchain-temperature').value = temperature;
        document.getElementById('temp-display').textContent = temperature;
    }
    
    if (document.getElementById('langchain-chain-type')) {
        document.getElementById('langchain-chain-type').value = chainType;
    }
    
    if (document.getElementById('langchain-output-parser')) {
        document.getElementById('langchain-output-parser').value = outputParser;
    }
    
    // Update workflow state
    workflowState.langchainConfig = {
        temperature: parseFloat(temperature),
        maxTokens: parseInt(maxTokens),
        chainType: chainType,
        outputParser: outputParser
    };
    
    // Update pipeline status
    const pipelineStatus = document.getElementById('pipeline-status');
    if (pipelineStatus) {
        pipelineStatus.innerHTML = '<i class="fas fa-check-circle text-green-600 mr-1"></i>Configured and ready';
    }
    
    // Close the popup
    closeLangChainConfigPopup();
    
    showNotification('LangChain configuration applied & pipeline updated', 'success');
}

// Pipeline execution functions
function runPipelineFromPopup() {
    // First apply current configuration
    applyConfigPopup();
    
    // Check prerequisites
    if (!workflowState.extractedSkills || workflowState.extractedSkills.length === 0) {
        // logApiCall('ERROR', 'No skills loaded. Please fetch JIE roles first.');
        showNotification('No skills loaded. Please fetch JIE roles first.', 'error');
        return;
    }
    
    if (!workflowState.llmConfigured) {
        // logApiCall('ERROR', 'LLM not configured. Please configure LLM provider first.');
        showNotification('Please configure LLM provider first', 'error');
        return;
    }
    
    // Start pipeline execution
    setPipelineStatus('running', 'Initializing pipeline...');
    updateProgressBar(10);
    
    // logApiCall('INFO', `Starting LangChain pipeline with ${workflowState.extractedSkills.length} skills`);
    // logApiCall('CONFIG', `Provider: ${document.getElementById('popup-provider').value}, Model: ${document.getElementById('popup-model').value}`);
    
    // Enable stop button, disable run button
    document.getElementById('run-pipeline-btn').disabled = true;
    document.getElementById('stop-pipeline-btn').disabled = false;
    
    // Run the actual pipeline
    executeLangChainPipelineWithProgress();
}

function stopPipeline() {
    // Set stop flag
    pipelineState.isStopped = true;
    pipelineState.isRunning = false;
    
    // Stop the pipeline execution
    setPipelineStatus('stopped', 'Pipeline stopped by user');
    updateProgressBar(0);
    logApiCall('WARNING', 'Pipeline execution stopped by user');
    
    // Reset button states
    document.getElementById('run-pipeline-btn').disabled = false;
    document.getElementById('stop-pipeline-btn').disabled = true;
    
    // Hide batch info after delay
    setTimeout(() => {
        document.getElementById('pipeline-batch-info')?.classList.add('hidden');
        document.getElementById('pipeline-progress-container')?.classList.add('hidden');
    }, 2000);
    
    showNotification('Pipeline execution stopped', 'warning');
}

// Simulate batch progress updates with comprehensive tracking
function simulateBatchProgress() {
    const BATCH_SIZE = 650;  // Match default batch size for consistency
    let simulatedBatch = 1;
    const totalBatches = pipelineState.totalBatches;
    
    // Update every 2 seconds to simulate batch processing
    const interval = setInterval(() => {
        if (pipelineState.isStopped || !pipelineState.isRunning) {
            clearInterval(interval);
            return;
        }
        
        if (simulatedBatch <= totalBatches) {
            const batchStartTime = Date.now();
            
            // Simulate batch start
            if (pipelineState.currentBatchStartTime === null) {
                pipelineState.currentBatchStartTime = batchStartTime;
            }
            
            const progress = (simulatedBatch / totalBatches) * 100;
            updateProgressBar(Math.min(progress * 0.8, 75)); // Cap at 75% during processing
            
            const skillsProcessed = Math.min(simulatedBatch * BATCH_SIZE, pipelineState.totalSkills);
            const skillsInCurrentBatch = Math.min(BATCH_SIZE, pipelineState.totalSkills - (simulatedBatch - 1) * BATCH_SIZE);
            
            // Update pipeline state with current batch info
            pipelineState.currentBatch = simulatedBatch;
            pipelineState.processedSkills = skillsProcessed;
            pipelineState.currentBatchSize = skillsInCurrentBatch;
            
            // Simulate batch completion timing (add some variance)
            const baseBatchTime = 2000; // 2 seconds base
            const variance = Math.random() * 800 - 400; // ±400ms variance
            const batchTime = baseBatchTime + variance;
            
            // Track batch completion
            if (simulatedBatch > 1) { // Complete previous batch
                const previousBatchTime = batchTime;
                pipelineState.batchTimes.push(previousBatchTime);
                
                // Simulate random success/failure (95% success rate)
                const batchSuccess = Math.random() > 0.05;
                if (!batchSuccess) {
                    pipelineState.errors.push(`Batch ${simulatedBatch - 1} failed: Simulated error`);
                    pipelineState.failedBatches++;
                } else {
                    pipelineState.successfulBatches++;
                }
                
                // Add to batch history
                pipelineState.batchHistory.push({
                    batchNumber: simulatedBatch - 1,
                    success: batchSuccess,
                    duration: previousBatchTime,
                    skillCount: Math.min(BATCH_SIZE, pipelineState.totalSkills - (simulatedBatch - 2) * BATCH_SIZE),
                    errors: batchSuccess ? [] : ['Simulated processing error']
                });
            }
            
            setPipelineStatus('running', `Processing batch ${simulatedBatch}/${totalBatches}...`, {
                current: simulatedBatch,
                total: totalBatches,
                skillsInBatch: skillsInCurrentBatch
            });
            
            // Update stats
            const elapsed = (Date.now() - pipelineState.startTime) / 1000;
            const speed = Math.round(skillsProcessed / elapsed);
            const remaining = pipelineState.totalSkills - skillsProcessed;
            const eta = remaining > 0 ? Math.round(remaining / speed) : 0;
            
            updatePipelineStats(speed, eta);
            
            simulatedBatch++;
        } else {
            // Complete the final batch
            if (pipelineState.batchHistory.length < totalBatches) {
                const finalBatchTime = 2000 + (Math.random() * 800 - 400);
                pipelineState.batchTimes.push(finalBatchTime);
                pipelineState.successfulBatches++;
                
                pipelineState.batchHistory.push({
                    batchNumber: totalBatches,
                    success: true,
                    duration: finalBatchTime,
                    skillCount: pipelineState.totalSkills - (totalBatches - 1) * BATCH_SIZE,
                    errors: []
                });
            }
            
            clearInterval(interval);
        }
    }, 2000);
    
    return interval;
}

// Update pipeline statistics
function updatePipelineStats(speed, etaSeconds) {
    const statsDiv = document.getElementById('pipeline-stats');
    const speedSpan = document.getElementById('pipeline-speed');
    const etaDiv = document.getElementById('pipeline-eta');
    const etaTimeSpan = document.getElementById('eta-time');
    
    if (statsDiv && speed > 0) {
        statsDiv.classList.remove('hidden');
        speedSpan.textContent = speed;
    }
    
    if (etaDiv && etaSeconds > 0) {
        etaDiv.classList.remove('hidden');
        const minutes = Math.floor(etaSeconds / 60);
        const seconds = etaSeconds % 60;
        etaTimeSpan.textContent = minutes > 0 ? `${minutes}m ${seconds}s` : `${seconds}s`;
    }
}

async function executeLangChainPipelineWithProgress() {
    try {
        // Initialize enhanced pipeline state
        pipelineState.isRunning = true;
        pipelineState.isStopped = false;
        pipelineState.startTime = Date.now();
        pipelineState.processedSkills = 0;
        pipelineState.currentBatch = 0;
        
        // Reset enhanced tracking
        pipelineState.batchHistory = [];
        pipelineState.batchTimes = [];
        pipelineState.errors = [];
        pipelineState.successfulBatches = 0;
        pipelineState.failedBatches = 0;
        pipelineState.currentBatchStartTime = null;
        pipelineState.currentBatchSize = 0;
        
        // Reset performance metrics
        pipelineState.skillsPerSecond = 0;
        pipelineState.averageBatchTime = 0;
        pipelineState.estimatedTimeRemaining = 0;
        
        // Step 1: Prepare request
        updateProgressBar(10);
        logApiCall('INFO', 'Preparing LangChain request...');
        
        const provider = document.getElementById('popup-provider').value;
        const model = document.getElementById('popup-model').value;
        const proficiencyInputs = document.querySelectorAll('.proficiency-input');
        const proficiencyLevels = Array.from(proficiencyInputs).map(input => input.value).filter(v => v.trim());
        
        // Get limited skills if configured
        const skillsToProcess = getLimitedSkills();
        pipelineState.totalSkills = skillsToProcess.length;
        
        // Calculate batch info
        // Check if this is a retry with optimal batch size
        const retryBatchSize = sessionStorage.getItem('retry_batch_size');
        const isRetry = sessionStorage.getItem('is_retry_assessment');
        let BATCH_SIZE;

        if (retryBatchSize) {
            BATCH_SIZE = parseInt(retryBatchSize);
            updateProcessingLog(`📦 Retry mode: Using optimized batch size of ${BATCH_SIZE} skills per batch`, 'info');
        } else if (provider === 'google' && skillsToProcess.length > 900) {
            // For Google with large skill sets, optimize for 2 batches to avoid rate limits
            BATCH_SIZE = Math.ceil(skillsToProcess.length / 2);
            updateProcessingLog(`🎯 Google optimization: Splitting ${skillsToProcess.length} skills into 2 batches of ~${BATCH_SIZE} each`, 'info');
        } else {
            BATCH_SIZE = 100; // Default batch size
        }

        pipelineState.totalBatches = Math.ceil(skillsToProcess.length / BATCH_SIZE);
        pipelineState.currentBatch = 0;
        
        // Get the current environment
        const environmentElement = document.getElementById('environmentSelect') || document.getElementById('sandbox-selector');
        const environment = environmentElement?.value || 'unknown';
        
        const request = {
            skills: skillsToProcess,
            provider: provider,
            model: model,
            proficiency_levels: proficiencyLevels,
            prompt_template: document.getElementById('assessment-prompt')?.value,
            use_langchain: true,
            environment: environment,  // Include environment in request
            batch_size: BATCH_SIZE,  // Include batch size for backend
            is_retry: !!retryBatchSize  // Flag to indicate this is a retry attempt
        };
        
        logApiCall('CONFIG', `Request prepared: ${request.skills.length} skills in ${pipelineState.totalBatches} batches, Provider: ${provider}`);
        
        // Update UI with batch info
        setPipelineStatus('running', 'Initializing pipeline...', {
            current: 0,
            total: pipelineState.totalBatches,
            skillsInBatch: Math.min(BATCH_SIZE, skillsToProcess.length)
        });
        
        // Step 2: Send API request with batch simulation
        updateProgressBar(20);
        setPipelineStatus('running', 'Starting batch processing...', {
            current: 1,
            total: pipelineState.totalBatches,
            skillsInBatch: Math.min(BATCH_SIZE, skillsToProcess.length)
        });
        
        // Force show detailed status during real execution
        const detailedStatus = document.getElementById('detailed-batch-status');
        if (detailedStatus) {
            detailedStatus.classList.remove('hidden');
        }
        
        logApiCall('API', `POST /api/skills/assess-proficiencies-simple`);
        
        // Start batch progress simulation
        const batchProgressInterval = simulateBatchProgress();
        
        // Also start real-time detailed status updates
        const detailedStatusInterval = setInterval(() => {
            updateDetailedBatchStatus('running', `Processing batch ${pipelineState.currentBatch}/${pipelineState.totalBatches}...`, {
                current: pipelineState.currentBatch,
                total: pipelineState.totalBatches
            });
        }, 500); // Update every 500ms
        
        const response = await fetch('/api/skills/assess-proficiencies-simple', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(request),
            signal: assessmentController.signal
        });
        
        // Stop both intervals
        clearInterval(batchProgressInterval);
        clearInterval(detailedStatusInterval);
        
        updateProgressBar(80);
        logApiCall('API', `Response received: Status ${response.status}`);
        
        // Step 3: Process response
        const result = await response.json();
        updateProgressBar(90);
        
        if (result.success) {
            logApiCall('SUCCESS', `Assessment completed: ${result.total_skills} skills processed`);
            if (result.langchain_details?.chain_type?.includes('Batch')) {
                logApiCall('INFO', `Batch processing used: ${result.langchain_details.chain_type}`);
            }

            // Check for rate limit warnings in batch info
            if (result.llm_response?.batch_info?.rate_limit_warnings) {
                const warnings = result.llm_response.batch_info.rate_limit_warnings;
                logApiCall('WARNING', `Rate limiting encountered during processing:`);
                warnings.forEach(warning => {
                    logApiCall('WARNING', `  ⚠️ ${warning}`);
                });
                showNotification(`Assessment completed with ${warnings.length} rate limit retries`, 'warning');
            }
            
            // Step 4: Update UI
            updateProgressBar(90);
            setPipelineStatus('success', 'Pipeline completed successfully');
            
            // Display results in the main UI viewers
            const requestViewerEl = document.getElementById('langchain-request-viewer');
            if (requestViewerEl) {
                requestViewerEl.innerHTML = `<pre class="text-xs">${JSON.stringify(request, null, 2)}</pre>`;
            }
            
            const responseViewerEl = document.getElementById('langchain-response-viewer');
            if (responseViewerEl) {
                responseViewerEl.innerHTML = `<pre class="text-xs">${JSON.stringify(result, null, 2)}</pre>`;
            }
            
            // Store assessment results for Step 6 role updates
            if (result.assessments) {
                workflowState.lastAssessmentResults = result;
                // Stored assessment results for role updates
            }
            
            updateProgressBar(100);
            logApiCall('SUCCESS', `Pipeline execution completed in ${Date.now() - workflowState.pipelineStartTime}ms`);
            
            showNotification('LangChain assessment completed successfully', 'success');
            
        } else {
            // Handle assessment failure with detailed logging
            const errorMsg = result.detail || result.error || 'Assessment failed';
            const skillCount = result.total_skills || 0;
            const assessedCount = result.assessed_skills ? result.assessed_skills.length : 0;
            
            logApiCall('FAILED', `Assessment failed: ${errorMsg}`);
            logApiCall('INFO', `Skills processed: ${assessedCount}/${skillCount}`);
            
            if (result.llm_response && result.llm_response.parsed_assessments === 0) {
                logApiCall('WARNING', `LLM response parsing failed - 0 assessments extracted`);
                logApiCall('INFO', `Raw response length: ${result.llm_response.raw_length || 0} characters`);
            }
            
            throw new Error(errorMsg);
        }
        
    } catch (error) {
        setPipelineStatus('error', `Pipeline failed: ${error.message}`);
        logApiCall('ERROR', `Pipeline execution failed: ${error.message}`);
        showNotification('Pipeline execution failed: ' + error.message, 'error');
        updateProgressBar(0);
    } finally {
        // Reset button states
        document.getElementById('run-pipeline-btn').disabled = false;
        document.getElementById('stop-pipeline-btn').disabled = true;
    }
}

// Enhanced global pipeline state
let pipelineState = {
    isRunning: false,
    isStopped: false,
    currentBatch: 0,
    totalBatches: 0,
    startTime: null,
    processedSkills: 0,
    totalSkills: 0,
    
    // Enhanced tracking
    batchHistory: [],  // Array of batch results {batchNumber, success, duration, skillCount, errors}
    batchTimes: [],    // Array of batch processing times
    errors: [],        // Array of error messages
    successfulBatches: 0,
    failedBatches: 0,
    currentBatchStartTime: null,
    currentBatchSize: 0,
    
    // Performance metrics
    skillsPerSecond: 0,
    averageBatchTime: 0,
    estimatedTimeRemaining: 0
};

function setPipelineStatus(status, message, batchInfo = null) {
    const indicator = document.querySelector('#pipeline-status-indicator span');
    const statusText = document.getElementById('pipeline-status-text');
    const progressContainer = document.getElementById('pipeline-progress-container');
    const batchInfoDiv = document.getElementById('pipeline-batch-info');
    const progressDetails = document.getElementById('pipeline-progress-details');
    
    // Update status indicator
    const colors = {
        ready: 'bg-gray-400',
        running: 'bg-blue-500 animate-pulse',
        success: 'bg-green-500',
        error: 'bg-red-500',
        stopped: 'bg-yellow-500'
    };
    
    if (indicator) {
        indicator.className = `w-2 h-2 ${colors[status] || 'bg-gray-400'} rounded-full mr-2`;
        if (status === 'running') {
            indicator.classList.add('animate-pulse');
        } else {
            indicator.classList.remove('animate-pulse');
        }
    }
    
    if (statusText) statusText.textContent = status.charAt(0).toUpperCase() + status.slice(1);
    if (progressDetails) progressDetails.textContent = message;
    
    // Store start time for performance tracking
    if (status === 'running' && !workflowState.pipelineStartTime) {
        workflowState.pipelineStartTime = Date.now();
    }
    
    // Update comprehensive batch status display
    updateDetailedBatchStatus(status, message, batchInfo);
}

function updateProgressBar(percentage) {
    const progressBar = document.getElementById('pipeline-progress-bar');
    const progressPercent = document.getElementById('pipeline-progress-percent');
    const progressPercentInline = document.getElementById('pipeline-progress-percent-inline');
    const progressContainer = document.getElementById('pipeline-progress-container');
    
    if (progressBar) {
        progressBar.style.width = percentage + '%';
        
        // Show inline percentage when bar is wide enough
        if (progressPercentInline && percentage > 20) {
            progressPercentInline.textContent = `${Math.round(percentage)}%`;
            progressPercentInline.classList.remove('hidden');
        } else if (progressPercentInline) {
            progressPercentInline.classList.add('hidden');
        }
    }
    
    if (progressPercent) {
        progressPercent.textContent = `${Math.round(percentage)}%`;
    }
    
    // Show progress container when there's progress
    if (progressContainer && percentage > 0) {
        progressContainer.classList.remove('hidden');
    }
}

// Update comprehensive batch status display
function updateDetailedBatchStatus(status, message, batchInfo) {
    const detailedStatus = document.getElementById('detailed-batch-status');
    if (!detailedStatus) {
        // detailed-batch-status element not found
        return;
    }
    
    // Show/hide detailed status based on pipeline state
    if (status === 'running' && pipelineState.totalBatches > 0) {
        detailedStatus.classList.remove('hidden');
        // Showing detailed batch status
        
        // Calculate current metrics
        const currentTime = Date.now();
        const elapsedSeconds = pipelineState.startTime ? (currentTime - pipelineState.startTime) / 1000 : 0;
        const completedBatches = pipelineState.currentBatch - 1;
        const batchCompletionRate = pipelineState.totalBatches > 0 ? (completedBatches / pipelineState.totalBatches * 100) : 0;
        const skillsCompletionRate = pipelineState.totalSkills > 0 ? (pipelineState.processedSkills / pipelineState.totalSkills * 100) : 0;
        
        // Calculate timing estimates
        const avgBatchTime = pipelineState.batchTimes.length > 0 ? 
            pipelineState.batchTimes.reduce((a, b) => a + b, 0) / pipelineState.batchTimes.length : 0;
        const remainingBatches = pipelineState.totalBatches - completedBatches;
        const etaSeconds = avgBatchTime > 0 ? remainingBatches * (avgBatchTime / 1000) : 0;
        
        // Calculate skills per second
        const skillsPerSecond = elapsedSeconds > 0 ? pipelineState.processedSkills / elapsedSeconds : 0;
        
        // Update batch progress
        const batchProgressElement = document.getElementById('batch-progress-text');
        const batchProgressBar = document.getElementById('batch-progress-bar');
        if (batchProgressElement) {
            batchProgressElement.textContent = `${completedBatches}/${pipelineState.totalBatches}`;
        }
        if (batchProgressBar) {
            batchProgressBar.style.width = `${Math.min(batchCompletionRate, 100)}%`;
        }
        
        // Update skills progress
        const skillsProgressElement = document.getElementById('skills-progress-text');
        const skillsProgressBar = document.getElementById('skills-progress-bar');
        if (skillsProgressElement) {
            skillsProgressElement.textContent = `${pipelineState.processedSkills}/${pipelineState.totalSkills}`;
        }
        if (skillsProgressBar) {
            skillsProgressBar.style.width = `${Math.min(skillsCompletionRate, 100)}%`;
        }
        
        // Update completion rates
        const batchRateElement = document.getElementById('batch-completion-rate');
        const skillsRateElement = document.getElementById('skills-completion-rate');
        if (batchRateElement) {
            batchRateElement.textContent = `${Math.round(batchCompletionRate)}%`;
        }
        if (skillsRateElement) {
            skillsRateElement.textContent = `${Math.round(skillsCompletionRate)}%`;
        }
        
        // Update current batch info
        const currentBatchElement = document.getElementById('current-batch-size');
        const currentBatchStatusElement = document.getElementById('current-batch-status');
        if (currentBatchElement) {
            currentBatchElement.textContent = pipelineState.currentBatchSize || 'N/A';
        }
        if (currentBatchStatusElement) {
            if (pipelineState.currentBatch <= pipelineState.totalBatches) {
                currentBatchStatusElement.textContent = `Batch ${pipelineState.currentBatch}`;
            } else {
                currentBatchStatusElement.textContent = 'Completed';
            }
        }
        
        // Update timing info
        const elapsedElement = document.getElementById('elapsed-time');
        const etaElement = document.getElementById('eta-time');
        if (elapsedElement) {
            elapsedElement.textContent = formatDuration(elapsedSeconds);
        }
        if (etaElement) {
            etaElement.textContent = etaSeconds > 0 ? formatDuration(etaSeconds) : 'Calculating...';
        }
        
        // Update performance stats
        const avgBatchTimeElement = document.getElementById('avg-batch-time');
        const skillsPerSecElement = document.getElementById('skills-per-second');
        const errorCountElement = document.getElementById('error-count');
        if (avgBatchTimeElement) {
            avgBatchTimeElement.textContent = avgBatchTime > 0 ? `${(avgBatchTime / 1000).toFixed(1)}s` : 'N/A';
        }
        if (skillsPerSecElement) {
            skillsPerSecElement.textContent = skillsPerSecond > 0 ? skillsPerSecond.toFixed(1) : '0.0';
        }
        if (errorCountElement) {
            errorCountElement.textContent = pipelineState.errors.length;
        }
        
        // Update batch history
        updateBatchHistory();
        
    } else {
        detailedStatus.classList.add('hidden');
    }
}

// Update batch history display
function updateBatchHistory() {
    const historyContainer = document.getElementById('batch-history-list');
    if (!historyContainer) return;
    
    // Keep only last 5 batches for display
    const recentHistory = pipelineState.batchHistory.slice(-5);
    
    historyContainer.innerHTML = recentHistory.map(batch => {
        const statusIcon = batch.success ? 
            '<i class="fas fa-check-circle text-green-500"></i>' : 
            '<i class="fas fa-times-circle text-red-500"></i>';
        const duration = batch.duration ? `${(batch.duration / 1000).toFixed(1)}s` : 'N/A';
        
        return `
            <div class="flex justify-between items-center text-xs">
                <span>${statusIcon} Batch ${batch.batchNumber}</span>
                <span class="text-gray-500">${duration}</span>
            </div>
        `;
    }).join('');
}

// Format duration in seconds to human readable
function formatDuration(seconds) {
    if (seconds < 60) {
        return `${Math.round(seconds)}s`;
    } else if (seconds < 3600) {
        const minutes = Math.floor(seconds / 60);
        const remainingSeconds = Math.round(seconds % 60);
        return `${minutes}m ${remainingSeconds}s`;
    } else {
        const hours = Math.floor(seconds / 3600);
        const minutes = Math.floor((seconds % 3600) / 60);
        return `${hours}h ${minutes}m`;
    }
}

function logApiCall(type, message) {
    const logContainer = document.getElementById('api-calls-log');
    if (!logContainer) return;
    
    const timestamp = new Date().toLocaleTimeString();
    const colors = {
        'INFO': 'text-blue-400',
        'SUCCESS': 'text-green-400',
        'WARNING': 'text-yellow-400',
        'ERROR': 'text-red-400',
        'API': 'text-purple-400',
        'CONFIG': 'text-cyan-400'
    };
    
    const logEntry = document.createElement('div');
    logEntry.innerHTML = `<span class="text-gray-500">[${timestamp}]</span> <span class="${colors[type] || 'text-gray-400'}">[${type}]</span> ${message}`;
    
    logContainer.appendChild(logEntry);
    logContainer.scrollTop = logContainer.scrollHeight;
    
    // Remove console logging that was causing console spam
    // console.log(`[${type}] ${message}`);
    
    // Limit log entries to prevent memory issues
    while (logContainer.children.length > 50) {
        logContainer.removeChild(logContainer.firstChild);
    }
}

function clearApiLog() {
    const logContainer = document.getElementById('api-calls-log');
    if (logContainer) {
        logContainer.innerHTML = '<div class="text-gray-500">[System] Log cleared...</div>';
    }
}

function updatePipelineConfigFromPopup() {
    // This function ensures the main UI is in sync with popup changes
    const statusDiv = document.getElementById('langchain-config-status');
    if (statusDiv) {
        statusDiv.classList.remove('hidden');
        statusDiv.innerHTML = '<div class="text-green-600"><i class="fas fa-check mr-1"></i>Pipeline configuration updated from popup</div>';
        
        // Hide status after 3 seconds
        setTimeout(() => {
            statusDiv.classList.add('hidden');
        }, 3000);
    }
}

// Event listeners for popup
document.addEventListener('DOMContentLoaded', function() {
    // Temperature slider
    const tempSlider = document.getElementById('popup-temperature');
    if (tempSlider) {
        tempSlider.addEventListener('input', (e) => {
            document.getElementById('popup-temp-value').textContent = e.target.value;
            refreshConfigPopupJson();
        });
    }
    
    // Provider change
    const providerSelect = document.getElementById('popup-provider');
    if (providerSelect) {
        providerSelect.addEventListener('change', (e) => {
            updatePopupModelDropdown(e.target.value);
            refreshConfigPopupJson();
        });
    }
    
    // Model change
    const modelSelect = document.getElementById('popup-model');
    if (modelSelect) {
        modelSelect.addEventListener('change', (e) => {
            updatePopupJsonSupport(e.target.value);
            refreshConfigPopupJson();
        });
    }
    
    // Max tokens change
    const maxTokensInput = document.getElementById('popup-max-tokens');
    if (maxTokensInput) {
        maxTokensInput.addEventListener('input', refreshConfigPopupJson);
    }
});

// All Skills Modal Functions
window.showAllSkillsPopup = function() {
    try {
        const modal = document.getElementById('all-skills-modal');
        if (!modal) {
            // All skills modal not found
            showNotification('Modal not found', 'error');
            return;
        }
        
        if (!workflowState.extractedSkills || workflowState.extractedSkills.length === 0) {
            showNotification('No skills loaded yet. Please fetch JIE roles first.', 'warning');
            return;
        }
        
        // Update modal content
        updateSkillsModalContent();
        
        // Show modal
        modal.classList.remove('hidden');
        modal.style.display = 'flex';
        
        // Add escape key listener
        document.addEventListener('keydown', handleSkillsModalEscape);
    } catch (error) {
        // Error showing skills popup
        showNotification('Error showing skills: ' + error.message, 'error');
    }
}

window.closeAllSkillsModal = function() {
    const modal = document.getElementById('all-skills-modal');
    if (modal) {
        modal.classList.add('hidden');
        modal.style.display = 'none';
        // Remove escape key listener
        document.removeEventListener('keydown', handleSkillsModalEscape);
    }
}

function handleSkillsModalEscape(event) {
    if (event.key === 'Escape') {
        const modal = document.getElementById('all-skills-modal');
        if (modal && !modal.classList.contains('hidden')) {
            closeAllSkillsModal();
        }
    }
}

function updateSkillsModalContent() {
    const skills = workflowState.extractedSkills || [];
    
    // Update statistics
    const totalSkillsElement = document.getElementById('modal-total-skills');
    const uniqueSkillsElement = document.getElementById('modal-unique-skills');
    const dataSourceElement = document.getElementById('modal-data-source');
    
    if (totalSkillsElement) {
        totalSkillsElement.textContent = skills.length;
    }
    if (uniqueSkillsElement) {
        uniqueSkillsElement.textContent = new Set(skills.map(s => s.name)).size;
    }
    if (dataSourceElement) {
        dataSourceElement.textContent = workflowState.skillsResponse?.source || 'Unknown';
    }
    
    // Update JSON viewer
    const skillsData = {
        metadata: {
            total_skills: skills.length,
            unique_skills: new Set(skills.map(s => s.name)).size,
            source: workflowState.skillsResponse?.source || 'unknown',
            extracted_at: new Date().toISOString(),
            api_endpoint: workflowState.skillsResponse?.eightfold_endpoint || 'unknown'
        },
        skills: skills.map((skill, index) => ({
            id: index + 1,
            name: skill.name,
            proficiency: skill.proficiency,  // Include proficiency (numeric value)
            skillGroupList: skill.skillGroupList || [],  // Include skillGroupList
            source_role: skill.source_role || 'unknown'
        }))
    };
    
    const jsonContentElement = document.getElementById('skills-json-content');
    if (jsonContentElement) {
        jsonContentElement.textContent = JSON.stringify(skillsData, null, 2);
    }
    
    // Update table
    updateSkillsTable(skills);
    
    // Update timestamp
    document.getElementById('skills-last-updated').textContent = new Date().toLocaleTimeString();
}

function updateSkillsTable(skills) {
    const tbody = document.getElementById('skills-table-body');
    
    if (skills.length === 0) {
        tbody.innerHTML = '<tr><td colspan="5" class="px-3 py-4 text-center text-gray-500">No skills to display</td></tr>';
        return;
    }
    
    tbody.innerHTML = skills.map((skill, index) => {
        // Get assessment data if available (from Step 5)
        const assessmentData = window.workflowState?.assessmentResults?.skills?.find(
            a => a.skill_name === skill.name || a.skill === skill.name || a.name === skill.name
        );
        
        // Proficiency is the numeric value (1-5) from assessment, or from API (which is always null)
        const proficiencyValue = assessmentData?.proficiency || skill.proficiency || 'null';
        
        // Level is the text (Novice/Developing/etc) from assessment
        const levelText = assessmentData?.level || skill.level || 'Not Assessed';
        
        // Source - truncate if from a role
        const source = skill.source_role ? 
            `From: ${skill.source_role.substring(0, 30)}${skill.source_role.length > 30 ? '...' : ''}` : 
            'Eightfold API';
        
        // Determine colors based on proficiency value - no background, white text
        const profColor = proficiencyValue !== 'null' ? 'text-white' : 'text-gray-400';
        const levelColor = levelText !== 'Not Assessed' ? 'bg-emerald-100 text-emerald-800' : 'bg-gray-100 text-gray-600';
        
        return `
        <tr class="hover:bg-gray-100">
            <td class="px-3 py-2 border-b">${index + 1}</td>
            <td class="px-3 py-2 border-b font-medium">${skill.name}</td>
            <td class="px-3 py-2 border-b">
                <span class="text-sm font-medium ${profColor}">
                    ${proficiencyValue}
                </span>
            </td>
            <td class="px-3 py-2 border-b">
                <span class="px-2 py-1 text-xs rounded ${levelColor}">
                    ${levelText}
                </span>
            </td>
            <td class="px-3 py-2 border-b text-xs text-gray-600">
                ${source}
            </td>
        </tr>
    `}).join('');
}

function viewRawRolesJSON() {
    if (!workflowState.jieRoles || workflowState.jieRoles.length === 0) {
        showNotification('No roles data to view', 'warning');
        return;
    }
    
    // Create a modal to show the JSON
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50';
    modal.innerHTML = `
        <div class="bg-white dark:bg-gray-800 rounded-lg p-6 max-w-4xl max-h-screen overflow-auto" style="width: 90%; height: 80%;">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-lg font-bold">Raw JIE Roles JSON (${workflowState.jieRoles.length} roles)</h3>
                <button onclick="this.closest('.fixed').remove()" class="text-gray-500 hover:text-gray-700">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>
            <div class="mb-4 text-sm text-gray-600">
                <p>Showing first 3 roles with complete skillProficiencies data:</p>
            </div>
            <pre class="bg-gray-100 dark:bg-gray-900 p-4 rounded overflow-auto text-xs" style="max-height: 60vh;">
${JSON.stringify(workflowState.jieRoles.slice(0, 3), null, 2)}
            </pre>
            <div class="mt-4 flex justify-end space-x-2">
                <button onclick="navigator.clipboard.writeText(JSON.stringify(workflowState.jieRoles, null, 2)); showNotification('Copied to clipboard', 'success');" 
                        class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">
                    <i class="fas fa-copy mr-2"></i>Copy All
                </button>
                <button onclick="downloadSkillsJSON()" class="px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700">
                    <i class="fas fa-download mr-2"></i>Download
                </button>
                <button onclick="this.closest('.fixed').remove()" class="px-4 py-2 bg-gray-600 text-white rounded hover:bg-gray-700">
                    Close
                </button>
            </div>
        </div>
    `;
    document.body.appendChild(modal);
}

function downloadSkillsJSON() {
    if (!workflowState.extractedSkills || workflowState.extractedSkills.length === 0) {
        showNotification('No skills data to download', 'warning');
        return;
    }
    
    const skillsData = {
        metadata: {
            total_skills: workflowState.extractedSkills.length,
            exported_at: new Date().toISOString(),
            source: 'Skills Proficiency Generator'
        },
        skills: workflowState.extractedSkills
    };
    
    const blob = new Blob([JSON.stringify(skillsData, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `skills_${new Date().toISOString().split('T')[0]}.json`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
    
    showNotification('Skills JSON downloaded successfully', 'success');
}

function copySkillsToClipboard() {
    const jsonContent = document.getElementById('skills-json-content').textContent;
    if (!jsonContent || jsonContent === 'No skills loaded') {
        showNotification('No skills data to copy', 'warning');
        return;
    }
    
    navigator.clipboard.writeText(jsonContent).then(() => {
        showNotification('Skills JSON copied to clipboard', 'success');
    }).catch(err => {
        // Failed to copy to clipboard
        showNotification('Failed to copy to clipboard', 'error');
    });
}

function refreshSkillsModal() {
    if (workflowState.extractedSkills && workflowState.extractedSkills.length > 0) {
        updateSkillsModalContent();
        showNotification('Skills data refreshed', 'success');
    } else {
        showNotification('No skills data available to refresh', 'warning');
    }
}

function clearAllSkills() {
    if (confirm('Are you sure you want to clear all loaded skills? This will remove all skill data from the current session.')) {
        workflowState.extractedSkills = [];
        workflowState.skillsLoaded = false;
        workflowState.skillsResponse = null;

        // Update skills count display
        updateSkillsCount();
        
        // Update main UI
        const skillsCountDisplay = document.getElementById('skills-count-display');
        const skillsPreview = document.getElementById('extracted-skills-preview');
        
        if (skillsCountDisplay) {
            skillsCountDisplay.textContent = 'No skills loaded';
        }
        if (skillsPreview) {
            skillsPreview.textContent = 'Skills will appear here after loading...';
        }
        
        // Update modal
        updateSkillsModalContent();
        
        showNotification('All skills cleared', 'success');
    }
}

function reloadSkills() {
    closeAllSkillsModal();
    extractSkillsForAssessment();
    showNotification('Reloading skills from API...', 'info');
}

// Load OpenAI key
function loadOpenAIKey() {
    document.getElementById('llm-provider').value = 'openai';
    document.getElementById('llm-api-key').value = presetKeys.openai.key;
    updateModelSelection();
}

// Load Google key
function loadGoogleKey() {
    document.getElementById('llm-provider').value = 'google';
    document.getElementById('llm-api-key').value = presetKeys.google.key;
    updateModelSelection();
    showNotification('Google Gemini API key loaded', 'success');
}

// Update model selection based on provider
function updateModelSelection() {
    const providerElement = document.getElementById('llm-provider');
    const modelSelect = document.getElementById('llm-model-select');
    
    // Check if elements exist
    if (!providerElement || !modelSelect) {
        // Provider or model select elements not found
        return;
    }
    
    const provider = providerElement.value;
    
    // Clear current options
    modelSelect.innerHTML = '<option value="">Select a model...</option>';
    
    // Add models for selected provider
    const models = availableModels[provider] || [];
    models.forEach(model => {
        const option = document.createElement('option');
        option.value = model;
        option.textContent = model;
        modelSelect.appendChild(option);
    });
    
    // Select gemini-2.5-pro as default for Google, otherwise first model
    if (models.length > 0) {
        if (provider === 'google' && models.includes('gemini-2.5-pro')) {
            modelSelect.value = 'gemini-2.5-pro';
        } else {
            modelSelect.value = models[0];
        }
    }
}

// Update temperature display
function updateTemperatureDisplay() {
    const temp = document.getElementById('langchain-temperature').value;
    document.getElementById('temperature-display').textContent = temp;
}

// Toggle API key visibility
function toggleKeyVisibility() {
    const keyInput = document.getElementById('llm-api-key');
    const icon = document.getElementById('key-visibility-icon');
    
    if (keyInput.type === 'password') {
        keyInput.type = 'text';
        icon.className = 'fas fa-eye-slash';
    } else {
        keyInput.type = 'password';
        icon.className = 'fas fa-eye';
    }
}

// Add proficiency level
window.addProficiencyLevel = function() {
    const container = document.getElementById('proficiency-levels-container');
    const colors = ['gray', 'blue', 'yellow', 'green', 'purple', 'red', 'indigo'];
    const levelNumber = container.children.length + 1; // Next level number
    const color = colors[(levelNumber - 1) % colors.length];
    
    const newLevel = document.createElement('div');
    newLevel.className = 'proficiency-level-item flex items-center';
    newLevel.innerHTML = `
        <span class="w-8 h-8 bg-${color}-400 rounded-full mr-2 flex items-center justify-center text-white font-bold text-xs">${levelNumber}</span>
        <input type="text" class="proficiency-input flex-1 px-2 py-1 text-sm border rounded dark:bg-gray-600 dark:border-gray-500 dark:text-white" placeholder="Enter level name" data-index="${levelNumber - 1}">
        <button onclick="removeProficiencyLevel(this)" class="ml-2 text-red-500 hover:text-red-700">
            <i class="fas fa-times"></i>
        </button>
    `;
    
    container.appendChild(newLevel);
}

// Remove proficiency level
window.removeProficiencyLevel = function(button) {
    const item = button.parentElement;
    const container = item.parentElement;
    const index = Array.from(container.children).indexOf(item);
    
    // Remove the item
    item.remove();
    
    // Remove corresponding numeric proficiency
    const numericContainer = document.getElementById('proficiency-numeric-container');
    const numericItems = numericContainer.querySelectorAll('.proficiency-numeric-item');
    if (numericItems[index]) {
        numericItems[index].remove();
    }
    
    // Update remaining numbers
    updateLevelNumbers();
    updateProficiencyNumbers();
}

// Add numeric proficiency
window.addProficiencyNumeric = function() {
    const container = document.getElementById('proficiency-numeric-container');
    const currentItems = container.querySelectorAll('.proficiency-numeric-item');
    const nextNumber = currentItems.length + 1;
    
    const newItem = document.createElement('div');
    newItem.className = 'proficiency-numeric-item flex items-center';
    newItem.setAttribute('data-index', nextNumber);
    newItem.innerHTML = `
        <span class="proficiency-numeric-label w-10 h-8 bg-gray-600 rounded mr-2 flex items-center justify-center text-white font-bold text-sm">${nextNumber}</span>
        <input type="number" class="proficiency-numeric-input flex-1 px-2 py-1 text-sm border rounded dark:bg-gray-600 dark:border-gray-500 dark:text-white" value="${nextNumber}" min="1" max="10" onchange="onProficiencyNumericChange()">
        <button onclick="removeProficiencyNumeric(this)" class="ml-2 text-red-500 hover:text-red-700">
            <i class="fas fa-times"></i>
        </button>
    `;
    
    container.appendChild(newItem);
    
    // Add corresponding text level if needed
    syncTextLevelWithNumeric();
}

// Remove numeric proficiency
window.removeProficiencyNumeric = function(button) {
    const item = button.parentElement;
    const container = item.parentElement;
    
    // Remove the item
    item.remove();
    
    // Update remaining proficiency numbers and labels
    updateProficiencyNumbers();
    
    // Sync with text levels
    syncTextLevelWithNumeric();
}

// Update proficiency numbers after add/remove
function updateProficiencyNumbers() {
    const container = document.getElementById('proficiency-numeric-container');
    const items = container.querySelectorAll('.proficiency-numeric-item');
    
    items.forEach((item, index) => {
        const label = item.querySelector('.proficiency-numeric-label');
        const input = item.querySelector('.proficiency-numeric-input');
        
        // Update the display label
        label.textContent = index + 1;
        
        // Update data-index
        item.setAttribute('data-index', index + 1);
    });
}

// Update level numbers after add/remove  
function updateLevelNumbers() {
    const container = document.getElementById('proficiency-levels-container');
    const items = container.querySelectorAll('.proficiency-level-item');
    const colors = ['gray', 'blue', 'yellow', 'green', 'purple', 'red', 'indigo'];
    
    items.forEach((item, index) => {
        const numberSpan = item.querySelector('span');
        const color = colors[index % colors.length];
        
        // Update number and color
        numberSpan.textContent = index + 1;
        numberSpan.className = `w-8 h-8 bg-${color}-400 rounded-full mr-2 flex items-center justify-center text-white font-bold text-xs`;
    });
}

// Sync text levels with numeric proficiencies
function syncTextLevelWithNumeric() {
    const numericContainer = document.getElementById('proficiency-numeric-container');
    const levelsContainer = document.getElementById('proficiency-levels-container');
    
    const numericCount = numericContainer.querySelectorAll('.proficiency-numeric-item').length;
    const levelCount = levelsContainer.querySelectorAll('.proficiency-level-item').length;
    
    // Add missing text levels
    if (levelCount < numericCount) {
        for (let i = levelCount; i < numericCount; i++) {
            addProficiencyLevel();
        }
    }
    
    // Remove extra text levels
    if (levelCount > numericCount) {
        const items = levelsContainer.querySelectorAll('.proficiency-level-item');
        for (let i = numericCount; i < levelCount; i++) {
            items[i].remove();
        }
    }
    
    updateLevelNumbers();
}

// Handle numeric proficiency change
window.onProficiencyNumericChange = function() {
    // Optional: Add validation or auto-save logic here
    showNotification('Proficiency value updated', 'info');
}

// Show LangChain configuration
function showLangChainConfig() {
    const modal = document.getElementById('langchain-config-modal');
    
    // Build configuration object
    const config = {
        provider: document.getElementById('llm-provider').value,
        model: document.getElementById('llm-model-select')?.value || '',
        // Removed: temperature, max_tokens, chain_type, output_parser, memory
        // These cause unnecessary bloat and LangChain uses good defaults
        prompt_template: document.getElementById('assessment-prompt').value,
        proficiency_levels: Array.from(document.querySelectorAll('.proficiency-input'))
            .map(input => input.value)
            .filter(v => v.trim()),
        skills_count: workflowState.extractedSkills.length
    };
    
    // Initialize JSON viewer for config
    if (!workflowState.langchainConfigViewer) {
        workflowState.langchainConfigViewer = new JsonViewer('langchain-config-viewer', {
            theme: 'light',
            searchable: true,
            copyable: true,
            maxHeight: '500px'
        });
    }
    workflowState.langchainConfigViewer.setJson(config, { filename: 'langchain_config' });
    
    modal.classList.remove('hidden');
}

// Close LangChain config modal
function closeLangChainConfigModal() {
    document.getElementById('langchain-config-modal').classList.add('hidden');
}

// AUTO-LOAD FUNCTIONS

// Auto insert skills into prompt
function autoInsertSkillsIntoPrompt() {
    
    if (!workflowState.extractedSkills || workflowState.extractedSkills.length === 0) {
        // Try to create test skills for debugging
        workflowState.extractedSkills = [
            {name: "Python"}, {name: "SQL"}, {name: "JavaScript"}
        ];
    }
    
    const promptField = document.getElementById('assessment-prompt');
    if (!promptField) {
        return false;
    }
    
    
    // Create both formatted list (for {skills_list}) and comma-separated list (for {skills_to_assess})
    const skillsListFormatted = workflowState.extractedSkills
        .map(s => `- ${s.name || s.skill_name}`)
        .join('\n');
    
    const skillsToAssess = workflowState.extractedSkills
        .map(s => s.name || s.skill_name)
        .join(', ');
    
    
    let currentPrompt = promptField.value;
    let wasUpdated = false;
    
    
    // Replace {skills_list} placeholder (formatted list)
    if (currentPrompt.includes('{skills_list}')) {
        currentPrompt = currentPrompt.replace('{skills_list}', skillsListFormatted);
        wasUpdated = true;
    }
    
    // No longer need to replace {skills_to_assess} - backend handles it automatically
    
    if (wasUpdated) {
        promptField.value = currentPrompt;
        
        // Highlight the prompt field briefly to show it was updated
        promptField.style.backgroundColor = '#d4edda';
        setTimeout(() => {
            promptField.style.backgroundColor = '';
        }, 1000);
        return true;
    } else {
        return false;
    }
}

// Manual test function you can call from browser console
window.testSkillsInsertion = function() {
    return autoInsertSkillsIntoPrompt();
}

// Auto insert proficiency levels (both numeric and text)
function autoInsertProficiencyLevels() {
    const promptField = document.getElementById('assessment-prompt');
    if (!promptField) return;
    
    const proficiencyInputs = document.querySelectorAll('.proficiency-input');
    const levelInputs = document.querySelectorAll('.level-input');
    
    // Create proficiency_levels mapping format: "1: Novice\n2: Developing\n..."
    const proficiencyLevelsMapping = Array.from(proficiencyInputs)
        .map((input, index) => {
            const numeric = input.value.trim();
            const levelText = levelInputs[index]?.value?.trim() || '';
            if (numeric && levelText) {
                return `${numeric}: ${levelText}`;
            }
            return null;
        })
        .filter(v => v !== null)
        .join('\n');
    
    // Create proficiencies list (just numbers): "1, 2, 3, 4, 5"
    const proficiencies = Array.from(proficiencyInputs)
        .map(input => input.value.trim())
        .filter(v => v)
        .join(', ');
        
    // Create levels list (just text labels from levels section): "Novice, Developing, Intermediate, Advanced, Expert"
    const levels = Array.from(levelInputs)
        .map(input => input.value.trim())
        .filter(v => v)
        .join(', ');
    
    let currentPrompt = promptField.value;
    
    // Replace all placeholders
    if (currentPrompt.includes('{proficiency_levels}')) {
        currentPrompt = currentPrompt.replace(/\{proficiency_levels\}/g, proficiencyLevelsMapping);
    }
    if (currentPrompt.includes('{proficiency_levels_description}')) {
        currentPrompt = currentPrompt.replace(/\{proficiency_levels_description\}/g, proficiencyLevelsMapping);
    }
    if (currentPrompt.includes('{proficiencies}')) {
        currentPrompt = currentPrompt.replace(/\{proficiencies\}/g, proficiencies);
    }
    if (currentPrompt.includes('{levels}')) {
        currentPrompt = currentPrompt.replace(/\{levels\}/g, levels);
    }
    
    promptField.value = currentPrompt;
    document.getElementById('proficiency-auto-status').innerHTML = 
        '<i class="fas fa-check-circle mr-1"></i>Auto-loaded';
}

// Toggle proficiency section
function toggleProficiencySection() {
    const content = document.getElementById('proficiency-section-content');
    const icon = document.getElementById('proficiency-toggle-icon');
    
    if (content.classList.contains('hidden')) {
        content.classList.remove('hidden');
        icon.className = 'fas fa-chevron-up text-xl';
    } else {
        content.classList.add('hidden');
        icon.className = 'fas fa-chevron-down text-xl';
    }
}

// On proficiency change - auto update prompt
function onProficiencyChange() {
    autoInsertProficiencyLevels();
    showNotification('Proficiency levels updated in prompt', 'info');
}

