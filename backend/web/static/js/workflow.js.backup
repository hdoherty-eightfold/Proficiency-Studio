window.updateStep6WithAssessmentResults = updateStep6WithAssessmentResults;
window.syncStep6EnvironmentWithStep1 = syncStep6EnvironmentWithStep1;
window.populateStep6EnvironmentDropdown = populateStep6EnvironmentDropdown;
window.populateStep6Credentials = populateStep6Credentials;
window.runLangChainAssessment = runLangChainAssessment;
