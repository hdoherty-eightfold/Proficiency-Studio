// ================================================
// BATCH CONFIGURATION FUNCTIONS
// ================================================

// Global batch configuration storage
// Default batch configuration - MUST be sequential with 1 batch to avoid quota issues
let batchConfig = {
    batchSize: 650,  // Match chunk size for sequential processing
    concurrentBatches: 1,  // MUST be 1 to avoid rate limiting
    skillsCount: 0,
    processingMode: 'sequential'  // MUST be sequential for Google API
};

// Global assessment control
let assessmentController = null;
let isAssessmentRunning = false;

// Chunking and accumulation state
let chunkingState = {
    accumulatedResults: [],
    currentChunkStart: 1,
    processedChunks: 0,
    totalSkillsProcessed: 0,
    sessionStartTime: null,
    totalElapsedTime: 0  // Track total time across chunks
};

// Global timer for session tracking
let sessionTimerInterval = null;

// Initialize chunking state from localStorage on page load
function initializeChunkingState() {
    const saved = localStorage.getItem('chunkingState');
    if (saved) {
        try {
            chunkingState = JSON.parse(saved);

            // Also restore the skills list if available
            const savedSkills = localStorage.getItem('workflowSkills');
            if (savedSkills) {
                try {
                    workflowState.extractedSkills = JSON.parse(savedSkills);
                    // Restored skills from localStorage
                } catch (e) {
                    console.error('Failed to restore skills:', e);
                }
            }

            updateChunkingUI();
            updateOverallProgress(); // Update progress bar to reflect restored state
        } catch (e) {
            console.error('Failed to load chunking state:', e);
        }
    }
}

// Save chunking state to localStorage
function saveChunkingState() {
    localStorage.setItem('chunkingState', JSON.stringify(chunkingState));

    // Also save the skills list if we have it
    if (workflowState.extractedSkills && workflowState.extractedSkills.length > 0) {
        localStorage.setItem('workflowSkills', JSON.stringify(workflowState.extractedSkills));
        localStorage.setItem('workflowSkillsCount', workflowState.extractedSkills.length);
    }
}

// Update chunking UI elements
function updateChunkingUI() {
    const totalSkills = workflowState.extractedSkills?.length || 0;

    // Update total available skills
    const totalAvailableEl = document.getElementById('total-available-skills');
    if (totalAvailableEl) {
        totalAvailableEl.textContent = `${totalSkills} skills`;
    }

    // Update accumulated count
    const accumulatedCountEl = document.getElementById('accumulated-count');
    if (accumulatedCountEl) {
        accumulatedCountEl.textContent = `${chunkingState.accumulatedResults.length} skills`;
    }

    // Update both progress bars
    updateOverallProgress();

    // Update processing estimates
    updateProcessingEstimates();

    // Start session timer if we have accumulated results
    if (chunkingState.accumulatedResults.length > 0 && !sessionTimerInterval) {
        startSessionTimer();
    }
}

// Start the session timer
function startSessionTimer() {
    if (!chunkingState.sessionStartTime) {
        chunkingState.sessionStartTime = Date.now() - (chunkingState.totalElapsedTime * 1000);
    }

    // Clear any existing timer
    if (sessionTimerInterval) {
        clearInterval(sessionTimerInterval);
    }

    // Clear any existing session timer first
    if (sessionTimerInterval) {
        clearInterval(sessionTimerInterval);
        sessionTimerInterval = null;
    }

    // Update timer every second
    sessionTimerInterval = setInterval(() => {
        if (!chunkingState.sessionStartTime || isNaN(chunkingState.sessionStartTime)) {
            console.warn('Invalid session start time, skipping timer update');
            return;
        }

        const elapsedSeconds = Math.floor((Date.now() - chunkingState.sessionStartTime) / 1000);
        if (isNaN(elapsedSeconds)) {
            console.warn('NaN in session timer calculation');
            return;
        }

        const minutes = Math.floor(elapsedSeconds / 60);
        const seconds = elapsedSeconds % 60;
        const timeStr = `${minutes}:${seconds.toString().padStart(2, '0')}`;

        const elapsedTimeEl = document.getElementById('elapsed-time');
        if (elapsedTimeEl) {
            elapsedTimeEl.textContent = timeStr;
        }

        // Save elapsed time
        chunkingState.totalElapsedTime = elapsedSeconds;
    }, 1000);
}

// Stop the session timer
function stopSessionTimer() {
    if (sessionTimerInterval) {
        clearInterval(sessionTimerInterval);
        sessionTimerInterval = null;
    }
}

// Select a specific chunk of skills
function selectChunk(start, end) {
    const totalSkills = workflowState.extractedSkills?.length || 0;

    if (totalSkills === 0) {
        showNotification('Please load skills first (Step 2: Fetch JIE Roles)', 'error');
        return;
    }

    // Adjust end if it exceeds total skills
    const actualEnd = Math.min(end, totalSkills);
    const chunkSize = actualEnd - start + 1;

    // Update UI inputs
    const chunkStartInput = document.getElementById('chunk-start-input');
    const chunkSizeInput = document.getElementById('chunk-size-input');

    if (chunkStartInput) chunkStartInput.value = start;
    if (chunkSizeInput) chunkSizeInput.value = chunkSize;

    // Update batch size to match chunk size for Google
    const provider = document.getElementById('llm-provider')?.value;
    if (provider === 'google') {
        const batchSizeInput = document.getElementById('batch-size-input');
        if (batchSizeInput) {
            batchSizeInput.value = Math.min(chunkSize, 650); // Cap at 650 for safety
        }
    }

    updateProcessingLog(`📦 Selected chunk: Skills ${start} to ${actualEnd} (${chunkSize} skills)`, 'info');
    showNotification(`Selected skills ${start}-${actualEnd}`, 'info');
}

// Select the next unprocessed chunk
function selectNextChunk() {
    // First try to restore skills from localStorage if not in memory
    if (!workflowState.extractedSkills || workflowState.extractedSkills.length === 0) {
        const savedSkills = localStorage.getItem('workflowSkills');
        if (savedSkills) {
            try {
                workflowState.extractedSkills = JSON.parse(savedSkills);
                console.log(`✅ Restored ${workflowState.extractedSkills.length} skills from localStorage`);
            } catch (e) {
                console.error('Failed to restore skills:', e);
            }
        }
    }

    const totalSkills = workflowState.extractedSkills?.length || 0;
    // Honor user's chunk size setting (450 as shown in screenshot)
    const chunkSize = parseInt(document.getElementById('chunk-size-input')?.value || 450);

    if (totalSkills === 0) {
        showNotification('No skills found. Please complete Step 2 first.', 'error');
        return;
    }

    // Calculate next chunk based on accumulated results
    const processedCount = chunkingState.accumulatedResults?.length || 0;

    // FIXED: Check if this is being called for auto-continuation or initial start
    // If we have processed skills, move to next chunk. Otherwise, check the input field
    let nextStart;
    const currentStartInput = document.getElementById('chunk-start-input');
    const currentInputValue = parseInt(currentStartInput?.value || 1);

    if (processedCount > 0) {
        // We have processed skills, so continue from where we left off
        nextStart = processedCount + 1;
    } else if (currentInputValue > 1) {
        // User has manually set a start position
        nextStart = currentInputValue;
    } else {
        // First chunk, start from 1
        nextStart = 1;
    }

    if (nextStart > totalSkills) {
        showNotification('All skills have been processed!', 'success');
        return;
    }

    // IMPORTANT: Keep the original chunk size consistent across all chunks
    // Don't change it for the last chunk - just process whatever remains
    const nextEnd = Math.min(nextStart + chunkSize - 1, totalSkills);
    const actualSkillsInChunk = nextEnd - nextStart + 1;

    // Update chunk start ONLY - keep chunk size consistent
    chunkingState.currentChunkStart = nextStart;
    chunkingState.chunkSize = chunkSize;  // Keep ORIGINAL chunk size

    // Update the input to reflect the current start position
    if (currentStartInput) {
        currentStartInput.value = nextStart;
    }
    // DON'T change the chunk-size-input - keep it at the original value

    // Restore batch size to match chunk size for the next chunk
    // This handles the case where batch was reduced due to truncation
    const batchSizeInput = document.getElementById('batch-size-input');
    if (batchSizeInput) {
        const currentBatchSize = parseInt(batchSizeInput.value);
        if (currentBatchSize < chunkSize) {
            console.log(`🔧 Restoring batch size from ${currentBatchSize} to ${chunkSize} for next chunk`);
            updateProcessingLog(`📊 Restoring batch size to ${chunkSize} for next chunk`, 'info');
        }
        batchSizeInput.value = chunkSize;
    }

    // Update batch calculations to reflect the new settings
    updateBatchCalculations();

    // Show what's being processed
    updateProcessingLog(`📦 Preparing next chunk: Skills ${nextStart} to ${nextEnd} (${actualSkillsInChunk} skills)`, 'info');
    showNotification(`Ready to process skills ${nextStart}-${nextEnd} (${actualSkillsInChunk} skills)`, 'info');

    // Update the LangChain request preview
    updateLangChainRequestPreview();
}

// Select all remaining unprocessed skills
function selectRemainingSkills() {
    const totalSkills = workflowState.extractedSkills?.length || 0;

    if (totalSkills === 0) {
        showNotification('Please load skills first', 'error');
        return;
    }

    const remainingStart = chunkingState.totalSkillsProcessed + 1;
    if (remainingStart > totalSkills) {
        showNotification('All skills have been processed!', 'success');
        return;
    }

    selectChunk(remainingStart, totalSkills);
}

// Show chunk retry options after failure
function showChunkRetryOptions(failedChunkNum, failedSkillCount, errorMessage) {
    const totalSkills = workflowState.extractedSkills?.length || 0;
    const processedCount = chunkingState.accumulatedResults?.length || 0;
    const remainingSkills = totalSkills - processedCount;
    const chunkStart = chunkingState.currentChunkStart || ((failedChunkNum - 1) * (chunkingState.chunkSize || 387) + 1);
    const chunkEnd = Math.min(chunkStart + (chunkingState.chunkSize || 387) - 1, totalSkills);

    // Get the actual error message or use a default
    const displayError = errorMessage || 'Assessment failed';

    // Create modal with retry options
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-gray-800 bg-opacity-50 z-50 flex items-center justify-center p-4';
    modal.innerHTML = `
        <div class="bg-white dark:bg-gray-800 p-6 rounded-lg max-w-lg w-full relative">
            <!-- Close button in top right -->
            <button onclick="this.closest('.fixed').remove();" class="absolute top-3 right-3 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">
                <i class="fas fa-times text-xl"></i>
            </button>

            <h3 class="text-lg font-bold mb-4 text-red-600">
                <i class="fas fa-exclamation-triangle mr-2"></i>
                Chunk ${failedChunkNum} Failed
            </h3>

            <div class="mb-4 text-sm">
                <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded p-3 mb-3">
                    <p class="text-red-700 dark:text-red-400 font-semibold mb-1">Error Details:</p>
                    <p class="text-red-600 dark:text-red-300 text-xs">${displayError}</p>
                </div>

                <div class="text-gray-600 dark:text-gray-400">
                    ${failedSkillCount > 0 ?
                        `<p>Failed to process ${failedSkillCount} skills (positions ${chunkStart}-${chunkEnd}).</p>` :
                        `<p>No skills were found for chunk ${failedChunkNum} (positions ${chunkStart}-${chunkEnd}).</p>`
                    }
                    <p class="mt-2">
                        <strong>Progress:</strong> ${processedCount}/${totalSkills} skills completed<br>
                        <strong>Remaining:</strong> ${remainingSkills} skills<br>
                        <strong>Chunk Range:</strong> Skills ${chunkStart} to ${chunkEnd}
                    </p>
                </div>
            </div>

            <div class="flex flex-col gap-2">
                <button onclick="this.closest('.fixed').remove(); fixAndRetryChunk();" class="bg-orange-600 text-white px-4 py-2 rounded hover:bg-orange-700">
                    <i class="fas fa-redo mr-1"></i>Retry This Chunk
                </button>

                <button onclick="this.closest('.fixed').remove(); selectNextChunk(); runLangChainAssessment();" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">
                    <i class="fas fa-forward mr-1"></i>Skip to Next Chunk
                </button>

                <button onclick="this.closest('.fixed').remove(); viewAccumulatedResults();" class="bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700">
                    <i class="fas fa-eye mr-1"></i>View Accumulated Results (${processedCount} skills)
                </button>

                <button onclick="this.closest('.fixed').remove();" class="bg-gray-600 text-white px-4 py-2 rounded hover:bg-gray-700">
                    <i class="fas fa-pause mr-1"></i>Pause Processing
                </button>
            </div>
        </div>
    `;
    document.body.appendChild(modal);
}

// Fix chunk position and retry
function fixAndRetryChunk() {
    console.log('Fixing and retrying current chunk...');

    // Ensure chunk position is properly set based on accumulated results
    const processedCount = chunkingState.accumulatedResults?.length || 0;
    // Honor user's chunk size setting (450)
    const chunkSize = parseInt(document.getElementById('chunk-size-input')?.value || 450);

    // Set the correct start position
    const correctStart = processedCount + 1; // 1-indexed for UI

    console.log(`Fixing chunk position: Setting start to ${correctStart} (processed: ${processedCount})`);

    // Update UI inputs with correct values
    document.getElementById('chunk-start-input').value = correctStart;
    document.getElementById('chunk-size-input').value = chunkSize;

    // Update chunking state
    chunkingState.currentChunkStart = correctStart;
    chunkingState.chunkSize = chunkSize;

    // Update batch size to match chunk size for consistency
    document.getElementById('batch-size-input').value = chunkSize;

    // Log the fix
    updateProcessingLog(`🔧 Fixed chunk position: Start=${correctStart}, Size=${chunkSize}`, 'info');

    // Now retry with corrected position
    runLangChainAssessment();
}

// Retry the current failed chunk (deprecated - use fixAndRetryChunk)
function retryCurrentChunk() {
    console.log('Retrying current chunk...');
    // Don't change chunk position, just retry
    runLangChainAssessment();
}

// Show continue chunking options
function showContinueChunkingOptions() {
    // Use the chunk retry options dialog
    const currentChunk = chunkingState.currentChunk || 1;
    const errorMsg = "Processing stopped - you can retry or continue";
    showChunkRetryOptions(currentChunk, 0, errorMsg);
}

// View accumulated results - show in popup instead of replacing response
function viewAccumulatedResults() {
    if (!chunkingState.accumulatedResults || chunkingState.accumulatedResults.length === 0) {
        showNotification('No accumulated results yet', 'warning');
        return;
    }

    const totalSkills = workflowState.extractedSkills?.length || 0;
    const processedCount = chunkingState.accumulatedResults.length;
    const remainingCount = totalSkills - processedCount;

    // Create popup modal
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-gray-800 bg-opacity-50 z-50 flex items-center justify-center p-4';
    modal.innerHTML = `
        <div class="bg-white dark:bg-gray-800 p-6 rounded-lg max-w-6xl w-full max-h-[90vh] flex flex-col">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-xl font-bold">
                    Accumulated Results (${processedCount} skills)
                    ${remainingCount > 0 ? `<span class="text-sm font-normal text-yellow-600 ml-2">• ${remainingCount} skills remaining</span>` : '<span class="text-sm font-normal text-green-600 ml-2">• All skills processed!</span>'}
                </h3>
                <div class="flex gap-2">
                    <button onclick="copyAccumulatedResults()" class="bg-blue-600 text-white px-3 py-1.5 rounded text-sm hover:bg-blue-700">
                        <i class="fas fa-copy mr-1"></i>Copy JSON
                    </button>
                    <button onclick="downloadAccumulatedResults()" class="bg-green-600 text-white px-3 py-1.5 rounded text-sm hover:bg-green-700">
                        <i class="fas fa-download mr-1"></i>Download
                    </button>
                    <button onclick="this.closest('.fixed').remove()" class="bg-gray-600 text-white px-3 py-1.5 rounded text-sm hover:bg-gray-700">
                        <i class="fas fa-times"></i> Close
                    </button>
                </div>
            </div>
            <div class="text-sm text-gray-600 dark:text-gray-400 mb-2">
                <i class="fas fa-info-circle mr-1"></i>
                Processed in ${chunkingState.processedChunks || 0} chunk(s) •
                ${chunkingState.totalSkillsProcessed || processedCount} total skills assessed
            </div>
            <div class="bg-gray-100 dark:bg-gray-900 rounded p-4 overflow-auto flex-1">
                <pre class="text-xs whitespace-pre-wrap">${JSON.stringify(chunkingState.accumulatedResults, null, 2)}</pre>
            </div>
            <div class="mt-4 flex gap-2">
                ${remainingCount > 0 ? `
                    <button onclick="this.closest('.fixed').remove(); selectNextChunk(); runLangChainAssessment();" class="flex-1 bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">
                        <i class="fas fa-forward mr-1"></i>Continue to Next Chunk
                    </button>
                ` : `
                    <button onclick="this.closest('.fixed').remove(); combineAndFinalize();" class="flex-1 bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700">
                        <i class="fas fa-check mr-1"></i>Finalize Results
                    </button>
                `}
                <button onclick="this.closest('.fixed').remove()" class="flex-1 bg-gray-600 text-white px-4 py-2 rounded hover:bg-gray-700">
                    <i class="fas fa-times mr-1"></i>Close
                </button>
            </div>
        </div>
    `;
    document.body.appendChild(modal);
}

// Combine and finalize all accumulated results
async function combineAndFinalize() {
    if (chunkingState.accumulatedResults.length === 0) {
        showNotification('No results to combine. Process some chunks first!', 'error');
        return;
    }

    updateProcessingLog(`🔄 Combining ${chunkingState.accumulatedResults.length} accumulated skills...`, 'info');

    // Create final combined response
    const finalResponse = {
        assessed_skills: chunkingState.accumulatedResults,
        timestamp: new Date().toISOString(),
        environment: document.getElementById('environment-select')?.value || 'unknown',
        provider: document.getElementById('llm-provider')?.value || 'google',
        model: document.getElementById('model-select')?.value || 'auto',
        total_skills: chunkingState.accumulatedResults.length,
        chunks_processed: chunkingState.processedChunks,
        statistics: {
            avg_proficiency: chunkingState.accumulatedResults.reduce((sum, s) => sum + s.proficiency, 0) / chunkingState.accumulatedResults.length,
            avg_confidence: chunkingState.accumulatedResults.reduce((sum, s) => sum + s.confidence_score, 0) / chunkingState.accumulatedResults.length,
            processing_chunks: chunkingState.processedChunks
        },
        api_request_payload: {
            endpoint: "/api/skills/update-proficiencies",
            method: "POST",
            description: "Combined from multiple chunks",
            total_skills: chunkingState.accumulatedResults.length,
            chunks: chunkingState.processedChunks
        }
    };

    // Display the combined results
    const responseViewerElement = document.getElementById('langchain-response-viewer');
    if (responseViewerElement) {
        const responseHtml = `
            <div class="relative">
                <div class="absolute top-2 right-2 flex gap-2">
                    <button onclick="copyJsonResponse()" class="bg-blue-600 text-white px-2 py-1 rounded text-xs hover:bg-blue-700">
                        <i class="fas fa-copy mr-1"></i>Copy
                    </button>
                    <button onclick="downloadJsonResponse()" class="bg-green-600 text-white px-2 py-1 rounded text-xs hover:bg-green-700">
                        <i class="fas fa-download mr-1"></i>Download
                    </button>
                    <button onclick="saveAssessmentToFile()" class="bg-purple-600 text-white px-2 py-1 rounded text-xs hover:bg-purple-700">
                        <i class="fas fa-save mr-1"></i>Save to File
                    </button>
                </div>
                <h3 class="text-lg font-bold mb-2">✅ Final Combined Results (${chunkingState.accumulatedResults.length} skills from ${chunkingState.processedChunks} chunks)</h3>
                <pre class="text-xs pt-8">${JSON.stringify(finalResponse, null, 2)}</pre>
            </div>
        `;
        responseViewerElement.innerHTML = responseHtml;
        workflowState.lastAssessmentResponse = finalResponse;
    }

    // Update status
    const statusElement = document.getElementById('langchain-status');
    if (statusElement) {
        statusElement.innerHTML = `
            <span class="text-green-600 dark:text-green-400">
                <i class="fas fa-check-circle mr-1"></i>Successfully combined ${chunkingState.accumulatedResults.length} skills from ${chunkingState.processedChunks} chunks
            </span>
        `;
    }

    updateProcessingLog(`✅ Successfully combined ${chunkingState.accumulatedResults.length} skills from ${chunkingState.processedChunks} chunks`, 'success');
    showNotification('All chunks successfully combined!', 'success');

    // Auto-save the combined results
    const filename = `combined_${finalResponse.environment}_${new Date().toISOString().slice(0, 19).replace(/:/g, '-')}.json`;
    await saveAssessmentToServer(finalResponse, filename);
}

// Save assessment to file
function saveAssessmentToFile() {
    // Get the assessment data to save
    const dataToSave = chunkingState.accumulatedResults?.length > 0
        ? {
            success: true,
            environment: workflowState.environment || 'unknown',
            total_skills: chunkingState.accumulatedResults.length,
            assessed_skills: chunkingState.accumulatedResults,
            chunks_processed: chunkingState.processedChunks,
            timestamp: new Date().toISOString(),
            extracted_skills: workflowState.extractedSkills
          }
        : workflowState.lastAssessmentResponse || {};

    const blob = new Blob([JSON.stringify(dataToSave, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    const filename = `assessment_${dataToSave.environment}_${new Date().toISOString().slice(0, 19).replace(/:/g, '-')}.json`;
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);

    showNotification(`Assessment saved to ${filename}`, 'success');
}

// Save assessment to server
async function saveAssessmentToServer(assessmentData, filename) {
    try {
        const response = await fetch('/api/assessments/save', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                filename: filename,
                data: assessmentData
            })
        });

        if (!response.ok) {
            throw new Error(`Failed to save: ${response.statusText}`);
        }

        const result = await response.json();
        console.log('Assessment saved to server:', result);
        return result;
    } catch (error) {
        console.error('Error saving assessment to server:', error);
        throw error;
    }
}

// Clear accumulated results
function clearAccumulatedResults(skipConfirm = false) {
    // Only show confirm dialog if not skipping and there are results
    if (!skipConfirm && chunkingState.accumulatedResults.length > 0) {
        showConfirmModal(
            'Clear Accumulated Results',
            `Are you sure you want to clear ${chunkingState.accumulatedResults.length} accumulated results? This cannot be undone.`,
            () => {
                performClearAccumulatedResults();
            }
        );
        return;
    }
    performClearAccumulatedResults();
}

function performClearAccumulatedResults() {

    chunkingState = {
        accumulatedResults: [],
        currentChunkStart: 1,
        processedChunks: 0,
        totalSkillsProcessed: 0
    };

    // Reset the chunk start input to 1
    const chunkStartInput = document.getElementById('chunk-start-input');
    if (chunkStartInput) {
        chunkStartInput.value = 1;
    }

    // Also clear the saved skills from localStorage
    localStorage.removeItem('workflowSkills');
    localStorage.removeItem('workflowSkillsCount');

    saveChunkingState();
    updateChunkingUI();
    updateOverallProgress(); // Update progress bar
    updateProcessingLog('🗑️ Cleared all accumulated results', 'warning');
    showNotification('Accumulated results cleared', 'info');
}

// Copy accumulated results to clipboard
function copyAccumulatedResults() {
    if (!chunkingState.accumulatedResults || chunkingState.accumulatedResults.length === 0) {
        showNotification('No accumulated results to copy', 'warning');
        return;
    }

    const resultsJson = JSON.stringify(chunkingState.accumulatedResults, null, 2);
    navigator.clipboard.writeText(resultsJson).then(() => {
        showNotification('Accumulated results copied to clipboard!', 'success');
    }).catch(err => {
        console.error('Failed to copy:', err);
        showNotification('Failed to copy to clipboard', 'error');
    });
}

// Download accumulated results
function downloadAccumulatedResults() {
    if (chunkingState.accumulatedResults.length === 0) {
        showNotification('No accumulated results to download', 'warning');
        return;
    }

    const dataStr = JSON.stringify(chunkingState.accumulatedResults, null, 2);
    const dataBlob = new Blob([dataStr], { type: 'application/json' });
    const url = URL.createObjectURL(dataBlob);
    const link = document.createElement('a');
    link.href = url;
    link.download = `accumulated_skills_${new Date().toISOString().slice(0, 19).replace(/:/g, '-')}.json`;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    URL.revokeObjectURL(url);
}

// Handle partial batch failures and accumulate successful results
function handlePartialBatchFailure(result) {
    // Check if we have any successful batches
    if (result.llm_response?.batch_info?.successful_batches > 0) {
        const batchInfo = result.llm_response.batch_info;
        const assessedSkills = result.assessed_skills || [];

        if (assessedSkills.length > 0) {
            // Accumulate successful results
            chunkingState.accumulatedResults.push(...assessedSkills);
            chunkingState.totalSkillsProcessed += assessedSkills.length;
            saveChunkingState();
            updateChunkingUI();

            // Enhanced partial failure logging
            updateProcessingLog(`━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━`, 'separator');
            updateProcessingLog(`⚠️ PARTIAL BATCH FAILURE`, 'warning');
            updateProcessingLog(`  ✅ Successful: ${batchInfo.successful_batches}/${batchInfo.total_batches} batches`, 'success');
            updateProcessingLog(`  ❌ Failed: ${batchInfo.failed_batches} batch(es)`, 'error');
            updateProcessingLog(`  💾 Saved: ${assessedSkills.length} skills to accumulator`, 'success');
            updateProcessingLog(`  📊 Total Accumulated: ${chunkingState.accumulatedResults.length} skills`, 'info');

            // Calculate what failed
            const chunkSize = parseInt(document.getElementById('chunk-size-input')?.value || 650);
            const batchSize = parseInt(document.getElementById('batch-size-input')?.value || chunkSize);
            const expectedSkills = batchInfo.total_batches * batchSize;
            const missingSkills = expectedSkills - assessedSkills.length;
            updateProcessingLog(`  ⚠️ Missing: ~${missingSkills} skills need retry`, 'warning');
            updateProcessingLog(`━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━`, 'separator');

            // Show retry modal
            showRetryModal(batchInfo);
        }
    }
}

// Show retry modal for failed batches
function showRetryModal(batchInfo) {
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50';
    modal.innerHTML = `
        <div class="bg-white dark:bg-gray-800 rounded-lg p-6 max-w-md w-full mx-4">
            <h3 class="text-lg font-bold mb-4 text-gray-900 dark:text-white">
                <i class="fas fa-exclamation-triangle text-yellow-500 mr-2"></i>
                Partial Batch Failure
            </h3>

            <div class="mb-4">
                <p class="text-gray-700 dark:text-gray-300 mb-2">
                    Some batches failed during processing:
                </p>
                <ul class="list-disc list-inside text-sm text-gray-600 dark:text-gray-400">
                    <li>Successful batches: ${batchInfo.successful_batches}</li>
                    <li>Failed batches: ${batchInfo.failed_batches}</li>
                    <li>Skills successfully assessed: ${chunkingState.accumulatedResults.length}</li>
                </ul>
            </div>

            <div class="mb-4 p-3 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-700 rounded">
                <p class="text-sm text-yellow-800 dark:text-yellow-200">
                    <i class="fas fa-info-circle mr-1"></i>
                    Successful results have been saved. You can retry the failed batches or continue with the next chunk.
                </p>
            </div>

            <div class="flex gap-3">
                <button onclick="retryFailedBatches()" class="flex-1 bg-orange-600 text-white px-4 py-2 rounded hover:bg-orange-700">
                    <i class="fas fa-redo mr-1"></i>Retry Failed
                </button>
                <button onclick="selectNextChunk(); this.closest('.fixed').remove();" class="flex-1 bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700">
                    <i class="fas fa-forward mr-1"></i>Next Chunk
                </button>
                <button onclick="this.closest('.fixed').remove()" class="flex-1 bg-gray-600 text-white px-4 py-2 rounded hover:bg-gray-700">
                    <i class="fas fa-times mr-1"></i>Close
                </button>
            </div>
        </div>
    `;
    document.body.appendChild(modal);
}

// Retry failed batches
async function retryFailedBatches() {
    // Close any open modals
    document.querySelectorAll('.fixed.inset-0').forEach(m => m.remove());

    // Get the failed skills (those not yet processed)
    const totalSkills = workflowState.extractedSkills?.length || 0;
    const processedSkillNames = new Set(chunkingState.accumulatedResults.map(s => s.skill_name || s.name));
    const unprocessedSkills = workflowState.extractedSkills.filter(s =>
        !processedSkillNames.has(s.name || s.skill_name)
    );

    if (unprocessedSkills.length === 0) {
        showNotification('All skills have been processed!', 'success');
        return;
    }

    // Update chunk inputs to retry the unprocessed skills
    const chunkStartInput = document.getElementById('chunk-start-input');
    const chunkSizeInput = document.getElementById('chunk-size-input');

    if (chunkStartInput && chunkSizeInput) {
        // Find the index of the first unprocessed skill
        const firstUnprocessedIndex = workflowState.extractedSkills.findIndex(s =>
            !processedSkillNames.has(s.name || s.skill_name)
        );

        chunkStartInput.value = firstUnprocessedIndex + 1; // Convert to 1-indexed
        chunkSizeInput.value = Math.min(unprocessedSkills.length, 650); // Retry with safe batch size
    }

    updateProcessingLog(`🔄 Retrying ${unprocessedSkills.length} unprocessed skills...`, 'info');
    showNotification(`Retrying ${unprocessedSkills.length} unprocessed skills`, 'info');

    // Run assessment again
    runLangChainAssessment();
}

// Intelligent Processing System
function analyzeAndRecommend() {
    const totalSkills = workflowState.extractedSkills?.length || 0;

    if (totalSkills === 0) {
        showNotification('Please load skills first', 'error');
        return;
    }

    // Intelligent recommendations based on skill count
    let recommendation = {
        strategy: 'balanced',
        approach: 'single',
        chunks: 1,
        message: '',
        config: {}
    };

    if (totalSkills <= 300) {
        // Small set - process all at once
        recommendation = {
            strategy: 'aggressive',
            approach: 'all-at-once',
            chunks: 1,
            message: `Small skill set (${totalSkills} skills) - Process all at once with aggressive strategy`,
            config: {
                chunkSize: totalSkills,
                batchSize: Math.min(totalSkills, 650),
                parallel: 1,
                mode: 'sequential'
            }
        };
    } else if (totalSkills <= 650) {
        // Medium set - single chunk, multiple batches
        recommendation = {
            strategy: 'balanced',
            approach: 'single-chunk',
            chunks: 1,
            message: `Medium skill set (${totalSkills} skills) - Single chunk with ${Math.ceil(totalSkills/300)} batches`,
            config: {
                chunkSize: totalSkills,
                batchSize: 650,
                parallel: 2,
                mode: 'parallel'
            }
        };
    } else if (totalSkills <= 1500) {
        // Large set - 2-3 chunks
        const optimalChunkSize = Math.ceil(totalSkills / 2);
        recommendation = {
            strategy: 'balanced',
            approach: 'multi-chunk',
            chunks: 2,
            message: `Large skill set (${totalSkills} skills) - Split into 2 chunks of ~${optimalChunkSize} skills each`,
            config: {
                chunkSize: optimalChunkSize,
                batchSize: optimalChunkSize,
                parallel: 2,
                mode: 'parallel'
            }
        };
    } else {
        // Very large set - multiple chunks with conservative approach
        const optimalChunkSize = 500;
        const chunks = Math.ceil(totalSkills / optimalChunkSize);
        recommendation = {
            strategy: 'conservative',
            approach: 'progressive',
            chunks: chunks,
            message: `Very large skill set (${totalSkills} skills) - Split into ${chunks} chunks of ${optimalChunkSize} skills`,
            config: {
                chunkSize: optimalChunkSize,
                batchSize: 200,
                parallel: 1,
                mode: 'sequential'
            }
        };
    }

    // Show intelligent recommendation modal
    showIntelligentRecommendation(recommendation, totalSkills);
    return recommendation;
}

// Show intelligent recommendation modal
function showIntelligentRecommendation(recommendation, totalSkills) {
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50';
    modal.id = 'intelligent-recommendation-modal';

    const estimatedTime = Math.ceil((totalSkills / 300) * 1.5); // Rough estimate
    const processedSoFar = chunkingState.accumulatedResults.length;
    const remaining = totalSkills - processedSoFar;

    modal.innerHTML = `
        <div class="bg-white dark:bg-gray-800 rounded-lg p-6 max-w-2xl w-full mx-4 max-h-[90vh] overflow-y-auto">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
                    <i class="fas fa-brain mr-2 text-blue-500"></i>Intelligent Processing Analysis
                </h2>
                <button onclick="this.closest('.fixed').remove()" class="text-gray-500 hover:text-gray-700">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <!-- Skill Analysis -->
            <div class="bg-blue-50 dark:bg-blue-900/20 rounded-lg p-4 mb-4">
                <h3 class="font-bold text-blue-800 dark:text-blue-200 mb-2">
                    <i class="fas fa-chart-bar mr-2"></i>Skill Analysis
                </h3>
                <div class="grid grid-cols-2 gap-4 text-sm">
                    <div>
                        <span class="text-gray-600 dark:text-gray-400">Total Skills:</span>
                        <span class="font-bold ml-2">${totalSkills}</span>
                    </div>
                    <div>
                        <span class="text-gray-600 dark:text-gray-400">Already Processed:</span>
                        <span class="font-bold ml-2 ${processedSoFar > 0 ? 'text-green-600' : ''}">${processedSoFar}</span>
                    </div>
                    <div>
                        <span class="text-gray-600 dark:text-gray-400">Remaining:</span>
                        <span class="font-bold ml-2 ${remaining > 0 ? 'text-orange-600' : 'text-green-600'}">${remaining}</span>
                    </div>
                    <div>
                        <span class="text-gray-600 dark:text-gray-400">Est. Time:</span>
                        <span class="font-bold ml-2">~${estimatedTime} minutes</span>
                    </div>
                </div>
            </div>

            <!-- Recommendation -->
            <div class="bg-green-50 dark:bg-green-900/20 rounded-lg p-4 mb-4">
                <h3 class="font-bold text-green-800 dark:text-green-200 mb-2">
                    <i class="fas fa-lightbulb mr-2"></i>Smart Recommendation
                </h3>
                <p class="text-sm text-gray-700 dark:text-gray-300 mb-3">${recommendation.message}</p>

                <div class="grid grid-cols-2 md:grid-cols-4 gap-3 text-sm">
                    <div class="bg-white dark:bg-gray-700 rounded p-2">
                        <span class="text-gray-600 dark:text-gray-400">Strategy:</span>
                        <div class="font-bold capitalize">${recommendation.strategy}</div>
                    </div>
                    <div class="bg-white dark:bg-gray-700 rounded p-2">
                        <span class="text-gray-600 dark:text-gray-400">Chunks:</span>
                        <div class="font-bold">${recommendation.chunks}</div>
                    </div>
                    <div class="bg-white dark:bg-gray-700 rounded p-2">
                        <span class="text-gray-600 dark:text-gray-400">Batch Size:</span>
                        <div class="font-bold">${recommendation.config.batchSize}</div>
                    </div>
                    <div class="bg-white dark:bg-gray-700 rounded p-2">
                        <span class="text-gray-600 dark:text-gray-400">Mode:</span>
                        <div class="font-bold capitalize">${recommendation.config.mode}</div>
                    </div>
                </div>
            </div>

            <!-- Processing Options -->
            <div class="mb-4">
                <h3 class="font-bold text-gray-800 dark:text-gray-200 mb-3">
                    <i class="fas fa-play-circle mr-2"></i>Processing Options
                </h3>
                <div class="space-y-2">
                    <button onclick="runIntelligentProcessing('full')"
                            class="w-full bg-green-600 text-white px-4 py-3 rounded-lg hover:bg-green-700 text-left">
                        <i class="fas fa-rocket mr-2"></i>
                        <span class="font-bold">Process All ${remaining > 0 ? 'Remaining' : ''} Skills</span>
                        <span class="block text-sm opacity-90">Automatically handle all ${remaining || totalSkills} skills with smart chunking</span>
                    </button>

                    ${processedSoFar > 0 ? `
                    <button onclick="runIntelligentProcessing('continue')"
                            class="w-full bg-blue-600 text-white px-4 py-3 rounded-lg hover:bg-blue-700 text-left">
                        <i class="fas fa-forward mr-2"></i>
                        <span class="font-bold">Continue From Where Left Off</span>
                        <span class="block text-sm opacity-90">Process remaining ${remaining} skills</span>
                    </button>
                    ` : ''}

                    <button onclick="runIntelligentProcessing('test')"
                            class="w-full bg-purple-600 text-white px-4 py-3 rounded-lg hover:bg-purple-700 text-left">
                        <i class="fas fa-vial mr-2"></i>
                        <span class="font-bold">Test Run (First 100 Skills)</span>
                        <span class="block text-sm opacity-90">Quick test to verify configuration</span>
                    </button>

                    <button onclick="applyRecommendation(${JSON.stringify(recommendation).replace(/"/g, '&quot;')})"
                            class="w-full bg-gray-600 text-white px-4 py-3 rounded-lg hover:bg-gray-700 text-left">
                        <i class="fas fa-cog mr-2"></i>
                        <span class="font-bold">Apply Settings & Configure Manually</span>
                        <span class="block text-sm opacity-90">Use recommended settings but control execution</span>
                    </button>
                </div>
            </div>

            <!-- Progress Tracking Info -->
            ${chunkingState.accumulatedResults.length > 0 ? `
            <div class="bg-yellow-50 dark:bg-yellow-900/20 rounded-lg p-3 text-sm">
                <i class="fas fa-info-circle mr-2 text-yellow-600"></i>
                <span class="text-yellow-800 dark:text-yellow-200">
                    You have ${chunkingState.accumulatedResults.length} skills already processed and saved.
                    These will be automatically included in the final result.
                </span>
            </div>
            ` : ''}
        </div>
    `;

    document.body.appendChild(modal);
}

// Run intelligent processing
async function runIntelligentProcessing(mode) {
    // Close modal
    document.getElementById('intelligent-recommendation-modal')?.remove();

    const totalSkills = workflowState.extractedSkills?.length || 0;
    const processedSoFar = chunkingState.accumulatedResults.length;

    let skillsToProcess = 0;
    let startFrom = 1;

    switch(mode) {
        case 'full':
            skillsToProcess = totalSkills - processedSoFar;
            startFrom = processedSoFar + 1;
            break;
        case 'continue':
            skillsToProcess = totalSkills - processedSoFar;
            startFrom = processedSoFar + 1;
            break;
        case 'test':
            skillsToProcess = Math.min(100, totalSkills);
            startFrom = 1;
            break;
    }

    // Set up intelligent processing state
    chunkingState.intelligentMode = true;
    chunkingState.targetTotal = mode === 'test' ? skillsToProcess : totalSkills;
    chunkingState.autoRetry = true;

    // Configure based on recommendations
    const recommendation = analyzeAndRecommend();
    applyRecommendation(recommendation);

    // Update UI to show intelligent mode
    updateProcessingLog('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━', 'separator');
    updateProcessingLog(`🧠 INTELLIGENT PROCESSING STARTED`, 'success');
    updateProcessingLog(`  📊 Mode: ${mode.toUpperCase()}`, 'info');
    updateProcessingLog(`  🎯 Target: ${skillsToProcess} skills`, 'info');
    updateProcessingLog(`  📍 Starting from: Skill #${startFrom}`, 'info');
    updateProcessingLog(`  🔄 Auto-retry: Enabled`, 'info');
    updateProcessingLog('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━', 'separator');

    // Set chunk position
    document.getElementById('chunk-start-input').value = startFrom;

    // Start processing
    runLangChainAssessment();

    // Monitor for completion
    monitorIntelligentProgress();
}

// Apply recommendation settings
function applyRecommendation(recommendation) {
    if (recommendation.config) {
        document.getElementById('chunk-size-input').value = recommendation.config.chunkSize;
        document.getElementById('batch-size-input').value = recommendation.config.batchSize;
        document.getElementById('concurrent-batches-input').value = recommendation.config.parallel;
        document.getElementById('processing-mode-select').value = recommendation.config.mode;

        updateProcessingEstimates();
        showNotification('Recommendation applied to settings', 'success');
    }

    // Close modal if open
    document.getElementById('intelligent-recommendation-modal')?.remove();
}

// Monitor intelligent processing progress
function monitorIntelligentProgress() {
    if (!chunkingState.intelligentMode) return;

    const checkInterval = setInterval(() => {
        const totalProcessed = chunkingState.totalSkillsProcessed;
        const target = chunkingState.targetTotal;

        if (totalProcessed >= target) {
            // Processing complete!
            clearInterval(checkInterval);
            completeIntelligentProcessing();
        } else if (!isAssessmentRunning && chunkingState.autoRetry) {
            // Check for failures and retry
            const unprocessedSkills = workflowState.extractedSkills.filter(skill => {
                const skillName = skill.name || skill.skill_name;
                return !chunkingState.accumulatedResults.some(
                    processed => (processed.skill_name || processed.name) === skillName
                );
            });

            if (unprocessedSkills.length > 0) {
                updateProcessingLog(`🔄 Auto-retrying ${unprocessedSkills.length} unprocessed skills...`, 'warning');
                selectNextChunk();
                setTimeout(() => runLangChainAssessment(), 2000);
            }
        }
    }, 3000); // Check every 3 seconds
}

// Complete intelligent processing
function completeIntelligentProcessing() {
    chunkingState.intelligentMode = false;

    updateProcessingLog('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━', 'separator');
    updateProcessingLog(`🎉 INTELLIGENT PROCESSING COMPLETE`, 'success');
    updateProcessingLog(`  ✅ Total Processed: ${chunkingState.accumulatedResults.length} skills`, 'success');
    updateProcessingLog(`  📊 Success Rate: ${Math.round((chunkingState.accumulatedResults.length / chunkingState.targetTotal) * 100)}%`, 'info');
    updateProcessingLog('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━', 'separator');

    // Auto-combine results
    showNotification('Processing complete! Combining results...', 'success');
    setTimeout(() => combineAndFinalize(), 1000);

    // Validate updates after a brief delay
    setTimeout(() => validateAssessmentUpdates(), 2000);
}

// Calculate optimal settings for automatic mode with smart distribution
function calculateOptimalSettings(totalSkills) {
    // For small skill sets, process all at once
    if (totalSkills <= 100) {
        return {
            chunkSize: totalSkills,
            batchSize: Math.min(totalSkills, 50),
            parallel: 1,
            strategy: 'single-batch'
        };
    } else if (totalSkills <= 300) {
        // Split evenly into batches of ~100
        const numBatches = Math.ceil(totalSkills / 100);
        const evenBatchSize = Math.ceil(totalSkills / numBatches);
        return {
            chunkSize: totalSkills,
            batchSize: evenBatchSize,
            parallel: Math.min(numBatches, 2),
            strategy: 'small-parallel'
        };
    } else if (totalSkills <= 650) {
        // Split chunk in half to avoid small leftover batches
        const numBatches = 2;
        const evenBatchSize = Math.ceil(totalSkills / numBatches);
        return {
            chunkSize: totalSkills,
            batchSize: evenBatchSize,
            parallel: numBatches,
            strategy: 'medium-parallel'
        };
    } else {
        // For large sets like 1223, always split in half for optimal processing
        const numChunks = 2;
        const evenChunkSize = Math.ceil(totalSkills / numChunks);
        // Process entire chunk in one batch to avoid small leftovers
        return {
            chunkSize: evenChunkSize,
            batchSize: evenChunkSize,  // Process entire chunk in one batch
            parallel: 1,  // Sequential processing
            strategy: 'large-distributed',
            totalChunks: numChunks,
            explanation: `Processing ${totalSkills} skills in ${numChunks} chunks of ${evenChunkSize} skills each`
        };
    }
}

// Run automatic assessment with retry logic
async function runAutomaticAssessment() {
    console.log('🤖 Running in Automatic Mode');
    // Removed annoying notification about auto mode

    const totalSkills = workflowState.extractedSkills?.length || 0;
    if (totalSkills === 0) {
        showNotification('No skills to assess', 'error');
        return;
    }

    // Calculate optimal distribution upfront
    const optimalPlan = calculateOptimalSettings(totalSkills);

    // Initialize automatic mode state
    chunkingState.intelligentMode = true;
    chunkingState.autoRetry = true;
    chunkingState.targetTotal = totalSkills;
    chunkingState.maxRetries = 3;
    chunkingState.currentRetryAttempt = 0;
    chunkingState.optimalPlan = optimalPlan;
    window.automaticProcessingMode = true;  // Set global flag for automatic mode

    updateProcessingLog('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━', 'separator');
    updateProcessingLog(`  📊 Total skills to process: ${totalSkills}`, 'info');
    updateProcessingLog(`  🎯 Strategy: ${optimalPlan.strategy}`, 'info');

    if (optimalPlan.explanation) {
        updateProcessingLog(`  📋 Plan: ${optimalPlan.explanation}`, 'info');
    } else {
        const batches = Math.ceil(optimalPlan.chunkSize / optimalPlan.batchSize);
        updateProcessingLog(`  📦 Processing in ${batches} batch${batches > 1 ? 'es' : ''} of ~${optimalPlan.batchSize} skills each`, 'info');
    }

    updateProcessingLog(`  🔄 Auto-retry enabled: Up to 3 attempts per batch`, 'info');
    updateProcessingLog(`  ⚡ Parallel processing: ${optimalPlan.parallel} concurrent request${optimalPlan.parallel > 1 ? 's' : ''}`, 'info');
    updateProcessingLog('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━', 'separator');

    // Process all skills with automatic retry
    await processSkillsWithRetry();
}

// Process skills with automatic retry on failures
async function processSkillsWithRetry() {
    // Track which skills have been successfully processed
    const processedSkillNames = new Set(
        chunkingState.accumulatedResults.map(r => r.skill || r.skill_name)
    );

    let remainingSkills = workflowState.extractedSkills.filter(skill => {
        const skillName = skill.name || skill.skill_name;
        return !processedSkillNames.has(skillName);
    });

    if (remainingSkills.length === 0) {
        updateProcessingLog('✅ All skills have been processed successfully!', 'success');
        completeAutomaticProcessing();
        return;
    }

    // Track failed skills for smarter retry
    if (!chunkingState.failedSkills) {
        chunkingState.failedSkills = [];
    }

    // Determine if this is a retry of failed skills
    const isRetry = chunkingState.failedSkills.length > 0 &&
                     chunkingState.failedSkills.length === remainingSkills.length;

    if (isRetry) {
        updateProcessingLog(`🔄 Retrying ${remainingSkills.length} previously failed skills...`, 'warning');
    } else {
        updateProcessingLog(`📦 Processing ${remainingSkills.length} remaining skills...`, 'info');
    }

    // Calculate optimal settings for the remaining skills
    const optimalSettings = calculateOptimalSettings(remainingSkills.length);

    // Log the distribution plan for transparency
    const numBatches = Math.ceil(remainingSkills.length / optimalSettings.batchSize);
    updateProcessingLog(`  📊 Distribution: ${numBatches} batch${numBatches > 1 ? 'es' : ''} × ~${optimalSettings.batchSize} skills`, 'info');

    // Update UI with optimal settings
    if (document.getElementById('chunk-size-input')) {
        document.getElementById('chunk-size-input').value = optimalSettings.chunkSize;
    }
    if (document.getElementById('batch-size-input')) {
        document.getElementById('batch-size-input').value = optimalSettings.batchSize;
    }
    if (document.getElementById('concurrent-batches-input')) {
        document.getElementById('concurrent-batches-input').value = optimalSettings.parallel;
    }

    // Process the chunk
    const chunkEnd = Math.min(optimalSettings.chunkSize, remainingSkills.length);
    const skillsToProcess = remainingSkills.slice(0, chunkEnd);

    // Set chunk configuration
    chunkingState.currentChunk = {
        start: 0,
        end: chunkEnd,
        skillsToProcess: skillsToProcess
    };

    // Clear failed skills before new attempt
    const previousFailedCount = chunkingState.failedSkills.length;
    chunkingState.failedSkills = [];

    // Run the assessment for this chunk
    try {
        // Temporarily disable automatic mode to run normal assessment
        window.automaticProcessingMode = false;
        await runLangChainAssessment();
        window.automaticProcessingMode = true;

        // After assessment completes, check if we need to continue or retry
        setTimeout(() => {
            if (chunkingState.intelligentMode) {
                // Always check for more work in automatic mode
                checkAndRetryFailures();
            }
        }, 2000);  // Reduced delay for faster processing
    } catch (error) {
        console.error('Error in automatic processing:', error);
        updateProcessingLog(`⚠️ Error occurred: ${error.message}`, 'error');

        // Add skills to failed list
        chunkingState.failedSkills = skillsToProcess;

        // Smart retry logic - only retry if we're making progress
        const madeProgress = processedSkillNames.size > 0 ||
                           chunkingState.failedSkills.length < previousFailedCount;

        if (madeProgress && chunkingState.currentRetryAttempt < chunkingState.maxRetries) {
            chunkingState.currentRetryAttempt++;
            updateProcessingLog(`🔄 Retrying (Attempt ${chunkingState.currentRetryAttempt}/${chunkingState.maxRetries})...`, 'warning');
            setTimeout(() => processSkillsWithRetry(), 5000);
        } else {
            updateProcessingLog('❌ Max retries reached or no progress made. Saving partial results...', 'error');
            completeAutomaticProcessing();
        }
    }
}

// Check for failures and retry
async function checkAndRetryFailures() {
    if (!chunkingState.intelligentMode) return;

    const totalProcessed = chunkingState.accumulatedResults.length;
    const targetTotal = chunkingState.targetTotal;

    updateProcessingLog(`📊 Progress: ${totalProcessed}/${targetTotal} skills processed`, 'info');

    if (totalProcessed < targetTotal) {
        // Still have skills to process
        const remainingCount = targetTotal - totalProcessed;

        if (remainingCount > 0) {
            // Calculate chunk information
            const chunkSize = parseInt(document.getElementById('chunk-size-input')?.value || 650);
            const currentChunkNum = Math.floor(totalProcessed / chunkSize) + 1;
            const totalChunks = Math.ceil(targetTotal / chunkSize);

            updateProcessingLog(`━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━`, 'info');
            updateProcessingLog(`🚀 Starting Chunk ${currentChunkNum + 1}/${totalChunks}`, 'info');
            updateProcessingLog(`📊 ${remainingCount} skills remaining...`, 'info');

            showNotification(`Processing chunk ${currentChunkNum + 1}/${totalChunks} (${Math.min(chunkSize, remainingCount)} skills)`, 'info');

            chunkingState.currentRetryAttempt = 0; // Reset retry counter for new chunk
            setTimeout(() => processSkillsWithRetry(), 2000);
        }
    } else {
        // All skills processed
        completeAutomaticProcessing();
    }
}

// Complete automatic processing
function completeAutomaticProcessing() {
    chunkingState.intelligentMode = false;
    window.automaticProcessingMode = false;

    const totalProcessed = chunkingState.accumulatedResults.length;
    const targetTotal = chunkingState.targetTotal;
    const successRate = Math.round((totalProcessed / targetTotal) * 100);

    updateProcessingLog('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━', 'separator');
    updateProcessingLog(`🎉 AUTOMATIC PROCESSING COMPLETE`, 'success');
    updateProcessingLog(`  ✅ Successfully processed: ${totalProcessed}/${targetTotal} skills (${successRate}%)`, 'success');

    // Provide detailed statistics
    if (chunkingState.optimalPlan) {
        const actualBatches = Math.ceil(totalProcessed / (chunkingState.optimalPlan.batchSize || 100));
        updateProcessingLog(`  📊 Batches completed: ${actualBatches}`, 'info');
        updateProcessingLog(`  ⚡ Processing strategy: ${chunkingState.optimalPlan.strategy}`, 'info');
    }

    if (totalProcessed < targetTotal) {
        const failed = targetTotal - totalProcessed;
        updateProcessingLog(`  ⚠️ Failed to process: ${failed} skills`, 'warning');

        // Check if we have specific failed skills tracked
        if (chunkingState.failedSkills && chunkingState.failedSkills.length > 0) {
            updateProcessingLog(`  📝 Failed skills saved for manual retry`, 'info');
            // Store failed skills in localStorage for future retry
            try {
                localStorage.setItem('failed_skills', JSON.stringify(chunkingState.failedSkills));
                updateProcessingLog(`  💾 Failed skills stored in browser for next session`, 'info');
            } catch (e) {
                console.error('Could not save failed skills:', e);
            }
        }

        updateProcessingLog(`  💡 Tip: Click "Run Skills Assessment" again to retry only the failed skills`, 'info');
    } else {
        updateProcessingLog(`  🏆 Perfect run! All skills processed successfully`, 'success');
        // Clear any previously failed skills
        try {
            localStorage.removeItem('failed_skills');
        } catch (e) {
            console.error('Could not clear failed skills:', e);
        }
    }

    updateProcessingLog('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━', 'separator');

    // Update workflow step
    if (typeof updateWorkflowStep === 'function') {
        updateWorkflowStep(6, totalProcessed === targetTotal ? 'completed' : 'partial',
            `Assessment ${totalProcessed === targetTotal ? 'completed' : 'partially completed'}`);
    }

    // Save final results using the existing save functions
    saveChunkingState();

    // Save to server if we have accumulated results
    if (chunkingState.accumulatedResults?.length > 0) {
        const finalData = {
            success: true,
            environment: workflowState.environment || 'unknown',
            total_skills: chunkingState.accumulatedResults.length,
            assessed_skills: chunkingState.accumulatedResults,
            chunks_processed: chunkingState.processedChunks,
            timestamp: new Date().toISOString()
        };
        const filename = `auto_${finalData.environment}_${new Date().toISOString().slice(0, 19).replace(/:/g, '-')}.json`;
        saveAssessmentToServer(finalData, filename).catch(console.error);
    }

    // Show appropriate notification
    if (totalProcessed === targetTotal) {
        showNotification(
            `✅ Perfect! All ${targetTotal} skills assessed successfully!`,
            'success'
        );
    } else {
        showNotification(
            `Automatic processing complete: ${totalProcessed}/${targetTotal} skills assessed (${successRate}%). Click Run again to retry failed skills.`,
            'warning'
        );
    }
}

// Processing strategy functions for the unified interface
function setProcessingStrategy(strategy) {
    const strategies = {
        automatic: {
            chunkSize: 'auto',
            batchSize: 'auto',
            parallel: 'auto',
            mode: 'smart',
            autoRetry: true,
            description: 'Automatically handles all processing with smart chunking and retries'
        },
        conservative: {
            chunkSize: 400,
            batchSize: 100,
            parallel: 1,
            mode: 'sequential'
        },
        balanced: {
            chunkSize: 650,
            batchSize: 650,
            parallel: 2,
            mode: 'parallel'
        },
        aggressive: {
            chunkSize: 1000,
            batchSize: 500,
            parallel: 3,
            mode: 'parallel'
        },
        custom: null // Don't change settings for custom
    };

    // Update button styles
    document.querySelectorAll('.strategy-btn').forEach(btn => {
        if (btn.dataset.strategy === strategy) {
            btn.classList.add('border-blue-500', 'bg-blue-50', 'dark:bg-blue-900/20');
            btn.classList.remove('border-gray-300', 'dark:border-gray-600');
        } else {
            btn.classList.remove('border-blue-500', 'bg-blue-50', 'dark:bg-blue-900/20');
            btn.classList.add('border-gray-300', 'dark:border-gray-600');
        }
    });

    const config = strategies[strategy];
    if (config) {
        // Store automatic mode flag
        window.automaticProcessingMode = (strategy === 'automatic');

        if (strategy === 'automatic') {
            // For automatic mode, calculate optimal settings based on skill count
            const totalSkills = workflowState.extractedSkills?.length || 0;

            if (totalSkills === 0) {
                showNotification('Please load skills first before selecting automatic mode', 'warning');
                return;
            }

            const optimalConfig = calculateOptimalSettings(totalSkills);

            console.log('Automatic mode calculation:', {
                totalSkills,
                optimalConfig
            });

            const chunkSizeInput = document.getElementById('chunk-size-input');
            const batchSizeInput = document.getElementById('batch-size-input');
            const concurrentBatchesInput = document.getElementById('concurrent-batches-input');
            const processingModeSelect = document.getElementById('processing-mode-select');

            if (chunkSizeInput) chunkSizeInput.value = optimalConfig.chunkSize;
            if (batchSizeInput) batchSizeInput.value = optimalConfig.batchSize;
            if (concurrentBatchesInput) concurrentBatchesInput.value = optimalConfig.parallel;
            if (processingModeSelect) processingModeSelect.value = 'sequential';

            showNotification(`Automatic mode: ${totalSkills} skills → ${Math.ceil(totalSkills/optimalConfig.batchSize)} batches of ~${optimalConfig.batchSize} each`, 'success');
        } else {
            // Apply the strategy settings for other modes
            const chunkSizeInput = document.getElementById('chunk-size-input');
            const batchSizeInput = document.getElementById('batch-size-input');
            const concurrentBatchesInput = document.getElementById('concurrent-batches-input');
            const processingModeSelect = document.getElementById('processing-mode-select');

            if (chunkSizeInput) chunkSizeInput.value = config.chunkSize;
            if (batchSizeInput) batchSizeInput.value = config.batchSize;
            if (concurrentBatchesInput) concurrentBatchesInput.value = config.parallel;
            if (processingModeSelect) processingModeSelect.value = config.mode;

            showNotification(`Applied ${strategy} processing strategy`, 'info');
        }

        updateProcessingEstimates();
    } else if (strategy === 'custom') {
        // Show advanced settings for custom configuration
        document.getElementById('advanced-settings')?.classList.remove('hidden');
    }
}

// Toggle advanced settings visibility
function toggleAdvancedSettings() {
    const advancedSettings = document.getElementById('advanced-settings');
    if (advancedSettings) {
        advancedSettings.classList.toggle('hidden');
    }
}

// Update processing estimates based on current configuration
// Sync batch size with chunk size for sequential processing
function syncBatchSizeWithChunkSize() {
    const chunkSizeInput = document.getElementById('chunk-size-input');
    const batchSizeInput = document.getElementById('batch-size-input');

    if (chunkSizeInput && batchSizeInput) {
        // Set batch size to match chunk size for sequential processing
        batchSizeInput.value = chunkSizeInput.value;
    }
}

function updateProcessingEstimates() {
    const totalSkills = workflowState.extractedSkills?.length || 0;
    // Honor user's chunk size setting (450 as shown in screenshot)
    const chunkSize = parseInt(document.getElementById('chunk-size-input')?.value || 450);
    const chunkStart = parseInt(document.getElementById('chunk-start-input')?.value || 1) - 1;
    const batchSize = parseInt(document.getElementById('batch-size-input')?.value || chunkSize);
    const mode = document.getElementById('processing-mode-select')?.value || 'sequential';

    // Calculate selected range
    const selectedEnd = Math.min(chunkStart + chunkSize, totalSkills);
    const selectedSkills = selectedEnd - chunkStart;

    // Update displays
    const selectedRangeEl = document.getElementById('selected-range');
    if (selectedRangeEl) {
        selectedRangeEl.textContent = `${selectedSkills} skills`;
    }

    // Calculate and display chunks required
    const totalChunksRequired = Math.ceil(totalSkills / chunkSize);
    const chunksRequiredEl = document.getElementById('chunks-required');
    if (chunksRequiredEl) {
        chunksRequiredEl.textContent = `${totalChunksRequired} ${totalChunksRequired === 1 ? 'chunk' : 'chunks'}`;
    }

    // Calculate batches
    const batchesPerChunk = Math.ceil(selectedSkills / batchSize);
    const batchesPerChunkEl = document.getElementById('batches-per-chunk');
    if (batchesPerChunkEl) {
        batchesPerChunkEl.textContent = `${batchesPerChunk} batches`;
    }

    // Estimate time (assuming ~1.5 seconds per batch in parallel, 3 seconds in sequential)
    const timePerBatch = mode === 'parallel' ? 1.5 : 3;
    const estimatedSeconds = batchesPerChunk * timePerBatch;
    const estimatedMinutes = Math.ceil(estimatedSeconds / 60);
    const estimatedTimeEl = document.getElementById('estimated-time');
    if (estimatedTimeEl) {
        estimatedTimeEl.textContent = `~${estimatedMinutes} min`;
    }

    // Update overall progress bar if needed
    updateOverallProgress();
}

// Update processing mode display
function updateProcessingMode() {
    const mode = document.getElementById('processing-mode-select')?.value;
    const modeDisplay = document.getElementById('mode-display');
    if (modeDisplay) {
        modeDisplay.textContent = mode === 'smart' ? 'Smart' :
                                  mode === 'parallel' ? 'Parallel' : 'Sequential';
    }
    updateProcessingEstimates();
}

// Update overall progress
function updateOverallProgress() {
    const totalSkills = workflowState.extractedSkills?.length || 0;
    // Use accumulated results count as the true progress
    const processedSkills = chunkingState.accumulatedResults?.length || chunkingState.totalSkillsProcessed || 0;
    const percentage = totalSkills > 0 ? Math.min(100, (processedSkills / totalSkills * 100)) : 0;

    // Update overall progress bar
    const overallProgressBar = document.getElementById('overall-progress-bar');
    const overallProgressText = document.getElementById('overall-progress-text');
    if (overallProgressBar) {
        overallProgressBar.style.width = `${percentage}%`;
    }
    if (overallProgressText) {
        overallProgressText.textContent = `${processedSkills} / ${totalSkills} skills`;
    }

    // Calculate chunk information
    const chunkSize = parseInt(document.getElementById('chunk-size-input')?.value || '650');
    const totalChunks = Math.ceil(totalSkills / chunkSize);
    const completedChunks = Math.floor(processedSkills / chunkSize);
    const currentChunkNum = processedSkills > 0 ? Math.min(totalChunks, completedChunks + (processedSkills % chunkSize > 0 ? 1 : 0)) : 0;

    // Update chunk progress bar (overall chunks)
    const chunkProgressBar = document.getElementById('chunk-progress-bar');
    const chunkProgressText = document.getElementById('chunk-progress-text');
    if (chunkProgressBar && chunkProgressText) {
        const chunkPercentage = totalChunks > 0 ? (completedChunks / totalChunks * 100) : 0;
        chunkProgressBar.style.width = `${chunkPercentage}%`;
        chunkProgressText.textContent = `${completedChunks} / ${totalChunks} chunks`;
    }

    // Update chunk status text
    const chunkStatus = document.getElementById('chunk-status');
    if (chunkStatus) {
        if (currentChunkNum > 0 && currentChunkNum <= totalChunks) {
            chunkStatus.textContent = `Chunk ${currentChunkNum} of ${totalChunks} (${chunkSize} skills per chunk)`;
        } else if (processedSkills >= totalSkills && totalSkills > 0) {
            chunkStatus.textContent = `All ${totalChunks} chunks completed`;
        } else {
            chunkStatus.textContent = totalChunks > 1 ? `Ready to process ${totalChunks} chunks` : '';
        }
    }

    // Also update current chunk progress if we're processing
    updateChunkProgress();


    // Calculate success rate
    const successRate = processedSkills > 0 ?
        Math.round((chunkingState.accumulatedResults.length / processedSkills) * 100) : 0;
    const successRateEl = document.getElementById('success-rate');
    if (successRateEl) successRateEl.textContent = `${successRate}%`;
}

// Update chunk progress (current chunk internal progress)
function updateChunkProgress() {
    // Get current chunk configuration
    const chunkSize = parseInt(document.getElementById('chunk-size-input')?.value || '650');
    const batchSize = parseInt(document.getElementById('batch-size-input')?.value || '650');

    // Always calculate progress based on accumulated results
    const totalSkills = workflowState.extractedSkills?.length || 0;
    const accumulatedCount = chunkingState.accumulatedResults?.length || 0;
    const currentChunkNum = accumulatedCount > 0 ? Math.floor(accumulatedCount / chunkSize) + 1 : (isAssessmentRunning ? 1 : 0);
    const chunkStartIdx = (currentChunkNum - 1) * chunkSize;
    const skillsInCurrentChunk = Math.min(chunkSize, totalSkills - chunkStartIdx);
    const skillsProcessedInChunk = Math.max(0, accumulatedCount - chunkStartIdx);

    // Calculate batches
    const totalBatchesInChunk = Math.ceil(skillsInCurrentChunk / batchSize);
    let completedBatches = 0;
    let currentBatch = 0;
    let batchPercentage = 0;
    let chunkPercentage = 0;

    if (isAssessmentRunning || accumulatedCount > 0) {
        if (skillsProcessedInChunk >= 0 && skillsInCurrentChunk > 0) {
            // Calculate completed batches and current batch
            completedBatches = Math.floor(skillsProcessedInChunk / batchSize);
            currentBatch = skillsProcessedInChunk > 0 ? Math.ceil(skillsProcessedInChunk / batchSize) : (isAssessmentRunning ? 1 : 0);

            // Chunk percentage is based on skills
            chunkPercentage = (skillsProcessedInChunk / skillsInCurrentChunk) * 100;

            // Batch percentage calculation
            if (totalBatchesInChunk === 1) {
                // Single batch: either 0% (not done) or 100% (done)
                batchPercentage = skillsProcessedInChunk >= skillsInCurrentChunk ? 100 :
                                 (isAssessmentRunning ? 50 : 0); // Show 50% while processing
            } else {
                // Multiple batches: show progress through batches
                batchPercentage = (completedBatches / totalBatchesInChunk) * 100;
                // Add partial progress for current batch
                if (currentBatch > completedBatches && currentBatch <= totalBatchesInChunk) {
                    const skillsInCurrentBatch = Math.min(batchSize, skillsInCurrentChunk - (completedBatches * batchSize));
                    const skillsProcessedInCurrentBatch = skillsProcessedInChunk - (completedBatches * batchSize);
                    const currentBatchProgress = skillsProcessedInCurrentBatch / skillsInCurrentBatch;
                    batchPercentage += (currentBatchProgress / totalBatchesInChunk) * 100;
                }
            }
        }
    }

    // Update current chunk progress bar (skills in chunk)
    const chunkProgressBar = document.getElementById('current-chunk-progress-bar');
    const chunkProgressText = document.getElementById('current-chunk-progress-text');

    if (chunkProgressBar) {
        chunkProgressBar.style.width = `${Math.min(100, Math.max(0, chunkPercentage))}%`;
    }
    if (chunkProgressText) {
        chunkProgressText.textContent = `${skillsProcessedInChunk} / ${skillsInCurrentChunk} skills`;
    }

    // Update batch progress bar
    const batchProgressBar = document.getElementById('batch-progress-bar');
    const batchProgressText = document.getElementById('batch-progress-text');

    if (batchProgressBar) {
        batchProgressBar.style.width = `${Math.min(100, Math.max(0, batchPercentage))}%`;
    }
    if (batchProgressText) {
        if (totalBatchesInChunk === 1) {
            batchProgressText.textContent = skillsProcessedInChunk >= skillsInCurrentChunk ? '1 / 1 batch' : '0 / 1 batch';
        } else {
            batchProgressText.textContent = `${completedBatches} / ${totalBatchesInChunk} batches`;
        }
    }

    // Update batch status text
    const batchStatus = document.getElementById('batch-status');
    if (batchStatus) {
        if (totalBatchesInChunk > 1 && currentChunkNum > 0) {
            batchStatus.textContent = `Batch ${currentBatch} of ${totalBatchesInChunk} in current chunk (${batchSize} skills per batch)`;
        } else if (totalBatchesInChunk === 1 && currentChunkNum > 0) {
            batchStatus.textContent = `Processing as single batch (chunk size = batch size = ${chunkSize} skills)`;
        } else {
            batchStatus.textContent = '';
        }
    }
}

// Pause processing (between chunks)
function pauseProcessing() {
    chunkingState.isPaused = true;
    const pauseBtn = document.getElementById('pause-btn');
    const resumeBtn = document.getElementById('resume-btn');
    if (pauseBtn) pauseBtn.classList.add('hidden');
    if (resumeBtn) resumeBtn.classList.remove('hidden');

    showNotification('Processing paused. Will stop after current chunk completes.', 'info');
    updateProcessingLog('⏸️ Processing paused - will stop after current chunk', 'warning');
}

// Resume processing
function resumeProcessing() {
    chunkingState.isPaused = false;
    const pauseBtn = document.getElementById('pause-btn');
    const resumeBtn = document.getElementById('resume-btn');
    if (pauseBtn) pauseBtn.classList.remove('hidden');
    if (resumeBtn) resumeBtn.classList.add('hidden');

    showNotification('Processing resumed', 'success');
    updateProcessingLog('▶️ Processing resumed', 'success');

    // Continue with next chunk if not currently processing
    if (!isAssessmentRunning) {
        selectNextChunk();
        runLangChainAssessment();
    }
}

// Reset processing configuration to defaults
function resetProcessingConfig() {
    // Reset to balanced strategy
    setProcessingStrategy('balanced');

    // Reset chunk position
    const chunkStartInput = document.getElementById('chunk-start-input');
    if (chunkStartInput) chunkStartInput.value = 1;

    // Clear accumulated results with confirmation
    if (chunkingState.accumulatedResults.length > 0) {
        showConfirmModal(
            'Reset Configuration',
            'This will also clear accumulated results. Continue?',
            () => {
                performClearAccumulatedResults();
            }
        );
    }

    updateProcessingEstimates();
    showNotification('Processing configuration reset to defaults', 'info');
}

// Toggle batch configuration panel
function toggleBatchConfig() {
    const details = document.getElementById('batch-config-details');
    const icon = document.getElementById('batch-config-icon');

    if (details.classList.contains('hidden')) {
        details.classList.remove('hidden');
        icon.classList.remove('fa-chevron-down');
        icon.classList.add('fa-chevron-up');
        updateBatchCalculations();
    } else {
        details.classList.add('hidden');
        icon.classList.remove('fa-chevron-up');
        icon.classList.add('fa-chevron-down');
    }
}

// Update batch calculations display
function updateBatchCalculations(skipSave = true) {
    // Check both workflowState.extractedSkills and extractedSkillsData for skills count
    let skillsCount = 0;

    if (workflowState.extractedSkills && workflowState.extractedSkills.length > 0) {
        skillsCount = workflowState.extractedSkills.length;
    } else if (typeof extractedSkillsData !== 'undefined' && extractedSkillsData.length > 0) {
        skillsCount = extractedSkillsData.length;
    }
    // Calculate recommended batch sizes dynamically based on skills count
    // Check the current provider
    const provider = document.getElementById('llm-provider')?.value || 'google';
    let recommendedBatchSize = 800; // default
    let recommendedConcurrent = 2;  // Default

    if (skillsCount > 0) {
        if (provider === 'google') {
            // For Google: Use chunk size for sequential processing
            const chunkSize = parseInt(document.getElementById('chunk-size-input')?.value || 650);
            recommendedBatchSize = chunkSize;
            recommendedConcurrent = 1; // Sequential for Google
        } else {
            // For other providers: also use chunk size for consistency
            const chunkSize = parseInt(document.getElementById('chunk-size-input')?.value || 650);
            recommendedBatchSize = chunkSize;
            recommendedConcurrent = 1; // Sequential processing by default

            // Set minimum and maximum bounds
            if (recommendedBatchSize < 50) {
                recommendedBatchSize = 50;
                recommendedConcurrent = 1; // Only need 1 worker for small sets
            } else if (recommendedBatchSize > 1000) {
                recommendedBatchSize = 1000; // Cap at 1000 to avoid token limits
                recommendedConcurrent = Math.min(Math.ceil(skillsCount / 1000), 4);
            }

            // For very large skill sets, adjust concurrency
            if (skillsCount > 2000) {
                recommendedConcurrent = 3;
                recommendedBatchSize = Math.ceil(skillsCount / 3 / 50) * 50;
            }
        }
    }

    // Get current values or use recommended
    const batchSizeInput = document.getElementById('batch-size-input');
    const concurrentBatchesInput = document.getElementById('concurrent-batches-input');

    let batchSize = parseInt(batchSizeInput.value) || recommendedBatchSize;
    let concurrentBatches = parseInt(concurrentBatchesInput.value) || recommendedConcurrent;

    // Don't override user's manual changes - only set if at HTML defaults
    if (skillsCount > 0 && batchSizeInput.value == '800' && concurrentBatchesInput.value == '2') {
        // User hasn't changed from defaults, so apply recommendations
        batchSize = recommendedBatchSize;
        concurrentBatches = recommendedConcurrent;
        batchSizeInput.value = recommendedBatchSize;
        concurrentBatchesInput.value = recommendedConcurrent;
    }

    batchConfig.skillsCount = skillsCount;
    batchConfig.batchSize = batchSize;
    batchConfig.concurrentBatches = concurrentBatches;

    const totalBatches = Math.ceil(skillsCount / batchSize);
    const estimatedMinutes = Math.ceil((totalBatches / concurrentBatches) * 1.5); // ~1.5 min per batch set

    // Update NEW skills count element (completely different ID)
    const skillsCountNEW = document.getElementById('skills-count-NEW');
    if (skillsCountNEW && skillsCount > 0) {
        skillsCountNEW.textContent = `${skillsCount} skills ready`;
    }
    const estimatedBatchesEl = document.getElementById('estimated-batches');
    const estimatedTimeEl = document.getElementById('estimated-time');
    if (estimatedBatchesEl) estimatedBatchesEl.textContent = totalBatches;
    if (estimatedTimeEl) estimatedTimeEl.textContent = `~${estimatedMinutes} min`;

    // Update batch calculation with recommendations
    const batchCalculationElement = document.getElementById('batch-calculation');
    if (batchCalculationElement && skillsCount > 0) {
        batchCalculationElement.innerHTML = `
            <i class="fas fa-calculator mr-1"></i>Estimated batches: <span id="estimated-batches">${totalBatches}</span> | Processing time: <span id="estimated-time">~${estimatedMinutes} min</span>
            <br><small class="text-green-600"><i class="fas fa-lightbulb mr-1"></i>Recommended: ${recommendedBatchSize} batch size, ${recommendedConcurrent} concurrent (optimized for ${skillsCount} skills)</small>
        `;
    }

    // Auto-save configuration if skills were loaded (unless this is a temporary reduction)
    if (skillsCount > 0 && skipSave !== false && !window.temporaryBatchReduction) {
        localStorage.setItem('batchConfig', JSON.stringify(batchConfig));
    }

    // Clear temporary reduction flag after use
    if (window.temporaryBatchReduction && skipSave !== false) {
        window.temporaryBatchReduction = false;
    }

    // Update the assessment status to show skills count
    const progressDetails = document.getElementById('overall-progress-details');
    if (progressDetails && skillsCount > 0) {
        progressDetails.innerHTML = `<span class="text-green-600 font-semibold"><i class="fas fa-check-circle mr-1"></i>Ready! ${skillsCount} skills auto-loaded into prompt. Click "Run Skills Assessment" to begin.</span>`;
    }
}

// Update skills count when skills are extracted
function updateSkillsCount() {
    // Check both workflowState.extractedSkills and extractedSkillsData for skills count
    let skillsCount = 0;
    if (workflowState.extractedSkills && workflowState.extractedSkills.length > 0) {
        skillsCount = workflowState.extractedSkills.length;
    } else if (typeof extractedSkillsData !== 'undefined' && extractedSkillsData.length > 0) {
        skillsCount = extractedSkillsData.length;
    }

    // Update the batch config display
    const skillsCountDisplay = document.getElementById('skills-count-display');
    if (skillsCountDisplay) {
        skillsCountDisplay.textContent = `${skillsCount} skills ready`;
    }

    // Always update batch calculations to ensure Google batch size is correct
    updateBatchCalculations();

    // For Google, sync batch size with chunk size
    const provider = document.getElementById('llm-provider')?.value;
    if (provider === 'google' && skillsCount > 0) {
        // Use chunk size as batch size for sequential processing
        syncBatchSizeWithChunkSize();
    }

    // Update the main status display to be more prominent
    const progressDetails = document.getElementById('overall-progress-details');
    if (progressDetails) {
        if (skillsCount > 0) {
            const batchSize = parseInt(document.getElementById('batch-size-input').value) || 800;
            const totalBatches = Math.ceil(skillsCount / batchSize);
            progressDetails.innerHTML = `<i class="fas fa-list-check mr-1"></i><strong>${skillsCount} skills</strong> ready for assessment (${totalBatches} batches planned)`;
        } else {
            progressDetails.innerHTML = 'Ready to start assessment...';
        }
    }
}

// Save batch configuration
function updateBatchConfig() {
    const batchSize = parseInt(document.getElementById('batch-size-input').value);
    const concurrentBatches = parseInt(document.getElementById('concurrent-batches-input').value);
    const provider = document.getElementById('llm-provider')?.value || 'google';

    // Auto-adjust for Google if needed - BUT respect chunk-based processing
    const chunkSize = parseInt(document.getElementById('chunk-size-input')?.value || 0);
    const isChunkBasedProcessing = chunkSize > 0 && batchSize === chunkSize;

    if (provider === 'google' && batchSize > 100 && !isChunkBasedProcessing) {
        // Only auto-adjust if we're NOT doing chunk-based processing
        console.log(`Google: Limiting batch size from ${batchSize} to 100 to avoid token limits`);
        document.getElementById('batch-size-input').value = 100;
        updateProcessingLog(`⚠️ Google: Auto-adjusted batch size to 100 (token limit safety)`, 'warning');
    } else if (provider === 'google' && batchSize > 100 && isChunkBasedProcessing) {
        // For chunk-based processing, just show a warning but don't change
        updateProcessingLog(`⚠️ Note: Using chunk size ${batchSize} for Google. Monitor for potential token limits.`, 'info');
    }

    // Validate inputs
    if (batchSize < 10 || batchSize > 5000) {
        showNotification('Batch size must be between 10 and 5000', 'error');
        return;
    }

    if (concurrentBatches < 1 || concurrentBatches > 10) {
        showNotification('Concurrent batches must be between 1 and 10', 'error');
        return;
    }

    // Save to global config
    batchConfig.batchSize = batchSize;
    batchConfig.concurrentBatches = concurrentBatches;
    batchConfig.processingMode = document.getElementById('processing-mode-select').value;

    // Save to localStorage for persistence
    localStorage.setItem('batchConfig', JSON.stringify(batchConfig));

    // Reset assessment state to enable Run button
    isAssessmentRunning = false;
    assessmentController = null;
    updateAssessmentButtonStates(false);

    updateBatchCalculations();
    showNotification('Batch configuration saved successfully', 'success');
}

// Reset batch configuration to defaults
function resetBatchConfig() {
    const provider = document.getElementById('llm-provider')?.value || 'google';
    const chunkSize = parseInt(document.getElementById('chunk-size-input')?.value || 650);

    // Set provider-specific defaults - always use chunk size as batch size for sequential processing
    let defaultBatchSize, defaultConcurrency, defaultMode;
    if (provider === 'google') {
        // For Google: use chunk size for sequential processing
        defaultBatchSize = chunkSize;
        defaultConcurrency = 1;
        defaultMode = 'sequential';
    } else {
        // Other providers: also default to chunk size for consistency
        defaultBatchSize = chunkSize;
        defaultConcurrency = 1;
        defaultMode = 'sequential';
    }

    document.getElementById('batch-size-input').value = defaultBatchSize;
    document.getElementById('concurrent-batches-input').value = defaultConcurrency;
    document.getElementById('processing-mode-select').value = defaultMode;

    batchConfig.batchSize = defaultBatchSize;
    batchConfig.concurrentBatches = defaultConcurrency;
    batchConfig.processingMode = defaultMode;

    localStorage.removeItem('batchConfig');
    updateBatchCalculations();
    showNotification(`Batch configuration reset to defaults (${defaultBatchSize}/1/sequential)`, 'success');
}

// Load batch configuration from localStorage on page load
function loadBatchConfig() {
    try {
        const saved = localStorage.getItem('batchConfig');
        const chunkSize = parseInt(document.getElementById('chunk-size-input')?.value || 650);

        if (saved) {
            const config = JSON.parse(saved);

            // Check for ANY non-sequential defaults and force update
            const hasOldDefaults = (
                config.batchSize === 100 ||
                config.batchSize === 300 ||
                config.batchSize === 800 ||
                config.concurrentBatches !== 1 ||
                config.processingMode !== 'sequential'
            );

            if (hasOldDefaults) {
                // Clear old config and use new defaults
                console.log('FORCE CLEARING: Old batch config detected with parallel mode or multiple batches');
                localStorage.removeItem('batchConfig');

                // Set new sequential defaults
                document.getElementById('batch-size-input').value = chunkSize;
                document.getElementById('concurrent-batches-input').value = 1;
                document.getElementById('processing-mode-select').value = 'sequential';

                batchConfig = {
                    batchSize: chunkSize,
                    concurrentBatches: 1,
                    processingMode: 'sequential',
                    skillsCount: 0
                };

                // Save the new config
                localStorage.setItem('batchConfig', JSON.stringify(batchConfig));
            } else {
                // Use saved config
                document.getElementById('batch-size-input').value = config.batchSize;
                document.getElementById('concurrent-batches-input').value = config.concurrentBatches || 1;
                document.getElementById('processing-mode-select').value = config.processingMode || 'sequential';
                batchConfig = { ...batchConfig, ...config };
            }
        } else {
            // No saved config - sync batch size with chunk size and use sequential defaults
            syncBatchSizeWithChunkSize();
            document.getElementById('concurrent-batches-input').value = 1;
            document.getElementById('processing-mode-select').value = 'sequential';

            batchConfig = {
                batchSize: chunkSize,
                concurrentBatches: 1,
                processingMode: 'sequential',
                skillsCount: 0
            };
        }
    } catch (e) {
        console.warn('Failed to load batch config:', e);
        // On error, sync batch size with chunk size
        syncBatchSizeWithChunkSize();
    }
}

// Auto-update calculations when inputs change
document.addEventListener('DOMContentLoaded', function() {
    // Load saved config UNLESS it's Google (use optimized defaults)
    const provider = document.getElementById('llm-provider')?.value;
    if (provider !== 'google') {
        loadBatchConfig();
    } else {
        // Ensure Google defaults are set - use chunk size as batch size
        const batchSizeInput = document.getElementById('batch-size-input');
        const concurrentBatchesInput = document.getElementById('concurrent-batches-input');
        if (batchSizeInput) {
            // Use chunk size as batch size for sequential processing
            const chunkSize = parseInt(document.getElementById('chunk-size-input')?.value || 650);
            batchSizeInput.value = chunkSize;
        }
        if (concurrentBatchesInput) {
            concurrentBatchesInput.value = 1;
        }
    }

    // Add event listeners for auto-calculation
    const batchSizeInput = document.getElementById('batch-size-input');
    const concurrentBatchesInput = document.getElementById('concurrent-batches-input');
    const providerSelect = document.getElementById('llm-provider');

    if (batchSizeInput) {
        batchSizeInput.addEventListener('input', updateBatchCalculations);
    }

    if (concurrentBatchesInput) {
        concurrentBatchesInput.addEventListener('input', updateBatchCalculations);
    }

    // Update batch config when provider changes
    if (providerSelect) {
        providerSelect.addEventListener('change', function() {
            const provider = this.value;

            // Auto-adjust batch size for Google to match chunk size
            if (provider === 'google') {
                // Sync batch size with chunk size for sequential processing
                syncBatchSizeWithChunkSize();
                const chunkSize = parseInt(document.getElementById('chunk-size-input')?.value || 650);
                updateProcessingLog(`⚠️ Google: Using batch size ${chunkSize} (matching chunk size for sequential processing)`, 'info');
            }

            updateBatchCalculations();
        });
    }

    // Reset assessment state on page load (in case of refresh during assessment)
    isAssessmentRunning = false;
    assessmentController = null;
    updateAssessmentButtonStates(false);

    // Also reset when API key is saved or changed
    window.resetAssessmentState = function() {
        isAssessmentRunning = false;
        assessmentController = null;
        updateAssessmentButtonStates(false);
        console.log('Assessment state reset - Run button should be enabled');
    };
});

// Stop LangChain Assessment
function stopLangChainAssessment() {
    if (!isAssessmentRunning) {
        showNotification('No assessment is currently running', 'warning');
        return;
    }

    // Confirm stop action with modal
    showConfirmModal(
        'Stop Assessment',
        `Are you sure you want to stop the current assessment? ${chunkingState.accumulatedResults?.length || 0} skills have been processed so far and will be saved.`,
        () => {
            if (assessmentController) {
                assessmentController.abort();
            }

            // Ensure assessment state is properly reset
            isAssessmentRunning = false;
            assessmentController = null;
            updateAssessmentButtonStates(false);

            // Update status to show stopped with accumulated results
            const statusEl = document.getElementById('overall-progress-details');
            if (statusEl) {
                const accumulated = chunkingState.accumulatedResults?.length || 0;
                if (accumulated > 0) {
                    statusEl.innerHTML = `<span class="text-yellow-600"><i class="fas fa-pause-circle mr-1"></i>Assessment stopped. ${accumulated} skills saved. Click "Next Chunk" to continue.</span>`;
                } else {
                    statusEl.innerHTML = `<span class="text-gray-600"><i class="fas fa-stop-circle mr-1"></i>Assessment stopped.</span>`;
                }
            }

            // Stop any running intervals
            if (window.progressInterval) {
                clearInterval(window.progressInterval);
                window.progressInterval = null;
            }

            // Hide any spinners
            const statusElements = document.querySelectorAll('[id*="status"]');
            statusElements.forEach(el => {
                if (el.innerHTML.includes('fa-spinner')) {
                    el.innerHTML = '<span class="text-gray-600">Assessment stopped</span>';
                }
            });

            showNotification('Assessment stopped successfully', 'info');
        }
    );
}

// Update button states during assessment
function updateAssessmentButtonStates(isRunning) {
    const runBtn = document.getElementById('run-assessment-btn');
    const stopBtn = document.getElementById('stop-assessment-btn');

    if (runBtn && stopBtn) {
        if (isRunning) {
            runBtn.disabled = true;
            runBtn.classList.add('opacity-50', 'cursor-not-allowed');
            stopBtn.classList.remove('hidden');
            stopBtn.disabled = false;
        } else {
            runBtn.disabled = false;
            runBtn.classList.remove('opacity-50', 'cursor-not-allowed');
            stopBtn.classList.add('hidden');
            stopBtn.disabled = true;
        }
    }
}

// Export batch configuration functions
window.toggleBatchConfig = toggleBatchConfig;
window.updateBatchCalculations = updateBatchCalculations;
window.updateSkillsCount = updateSkillsCount;
window.updateBatchConfig = updateBatchConfig;
window.resetBatchConfig = resetBatchConfig;
window.loadBatchConfig = loadBatchConfig;

// Export assessment control functions
window.stopLangChainAssessment = stopLangChainAssessment;
window.updateAssessmentButtonStates = updateAssessmentButtonStates;

// ========================================
// VALIDATION SYSTEM
// ========================================

// Validate assessment updates by fetching current state from backend
async function validateAssessmentUpdates() {
    updateProcessingLog('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━', 'separator');
    updateProcessingLog('🔍 STARTING VALIDATION', 'info');

    try {
        // Get accumulated results from local storage
        const assessedSkills = chunkingState.accumulatedResults ||
                              JSON.parse(localStorage.getItem('accumulated_skills') || '[]');

        if (assessedSkills.length === 0) {
            updateProcessingLog('⚠️ No assessed skills to validate', 'warning');
            return;
        }

        updateProcessingLog(`📊 Validating ${assessedSkills.length} assessed skills...`, 'info');

        // Fetch current skills from backend (simulate getting from Eightfold API)
        const response = await fetch('/api/skills/current', {
            method: 'GET',
            headers: {
                'Content-Type': 'application/json'
            }
        });

        let backendSkills = [];
        if (response.ok) {
            const data = await response.json();
            backendSkills = data.skills || [];
        } else {
            // If no endpoint exists, use original extracted skills as baseline
            backendSkills = workflowState.extractedSkills || [];
        }

        // Create maps for easy comparison
        const assessedMap = new Map();
        assessedSkills.forEach(skill => {
            const name = skill.skill_name || skill.name;
            assessedMap.set(name, skill);
        });

        const backendMap = new Map();
        backendSkills.forEach(skill => {
            const name = skill.skill_name || skill.name;
            backendMap.set(name, skill);
        });

        // Validation results
        const validationResults = {
            total: assessedSkills.length,
            validated: 0,
            failed: 0,
            missing: 0,
            mismatched: 0,
            failures: []
        };

        // Check each assessed skill
        assessedSkills.forEach(assessedSkill => {
            const skillName = assessedSkill.skill_name || assessedSkill.name;
            const backendSkill = backendMap.get(skillName);

            if (!backendSkill) {
                validationResults.missing++;
                validationResults.failures.push({
                    skill: skillName,
                    reason: 'Skill not found in backend',
                    assessed: assessedSkill,
                    backend: null
                });
            } else if (backendSkill.proficiency !== assessedSkill.proficiency) {
                // Check if proficiency matches
                const assessedProf = assessedSkill.proficiency;
                const backendProf = backendSkill.proficiency;

                if (!backendProf || backendProf === null) {
                    // Backend hasn't been updated yet
                    validationResults.failed++;
                    validationResults.failures.push({
                        skill: skillName,
                        reason: 'Update not saved to backend',
                        assessed: assessedProf,
                        backend: backendProf
                    });
                } else if (assessedProf !== backendProf) {
                    validationResults.mismatched++;
                    validationResults.failures.push({
                        skill: skillName,
                        reason: 'Proficiency mismatch',
                        assessed: assessedProf,
                        backend: backendProf
                    });
                }
            } else {
                validationResults.validated++;
            }
        });

        // Display validation results
        displayValidationResults(validationResults);

    } catch (error) {
        console.error('Validation error:', error);
        updateProcessingLog(`❌ Validation failed: ${error.message}`, 'error');
    }
}

// Display validation results with details
function displayValidationResults(results) {
    updateProcessingLog('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━', 'separator');

    const successRate = Math.round((results.validated / results.total) * 100);

    if (results.validated === results.total) {
        updateProcessingLog('✅ VALIDATION SUCCESSFUL', 'success');
        updateProcessingLog(`  ✓ All ${results.total} skills validated successfully`, 'success');
        updateProcessingLog(`  ✓ 100% success rate`, 'success');
    } else {
        updateProcessingLog('⚠️ VALIDATION COMPLETED WITH ISSUES', 'warning');
        updateProcessingLog(`  📊 Total Skills: ${results.total}`, 'info');
        updateProcessingLog(`  ✅ Validated: ${results.validated} (${successRate}%)`, 'success');

        if (results.failed > 0) {
            updateProcessingLog(`  ❌ Not Saved: ${results.failed}`, 'error');
        }
        if (results.missing > 0) {
            updateProcessingLog(`  ⚠️ Missing: ${results.missing}`, 'warning');
        }
        if (results.mismatched > 0) {
            updateProcessingLog(`  🔄 Mismatched: ${results.mismatched}`, 'warning');
        }
    }

    // Show failed updates if any
    if (results.failures.length > 0) {
        showFailedUpdates(results.failures);
    }

    updateProcessingLog('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━', 'separator');
}

// Show detailed information about failed updates
function showFailedUpdates(failures) {
    updateProcessingLog('', 'separator');
    updateProcessingLog('📋 FAILED UPDATE DETAILS:', 'warning');

    // Group failures by reason
    const groupedFailures = {};
    failures.forEach(failure => {
        if (!groupedFailures[failure.reason]) {
            groupedFailures[failure.reason] = [];
        }
        groupedFailures[failure.reason].push(failure);
    });

    // Display grouped failures
    Object.entries(groupedFailures).forEach(([reason, failureList]) => {
        updateProcessingLog(``, 'info');
        updateProcessingLog(`  ${reason} (${failureList.length} skills):`, 'warning');

        // Show first 5 examples
        const examples = failureList.slice(0, 5);
        examples.forEach(failure => {
            const details = failure.assessed ?
                `Assessed: ${failure.assessed}, Backend: ${failure.backend || 'null'}` :
                'Not found in backend';
            updateProcessingLog(`    • ${failure.skill}: ${details}`, 'error');
        });

        if (failureList.length > 5) {
            updateProcessingLog(`    ... and ${failureList.length - 5} more`, 'info');
        }
    });

    // Add retry button for failed updates
    const retryBtn = createRetryValidationButton(failures);
    if (retryBtn) {
        document.getElementById('processing-log').appendChild(retryBtn);
    }
}

// Create retry button for failed validations
function createRetryValidationButton(failures) {
    const failedSkills = failures.map(f => f.skill);

    const retryDiv = document.createElement('div');
    retryDiv.className = 'mt-3 p-3 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-300 dark:border-yellow-700 rounded-lg';
    retryDiv.innerHTML = `
        <div class="flex items-center justify-between">
            <div>
                <div class="font-semibold text-yellow-800 dark:text-yellow-200">
                    <i class="fas fa-sync-alt mr-2"></i>
                    ${failures.length} Skills Failed Validation
                </div>
                <div class="text-sm text-yellow-600 dark:text-yellow-400 mt-1">
                    Click to retry saving these skills to the backend
                </div>
            </div>
            <button onclick="retryFailedValidations(${JSON.stringify(failedSkills).replace(/"/g, '&quot;')})"
                    class="px-4 py-2 bg-yellow-600 text-white rounded-lg hover:bg-yellow-700 transition-colors">
                <i class="fas fa-redo mr-2"></i>Retry Failed Updates
            </button>
        </div>
    `;

    return retryDiv;
}

// Retry saving failed validations
async function retryFailedValidations(failedSkillNames) {
    updateProcessingLog('🔄 Retrying failed updates...', 'info');

    // Get the assessed skills for the failed ones
    const assessedSkills = chunkingState.accumulatedResults ||
                          JSON.parse(localStorage.getItem('accumulated_skills') || '[]');

    const skillsToRetry = assessedSkills.filter(skill => {
        const skillName = skill.skill_name || skill.name;
        return failedSkillNames.includes(skillName);
    });

    if (skillsToRetry.length === 0) {
        updateProcessingLog('⚠️ No skills to retry', 'warning');
        return;
    }

    // Simulate sending updates to backend
    updateProcessingLog(`📤 Sending ${skillsToRetry.length} skill updates to backend...`, 'info');

    try {
        // In real implementation, this would call the Eightfold API
        const response = await fetch('/api/skills/update', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                skills: skillsToRetry,
                environment: workflowState.currentEnvironment
            })
        });

        if (response.ok) {
            updateProcessingLog(`✅ Successfully updated ${skillsToRetry.length} skills`, 'success');

            // Re-run validation
            setTimeout(() => validateAssessmentUpdates(), 1000);
        } else {
            const error = await response.text();
            updateProcessingLog(`❌ Failed to update skills: ${error}`, 'error');
        }
    } catch (error) {
        updateProcessingLog(`❌ Error updating skills: ${error.message}`, 'error');
    }
}

// Export validation functions
window.validateAssessmentUpdates = validateAssessmentUpdates;
window.retryFailedValidations = retryFailedValidations;

// Start Over Workflow - Clear all data and refresh
function startOverWorkflow() {
    showConfirmModal(
        'Start Over',
        'This will clear all workflow data, including saved assessments, accumulated results, and API configurations. Are you sure you want to start over?',
        () => {
            // Clear all localStorage items related to the workflow
            const keysToRemove = [
                'accumulated_skills',
                'chunkingState',
                'workflowSkills',
                'workflowSkillsCount',
                'batchConfig',
                'workflowState',
                'extractedSkills',
                'assessment_skills',
                'assessment_history',
                'api_keys',
                'eightfold_token',
                'eightfold_refresh_token',
                'token_expiry',
                'selectedRole'
            ];

            keysToRemove.forEach(key => {
                localStorage.removeItem(key);
            });

            // Stop any running assessments
            if (isAssessmentRunning && assessmentController) {
                assessmentController.abort();
            }

            // Reset all state variables
            isAssessmentRunning = false;
            assessmentController = null;
            workflowState = {
                authenticated: false,
                rolesLoaded: false,
                skillsLoaded: false,
                roleSelected: false,
                apiKeysConfigured: false,
                extractedSkills: [],
                assessmentResults: null,
                currentEnvironment: 'eightfold_sandbox',
                currentStep: 1,
                proficiencyLevels: ['Novice', 'Developing', 'Intermediate', 'Advanced', 'Expert']
            };
            chunkingState = {
                accumulatedResults: [],
                currentChunkStart: 1,
                processedChunks: 0,
                totalSkillsProcessed: 0
            };

            // Clear any intervals
            if (window.progressInterval) {
                clearInterval(window.progressInterval);
                window.progressInterval = null;
            }

            showNotification('Workflow cleared. Refreshing page...', 'info');

            // Refresh the page after a short delay
            setTimeout(() => {
                window.location.reload();
            }, 1000);
        }
    );
}

// Export the function
window.startOverWorkflow = startOverWorkflow;

