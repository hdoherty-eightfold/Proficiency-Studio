// Function to replay the last skills request
async function replayLastSkillsRequest() {
    if (!workflowState.skillsRequest) {
        showNotification('No previous request to replay', 'error');
        return;
    }
    
    showNotification('Replaying API request...', 'info');
    
    try {
        // Replay the direct API request
        const request = workflowState.skillsRequest;
        const response = await fetch(request.url, {
            method: request.method,
            headers: request.headers
        });
        
        const result = await response.json();
        
        // Show the curl command in a modal
        if (result.curl_command) {
            const curlModal = `
                <div class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50" id="curl-modal">
                    <div class="bg-white rounded-lg p-6 max-w-4xl w-full mx-4">
                        <h3 class="text-lg font-bold mb-4">Eightfold API Request Details</h3>
                        <div class="mb-4">
                            <h4 class="font-semibold mb-2">Endpoint:</h4>
                            <code class="bg-gray-100 p-2 rounded block">${result.eightfold_endpoint}</code>
                        </div>
                        <div class="mb-4">
                            <h4 class="font-semibold mb-2">Status:</h4>
                            <span class="${result.status_code === 200 ? 'text-green-600' : 'text-red-600'} font-bold">
                                ${result.status_code} ${result.success ? 'Success' : 'Failed'}
                            </span>
                        </div>
                        <div class="mb-4">
                            <h4 class="font-semibold mb-2">Curl Command:</h4>
                            <pre class="bg-gray-900 text-white p-4 rounded overflow-x-auto text-sm">${result.curl_command}</pre>
                        </div>
                        <div class="mb-4">
                            <h4 class="font-semibold mb-2">Response:</h4>
                            <pre class="bg-gray-100 p-4 rounded overflow-auto max-h-64 text-xs">${JSON.stringify(result.data, null, 2)}</pre>
                        </div>
                        <button onclick="document.getElementById('curl-modal').remove()" 
                                class="bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600">
                            Close
                        </button>
                    </div>
                </div>
            `;
            document.body.insertAdjacentHTML('beforeend', curlModal);
        }
        
        showNotification(`Request replayed - Status: ${result.status_code}`, result.success ? 'success' : 'error');
    } catch (error) {
        showNotification('Error replaying request: ' + error.message, 'error');
    }
}

// Preset API keys - Currently only Google is supported
const PRESET_KEYS = {
    google: "your-google-api-key"
};

// Toggle between preset and custom key input
function toggleKeySource() {
    const source = document.getElementById('key-source').value;
    const presetSection = document.getElementById('preset-keys-section');
    const customSection = document.getElementById('custom-key-section');
    
    if (source === 'preset') {
        presetSection.classList.remove('hidden');
        customSection.classList.add('hidden');
    } else {
        presetSection.classList.add('hidden');
        customSection.classList.remove('hidden');
    }
}

// Load a preset key
function loadPresetKey(provider) {
    const key = PRESET_KEYS[provider];
    if (key) {
        // Set the provider dropdown if it exists
        const providerDropdown = document.getElementById('llm-provider');
        if (providerDropdown) {
            providerDropdown.value = provider;
            updateModelSelection();
        }
        
        // Store the key temporarily (not in the input field for security)
        workflowState.currentApiKey = key;
        workflowState.keySource = 'preset';
        
        
        // Preset key loaded silently - no notification needed
    } else {
        showNotification(`No preset key available for ${provider}`, 'warning');
    }
}


// Toggle between preset and custom key methods
function toggleKeyMethod() {
    const method = document.getElementById('key-method').value;
    const customSection = document.getElementById('custom-key-section');
    
    if (method === 'custom') {
        // Show custom key input
        customSection.classList.remove('hidden');
        customSection.style.display = 'block';
    } else {
        // Hide custom key input (for preset mode)
        customSection.classList.add('hidden');
        customSection.style.display = 'none';
    }
}

// Test Google Gemini connection specifically
async function testGeminiConnection() {
    const provider = document.getElementById('llm-provider').value;
    const model = document.getElementById('llm-model-select').value;
    const methodElement = document.getElementById('key-method') || document.getElementById('key-source');
    const method = methodElement ? methodElement.value : 'custom';
    let apiKey = '';
    
    if (method === 'preset') {
        // Try to auto-load preset key if not already loaded
        if (!workflowState.currentApiKey && PRESET_KEYS[provider]) {
            loadPresetKey(provider);
        }
        apiKey = workflowState.currentApiKey;
    } else if (method === 'custom') {
        apiKey = document.getElementById('llm-api-key').value;
    }
    
    if (!apiKey) {
        showNotification('Please enter an API key first', 'error');
        return;
    }
    
    if (!model) {
        showNotification('Please select a Gemini model first', 'error');
        return;
    }
    
    const resultsDiv = document.getElementById('llm-test-results');
                    resultsDiv.innerHTML = `
        <div class="flex items-center text-blue-600">
            <i class="fas fa-spinner fa-spin mr-2"></i>
            Testing connection to ${model}...
            <div class="text-xs text-yellow-600 dark:text-yellow-400 mt-1">
                <i class="fas fa-exclamation-triangle mr-1"></i>
                Note: This test counts against your API rate limit (2 requests/minute for free tier)
            </div>
        </div>
    `;
    
    try {
        const response = await fetch('/api/test-gemini-connection', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                api_key: apiKey,
                model: model,
                provider: provider
            })
        });
        
        const result = await response.json();
        
        if (response.ok && result.success) {
            // Prepare the test details data
            const testDetails = {
                request: {
                    url: '/api/test-gemini-connection',
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: {api_key: apiKey.substring(0, 10) + '...', model: model, provider: provider}
                },
                response: result
            };
            
            resultsDiv.innerHTML = `
                <div class="text-green-600">
                    <i class="fas fa-check-circle mr-2"></i>
                    <strong>Connected!</strong> Model: ${result.model}
                    <button onclick="showApiTestDetails('${btoa(JSON.stringify(testDetails))}')" class="ml-3 text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded hover:bg-blue-200">
                        <i class="fas fa-code mr-1"></i>View Test JSON
                    </button>
                </div>
            `;
            
            // Save the working configuration
            workflowState.currentApiKey = apiKey;
            workflowState.currentProvider = provider;
            workflowState.currentModel = model;
            
            // Update Step 4 status
            updateStep4Status('success', `Connected to ${model}`);
            
            // Show success notification
            showNotification('Gemini connection test successful!', 'success');
        } else {
            throw new Error(result.error || 'Connection test failed');
        }
    } catch (error) {
        // Prepare failure details for popup
        const failureDetails = {
            request: {
                url: '/api/test-gemini-connection',
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: {
                    api_key: apiKey.substring(0, 10) + '...',
                    model: model,
                    provider: provider
                }
            },
            response: {
                success: false,
                error: error.message,
                debug_info: result?.debug_info || {
                    error_type: 'NetworkError',
                    original_error: error.message,
                    attempted_models: result?.attempted_models || [model],
                    request_details: {
                        provider: provider,
                        original_model: model,
                        api_key_provided: apiKey && apiKey.length > 10
                    }
                }
            }
        };
        
        resultsDiv.innerHTML = `
            <div class="text-red-600">
                <i class="fas fa-times-circle mr-2"></i>
                <strong>Failed:</strong> ${error.message}
                <button onclick="showApiTestDetails('${btoa(JSON.stringify(failureDetails))}')" class="ml-3 text-xs bg-red-100 text-red-700 px-2 py-1 rounded hover:bg-red-200">
                    <i class="fas fa-bug mr-1"></i>View Error JSON
                </button>
            </div>
        `;
        
        // Failure details available via "View Debug Details" button
        
        showNotification('Gemini connection test failed', 'error');
    }
}

// Function to show API test details in a popup
function showApiTestDetails(encodedData) {
    try {
        const data = JSON.parse(atob(encodedData));
        
        // Create a modal to show the request/response details
        const modal = document.createElement('div');
        modal.className = 'fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50';
        modal.innerHTML = `
            <div class="rounded-lg p-6 max-w-4xl max-h-screen overflow-auto" style="width: 90%; height: 80%; background-color: #1e293b; color: #e2e8f0;">
                <div class="flex justify-between items-center mb-4">
                    <h3 class="text-lg font-bold text-white">
                        <i class="fas fa-exchange-alt mr-2 text-blue-400"></i>
                        Gemini API Test Details
                    </h3>
                    <button onclick="this.closest('.fixed').remove()" class="text-gray-400 hover:text-gray-200">
                        <i class="fas fa-times text-xl"></i>
                    </button>
                </div>
                
                <!-- Request Section -->
                <div class="mb-6">
                    <h4 class="text-md font-semibold mb-3 flex items-center" style="color: #3b82f6;">
                        <i class="fas fa-arrow-up mr-2"></i>
                        Gemini Request JSON
                    </h4>
                    <div class="rounded-lg p-4" style="background-color: #0f172a; border: 1px solid #334155;">
                        <div class="flex justify-between items-center mb-2">
                            <span class="text-xs text-gray-400">Request will appear here after execution</span>
                            <button onclick="navigator.clipboard.writeText(JSON.stringify(${JSON.stringify(data.request)}, null, 2)); showNotification('Request copied to clipboard', 'success');" class="text-xs text-blue-400 hover:text-blue-300">
                                <i class="fas fa-copy mr-1"></i>Copy
                            </button>
                        </div>
                        <pre class="text-xs text-gray-300 whitespace-pre-wrap overflow-auto" style="max-height: 200px;">${JSON.stringify(data.request, null, 2)}</pre>
                    </div>
                </div>
                
                <!-- Response Section -->
                <div class="mb-6">
                    <h4 class="text-md font-semibold mb-3 flex items-center" style="color: #10b981;">
                        <i class="fas fa-arrow-down mr-2"></i>
                        Gemini Response JSON
                    </h4>
                    <div class="rounded-lg p-4" style="background-color: #0f172a; border: 1px solid #334155;">
                        <div class="flex justify-between items-center mb-2">
                            <span class="text-xs text-gray-400">Response will appear here after execution</span>
                            <button onclick="navigator.clipboard.writeText(JSON.stringify(${JSON.stringify(data.response)}, null, 2)); showNotification('Response copied to clipboard', 'success');" class="text-xs text-blue-400 hover:text-blue-300">
                                <i class="fas fa-copy mr-1"></i>Copy
                            </button>
                        </div>
                        <pre class="text-xs text-gray-300 whitespace-pre-wrap overflow-auto" style="max-height: 300px;">${JSON.stringify(data.response, null, 2)}</pre>
                    </div>
                </div>
                
                <!-- Status Indicator -->
                <div class="mb-4">
                    <div class="flex items-center">
                        <span class="text-xs font-medium text-gray-400 mr-3">Connection Status:</span>
                        <span class="text-sm font-mono px-3 py-1 rounded ${data.response.success ? 'bg-green-900 text-green-200' : 'bg-red-900 text-red-200'}">
                            <i class="fas ${data.response.success ? 'fa-check-circle' : 'fa-times-circle'} mr-1"></i>
                            ${data.response.success ? 'SUCCESS' : 'FAILED'}
                        </span>
                    </div>
                </div>
                
                <!-- Actions -->
                <div class="flex justify-end space-x-3">
                    <button onclick="navigator.clipboard.writeText(JSON.stringify(${JSON.stringify(data)}, null, 2)); showNotification('API test details copied to clipboard', 'success');" 
                            class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 text-sm">
                        <i class="fas fa-copy mr-2"></i>Copy All
                    </button>
                    <button onclick="this.closest('.fixed').remove()" class="px-4 py-2 bg-gray-600 text-white rounded hover:bg-gray-700 text-sm">
                        <i class="fas fa-times mr-2"></i>Close
                    </button>
                </div>
            </div>
        `;
        
        // Add modal to page
        document.body.appendChild(modal);
        
        // Focus on modal for keyboard accessibility
        modal.focus();
        
        // Close modal on Escape key
        modal.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                modal.remove();
            }
        });
        
    } catch (error) {
        showNotification('Error displaying API test details: ' + error.message, 'error');
    }
}

// Legacy function for backward compatibility
async function testLLMKey() {
    return testGeminiConnection();
}

// Update Step 4 status display
function updateStep4Status(status, message) {
    const step4Element = document.querySelector('[data-step="4"]');
    if (!step4Element) return;
    
    const statusIcon = step4Element.querySelector('.step-status-icon') || 
                      step4Element.querySelector('i') || 
                      step4Element.querySelector('.fas');
    
    if (statusIcon) {
        statusIcon.className = status === 'success' ? 
            'fas fa-check-circle text-green-500' : 
            'fas fa-exclamation-circle text-red-500';
    }
    
    // Update any status text
    const statusText = step4Element.querySelector('.step-status-text');
    if (statusText) {
        statusText.textContent = message;
    }
}

// Save current key (preset or custom) - simplified version
async function saveCurrentKey() {
    const provider = document.getElementById('llm-provider').value;
    const methodElement = document.getElementById('key-method') || document.getElementById('key-source');
    const method = methodElement ? methodElement.value : 'custom';
    let apiKey = '';
    
    if (method === 'preset') {
        apiKey = workflowState.currentApiKey || PRESET_KEYS[provider];
    } else if (method === 'custom') {
        apiKey = document.getElementById('llm-api-key').value;
    }
    
    if (!apiKey) {
        showNotification('Please enter an API key first', 'error');
        return;
    }
    
    try {
        // Store the key in session
        const updatePayload = {};
        updatePayload[provider] = apiKey;
        
        const response = await fetch('/api/keys/update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(updatePayload)
        });
        
        if (response.ok) {
            workflowState.currentApiKey = apiKey;
            workflowState.currentProvider = provider;

            // Reset assessment state to enable Run button
            isAssessmentRunning = false;
            assessmentController = null;
            updateAssessmentButtonStates(false);

            showNotification('API key saved successfully', 'success');
            updateStep4Status('success', 'API key configured');
            } else {
            throw new Error('Failed to save API key');
        }
    } catch (error) {
        showNotification('Failed to save API key: ' + error.message, 'error');
    }
}

// Update LangChain pipeline configuration
async function updateLangChainConfig() {
    const statusDiv = document.getElementById('langchain-config-status');
    statusDiv.classList.remove('hidden');
    statusDiv.innerHTML = '<div class="text-blue-600"><i class="fas fa-spinner fa-spin mr-1"></i>Updating configuration...</div>';
    
    // Collect all LangChain configuration parameters
    const config = {
        temperature: parseFloat(document.getElementById('langchain-temperature').value),
        max_tokens: parseInt(document.getElementById('langchain-max-tokens').value),
        top_p: parseFloat(document.getElementById('langchain-top-p').value),
        chain_type: document.getElementById('langchain-chain-type').value,
        output_parser: document.getElementById('langchain-output-parser').value,
        memory: document.getElementById('langchain-memory').value
    };
    
    try {
        // Store configuration in workflow state
        workflowState.langchainConfig = config;
        
        // Show success
        statusDiv.innerHTML = '<div class="text-green-600"><i class="fas fa-check mr-1"></i>Configuration updated successfully</div>';
        showNotification('LangChain pipeline configuration updated', 'success');
        
        // Hide status after 3 seconds
        setTimeout(() => {
            statusDiv.classList.add('hidden');
        }, 3000);
        
    } catch (error) {
        statusDiv.innerHTML = '<div class="text-red-600"><i class="fas fa-times mr-1"></i>Error updating configuration</div>';
        showNotification('Failed to update configuration: ' + error.message, 'error');
    }
}

// Get available models for a provider
function getModelsForProvider(provider) {
    const models = {
        google: [
            'gemini-2.5-pro',
            'gemini-2.5-flash'
        ]
        // Only Google is currently supported
    };
    
    return models[provider] || [];
}

// Test current LLM configuration with selected model
async function testCurrentLLM() {
    const provider = document.getElementById('llm-provider').value;
    const model = document.getElementById('llm-model-select')?.value || '';
    const source = document.getElementById('key-source').value;
    let apiKey = '';
    
    if (source === 'preset' && workflowState.currentApiKey) {
        apiKey = workflowState.currentApiKey;
    } else {
        apiKey = document.getElementById('llm-api-key').value;
    }
    
    if (!apiKey) {
        showNotification('Please load a preset key or enter a custom key', 'error');
        return;
    }
    
    if (!model) {
        showNotification('Please select a model', 'error');
        return;
    }
    
    const resultsDiv = document.getElementById('llm-test-results');
    resultsDiv.innerHTML = '<div class="text-blue-600"><i class="fas fa-spinner fa-spin mr-1"></i>Testing model...</div>';
    
    try {
        const response = await fetch('/api/keys/test-single', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                provider: provider,
                api_key: apiKey,
                model: model
            })
        });
        
        const result = await response.json();
        
        if (result.success || result.configured) {
            resultsDiv.innerHTML = `<div class="text-green-600">✅ ${provider}/${model} working!</div>`;
            showNotification(`${provider} model test successful!`, 'success');
        } else {
            resultsDiv.innerHTML = `<div class="text-red-600">❌ ${result.error || 'Model test failed'}</div>`;
            showNotification(`${provider} model test failed`, 'error');
        }
    } catch (error) {
        resultsDiv.innerHTML = `<div class="text-red-600">❌ ${error.message}</div>`;
        showNotification('Test error: ' + error.message, 'error');
    }
}

// Remove hardcoded prompt - use API endpoint only

// Force clear problematic settings on every load
window.forceCorrectDefaults = function() {
    // DISABLED: This function was overriding user settings
    // Users should be able to choose their own batch configuration

    // Only provide helpful defaults if fields are empty/invalid
    const batchSizeInput = document.getElementById('batch-size-input');
    const concurrentInput = document.getElementById('concurrent-batches-input');
    const modeSelect = document.getElementById('processing-mode-select');

    // Only set defaults if fields are empty or invalid
    if (batchSizeInput && (!batchSizeInput.value || parseInt(batchSizeInput.value) <= 0)) {
        console.log('Setting default batch size: 650');
        batchSizeInput.value = 650;
    }

    if (concurrentInput && (!concurrentInput.value || parseInt(concurrentInput.value) <= 0)) {
        console.log('Setting default concurrent batches: 2');
        concurrentInput.value = 2;  // Allow parallel by default
    }

    if (modeSelect && !modeSelect.value) {
        console.log('Setting default processing mode: parallel');
        modeSelect.value = 'parallel';  // Allow parallel by default
    }

    // Don't override localStorage - respect user's saved preferences
    const saved = localStorage.getItem('batchConfig');
    if (saved) {
        try {
            const config = JSON.parse(saved);
            console.log('Respecting saved user preferences:', config);
            // Apply saved settings to UI instead of forcing defaults
            if (batchSizeInput && config.batchSize) batchSizeInput.value = config.batchSize;
            if (concurrentInput && config.concurrentBatches) concurrentInput.value = config.concurrentBatches;
            if (modeSelect && config.processingMode) modeSelect.value = config.processingMode;
        } catch (e) {
            console.error('Error loading saved batch config:', e);
        }
    }
}

// Custom Breakdown Functions
window.openCustomBreakdownModal = function() {
    const modal = document.getElementById('custom-breakdown-modal');
    if (modal) {
        // Get total skills count
        const totalSkills = workflowState.extractedSkills ? workflowState.extractedSkills.length : 0;
        document.getElementById('breakdown-total-skills').textContent = totalSkills;

        // Show modal
        modal.classList.remove('hidden');

        // Update preview
        updateBreakdownPreview();
    }
};

window.closeCustomBreakdownModal = function() {
    const modal = document.getElementById('custom-breakdown-modal');
    if (modal) {
        modal.classList.add('hidden');
    }
};

window.updateBreakdownPreview = function() {
    const totalSkills = workflowState.extractedSkills ? workflowState.extractedSkills.length : 0;
    const numChunks = parseInt(document.getElementById('custom-num-chunks').value) || 1;
    const batchesPerChunk = parseInt(document.getElementById('custom-batches-per-chunk').value) || 2;
    const concurrentBatches = parseInt(document.getElementById('custom-concurrent-batches').value) || 2;

    // Calculate sizes
    const chunkSize = Math.ceil(totalSkills / numChunks);
    const batchSize = Math.ceil(chunkSize / batchesPerChunk);

    // Update preview
    const previewDiv = document.getElementById('breakdown-preview');
    let previewHTML = '';

    for (let i = 0; i < numChunks; i++) {
        const chunkStart = i * chunkSize + 1;
        const chunkEnd = Math.min((i + 1) * chunkSize, totalSkills);
        const chunkSkills = chunkEnd - chunkStart + 1;
        const actualBatches = Math.ceil(chunkSkills / batchSize);

        previewHTML += `
            <div class="mb-2 p-2 bg-white dark:bg-gray-800 rounded">
                <div class="font-semibold">Chunk ${i + 1}:</div>
                <div class="text-xs pl-2">
                    • Skills ${chunkStart}-${chunkEnd} (${chunkSkills} skills)<br>
                    • ${actualBatches} batch${actualBatches > 1 ? 'es' : ''} of ~${batchSize} skills each
                </div>
            </div>
        `;
    }

    previewDiv.innerHTML = previewHTML;

    // Update calculated settings
    document.getElementById('calc-chunk-size').textContent = chunkSize;
    document.getElementById('calc-batch-size').textContent = batchSize;
    document.getElementById('calc-concurrent').textContent = concurrentBatches;
    document.getElementById('calc-mode').textContent = concurrentBatches > 1 ? 'parallel' : 'sequential';
};

window.applyCustomBreakdown = function() {
    const totalSkills = workflowState.extractedSkills ? workflowState.extractedSkills.length : 0;
    const numChunks = parseInt(document.getElementById('custom-num-chunks').value) || 1;
    const batchesPerChunk = parseInt(document.getElementById('custom-batches-per-chunk').value) || 2;
    const concurrentBatches = parseInt(document.getElementById('custom-concurrent-batches').value) || 2;

    // Calculate sizes
    const chunkSize = Math.ceil(totalSkills / numChunks);
    const batchSize = Math.ceil(chunkSize / batchesPerChunk);

    // Apply settings to UI
    document.getElementById('chunk-size-input').value = chunkSize;
    document.getElementById('batch-size-input').value = batchSize;
    document.getElementById('concurrent-batches-input').value = concurrentBatches;
    document.getElementById('processing-mode-select').value = concurrentBatches > 1 ? 'parallel' : 'sequential';

    // Update global configs
    if (window.chunkingState) {
        window.chunkingState.chunkSize = chunkSize;
    }
    if (window.batchConfig) {
        window.batchConfig.batchSize = batchSize;
        window.batchConfig.concurrentBatches = concurrentBatches;
        window.batchConfig.processingMode = concurrentBatches > 1 ? 'parallel' : 'sequential';
    }

    // Save to localStorage
    localStorage.setItem('chunkSize', chunkSize);
    localStorage.setItem('batchConfig', JSON.stringify({
        batchSize: batchSize,
        concurrentBatches: concurrentBatches,
        processingMode: concurrentBatches > 1 ? 'parallel' : 'sequential'
    }));

    // Update displays
    updateBatchCalculations();
    updateProcessingEstimates();

    // Show success message
    showNotification(
        `Settings Applied: ${numChunks} chunk(s), ${batchesPerChunk} batch(es) per chunk, ${concurrentBatches} concurrent`,
        'success'
    );

    // Close modal
    closeCustomBreakdownModal();

    console.log('Custom breakdown applied:', {
        numChunks,
        batchesPerChunk,
        concurrentBatches,
        calculatedChunkSize: chunkSize,
        calculatedBatchSize: batchSize
    });
};

// Initialize on page load
document.addEventListener('DOMContentLoaded', function() {
    // FIRST: Force correct defaults before anything else
    forceCorrectDefaults();

    initializeWorkflow();

    // Initialize chunking state
    initializeChunkingState();

    // Sync batch size with chunk size on load
    syncBatchSizeWithChunkSize();

    // Clean up localStorage if needed
    checkAndFixLocalStorageQuota();

    // Check for accumulated results and notify user
    setTimeout(() => {
        // Check new chunking state first
        if (chunkingState.accumulatedResults && chunkingState.accumulatedResults.length > 0) {
            showNotification(
                `📊 Found ${chunkingState.accumulatedResults.length} accumulated skills from previous session. ` +
                `You can continue processing or clear them.`,
                'info'
            );
            updateOverallProgress(); // Make sure progress bar reflects the state
        }

        // Also check old format for backward compatibility
        const accumulated = localStorage.getItem('accumulated_skills');
        if (accumulated) {
            try {
                const skills = JSON.parse(accumulated);
                if (skills && skills.length > 0) {
                    showNotification(`ℹ️ Found ${skills.length} previously assessed skills. Click "Clear" to start fresh or continue processing.`, 'info');

                    // Update the overall progress to reflect accumulated skills
                    updateOverallProgress();

                    // Update the accumulated display
                    updateChunkingUI();
                }
            } catch (e) {
                console.error('Error checking accumulated skills:', e);
            }
        }
    }, 1500);

    // Get the sandbox selector
    const selectorElement = document.getElementById('sandbox-selector');
    
    // Default to ADoherty Demo if nothing selected
    if (selectorElement && !selectorElement.value) {
        selectorElement.value = 'adoherty-demo';
    }
    
    // Load the credentials for the selected environment
    if (selectorElement && selectorElement.value) {
        loadSandboxCredentials();
    }
    
    // Load configurations after a brief delay
    setTimeout(() => {
        loadSandboxConfigurations();
    }, 200);
    
    // Ensure tabs are properly initialized - show workflow tab by default
    switchTab('workflow');
});

// Auto-load credentials function
function autoLoadCredentials() {
    // Get the selected environment
    const envSelect = document.getElementById('sandbox-selector');
    const selectedValue = envSelect ? envSelect.value : 'tm-sandbox';
    
    // Get credentials for the selected environment
    let config = sandboxConfigs[selectedValue] || sandboxConfigs['tm-sandbox'];
    
    const credentials = {
        username: config.username,
        password: config.password
    };
    
    // Set in all auth fields
    const usernameField = document.getElementById('api-eightfold-username');
    const passwordField = document.getElementById('api-eightfold-password');
    
    if (usernameField) {
        usernameField.value = credentials.username;
        // Remove placeholder to show actual value
        usernameField.placeholder = '';
    }
    if (passwordField) {
        passwordField.value = credentials.password;
        // Remove placeholder to show actual value
        passwordField.placeholder = '';
    }
    
    // Save to session storage for persistence
    sessionStorage.setItem('eightfold_username', credentials.username);
    sessionStorage.setItem('eightfold_password', credentials.password);
    
    // Set the sandbox selector
    const sandboxSelect = document.getElementById('sandbox-selector');
    if (sandboxSelect) {
        sandboxSelect.value = 'adoherty-demo';
    }
}

// Also load on window load as a fallback
window.addEventListener('load', function() {
    setTimeout(() => {
        autoLoadCredentials();
    }, 500);
});

function initializeWorkflow() {
    // Prompt will be loaded by loadAssessmentSettings() in app.js
    // No need to set default here
    
    // Initialize main JSON viewers only if the elements exist
    const requestViewerElement = document.getElementById('langchain-request-viewer');
    const responseViewerElement = document.getElementById('langchain-response-viewer');
    
    if (requestViewerElement) {
        requestViewerElement.innerHTML = '<div class="text-gray-500 dark:text-gray-400">Request will appear here when skills are loaded</div>';
    }
    
    if (responseViewerElement) {
        responseViewerElement.innerHTML = '<div class="text-gray-500 dark:text-gray-400">Response will appear here after execution</div>';
    }
    
    // Set up listeners to update request JSON when form changes
    setupRequestPreview();
    
    
    // Initialize Step 6 environment dropdown and check authentication
    populateStep6EnvironmentDropdown();
}

// Function to set up request preview that updates when form changes
function setupRequestPreview() {
    // Update request preview when skills are loaded or form changes
    const updatePreview = () => {
        if (workflowState.skillsLoaded && workflowState.extractedSkills && workflowState.extractedSkills.length > 0) {
            updateLangChainRequestPreview();
        }
    };
    
    // Listen for changes in form elements
    const providerSelect = document.getElementById('llm-provider');
    const modelSelect = document.getElementById('llm-model-select');
    const promptTextarea = document.getElementById('assessment-prompt');
    
    if (providerSelect) providerSelect.addEventListener('change', updatePreview);
    if (modelSelect) modelSelect.addEventListener('change', updatePreview);
    if (promptTextarea) promptTextarea.addEventListener('input', updatePreview);
    
    // Listen for proficiency level changes
    document.addEventListener('input', (e) => {
        if (e.target.classList.contains('proficiency-input')) {
            updatePreview();
        }
    });
}

// Function to update the LangChain request preview
function updateLangChainRequestPreview() {
    // Try to restore skills from localStorage if not loaded
    if (!workflowState.extractedSkills || workflowState.extractedSkills.length === 0) {
        const savedSkills = localStorage.getItem('workflowSkills');
        if (savedSkills) {
            try {
                workflowState.extractedSkills = JSON.parse(savedSkills);
                workflowState.skillsLoaded = true;
            } catch (e) {
                console.error('Failed to restore skills for preview:', e);
            }
        }
    }

    if (!workflowState.extractedSkills || workflowState.extractedSkills.length === 0) {
        // Still no skills - show empty state
        const requestViewerElement = document.getElementById('langchain-request-viewer');
        if (requestViewerElement) {
            requestViewerElement.innerHTML = '<div class="text-gray-500 text-sm">No skills loaded. Complete Step 2 to load skills.</div>';
        }
        return;
    }

    const provider = document.getElementById('llm-provider')?.value || 'google';
    const model = document.getElementById('llm-model-select')?.value || '';
    const promptTemplate = document.getElementById('assessment-prompt')?.value || '';

    // Get editable proficiency levels
    const proficiencyInputs = document.querySelectorAll('.proficiency-input');
    const proficiencyLevels = Array.from(proficiencyInputs).map(input => input.value).filter(v => v.trim());

    // Get the current environment
    const environmentElement = document.getElementById('environmentSelect') || document.getElementById('sandbox-selector');
    const environment = environmentElement?.value || 'unknown';

    // Determine which skills to show based on chunking
    const chunkSize = parseInt(document.getElementById('chunk-size-input')?.value || 650);
    const chunkStart = chunkingState.currentChunkStart || parseInt(document.getElementById('chunk-start-input')?.value || 1);
    const chunkEnd = Math.min(chunkStart + chunkSize - 1, workflowState.extractedSkills.length);

    // Get the skills for current chunk
    const chunkedSkills = workflowState.extractedSkills.slice(chunkStart - 1, chunkEnd);

    // Create optimized request for preview (same as actual request)
    const optimizedSkills = chunkedSkills.map(skill => ({
        name: skill.name || skill.skill_name,
    }));

    const previewRequest = {
        skills: optimizedSkills,
        provider: provider,
        model: model,
        proficiency_levels: proficiencyLevels,
        prompt_template: promptTemplate,
        use_langchain: true,
        environment: environment,
        chunk_info: {
            chunk_start: chunkStart - 1,  // Convert to 0-based index
            chunk_end: chunkEnd - 1,      // Convert to 0-based index
            total_skills: workflowState.extractedSkills.length,
            chunk_size: optimizedSkills.length,
            actual_chunk_index: Math.floor((chunkStart - 1) / chunkSize),  // Which chunk number (0-based)
            display_chunk_number: Math.floor((chunkStart - 1) / chunkSize) + 1  // For display (1-based)
        }
    };

    // Display preview in the request viewer
    const requestViewerElement = document.getElementById('langchain-request-viewer');
    if (requestViewerElement) {
        const requestHtml = `
            <div class="relative">
                <div class="absolute top-2 right-2 flex gap-2">
                    <span class="bg-blue-600 text-white px-2 py-1 rounded text-xs">Chunk ${Math.ceil(chunkStart / chunkSize)} (${optimizedSkills.length} skills)</span>
                </div>
                <pre class="text-xs pt-8">${JSON.stringify(previewRequest, null, 2)}</pre>
            </div>
        `;
        requestViewerElement.innerHTML = requestHtml;
    }
}

// Step 6 Environment Management Functions
function loadStep6SandboxCredentials() {
    const selector = document.getElementById('step6-sandbox-selector');
    const selectedValue = selector.value;
    
    if (!selectedValue) {
        // Clear fields
        document.getElementById('step6-username').value = '';
        document.getElementById('step6-password').value = '';
        return;
    }
    
    let config = null;
    
    // Check predefined configs first
    if (sandboxConfigs[selectedValue]) {
        config = sandboxConfigs[selectedValue];
    } else if (selectedValue === 'custom') {
        // Show custom config modal
        openStep6ConfigManager();
        return;
    } else if (customConfigs[selectedValue]) {
        config = customConfigs[selectedValue];
    }
    
    if (config) {
        document.getElementById('step6-username').value = config.username || '';
        document.getElementById('step6-password').value = config.password || '';
    }
}

