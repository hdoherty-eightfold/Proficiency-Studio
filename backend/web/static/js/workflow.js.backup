// LANGCHAIN CONFIG FUNCTIONS

// Switch LangChain tab
function switchLangChainTab(tab) {
    // Hide all tabs
    document.querySelectorAll('.langchain-tab-content').forEach(content => {
        content.classList.add('hidden');
    });
    
    // Remove active class from all tabs
    document.querySelectorAll('.langchain-tab').forEach(button => {
        button.className = 'langchain-tab px-4 py-2 text-sm font-medium text-gray-600 hover:text-gray-800';
    });
    
    // Show selected tab
    document.getElementById(`langchain-tab-${tab}`).classList.remove('hidden');
    
    // Add active class to selected tab button
    event.target.className = 'langchain-tab px-4 py-2 text-sm font-medium border-b-2 border-yellow-500 text-yellow-600';
    
    // Auto-refresh JSON config when tab is opened
    if (tab === 'json') {
        refreshJsonConfig();
    }
}

// Select chain type
function selectChainType(type) {
    const details = document.getElementById('chain-config-details');
    
    const chainConfigs = {
        'llm': `
            <h4 class="font-medium mb-2">LLM Chain Configuration</h4>
            <div class="space-y-2">
                <label class="text-xs">
                    <input type="checkbox" checked> Use prompt template
                </label>
                <label class="text-xs">
                    <input type="checkbox"> Stream responses
                </label>
                <label class="text-xs">
                    <input type="checkbox" checked> Parse output as JSON
                </label>
            </div>
        `,
        'sequential': `
            <h4 class="font-medium mb-2">Sequential Chain Configuration</h4>
            <div class="space-y-2">
                <div>
                    <label class="text-xs">Number of steps:</label>
                    <input type="number" value="3" class="w-full px-1 py-0.5 border rounded text-xs">
                </div>
                <label class="text-xs">
                    <input type="checkbox" checked> Pass context between steps
                </label>
            </div>
        `,
        'map_reduce': `
            <h4 class="font-medium mb-2">Map-Reduce Configuration</h4>
            <div class="space-y-2">
                <div>
                    <label class="text-xs">Batch size:</label>
                    <input type="number" value="10" class="w-full px-1 py-0.5 border rounded text-xs">
                </div>
                <label class="text-xs">
                    <input type="checkbox" checked> Parallel processing
                </label>
            </div>
        `,
        'router': `
            <h4 class="font-medium mb-2">Router Chain Configuration</h4>
            <div class="space-y-2">
                <div>
                    <label class="text-xs">Routes:</label>
                    <select class="w-full px-1 py-0.5 border rounded text-xs">
                        <option>Skills-based routing</option>
                        <option>Complexity-based routing</option>
                    </select>
                </div>
            </div>
        `
    };
    
    details.innerHTML = chainConfigs[type] || 'Configuration not available';
    
    // Update main chain type selector
    document.getElementById('langchain-chain-type').value = type;
}

// CRUD Operations for Roles
async function showCreateRoleModal() {
    const roleName = prompt('Enter the name for the new role:');
    if (!roleName) return;
    
    const roleData = {
        title: roleName,
        skillProficiencies: []
    };
    
    try {
        const response = await fetch('/api/roles/create', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${sessionStorage.getItem('auth_token') || workflowState.authToken}`
            },
            body: JSON.stringify(roleData)
        });
        
        if (response.ok) {
            showNotification('Role created successfully', 'success');
            await extractSkillsForAssessment(); // Refresh roles
        } else {
            const error = await response.json();
            showNotification('Failed to create role: ' + (error.message || 'Unknown error'), 'error');
        }
    } catch (error) {
        showNotification('Error creating role: ' + error.message, 'error');
    }
}

async function showEditRoleModal() {
    const selector = document.getElementById('role-management-selector');
    const selectedRole = selector.value;
    
    if (!selectedRole) {
        showNotification('Please select a role to edit', 'warning');
        return;
    }
    
    const newName = prompt('Enter new name for the role:', selectedRole);
    if (!newName || newName === selectedRole) return;
    
    // Note: Eightfold API may not support role updates in sandbox
    showNotification('Role editing is not available in sandbox environment', 'warning');
}

async function deleteSelectedRole() {
    const selector = document.getElementById('role-management-selector');
    const selectedRole = selector.value;
    
    if (!selectedRole) {
        showNotification('Please select a role to delete', 'warning');
        return;
    }
    
    if (!confirm(`Are you sure you want to delete the role "${selectedRole}"?`)) return;
    
    // Note: Eightfold API may not support role deletion in sandbox
    showNotification('Role deletion is not available in sandbox environment', 'warning');
}

async function confirmResetProficiencies() {
    if (!confirm('This will reset all skill proficiency levels to null. Are you sure?')) return;
    
    try {
        // Reset proficiencies locally
        if (workflowState.extractedSkills) {
            workflowState.extractedSkills = workflowState.extractedSkills.map(skill => ({
                ...skill,
                proficiency: null
            }));
        }
        
        showNotification('All proficiencies have been reset', 'success');
        updateSkillCountDisplay();
    } catch (error) {
        showNotification('Error resetting proficiencies: ' + error.message, 'error');
    }
}

async function confirmWipeAllData() {
    if (!confirm('This will delete ALL skills and proficiency data. This cannot be undone. Are you sure?')) return;
    if (!confirm('Are you REALLY sure? All data will be permanently deleted.')) return;
    
    try {
        // Clear all workflow state
        workflowState.extractedSkills = [];
        workflowState.skillsLoaded = false;
        workflowState.assessmentResults = null;
        workflowState.jieRoles = [];
        
        // Clear session storage
        sessionStorage.removeItem('extracted_skills');
        sessionStorage.removeItem('assessment_results');
        
        // Clear UI
        const skillsDisplay = document.getElementById('skills-count-display');
        if (skillsDisplay) {
            skillsDisplay.innerHTML = '<span class="text-gray-500">No skills loaded</span>';
        }
        
        // Clear role selector
        const selector = document.getElementById('role-management-selector');
        if (selector) {
            selector.innerHTML = '<option value="">-- Select a Role --</option>';
        }
        
        showNotification('All data has been wiped successfully', 'success');
    } catch (error) {
        showNotification('Error wiping data: ' + error.message, 'error');
    }
}

// Populate role dropdown when roles are fetched
function populateRoleManagementDropdown(roles) {
    const selector = document.getElementById('role-management-selector');
    if (!selector) return;
    
    selector.innerHTML = '<option value="">-- Select a Role --</option>';
    
    if (roles && Array.isArray(roles)) {
        roles.forEach(role => {
            const option = document.createElement('option');
            option.value = role.title || role.name || 'Unknown Role';
            option.textContent = role.title || role.name || 'Unknown Role';
            selector.appendChild(option);
        });
    }
}

// Update config displays
document.addEventListener('DOMContentLoaded', function() {
    // Temperature
    const tempSlider = document.getElementById('config-temperature');
    if (tempSlider) {
        tempSlider.addEventListener('input', (e) => {
            document.getElementById('config-temp-value').textContent = e.target.value;
        });
    }
    
    // Top P
    const topPSlider = document.getElementById('config-top-p');
    if (topPSlider) {
        topPSlider.addEventListener('input', (e) => {
            document.getElementById('config-top-p-value').textContent = e.target.value;
        });
    }
    
    // Frequency Penalty
    const freqSlider = document.getElementById('config-freq-penalty');
    if (freqSlider) {
        freqSlider.addEventListener('input', (e) => {
            document.getElementById('config-freq-value').textContent = e.target.value;
        });
    }
    
    // Presence Penalty
    const presSlider = document.getElementById('config-pres-penalty');
    if (presSlider) {
        presSlider.addEventListener('input', (e) => {
            document.getElementById('config-pres-value').textContent = e.target.value;
        });
    }
});

// Refresh JSON configuration display - Keep legitimate LLM parameters, remove metadata bloat
function refreshJsonConfig() {
    const provider = document.getElementById('llm-provider').value;
    const model = document.getElementById('llm-model-select')?.value || '';
    
    // Get current proficiency levels
    const proficiencyInputs = document.querySelectorAll('.proficiency-input');
    const proficiencyLevels = Array.from(proficiencyInputs).map(input => input.value).filter(v => v.trim());
    
    // Build configuration with legitimate LLM parameters
    const config = {
        provider: provider,
        model: model || 'gpt-4',
        // Keep LLM parameters that affect response quality
        temperature: parseFloat(document.getElementById('config-temperature').value),
        max_tokens: parseInt(document.getElementById('config-max-tokens').value),
        top_p: parseFloat(document.getElementById('config-top-p').value),
        response_format: supportsJsonFormat(model || 'gpt-4') ? { type: "json_object" } : null,
        proficiency_levels: proficiencyLevels,
        use_langchain: true
        // REMOVED the real bloat: timestamp, estimated_cost, extensive validation configs
        // But kept the important LLM parameters you added UI controls for
    };
    
    // Display in JSON viewer
    const jsonContent = document.getElementById('langchain-json-content');
    if (jsonContent) {
        jsonContent.textContent = JSON.stringify(config, null, 2);
    }
}

// Apply LangChain configuration - OPTIMIZED for essential settings only
window.applyLangChainConfig = function() {
    // Gather ONLY essential configuration
    const config = {
        // Only store basic provider/model info
        provider: document.getElementById('llm-provider')?.value,
        model: document.getElementById('llm-model')?.value
        // Removed 13 unnecessary config fields - LangChain will use sensible defaults
    };
    
    // Store minimal config in workflow state
    workflowState.langchainConfig = config;
    
    // Update main UI elements
    document.getElementById('langchain-temperature').value = config.temperature;
    document.getElementById('temperature-display').textContent = config.temperature;
    document.getElementById('langchain-max-tokens').value = config.max_tokens;
    document.getElementById('langchain-chain-type').value = config.chain_type;
    document.getElementById('langchain-memory').value = config.memory_type;
    document.getElementById('langchain-output-parser').value = config.output_format;
    
    showNotification('LangChain configuration applied', 'success');
    closeLangChainConfigModal();
}

// Reset LangChain configuration
window.resetLangChainConfig = function() {
    // Reset to defaults
    document.getElementById('config-temperature').value = 1.0;
    document.getElementById('config-top-p').value = 1;
    document.getElementById('config-freq-penalty').value = 0;
    document.getElementById('config-pres-penalty').value = 0;
    document.getElementById('config-max-tokens').value = 2000;
    document.getElementById('config-output-format').value = 'json';
    document.getElementById('config-validation').value = 'none';
    document.getElementById('config-retry').value = 'exponential';
    document.getElementById('config-cache-ttl').value = 3600;
    document.getElementById('config-timeout').value = 30000;
    document.getElementById('config-memory-type').value = 'none';
    document.getElementById('config-memory-tokens').value = 1000;
    
    // Update displays
    document.getElementById('config-temp-value').textContent = '1.0';
    document.getElementById('config-top-p-value').textContent = '1.0';
    document.getElementById('config-freq-value').textContent = '0';
    document.getElementById('config-pres-value').textContent = '0';
    
    showNotification('Configuration reset to defaults', 'info');
}

// Get limited/sampled skills based on user selection
function getLimitedSkills() {
    if (!workflowState.extractedSkills || workflowState.extractedSkills.length === 0) {
        return [];
    }
    
    const limitType = document.getElementById('skill-limit-type').value;
    const limitCount = parseInt(document.getElementById('skill-limit-count').value) || 10;
    const allSkills = [...workflowState.extractedSkills];
    
    switch(limitType) {
        case 'all':
            return allSkills;
            
        case 'first':
            return allSkills.slice(0, limitCount);
            
        case 'random':
            // Shuffle array and take first N
            const shuffled = allSkills.sort(() => Math.random() - 0.5);
            return shuffled.slice(0, limitCount);
            
        case 'custom':
            // For custom, we could show a modal to select specific skills
            // For now, just take first N
            return allSkills.slice(0, limitCount);
            
        default:
            return allSkills;
    }
}

// Update skill limit UI
window.updateSkillLimitUI = function() {
    const limitType = document.getElementById('skill-limit-type').value;
    const countInput = document.getElementById('skill-limit-count');
    
    if (limitType === 'all') {
        countInput.classList.add('hidden');
    } else {
        countInput.classList.remove('hidden');
    }
    
    // Update skill count display
    updateSkillCountDisplay();
}

// Update skill count display
function updateSkillCountDisplay() {
    const totalSkills = workflowState.extractedSkills ? workflowState.extractedSkills.length : 0;
    const totalRoles = workflowState.jieRoles ? workflowState.jieRoles.length : 0;
    
    const totalSkillsElement = document.getElementById('total-skills-count');
    if (totalSkillsElement) {
        totalSkillsElement.textContent = totalSkills;
    }
    
    // Get the skill limit from the slider or workflow state
    const skillLimitSlider = document.getElementById('skill-limit-slider');
    const limitCount = workflowState.skillLimit || (skillLimitSlider ? parseInt(skillLimitSlider.value) : totalSkills);
    
    const displayElement = document.getElementById('skills-count-display');
    
    if (displayElement) {
        // If we have JIE roles loaded, show comprehensive info
        if (totalRoles > 0) {
            let html = '<div class="space-y-2">';
            
            // Roles and skills summary
            html += `<div class="text-sm text-gray-700 dark:text-gray-300">
                <i class="fas fa-briefcase mr-1"></i><strong>${totalRoles}</strong> JIE roles loaded
            </div>`;
            
            html += `<div class="text-sm text-gray-700 dark:text-gray-300">
                <i class="fas fa-list mr-1"></i><strong>${totalSkills}</strong> total skills extracted
            </div>`;
            
            // Show skill limit info
            if (limitCount >= totalSkills) {
                html += `<div class="text-sm text-blue-600 dark:text-blue-400">
                    <i class="fas fa-check-circle mr-1"></i>All ${totalSkills} skills will be used
                </div>`;
            } else {
                const actualCount = Math.min(limitCount, totalSkills);
                html += `<div class="text-sm text-blue-600 dark:text-blue-400">
                    <i class="fas fa-filter mr-1"></i>${actualCount} of ${totalSkills} skills will be used
                </div>`;
            }
            
            html += '</div>';
            displayElement.innerHTML = html;
        } else if (totalSkills > 0) {
            // Fallback to just skills info if no roles
            if (limitCount >= totalSkills) {
                displayElement.innerHTML = `<i class="fas fa-info-circle"></i> All ${totalSkills} skills loaded`;
            } else {
                const actualCount = Math.min(limitCount, totalSkills);
                displayElement.innerHTML = `<i class="fas fa-info-circle"></i> ${actualCount} of ${totalSkills} skills will be used`;
            }
        } else {
            // No data loaded
            displayElement.innerHTML = '<div class="text-sm text-gray-600 dark:text-gray-400"><i class="fas fa-info-circle mr-1"></i>No skills loaded</div>';
        }
    }
}

// Preview skill selection
window.previewSkillSelection = function() {
    const limitedSkills = getLimitedSkills();
    
    if (limitedSkills.length === 0) {
        showNotification('No skills to preview', 'warning');
        return;
    }
    
    // Create preview modal
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50';
    modal.innerHTML = `
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-xl max-w-2xl w-full mx-4 max-h-[80vh] overflow-hidden">
            <div class="p-4 border-b dark:border-gray-700">
                <div class="flex justify-between items-center">
                    <h3 class="text-lg font-bold text-gray-900 dark:text-white">
                        Skill Selection Preview (${limitedSkills.length} skills)
                    </h3>
                    <button onclick="this.closest('.fixed').remove()" class="text-gray-500 hover:text-gray-700">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            </div>
            <div class="p-4 overflow-y-auto max-h-[60vh]">
                <div class="space-y-1">
                    ${limitedSkills.map((skill, idx) => `
                        <div class="flex items-center text-sm">
                            <span class="w-8 text-gray-500">${idx + 1}.</span>
                            <span class="text-gray-700 dark:text-gray-300">${skill.name || skill.skill_name}</span>
                        </div>
                    `).join('')}
                </div>
            </div>
            <div class="p-4 border-t dark:border-gray-700 flex justify-end">
                <button onclick="this.closest('.fixed').remove()" 
                        class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">
                    Close
                </button>
            </div>
        </div>
    `;
    document.body.appendChild(modal);
}

// Note: insertSkillsIntoPrompt function removed - skills are now automatically included in API request

// Insert numeric proficiencies into prompt (1-5)
window.insertProficienciesIntoPrompt = function() {
    const promptField = document.getElementById('assessment-prompt');
    const proficiencyInputs = document.querySelectorAll('.proficiency-numeric-input');
    
    const proficiencies = Array.from(proficiencyInputs)
        .map(input => input.value)
        .filter(v => v)
        .join(', ');
    
    let currentPrompt = promptField.value;
    
    // Replace {proficiencies} placeholder or insert at cursor
    if (currentPrompt.includes('{proficiencies}')) {
        currentPrompt = currentPrompt.replace(/\{proficiencies\}/g, proficiencies);
        promptField.value = currentPrompt;
    } else {
        const cursorPos = promptField.selectionStart;
        const textBefore = currentPrompt.substring(0, cursorPos);
        const textAfter = currentPrompt.substring(cursorPos);
        promptField.value = textBefore + '\n\nNumeric Proficiencies: ' + proficiencies + '\n' + textAfter;
    }
    
    showNotification('Numeric proficiencies inserted', 'success');
}

// Insert text levels into prompt
window.insertLevelsIntoPrompt = function() {
    const promptField = document.getElementById('assessment-prompt');
    const levelInputs = document.querySelectorAll('.proficiency-input');
    
    const levels = Array.from(levelInputs)
        .map(input => input.value.trim())
        .filter(v => v)
        .join(', ');
    
    let currentPrompt = promptField.value;
    
    // Replace {levels} placeholder or insert at cursor
    if (currentPrompt.includes('{levels}')) {
        currentPrompt = currentPrompt.replace(/\{levels\}/g, levels);
        promptField.value = currentPrompt;
    } else {
        const cursorPos = promptField.selectionStart;
        const textBefore = currentPrompt.substring(0, cursorPos);
        const textAfter = currentPrompt.substring(cursorPos);
        promptField.value = textBefore + '\n\nText Levels: ' + levels + '\n' + textAfter;
    }
    
    showNotification('Text levels inserted', 'success');
}

