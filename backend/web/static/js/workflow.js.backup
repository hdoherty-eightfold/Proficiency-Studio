// Skill Data Management
window.stripProficiencies = function() {
    if (confirm('Are you sure you want to strip all proficiency levels from skills? This will remove numerical ratings (1-5) from all skills.')) {
        showOperationStatus('Stripping proficiencies...', 'processing');
        showOperationProgress(0, 'Analyzing skills...');
        
        let progress = 0;
        const interval = setInterval(() => {
            progress += 10;
            showOperationProgress(progress, `Processing ${progress}% of skills...`);
            
            if (progress >= 100) {
                clearInterval(interval);
                hideOperationStatus();
                showNotification('All proficiency levels stripped from skills', 'success');
            }
        }, 200);
    }
};

window.stripLevels = function() {
    if (confirm('Are you sure you want to strip all level assignments from skills? This will remove job level classifications.')) {
        showOperationStatus('Stripping levels...', 'processing');
        showOperationProgress(0, 'Analyzing role levels...');
        
        let progress = 0;
        const interval = setInterval(() => {
            progress += 15;
            showOperationProgress(progress, `Processing ${progress}% of role levels...`);
            
            if (progress >= 100) {
                clearInterval(interval);
                hideOperationStatus();
                showNotification('All level assignments stripped from skills', 'success');
            }
        }, 300);
    }
};

window.resetAllSkillData = function() {
    if (confirm('Are you sure you want to reset ALL skill data? This will clear proficiencies, levels, and start completely fresh.')) {
        showOperationStatus('Resetting all skill data...', 'resetting');
        showOperationProgress(0, 'Clearing existing data...');
        
        let progress = 0;
        const tasks = ['Clearing proficiencies...', 'Clearing levels...', 'Clearing role assignments...', 'Resetting configurations...', 'Finalizing reset...'];
        let taskIndex = 0;
        
        const interval = setInterval(() => {
            progress += 20;
            if (taskIndex < tasks.length) {
                showOperationProgress(progress, tasks[taskIndex]);
                taskIndex++;
            }
            
            if (progress >= 100) {
                clearInterval(interval);
                // Actually clear the skills data
                clearAllSkills();
                hideOperationStatus();
                showNotification('All skill data has been reset', 'success');
            }
        }, 400);
    }
};

// Role Transfer
window.transferRoles = function() {
    const fromEnv = document.getElementById('transfer-from-env').value;
    const toEnv = document.getElementById('transfer-to-env').value;
    
    if (!fromEnv || !toEnv) {
        showNotification('Please select both source and destination environments', 'warning');
        return;
    }
    
    if (fromEnv === toEnv) {
        showNotification('Source and destination environments must be different', 'warning');
        return;
    }
    
    if (confirm(`Transfer roles from ${fromEnv} to ${toEnv}? This will copy all roles and their skill proficiencies.`)) {
        showOperationStatus('Transferring roles...', 'transferring');
        showOperationProgress(0, 'Connecting to source environment...');
        
        let progress = 0;
        const steps = [
            'Connecting to source environment...',
            'Loading roles from source...',
            'Connecting to destination environment...',
            'Transferring role data...',
            'Updating skill proficiencies...',
            'Finalizing transfer...'
        ];
        let stepIndex = 0;
        
        const interval = setInterval(() => {
            progress += 16;
            if (stepIndex < steps.length) {
                showOperationProgress(Math.min(progress, 100), steps[stepIndex]);
                stepIndex++;
            }
            
            if (progress >= 100) {
                clearInterval(interval);
                hideOperationStatus();
                showNotification(`Successfully transferred roles from ${fromEnv} to ${toEnv}`, 'success');
            }
        }, 800);
    }
};

// Operation Status Functions
function showOperationStatus(message, type = 'info') {
    const statusDiv = document.getElementById('operation-status');
    const statusIcon = document.getElementById('operation-status-icon');
    const statusText = document.getElementById('operation-status-text');
    const statusDetails = document.getElementById('operation-status-details');
    
    if (!statusDiv) return;
    
    const icons = {
        info: 'fas fa-info-circle text-blue-600',
        switching: 'fas fa-exchange-alt text-blue-600',
        creating: 'fas fa-plus text-green-600',
        loading: 'fas fa-spinner fa-spin text-blue-600',
        deleting: 'fas fa-trash text-red-600',
        processing: 'fas fa-cog fa-spin text-yellow-600',
        resetting: 'fas fa-undo text-gray-600',
        transferring: 'fas fa-arrow-right text-green-600'
    };
    
    statusDiv.classList.remove('hidden');
    statusIcon.className = icons[type] || icons.info;
    statusText.textContent = message;
    statusDetails.textContent = '';
    
    // Hide progress by default
    const progressDiv = document.getElementById('operation-progress');
    if (progressDiv) {
        progressDiv.classList.add('hidden');
    }
}

function showOperationProgress(percentage, details = '') {
    const progressDiv = document.getElementById('operation-progress');
    const progressBar = document.getElementById('operation-progress-bar');
    const progressText = document.getElementById('operation-progress-text');
    const statusDetails = document.getElementById('operation-status-details');
    const etaSpan = document.getElementById('operation-eta');
    
    if (progressDiv) {
        progressDiv.classList.remove('hidden');
    }
    if (progressBar) {
        progressBar.style.width = `${Math.min(percentage, 100)}%`;
    }
    if (progressText) {
        progressText.textContent = `${Math.round(percentage)}%`;
    }
    if (statusDetails && details) {
        statusDetails.textContent = details;
    }
    if (etaSpan) {
        const remaining = 100 - percentage;
        const eta = remaining > 0 ? Math.ceil(remaining / 10) : 0;
        etaSpan.textContent = eta > 0 ? `~${eta}s remaining` : 'Almost done...';
    }
}

function hideOperationStatus() {
    const statusDiv = document.getElementById('operation-status');
    if (statusDiv) {
        statusDiv.classList.add('hidden');
    }
}

// Initialize environment dropdowns
function initializeEnvironmentDropdowns() {
    const switcher = document.getElementById('environment-switcher');
    const fromSelect = document.getElementById('transfer-from-env');
    const toSelect = document.getElementById('transfer-to-env');
    
    // Get environments from Step 1 dropdown
    const step1Select = document.getElementById('sandbox-select');
    const environments = [];
    
    if (step1Select) {
        for (let option of step1Select.options) {
            if (option.value && option.value !== 'custom') {
                environments.push({
                    value: option.value,
                    text: option.textContent
                });
            }
        }
    }
    
    // Populate all dropdowns
    [switcher, fromSelect, toSelect].forEach(select => {
        if (select) {
            // Clear existing options except first
            while (select.children.length > 1) {
                select.removeChild(select.lastChild);
            }
            
            // Add environment options
            environments.forEach(env => {
                const option = document.createElement('option');
                option.value = env.value;
                option.textContent = env.text;
                select.appendChild(option);
            });
        }
    });
    
    // Set current environment
    if (switcher && step1Select) {
        switcher.value = step1Select.value;
    }
}

// Initialize skill limit on page load
document.addEventListener('DOMContentLoaded', function() {
    // Set default skill limit
    const slider = document.getElementById('skill-limit-slider');
    if (slider) {
        updateSkillLimitDisplay(slider.value);
        workflowState.skillLimit = parseInt(slider.value);
    }
    
    // Update LLM summary
    updateLLMSummary();
    
    // Initialize environment dropdowns
    setTimeout(initializeEnvironmentDropdowns, 1000);
});

// JSON Copy and Download functions
function copyJsonRequest() {
    if (workflowState.lastAssessmentRequest) {
        const jsonStr = JSON.stringify(workflowState.lastAssessmentRequest, null, 2);
        navigator.clipboard.writeText(jsonStr).then(() => {
            showNotification('Request JSON copied to clipboard', 'success');
        });
    }
}

function copyJsonResponse() {
    if (workflowState.lastAssessmentResponse) {
        const jsonStr = JSON.stringify(workflowState.lastAssessmentResponse, null, 2);
        navigator.clipboard.writeText(jsonStr).then(() => {
            showNotification('Response JSON copied to clipboard', 'success');
        });
    }
}

function downloadJsonRequest() {
    if (workflowState.lastAssessmentRequest) {
        const jsonStr = JSON.stringify(workflowState.lastAssessmentRequest, null, 2);
        const blob = new Blob([jsonStr], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'langchain_request.json';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
    }
}

function downloadJsonResponse() {
    if (workflowState.lastAssessmentResponse) {
        const jsonStr = JSON.stringify(workflowState.lastAssessmentResponse, null, 2);
        const blob = new Blob([jsonStr], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'langchain_response.json';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
    }
}

// Export functions for global access
window.testEightfoldAuth = testEightfoldAuth;
window.loadSandboxCredentials = loadSandboxCredentials;
window.addNewSandbox = addNewSandbox;
// Function to sync Step 6 environment dropdown with Step 1
function syncStep6EnvironmentWithStep1() {
    const step1Select = document.getElementById('sandbox-selector');
    const step6Select = document.getElementById('step6-environment');
    
    if (step1Select && step6Select) {
        // Copy the selected value from Step 1 to Step 6
        step6Select.value = step1Select.value;
        
        // Populate Step 6 dropdown if it's empty
        if (step6Select.options.length <= 1) {
            populateStep6EnvironmentDropdown();
        }
    }
}

// Function to populate Step 6 environment dropdown
function populateStep6EnvironmentDropdown() {
    const step6Select = document.getElementById('step6-environment');
    if (!step6Select) return;
    
    // Clear existing options
    step6Select.innerHTML = '';
    
    // Add default option
    const defaultOption = document.createElement('option');
    defaultOption.value = '';
    defaultOption.textContent = '-- Select Environment --';
    step6Select.appendChild(defaultOption);
    
    // Add predefined configurations
    Object.keys(sandboxConfigs).forEach(key => {
        const config = sandboxConfigs[key];
        const option = document.createElement('option');
        option.value = key;
        option.textContent = config.name;
        step6Select.appendChild(option);
    });
    
    // Add custom configurations
    Object.keys(customConfigs).forEach(key => {
        const config = customConfigs[key];
        const option = document.createElement('option');
        option.value = key;
        option.textContent = config.name;
        step6Select.appendChild(option);
    });
    
    // Auto-select current authenticated environment and check status
    const currentAuthEnv = document.getElementById('sandbox-selector')?.value;
    if (currentAuthEnv && workflowState.authenticated) {
        // Set the dropdown to match Step 1's authenticated environment
        step6Select.value = currentAuthEnv;
        // Immediately trigger the check which will auto-authenticate
        setTimeout(() => {
            checkStep6Environment();
        }, 100);
    } else {
        // Clear the "Checking authentication..." message if no environment selected
        const messageDiv = document.getElementById('step6-auth-message');
        if (messageDiv) {
            messageDiv.innerHTML = '<span class="text-gray-500"><i class="fas fa-info-circle mr-1"></i>Select an environment</span>';
        }
    }
}

// Function to populate Step 6 credentials based on selected environment
function populateStep6Credentials() {
    const step6Env = document.getElementById('step6-environment');
    if (!step6Env) return;
    
    const selectedEnv = step6Env.value;
    
    // USE THE SAME sandboxConfigs THAT STEP 1 USES - NO DUPLICATES!
    // This ensures Step 6 always has the correct credentials
    const config = sandboxConfigs[selectedEnv];
    
    if (config) {
        const usernameField = document.getElementById('step6-username');
        const passwordField = document.getElementById('step6-password');
        
        // Use the exact same credentials from Step 1's config
        if (usernameField) usernameField.value = config.username || '';
        if (passwordField) passwordField.value = config.password || '';
        
        // Using credentials from shared sandboxConfigs
    } else {
        // Clear fields if no config found
        const usernameField = document.getElementById('step6-username');
        const passwordField = document.getElementById('step6-password');
        
        if (usernameField) usernameField.value = '';
        if (passwordField) passwordField.value = '';
        
        // No config found for environment
    }
}

// Function to check Step 6 environment and authentication
function checkStep6Environment() {
    const envSelect = document.getElementById('step6-environment');
    const statusDiv = document.getElementById('step6-auth-status');
    const messageDiv = document.getElementById('step6-auth-message');
    const authSection = document.getElementById('step6-auth-section');
    
    if (!envSelect || !statusDiv || !messageDiv) return;
    
    const selectedEnv = envSelect.value;
    if (!selectedEnv) {
        messageDiv.innerHTML = '<span class="text-gray-500"><i class="fas fa-info-circle mr-1"></i>Select an environment</span>';
        // Still need to show the auth section when no environment is selected
        if (authSection) {
            authSection.classList.remove('hidden');
        }
        return;
    }
    
    // Check multiple sources for existing authentication:
    // 1. Check if authenticated in Step 1 (workflowState)
    // 2. Check session storage for this environment
    // 3. Check if it matches the current authenticated environment
    
    let isAuthenticated = false;
    let authSource = '';
    
    // First check if this is the currently authenticated environment from Step 1
    const currentAuthEnv = document.getElementById('sandbox-selector')?.value;
    
    if (currentAuthEnv === selectedEnv && workflowState.authenticated && workflowState.authToken) {
        isAuthenticated = true;
        authSource = 'Step 1 (current session)';
        
        // AUTO-AUTHENTICATE: If already authenticated in Step 1, no need to re-auth
        // Store the auth for Step 6 to use
        sessionStorage.setItem(`auth_${selectedEnv}`, JSON.stringify({
            token: workflowState.authToken,
            username: sandboxConfigs[selectedEnv]?.username || '',
            timestamp: Date.now()
        }));
    } else {
        // Otherwise check stored auth
        isAuthenticated = checkEnvironmentAuth(selectedEnv);
        authSource = isAuthenticated ? 'stored authentication' : '';
    }
    
    if (isAuthenticated) {
        statusDiv.className = 'mt-3 p-3 rounded-lg bg-green-100 dark:bg-green-900/30';
        messageDiv.innerHTML = `
            <span class="text-green-600 dark:text-green-400">
                <i class="fas fa-check-circle mr-1"></i>Already authenticated to ${selectedEnv} (from ${authSource})
            </span>
            <button onclick="authenticateStep6Environment()" class="text-sm bg-blue-600 text-white px-2 py-1 rounded hover:bg-blue-700 ml-2">
                Re-authenticate
            </button>
        `;
        
        // AUTO-POPULATE: If authenticated, auto-populate the fields
        populateStep6Credentials();
        
        // Hide the auth section since we're already authenticated
        if (authSection) {
            authSection.classList.add('hidden');
        }
    } else {
        statusDiv.className = 'mt-3 p-3 rounded-lg bg-yellow-100 dark:bg-yellow-900/30';
        messageDiv.innerHTML = `
            <span class="text-yellow-600 dark:text-yellow-400">
                <i class="fas fa-exclamation-triangle mr-1"></i>Not authenticated to ${selectedEnv}
            </span>
        `;
        
        // Show the auth section for authentication
        if (authSection) {
            authSection.classList.remove('hidden');
        }
        
        // Populate credentials if available
        populateStep6Credentials();
    }
}

// Check if authenticated to an environment
function checkEnvironmentAuth(environment) {
    // No mapping needed - use values directly
    const storageKey = environment;
    
    // Check if we have an auth token for this environment
    if (storageKey === 'tm-sandbox' && workflowState.authToken) {
        return true;
    }
    
    // Check stored auth tokens
    const storedAuth = sessionStorage.getItem(`auth_${storageKey}`);
    return !!storedAuth;
}

// Authenticate Step 6 environment
async function authenticateStep6Environment() {
    const envSelect = document.getElementById('step6-environment');
    const username = document.getElementById('step6-username');
    const password = document.getElementById('step6-password');
    const statusDiv = document.getElementById('step6-auth-status');
    const messageDiv = document.getElementById('step6-auth-message');
    const requestJson = document.getElementById('step6-request-json');
    const responseJson = document.getElementById('step6-response-json');
    
    if (!envSelect.value) {
        showNotification('Please select an environment first', 'error');
        return;
    }
    
    if (!username.value || !password.value) {
        showNotification('Please enter username and password', 'error');
        return;
    }
    
    // Update status
    statusDiv.className = 'mt-3 p-3 rounded-lg bg-blue-100 dark:bg-blue-900/30';
    messageDiv.innerHTML = '<span class="text-blue-600"><i class="fas fa-spinner fa-spin mr-1"></i>Authenticating...</span>';
    
    // No mapping needed - use values directly since they now match sandboxConfigs keys
    const storageKey = envSelect.value;
    const selectedConfig = sandboxConfigs[envSelect.value];
    
    // USE EXACT SAME METHOD AS STEP 1 (testEightfoldAuth)
    let authHeader = null;
    let grantType = 'password';
    
    // Check if credentials match sandbox config to use predefined auth header
    if (selectedConfig && username.value === selectedConfig.username && password.value === selectedConfig.password) {
        authHeader = selectedConfig.authHeader;
        grantType = selectedConfig.grantType || 'password';
    } else {
        // Generate Basic auth from entered credentials
        const credentials = btoa(`${username.value}:${password.value}`);
        authHeader = `Basic ${credentials}`;
    }
    
    // Build auth request EXACTLY like Step 1 does
    const authRequest = {
        endpoint: '/oauth/v1/authenticate',
        method: 'POST',
        headers: {
            'Authorization': authHeader,
            'Content-Type': 'application/json',
            'Accept': 'application/json'
        },
        body: {
            grant_type: grantType,
            username: username.value,
            password: password.value
        },
        base_url: selectedConfig?.apiUrl || 'https://apiv2.eightfold.ai'
    };
    
    // Store request for workflow state (like Step 1 does)
    workflowState.authRequest = authRequest;
    
    // Display request JSON
    if (requestJson) {
        requestJson.textContent = JSON.stringify(authRequest, null, 2);
    }
    
    try {
        // Direct API call to Eightfold
        const environment = envSelect.value; // Define environment from selected value
        const apiBaseUrl = getEightfoldApiUrl(environment);
        const authUrl = `${apiBaseUrl}/oauth/v1/authenticate`;
        
        const response = await fetch(authUrl, {
            method: 'POST',
            headers: {
                'Authorization': authHeader,
                'Content-Type': 'application/json',
                'Accept': 'application/json'
            },
            body: JSON.stringify(authRequest)
        });
        
        const result = await response.json();
        
        // Display response JSON
        if (responseJson) {
            responseJson.textContent = JSON.stringify(result, null, 2);
        }
        
        // Check for success 
        if (response.ok && result) {
            const authData = result;
            
            // Store auth data in workflow state (like Step 1)
            workflowState.authToken = authData.auth_token || authData.access_token;
            workflowState.authenticated = true;
            workflowState.authData = authData;
            workflowState.currentAuthEnv = envSelect.value;
            
            // Store token for this environment
            sessionStorage.setItem(`auth_${storageKey}`, workflowState.authToken);
            sessionStorage.setItem('eightfold_auth_token', workflowState.authToken);
            
            statusDiv.className = 'mt-3 p-3 rounded-lg bg-green-100 dark:bg-green-900/30';
            messageDiv.innerHTML = `
                <span class="text-green-600 dark:text-green-400">
                    <i class="fas fa-check-circle mr-1"></i>Successfully authenticated to ${envSelect.value}
                </span>
            `;
            
            showNotification('Authentication successful!', 'success');
            
            // Update workflow status
        } else {
            throw new Error(result.detail || result.error || 'Authentication failed');
        }
    } catch (error) {
        // Authentication error
        statusDiv.className = 'mt-3 p-3 rounded-lg bg-red-100 dark:bg-red-900/30';
        messageDiv.innerHTML = `
            <span class="text-red-600 dark:text-red-400">
                <i class="fas fa-times-circle mr-1"></i>Authentication failed: ${error.message}
            </span>
        `;
        showNotification('Authentication failed: ' + error.message, 'error');
    }
}

// Function to update roles in the source environment with LLM proficiencies
async function updateRolesToSource() {
    // Updating roles to source environment
    
    // Check if we have assessment results but step6Data is not set (can happen after page refresh)
    if (!workflowState.step6Data && workflowState.assessmentResults) {
        // Reconstruct step6Data from assessment results
        workflowState.step6Data = {
            roles: workflowState.assessmentResults.roles,
            skills: workflowState.assessmentResults.skills,
            proficiencyLevels: workflowState.assessmentResults.proficiency_levels || {},
            timestamp: workflowState.assessmentResults.timestamp || new Date().toISOString()
        };
    }
    
    if (!workflowState.step6Data) {
        showNotification('Please run the LangChain assessment first (Step 5)', 'error');
        return;
    }
    
    // Get the environment from Step 6 dropdown
    const step6Env = document.getElementById('step6-environment');
    const environment = step6Env ? step6Env.value : '';
    
    if (!environment) {
        showNotification('Please select a target environment', 'error');
        return;
    }
    
    // Prepare the request - merge JIE roles with proficiency levels
    // Use the JIE roles as base (they have the IDs) and add proficiencies
    const rolesWithProficiencies = (workflowState.jieRoles || []).map(role => {
        // Get ALL assessed skills with their proficiency levels
        // Since we assessed skills globally (not per-role), we apply all skills to all roles
        const assessedSkills = workflowState.step6Data.skills || [];
        
        // Map the assessed skills to the format expected by Eightfold API
        // Note: confidence is NOT part of Eightfold API - it's only for our internal use
        const skillProficiencies = assessedSkills.map(skill => ({
            name: skill.skill || skill.skill_name || skill.name,
            // Use either proficiency or level field - Eightfold API may accept either
            proficiency: skill.proficiency || skill.level || 'Intermediate'
            // Do NOT include confidence - it's not part of Eightfold API structure
        }));
        
        // Create updated role with all assessed skills (id excluded - it's read-only for PUT requests)
        const updatedRole = {
            title: role.title,
            roleDescription: role.roleDescription || '',
            archivalStatus: role.archivalStatus || false,
            skillProficiencies: skillProficiencies
        };
        
        return updatedRole;
    });
    
    const requestData = {
        environment: environment,
        roles: rolesWithProficiencies,
        operation: 'update_source'
    };
    
    // Display request JSON
    const requestJsonElement = document.getElementById('step6-request-json');
    if (requestJsonElement) {
        requestJsonElement.textContent = JSON.stringify(requestData, null, 2);
    }
    
    try {
        const response = await fetch('/api/roles/update-to-source', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(requestData)
        });
        
        const result = await response.json();
        
        // Display response JSON
        const responseJsonElement = document.getElementById('step6-response-json');
        if (responseJsonElement) {
            responseJsonElement.textContent = JSON.stringify(result, null, 2);
        }
        
        if (response.ok) {
            showNotification('Roles updated successfully in source environment', 'success');
        } else {
            showNotification('Failed to update roles: ' + (result.detail || 'Unknown error'), 'error');
        }
    } catch (error) {
        // Error updating roles
        showNotification('Error updating roles: ' + error.message, 'error');
    }
}

// Function to create roles in a new environment with LLM proficiencies
async function createRolesToTarget() {
    // Creating roles in target environment
    
    // Check for JIE roles from Step 2
    if (!workflowState.jieRoles || workflowState.jieRoles.length === 0) {
        showNotification('Please fetch JIE roles first (Step 2)', 'error');
        return;
    }
    
    // Check for assessment data from Step 5 or loaded file
    const assessmentData = workflowState.step6Data || workflowState.assessmentResults;
    
    if (!assessmentData) {
        showNotification('Please run the assessment first (Step 5) or load assessment results', 'error');
        return;
    }
    
    // Get the environment from Step 6 dropdown
    const step6Env = document.getElementById('step6-environment');
    const environment = step6Env ? step6Env.value : '';
    
    if (!environment) {
        showNotification('Please select a target environment', 'error');
        return;
    }
    
    // Check if authenticated to this environment
    if (!checkEnvironmentAuth(environment)) {
        showNotification('Please authenticate to the target environment first', 'error');
        return;
    }
    
    // Get auth token for this environment
    let authToken = null;
    const currentAuthEnv = document.getElementById('sandbox-selector')?.value;
    
    if (currentAuthEnv === environment && workflowState.authenticated && workflowState.authToken) {
        authToken = workflowState.authToken;
        // Using authentication token from Step 1
    } else {
        const storageKey = environment;
        authToken = sessionStorage.getItem(`auth_${storageKey}`);
        // Using stored authentication token from Step 6
    }
    
    if (!authToken) {
        showNotification('No authentication token found. Please authenticate first.', 'error');
        return;
    }
    
    // Get the API URL for the selected environment
    const selectedConfig = sandboxConfigs[environment];
    const apiUrl = selectedConfig?.apiUrl || 'https://apiv2.eightfold.ai';
    
    // Create a map of skill names to their assessed proficiency levels
    const proficiencyMap = {};
    
    // Convert text proficiency levels to numeric values
    const textToNum = {
        'Novice': 1.0,
        'Developing': 2.0,
        'Intermediate': 3.0,
        'Advanced': 4.0,
        'Expert': 5.0
    };
    
    if (assessmentData.assessments) {
        // LangChain/assessment format
        assessmentData.assessments.forEach(assessment => {
            const skillName = assessment.skill_name || assessment.skill || assessment.name;
            let profValue = assessment.level || assessment.proficiency;
            
            // Convert to numeric if it's a string
            if (typeof profValue === 'string') {
                profValue = textToNum[profValue] || 3.0;
            } else if (typeof profValue === 'number') {
                profValue = parseFloat(profValue);
            } else {
                profValue = 3.0;
            }
            
            proficiencyMap[skillName.toLowerCase()] = {
                proficiency: profValue,  // Store as numeric
                confidence: assessment.confidence_score || assessment.confidence
            };
        });
    } else if (assessmentData.skills) {
        // Alternative format
        assessmentData.skills.forEach(skill => {
            const skillName = skill.skill_name || skill.name || skill.skill;
            let profValue = skill.level || skill.proficiency || skill.proficiency_level;
            
            // Convert to numeric if it's a string
            if (typeof profValue === 'string') {
                profValue = textToNum[profValue] || 3.0;
            } else if (typeof profValue === 'number') {
                profValue = parseFloat(profValue);
            } else {
                profValue = 3.0;
            }
            
            proficiencyMap[skillName.toLowerCase()] = {
                proficiency: profValue,  // Store as numeric
                confidence: skill.confidence_score || skill.confidence
            };
        });
    }
    
    // Proficiency map created
    // Processing roles
    
    // Process each JIE role and combine with assessed proficiencies
    const rolesToCreate = [];
    
    workflowState.jieRoles.forEach(role => {
        // Create updated skill proficiencies array
        const updatedSkillProficiencies = [];
        
        if (role.skillProficiencies && Array.isArray(role.skillProficiencies)) {
            role.skillProficiencies.forEach(skill => {
                const skillName = skill.name || '';
                const assessedProficiency = proficiencyMap[skillName.toLowerCase()];
                
                if (assessedProficiency) {
                    // Skill was assessed - use the assessed proficiency (numeric only)
                    updatedSkillProficiencies.push({
                        name: skillName,
                        proficiency: assessedProficiency.proficiency,  // Numeric value
                        skillGroupList: []  // REQUIRED field for API
                    });
                } else {
                    // Skill was not assessed - keep original or set as null
                    updatedSkillProficiencies.push({
                        name: skillName,
                        proficiency: skill.proficiency || null,
                        skillGroupList: []  // REQUIRED field for API
                    });
                }
            });
        }
        
        // Create the role payload (id excluded - it's read-only for PUT requests)
        rolesToCreate.push({
            title: role.title,
            skillProficiencies: updatedSkillProficiencies
        });
    });
    
    // For now, we'll create/update the first role as an example
    // In production, you might want to batch these or provide UI to select which roles to update
    const roleToProcess = rolesToCreate[0];
    
    if (!roleToProcess) {
        showNotification('No roles to process', 'error');
        return;
    }
    
    // Prepare the Eightfold API request payload
    const eightfoldPayload = {
        title: roleToProcess.title,
        skillProficiencies: roleToProcess.skillProficiencies
    };
    
    // Display the actual API request that will be sent
    const requestJsonElement = document.getElementById('step6-request-json');
    if (requestJsonElement) {
        const displayRequest = {
            endpoint: `${apiUrl}/api/v2/JIE/roles`,
            method: 'POST',
            headers: {
                'Authorization': 'Bearer [TOKEN]',
                'Content-Type': 'application/json'
            },
            body: eightfoldPayload,
            metadata: {
                totalRoles: rolesToCreate.length,
                roleBeingProcessed: 1,
                skillsWithProficiencies: roleToProcess.skillProficiencies.filter(s => s.proficiency).length,
                totalSkills: roleToProcess.skillProficiencies.length
            }
        };
        requestJsonElement.textContent = JSON.stringify(displayRequest, null, 2);
    }
    
    // Log operation to the operation log
    const logElement = document.getElementById('step6-operation-log');
    if (logElement) {
        const timestamp = new Date().toLocaleTimeString();
        logElement.innerHTML = `<div class="text-blue-600">[${timestamp}] Creating/Updating role "${roleToProcess.title}"...</div>`;
        logElement.innerHTML += `<div class="text-gray-600 ml-4">- Total skills: ${roleToProcess.skillProficiencies.length}</div>`;
        logElement.innerHTML += `<div class="text-gray-600 ml-4">- Skills with proficiencies: ${roleToProcess.skillProficiencies.filter(s => s.proficiency).length}</div>`;
        if (rolesToCreate.length > 1) {
            logElement.innerHTML += `<div class="text-yellow-600 ml-4">Note: Processing 1 of ${rolesToCreate.length} roles</div>`;
        }
    }
    
    // Creating/updating role with Eightfold API
    
    try {
        // Direct API call to Eightfold
        const createUrl = `${apiUrl}/api/v2/JIE/roles`;
        const response = await fetch(createUrl, {
            method: 'POST',
            headers: {
                'Authorization': `Bearer ${authToken}`,
                'Content-Type': 'application/json',
                'Accept': 'application/json'
            },
            body: JSON.stringify(eightfoldPayload)
        });
        
        const result = await response.json();
        
        // Display response JSON
        const responseJsonElement = document.getElementById('step6-response-json');
        if (responseJsonElement) {
            responseJsonElement.textContent = JSON.stringify(result, null, 2);
        }
        
        // Update operation log
        if (logElement) {
            const timestamp = new Date().toLocaleTimeString();
            if (response.ok && result.success !== false) {
                logElement.innerHTML += `<div class="text-green-600">[${timestamp}] ✓ Role created/updated successfully!</div>`;
                logElement.innerHTML += `<div class="text-gray-600 ml-4">- Role: ${roleToProcess.title}</div>`;
                logElement.innerHTML += `<div class="text-gray-600 ml-4">- Total skills: ${roleToProcess.skillProficiencies.length}</div>`;
                logElement.innerHTML += `<div class="text-gray-600 ml-4">- Skills with proficiencies: ${roleToProcess.skillProficiencies.filter(s => s.proficiency).length}</div>`;
                if (result.data?.id) {
                    logElement.innerHTML += `<div class="text-gray-600 ml-4">- Role ID: ${result.data.id}</div>`;
                }
                if (rolesToCreate.length > 1) {
                    logElement.innerHTML += `<div class="text-blue-600 mt-2">ℹ️ ${rolesToCreate.length - 1} more roles available for processing</div>`;
                }
            } else {
                const errorMsg = result.detail || result.error || result.message || 'Unknown error';
                logElement.innerHTML += `<div class="text-red-600">[${timestamp}] ✗ Failed: ${errorMsg}</div>`;
            }
        }
        
        // Update progress bar
        const progressBar = document.getElementById('step6-progress-bar');
        const progressPercent = document.getElementById('step6-progress-percent');
        if (progressBar && progressPercent) {
            progressBar.style.width = '100%';
            progressPercent.textContent = '100%';
        }
        
        if (response.ok && result.success !== false) {
            showNotification(`Role "${roleToProcess.title}" created/updated successfully with ${roleToProcess.skillProficiencies.filter(s => s.proficiency).length} proficiency levels`, 'success');
            
            // Refresh the JIE roles list if function exists
            if (window.fetchJIERoles) {
                setTimeout(() => {
                    window.fetchJIERoles();
                }, 1000);
            }
        } else {
            const errorMsg = result.detail || result.error || result.message || 'Unknown error';
            showNotification('Failed to create role: ' + errorMsg, 'error');
            // API Error
        }
    } catch (error) {
        // Error creating role
        showNotification('Error creating role: ' + error.message, 'error');
        
        // Display error in response JSON
        const responseJsonElement = document.getElementById('step6-response-json');
        if (responseJsonElement) {
            responseJsonElement.textContent = JSON.stringify({
                error: error.message,
                success: false
            }, null, 2);
        }
        
        // Update operation log with error
        if (logElement) {
            const timestamp = new Date().toLocaleTimeString();
            logElement.innerHTML += `<div class="text-red-600">[${timestamp}] ✗ Error: ${error.message}</div>`;
        }
    }
}

// Function to wipe proficiencies from roles
async function wipeProficiencies() {
    // Wiping proficiencies from roles
    
    if (!confirm('Are you sure you want to wipe all proficiencies? This cannot be undone.')) {
        return;
    }
    
    // Get the environment from Step 6 dropdown
    const step6Env = document.getElementById('step6-environment');
    const environment = step6Env ? step6Env.value : '';
    
    if (!environment) {
        showNotification('Please select a target environment', 'error');
        return;
    }
    
    // Prepare the request
    const requestData = {
        environment: environment,
        roles: workflowState.step6Data?.roles || workflowState.jieRoles || [],
        operation: 'wipe'
    };
    
    // Display request JSON
    const requestJsonElement = document.getElementById('step6-request-json');
    if (requestJsonElement) {
        requestJsonElement.textContent = JSON.stringify(requestData, null, 2);
    }
    
    try {
        const response = await fetch('/api/roles/wipe', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(requestData)
        });
        
        const result = await response.json();
        
        // Display response JSON
        const responseJsonElement = document.getElementById('step6-response-json');
        if (responseJsonElement) {
            responseJsonElement.textContent = JSON.stringify(result, null, 2);
        }
        
        if (response.ok) {
            showNotification('Proficiencies wiped successfully', 'success');
        } else {
            showNotification('Failed to wipe proficiencies: ' + (result.detail || 'Unknown error'), 'error');
        }
    } catch (error) {
        // Error wiping proficiencies
        showNotification('Error wiping proficiencies: ' + error.message, 'error');
    }
}

// Function to delete all JIE roles from the environment
async function deleteAllRoles() {
    // Get the environment from Step 6 dropdown
    const step6Env = document.getElementById('step6-environment');
    const environment = step6Env ? step6Env.value : '';
    
    if (!environment) {
        showNotification('Please select a target environment', 'warning');
        return;
    }
    
    // Create confirmation modal
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50';
    modal.innerHTML = `
        <div class="bg-white dark:bg-gray-800 rounded-lg p-6 max-w-md mx-4 shadow-xl">
            <div class="mb-4">
                <div class="flex items-center mb-3">
                    <i class="fas fa-exclamation-triangle text-red-500 text-3xl mr-3"></i>
                    <h3 class="text-xl font-bold text-gray-900 dark:text-white">Confirm Deletion</h3>
                </div>
                <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-700 rounded-lg p-4 mb-4">
                    <p class="text-red-800 dark:text-red-300 font-semibold mb-2">
                        ⚠️ DANGER: Permanent Deletion
                    </p>
                    <p class="text-gray-700 dark:text-gray-300 mb-2">
                        You are about to delete ALL JIE roles from:
                    </p>
                    <p class="text-lg font-bold text-red-600 dark:text-red-400 mb-3">
                        ${environment} environment
                    </p>
                    <p class="text-sm text-gray-600 dark:text-gray-400">
                        This action cannot be undone. All roles and their associated skills will be permanently removed.
                    </p>
                </div>
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                        Type <span class="font-mono bg-gray-100 dark:bg-gray-700 px-2 py-1 rounded">DELETE ALL</span> to confirm:
                    </label>
                    <input type="text" id="delete-confirmation-input" 
                           class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-red-500 dark:bg-gray-700 dark:border-gray-600"
                           placeholder="Type DELETE ALL here">
                </div>
            </div>
            <div class="flex justify-end space-x-3">
                <button id="cancel-delete-btn" 
                        class="px-4 py-2 bg-gray-300 dark:bg-gray-600 text-gray-700 dark:text-gray-200 rounded-lg hover:bg-gray-400 dark:hover:bg-gray-500">
                    <i class="fas fa-times mr-2"></i>Cancel
                </button>
                <button id="confirm-delete-btn" 
                        class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 disabled:bg-red-300 disabled:cursor-not-allowed"
                        disabled>
                    <i class="fas fa-trash mr-2"></i>Yes, Delete All Roles
                </button>
            </div>
        </div>
    `;
    
    document.body.appendChild(modal);
    
    // Handle input validation
    const input = document.getElementById('delete-confirmation-input');
    const confirmBtn = document.getElementById('confirm-delete-btn');
    const cancelBtn = document.getElementById('cancel-delete-btn');
    
    input.addEventListener('input', (e) => {
        confirmBtn.disabled = e.target.value !== 'DELETE ALL';
    });
    
    // Handle cancel
    cancelBtn.addEventListener('click', () => {
        document.body.removeChild(modal);
        showNotification('Deletion cancelled', 'info');
    });
    
    // Handle confirm
    confirmBtn.addEventListener('click', async () => {
        if (input.value !== 'DELETE ALL') {
            return;
        }
        
        // Remove modal
        document.body.removeChild(modal);
        
        // Proceed with deletion
        await proceedWithDeletion(environment);
    });
    
    // Focus input
    input.focus();
    
    // Handle escape key
    modal.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            document.body.removeChild(modal);
            showNotification('Deletion cancelled', 'info');
        }
    });
    
    return; // Exit here, actual deletion happens in proceedWithDeletion
}

async function proceedWithDeletion(environment) {
    // This function continues the deletion process after confirmation
    
    try {
        // Check if we need to authenticate first
        const authToken = await getStep6AuthToken(environment);
        
        if (!authToken) {
            showNotification('Authentication required', 'error');
            return;
        }
        
        showNotification('Fetching all roles from environment...', 'info');
        
        // First, fetch all current roles from the environment
        // Use proxy to avoid CORS issues
        const apiBaseUrl = getEightfoldApiUrl(environment);
        
        const proxyRequest = {
            endpoint: '/api/v2/JIE/roles?limit=200',
            method: 'GET',
            headers: {
                'Authorization': `Bearer ${authToken}`,
                'Content-Type': 'application/json',
                'Accept': 'application/json'
            },
            base_url: apiBaseUrl
        };
        
        const fetchResponse = await fetch('/api/eightfold/proxy', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(proxyRequest)
        });
        
        const fetchResult = await fetchResponse.json();
        
        if (!fetchResponse.ok) {
            showNotification('Failed to fetch roles: ' + (fetchResult.message || 'Unknown error'), 'error');
            return;
        }
        
        // Extract role IDs from fetched data (direct API returns data array)
        const roles = fetchResult.data || [];
        const roleIds = roles.map(role => role.id || role.roleId).filter(id => id);
        
        if (roleIds.length === 0) {
            showNotification('No roles found in the environment to delete', 'warning');
            return;
        }
        
        // Show count and start deletion
        showNotification(`Found ${roleIds.length} roles. Starting deletion...`, 'info');
        
        // Delete roles one by one (API doesn't support bulk delete)
        let successCount = 0;
        let failCount = 0;
        const failedRoles = [];
        
        // Show progress
        const progressMessage = document.createElement('div');
        progressMessage.className = 'fixed bottom-4 right-4 bg-blue-600 text-white p-4 rounded-lg shadow-lg z-50';
        progressMessage.innerHTML = `
            <div class="font-semibold mb-2">Deleting Roles...</div>
            <div id="delete-progress">0 / ${roleIds.length}</div>
        `;
        document.body.appendChild(progressMessage);
        
        for (let i = 0; i < roleIds.length; i++) {
            const roleId = roleIds[i];
            
            // Update progress
            document.getElementById('delete-progress').textContent = `${i + 1} / ${roleIds.length}`;
            
            try {
                // Use proxy to avoid CORS issues
                const deleteProxyRequest = {
                    endpoint: `/api/v2/JIE/roles/${roleId}`,
                    method: 'DELETE',
                    headers: {
                        'Authorization': `Bearer ${authToken}`,
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    base_url: apiBaseUrl
                };
                
                const response = await fetch('/api/eightfold/proxy', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(deleteProxyRequest)
                });
                
                let result = null;
                if (response.status !== 204) {
                    try {
                        result = await response.json();
                    } catch (e) {
                        // Response might be empty for successful delete
                    }
                }
                
                if (response.ok || response.status === 204) {
                    successCount++;
                } else {
                    failCount++;
                    failedRoles.push(roleId);
                    console.error(`Failed to delete role ${roleId}:`, result);
                }
            } catch (error) {
                failCount++;
                failedRoles.push(roleId);
                console.error(`Error deleting role ${roleId}:`, error);
            }
            
            // Small delay to avoid rate limiting
            if (i < roleIds.length - 1) {
                await new Promise(resolve => setTimeout(resolve, 100));
            }
        }
        
        // Remove progress message
        document.body.removeChild(progressMessage);
        
        // Show final result
        if (successCount > 0) {
            showNotification(`Successfully deleted ${successCount} out of ${roleIds.length} roles`, 'success');
            
            // Update local state - remove deleted roles
            if (failCount === 0) {
                workflowState.jieRoles = [];
                workflowState.extractedSkills = [];
            } else {
                // Keep only failed roles
                workflowState.jieRoles = workflowState.jieRoles.filter(role => 
                    failedRoles.includes(role.id || role.roleId)
                );
            }
            
            updateSkillCountDisplay();
            
            // Clear role dropdowns if all deleted
            if (failCount === 0) {
                const roleSelect = document.getElementById('update-role-select');
                if (roleSelect) {
                    roleSelect.innerHTML = '<option value="">No roles available (deleted)</option>';
                }
            }
        }
        
        if (failCount > 0) {
            showNotification(`Failed to delete ${failCount} roles. Check console for details.`, 'error');
            console.error('Failed to delete roles:', failedRoles);
        }
    } catch (error) {
        showNotification('Error deleting roles: ' + error.message, 'error');
        
        // Display error in response JSON
        const responseJsonElement = document.getElementById('step6-response-json');
        if (responseJsonElement) {
            responseJsonElement.textContent = JSON.stringify({error: error.message}, null, 2);
        }
    }
}

// Helper function to get Step 6 auth token
async function getStep6AuthToken(environment) {
    // Check if we have a stored token for this environment
    const storedAuth = sessionStorage.getItem(`auth_${environment}`);
    if (storedAuth) {
        const authData = JSON.parse(storedAuth);
        if (authData.token) {
            return authData.token;
        }
    }
    
    // Check if current workflow has token for this environment
    if (workflowState.authenticated && workflowState.authToken) {
        const currentEnv = document.getElementById('sandbox-selector')?.value;
        if (currentEnv === environment) {
            return workflowState.authToken;
        }
    }
    
    return null;
}

// Helper function to extract confidence from LangChain response
function extractConfidenceFromResponse(skill, response) {
    // Try to parse confidence from the response
    // This is a simple implementation - can be enhanced based on actual response format
    if (typeof response === 'string') {
        // Look for confidence patterns in the response
        const patterns = [
            /confidence[:\s]+(\d+(?:\.\d+)?)/i,
            /(\d+(?:\.\d+)?)[%\s]*confidence/i,
            /certainty[:\s]+(\d+(?:\.\d+)?)/i
        ];
        
        for (const pattern of patterns) {
            const match = response.match(pattern);
            if (match) {
                return parseFloat(match[1]);
            }
        }
    }
    
    // Default confidence based on proficiency level
    const confidenceMap = {
        'Expert': 95,
        'Advanced': 85,
        'Intermediate': 75,
        'Developing': 65,
        'Novice': 55
    };
    
    return confidenceMap[skill.proficiency] || 70;
}

// Function to load assessment history
async function loadAssessmentHistory() {
    // Loading assessment history from server
    
    try {
        // Fetch list of saved assessments from server
        const response = await fetch('/api/assessments/list');
        const data = await response.json();
        
        if (data.success && data.assessments && data.assessments.length > 0) {
            // Show assessment browser modal with saved assessments
            showAssessmentBrowser(data.assessments, data.storage_info);
        } else {
            // No assessments found - show empty browser with upload option
            showAssessmentBrowser([], {
                storage_dir: 'assessment_history',
                total_assessments: 0,
                total_size_mb: 0
            });
            showNotification('No saved assessments found yet. Run an assessment or upload a file.', 'info');
        }
    } catch (error) {
        // Error loading assessments
        showNotification('Error loading assessment history', 'error');
        // Show empty browser even on error
        showAssessmentBrowser([], {
            storage_dir: 'assessment_history',
            total_assessments: 0,
            total_size_mb: 0
        });
    }
}

// Function to show assessment browser modal
function showAssessmentBrowser(assessments, storageInfo) {
    // Create modal
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50';
    
    let assessmentRows = '';
    if (assessments && assessments.length > 0) {
        assessmentRows = assessments.map(a => `
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700 cursor-pointer" onclick="loadServerAssessment('${a.filename}')">
                <td class="px-4 py-2 text-sm">${a.date_display}</td>
                <td class="px-4 py-2 text-sm">${a.environment}</td>
                <td class="px-4 py-2 text-sm">${a.model}</td>
                <td class="px-4 py-2 text-sm text-center">${a.skill_count}</td>
                <td class="px-4 py-2 text-sm">
                    <button onclick="event.stopPropagation(); loadServerAssessment('${a.filename}')" 
                            class="bg-blue-600 text-white px-3 py-1 rounded text-xs hover:bg-blue-700">
                        Load
                    </button>
                    <button onclick="event.stopPropagation(); deleteServerAssessment('${a.filename}')" 
                            class="bg-red-600 text-white px-3 py-1 rounded text-xs hover:bg-red-700 ml-2">
                        Delete
                    </button>
                </td>
            </tr>
        `).join('');
    } else {
        assessmentRows = `
            <tr>
                <td colspan="5" class="px-4 py-8 text-center text-gray-500 dark:text-gray-400">
                    <i class="fas fa-folder-open text-4xl mb-4"></i>
                    <p class="text-lg">No saved assessments found</p>
                    <p class="text-sm mt-2">Run an assessment to save it automatically, or upload a JSON file</p>
                </td>
            </tr>
        `;
    }
    
    modal.innerHTML = `
        <div class="bg-white dark:bg-gray-800 rounded-lg p-6 max-w-6xl max-h-[90vh] overflow-hidden flex flex-col">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
                    <i class="fas fa-history mr-2"></i>Load Previous Assessment
                </h2>
                <button onclick="this.closest('.fixed').remove()" class="text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>
            
            <div class="mb-4 text-sm text-gray-600 dark:text-gray-400">
                <p>Storage location: ${storageInfo.storage_dir}</p>
                <p>Total assessments: ${storageInfo.total_assessments} (${storageInfo.total_size_mb} MB)</p>
            </div>
            
            <div class="flex-1 overflow-auto">
                <table class="w-full border-collapse">
                    <thead class="bg-gray-100 dark:bg-gray-700 sticky top-0">
                        <tr>
                            <th class="px-4 py-2 text-left text-sm font-medium">Date</th>
                            <th class="px-4 py-2 text-left text-sm font-medium">Environment</th>
                            <th class="px-4 py-2 text-left text-sm font-medium">Model</th>
                            <th class="px-4 py-2 text-center text-sm font-medium">Skills</th>
                            <th class="px-4 py-2 text-center text-sm font-medium">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 dark:divide-gray-600">
                        ${assessmentRows}
                    </tbody>
                </table>
            </div>
            
            <div class="mt-4 flex justify-between">
                <button onclick="document.getElementById('assessment-file-input').click()" 
                        class="bg-gray-600 text-white px-4 py-2 rounded hover:bg-gray-700">
                    <i class="fas fa-upload mr-2"></i>Upload from File
                </button>
                <button onclick="this.closest('.fixed').remove()" 
                        class="bg-gray-600 text-white px-4 py-2 rounded hover:bg-gray-700">
                    Close
                </button>
            </div>
        </div>
    `;
    
    document.body.appendChild(modal);
}

// Function to load assessment from server
async function loadServerAssessment(filename) {
    // Loading assessment
    
    try {
        const response = await fetch(`/api/assessments/load/${filename}`);
        const data = await response.json();
        
        if (data.success && data.assessment) {
            // Close modal
            const modal = document.querySelector('.fixed.inset-0');
            if (modal) modal.remove();
            
            // Apply the loaded assessment
            applyLoadedAssessment(data.assessment);
            showNotification(`Assessment loaded: ${filename}`, 'success');
        } else {
            showNotification('Failed to load assessment', 'error');
        }
    } catch (error) {
        // Error loading assessment
        showNotification('Error loading assessment', 'error');
    }
}

// Function to delete assessment from server
async function deleteServerAssessment(filename) {
    // Show custom confirmation popup instead of browser alert
    const confirmed = await showDeleteConfirmation(filename);
    if (!confirmed) return;

    try {
        // Add cache busting to ensure fresh data
        const response = await fetch(`/api/assessments/${filename}?t=${Date.now()}`, {
            method: 'DELETE',
            headers: {
                'Cache-Control': 'no-cache, no-store, must-revalidate',
                'Pragma': 'no-cache',
                'Expires': '0'
            }
        });
        const data = await response.json();

        if (data.success) {
            showNotification('Assessment deleted successfully', 'success');

            // Immediately remove the row from the UI
            const rows = document.querySelectorAll('tr[onclick*="' + filename + '"]');
            rows.forEach(row => {
                row.style.opacity = '0.5';
                setTimeout(() => row.remove(), 200);
            });

            // Also force refresh the list with cache busting
            await refreshAssessmentList();
        } else {
            showNotification('Failed to delete assessment: ' + (data.error || 'Unknown error'), 'error');
        }
    } catch (error) {
        console.error('Error deleting assessment:', error);
        showNotification('Error deleting assessment: ' + error.message, 'error');
    }
}

// Function to update existing assessment browser content
function updateAssessmentBrowserContent(assessments, storageInfo) {
    // Find the existing assessment modal - fixed selector
    const modal = document.querySelector('[id*="assessment-modal"]') ||
                  document.querySelector('.fixed.inset-0.bg-black.bg-opacity-50') ||
                  Array.from(document.querySelectorAll('.fixed.inset-0')).find(el =>
                      el.querySelector('h2') && el.querySelector('h2').textContent.includes('Load Previous Assessment')
                  );

    if (!modal) {
        console.warn('Assessment modal not found for content update');
        return;
    }

    const tbody = modal.querySelector('tbody');
    const storageInfoDiv = modal.querySelector('.mb-4.text-sm');

    if (!tbody) {
        console.warn('Table body not found in assessment modal');
        return;
    }

    // Update storage info
    if (storageInfoDiv) {
        storageInfoDiv.innerHTML = `
            <p>Storage location: ${storageInfo.storage_dir}</p>
            <p>Total assessments: ${storageInfo.total_assessments} (${storageInfo.total_size_mb} MB)</p>
        `;
    }

    // Update table content
    let assessmentRows = '';
    if (assessments && assessments.length > 0) {
        assessmentRows = assessments.map(a => `
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700 cursor-pointer" onclick="loadServerAssessment('${a.filename}')">
                <td class="px-4 py-2 text-sm">${a.date_display}</td>
                <td class="px-4 py-2 text-sm">${a.environment}</td>
                <td class="px-4 py-2 text-sm">${a.model}</td>
                <td class="px-4 py-2 text-sm text-center">${a.skill_count}</td>
                <td class="px-4 py-2 text-sm">
                    <button onclick="event.stopPropagation(); loadServerAssessment('${a.filename}')"
                            class="bg-blue-600 text-white px-3 py-1 rounded text-xs hover:bg-blue-700">
                        Load
                    </button>
                    <button onclick="event.stopPropagation(); deleteServerAssessment('${a.filename}')"
                            class="bg-red-600 text-white px-3 py-1 rounded text-xs hover:bg-red-700 ml-2">
                        Delete
                    </button>
                </td>
            </tr>
        `).join('');
    } else {
        assessmentRows = `
            <tr>
                <td colspan="5" class="px-4 py-8 text-center text-gray-500 dark:text-gray-400">
                    <i class="fas fa-folder-open text-4xl mb-4"></i>
                    <p class="text-lg">No saved assessments found</p>
                    <p class="text-sm mt-2">Run an assessment to save it automatically, or upload a JSON file</p>
                </td>
            </tr>
        `;
    }

    tbody.innerHTML = assessmentRows;
}

// Enhanced refresh function with cache busting
async function refreshAssessmentList() {
    console.log('Refreshing assessment list...');
    try {
        // Force refresh with cache busting
        const response = await fetch(`/api/assessments/list?t=${Date.now()}`, {
            headers: {
                'Cache-Control': 'no-cache, no-store, must-revalidate',
                'Pragma': 'no-cache',
                'Expires': '0'
            }
        });
        const data = await response.json();

        if (data.success && data.assessments) {
            // Update the modal content directly instead of reopening
            updateAssessmentBrowserContent(data.assessments, data.storage_info);
        } else {
            // Show empty state
            updateAssessmentBrowserContent([], {
                storage_dir: 'assessment_history',
                total_assessments: 0,
                total_size_mb: 0
            });
        }
    } catch (error) {
        console.error('Error refreshing assessment list:', error);
        showNotification('Error refreshing list: ' + error.message, 'error');
    }
}

// Function to show custom delete confirmation popup
function showDeleteConfirmation(filename) {
    return new Promise((resolve) => {
        // Create overlay
        const overlay = document.createElement('div');
        overlay.className = 'fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50';
        overlay.innerHTML = `
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-xl max-w-md w-full mx-4 p-6">
                <div class="flex items-center mb-4">
                    <i class="fas fa-exclamation-triangle text-red-500 text-2xl mr-3"></i>
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Confirm Deletion</h3>
                </div>
                <p class="text-gray-600 dark:text-gray-300 mb-6">
                    Are you sure you want to delete this assessment? This action cannot be undone.
                </p>
                <div class="bg-gray-100 dark:bg-gray-700 rounded p-2 mb-6">
                    <code class="text-sm text-gray-800 dark:text-gray-200">${filename}</code>
                </div>
                <div class="flex gap-3 justify-end">
                    <button id="cancel-delete" class="px-4 py-2 bg-gray-300 dark:bg-gray-600 text-gray-700 dark:text-gray-300 rounded hover:bg-gray-400 dark:hover:bg-gray-500">
                        Cancel
                    </button>
                    <button id="confirm-delete" class="px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700">
                        Delete
                    </button>
                </div>
            </div>
        `;

        // Add event listeners
        const cancelBtn = overlay.querySelector('#cancel-delete');
        const confirmBtn = overlay.querySelector('#confirm-delete');

        cancelBtn.addEventListener('click', () => {
            document.body.removeChild(overlay);
            resolve(false);
        });

        confirmBtn.addEventListener('click', () => {
            document.body.removeChild(overlay);
            resolve(true);
        });

        // Close on overlay click
        overlay.addEventListener('click', (e) => {
            if (e.target === overlay) {
                document.body.removeChild(overlay);
                resolve(false);
            }
        });

        // Close on escape key
        const handleEscape = (e) => {
            if (e.key === 'Escape') {
                document.body.removeChild(overlay);
                document.removeEventListener('keydown', handleEscape);
                resolve(false);
            }
        };
        document.addEventListener('keydown', handleEscape);

        // Add to DOM
        document.body.appendChild(overlay);
    });
}

// Function to handle file load
function handleAssessmentFileLoad(event) {
    const file = event.target.files[0];
    if (!file) return;
    
    const reader = new FileReader();
    reader.onload = function(e) {
        try {
            const data = JSON.parse(e.target.result);
            applyLoadedAssessment(data);
        } catch (error) {
            // Error parsing assessment file
            showNotification('Invalid assessment file format', 'error');
        }
    };
    reader.readAsText(file);
    
    // Reset file input
    event.target.value = '';
}

// Function to load selected assessment from dropdown
function loadSelectedAssessment() {
    const dropdown = document.getElementById('recent-assessments-dropdown');
    const assessmentId = dropdown.value;
    
    if (!assessmentId) return;
    
    const assessment = window.assessmentAnalytics.history.find(a => a.id === assessmentId);
    if (assessment) {
        applyLoadedAssessment(assessment);
    }
}

// Function to apply loaded assessment data
function applyLoadedAssessment(data) {
    // Applying loaded assessment
    
    // First restore JIE roles if they exist in the saved assessment
    if (data.jie_roles && data.jie_roles.length > 0) {
        workflowState.jieRoles = data.jie_roles;

        // Also restore all skills - check multiple possible field names
        if (data.extracted_skills && data.extracted_skills.length > 0) {
            workflowState.extractedSkills = data.extracted_skills;
        } else if (data.all_skills && data.all_skills.length > 0) {
            workflowState.extractedSkills = data.all_skills;
        } else {
            // Fallback: extract skills from JIE roles
            const allSkills = [];
            data.jie_roles.forEach(role => {
                if (role.skillProficiencies) {
                    role.skillProficiencies.forEach(skill => {
                        allSkills.push({
                            name: skill.name,
                            proficiency: skill.proficiency,
                            level: skill.level
                        });
                    });
                }
            });
            workflowState.extractedSkills = allSkills;
        }
    } else if (data.extracted_skills && data.extracted_skills.length > 0) {
        // Even if no JIE roles, restore extracted skills if they exist
        workflowState.extractedSkills = data.extracted_skills;
    }
    
    // Handle different JSON formats - check if this is LangChain format
    let assessedSkills = [];
    if (data.assessments && data.provider && !data.skills) {
        // This is LangChain format (like TM-sandbox.json)
        assessedSkills = data.assessments.map(assessment => ({
            skill: assessment.skill_name || assessment.name,
            name: assessment.skill_name || assessment.name,
            proficiency: assessment.proficiency || 0,
            level: assessment.level || 'Unknown',
            confidence: assessment.confidence_score || 0,
            reasoning: assessment.reasoning || ''
        }));
    } else {
        // Standard format
        assessedSkills = data.skills || data.assessed_skills || [];
    }
    
    // Set assessedSkills for validation to work properly
    workflowState.assessedSkills = assessedSkills;

    workflowState.assessmentResults = {
        roles: data.jie_roles || data.roles || workflowState.jieRoles || [],
        skills: assessedSkills,
        proficiency_levels: data.proficiency_levels || {},
        langchain_response: data.langchain_response || data,  // Store the whole data if it's LangChain format
        model_used: data.model || data.provider || 'Loaded from file',
        processing_time: data.statistics?.processing_time || data.processing_time || 0,
        loaded_from_file: true,
        loaded_timestamp: data.timestamp || new Date().toISOString()
    };
    
    // If proficiency_levels not present, extract from skills
    if (!data.proficiency_levels || Object.keys(data.proficiency_levels).length === 0) {
        assessedSkills.forEach(skill => {
            const skillName = skill.skill || skill.name;
            if (skillName && skill.proficiency) {
                workflowState.assessmentResults.proficiency_levels[skillName] = skill.proficiency;
            }
        });
    }
    
    // Update Step 6 data
    workflowState.step6Data = {
        roles: workflowState.assessmentResults.roles,
        proficiencyLevels: workflowState.assessmentResults.proficiency_levels
    };
    
    // Update UI to show loaded state
    const statusElement = document.getElementById('langchain-status') || document.getElementById('assessment-status');
    if (statusElement) {
        const loadedDate = data.timestamp ? new Date(data.timestamp).toLocaleString() : 'Unknown';
        statusElement.innerHTML = `
            <span class="text-green-600 dark:text-green-400">
                <i class="fas fa-check-circle mr-1"></i>Assessment loaded from ${data.loaded_from_file ? 'file' : 'history'} 
                (${assessedSkills.length} skills, originally from ${loadedDate})
            </span>
        `;
    }
    
    // Update progress bars to show complete
    updateAssessmentProgress(assessedSkills.length, assessedSkills.length, 'Assessment loaded from history');
    
    // Display the response JSON
    const responseViewerElement = document.getElementById('langchain-response-viewer');
    if (responseViewerElement) {
        const responseHtml = `
            <div class="relative">
                <div class="absolute top-2 right-2 flex gap-2">
                    <button onclick="copyJsonResponse()" class="bg-blue-600 text-white px-2 py-1 rounded text-xs hover:bg-blue-700">
                        <i class="fas fa-copy mr-1"></i>Copy
                    </button>
                    <button onclick="downloadJsonResponse()" class="bg-green-600 text-white px-2 py-1 rounded text-xs hover:bg-green-700">
                        <i class="fas fa-download mr-1"></i>Download
                    </button>
                </div>
                <pre class="text-xs pt-8">${JSON.stringify(data, null, 2)}</pre>
            </div>
        `;
        responseViewerElement.innerHTML = responseHtml;
        workflowState.lastAssessmentResponse = data;
    }
    
    // Update metrics
    const totalAssessedEl = document.getElementById('total-assessed-skills');
    const avgConfidenceEl = document.getElementById('average-confidence');
    
    if (totalAssessedEl) totalAssessedEl.textContent = assessedSkills.length.toString();
    if (avgConfidenceEl && data.statistics?.avg_confidence) {
        avgConfidenceEl.textContent = data.statistics.avg_confidence.toString();
    }
    
    // Show results summary
    const resultsSummary = document.getElementById('assessment-results-summary');
    if (resultsSummary) {
        resultsSummary.classList.remove('hidden');
    }
    
    // Show notification about restored data
    if (data.jie_roles && data.jie_roles.length > 0) {
    } else {
    }
    
    // Display the assessed skills
    if (assessedSkills.length > 0) {
        // Store the skills for the modal to access
        workflowState.lastAssessmentResults = assessedSkills;
        displayAssessedSkills(assessedSkills);
        showNotification(`Successfully loaded ${assessedSkills.length} assessed skills`, 'success');
        
        // Update Step 6 with the results
        updateStep6WithAssessmentResults();
    }
    
    // Store in assessment analytics if not already there
    if (window.assessmentAnalytics && !data.id) {
        const assessmentId = window.assessmentAnalytics.addAssessment(data);
        // Loaded assessment stored successfully
    }
}

// Function to show detailed assessment results in modal
function proceedToResults() {
    showNotification('Opening assessment results...', 'info');

    // Use accumulated results from chunking state as the primary source
    const accumulatedSkills = chunkingState.accumulatedResults;

    // Check if we have any results to show
    if ((!accumulatedSkills || accumulatedSkills.length === 0) &&
        !workflowState.assessmentResults &&
        !workflowState.step6Data &&
        !workflowState.lastAssessmentResults) {
        showNotification('No assessment results available. Please run the assessment first.', 'warning');
        return;
    }

    const modal = document.getElementById('assessment-results-modal');
    if (!modal) {
        showNotification('Modal not found - please refresh the page', 'error');
        return;
    }

    // Get assessment data - prioritize accumulated results from chunking
    const results = accumulatedSkills && accumulatedSkills.length > 0 ?
        { skills: accumulatedSkills, ...workflowState.assessmentResults } :
        (workflowState.lastAssessmentResults ?
            { skills: workflowState.lastAssessmentResults, ...workflowState.assessmentResults } :
            (workflowState.step6Data || workflowState.assessmentResults));

    const skills = accumulatedSkills && accumulatedSkills.length > 0 ?
        accumulatedSkills :
        (workflowState.lastAssessmentResults || results.assessments || results.skills || []);
    
    // Update summary stats
    document.getElementById('assessment-modal-total-skills').textContent = skills.length;
    document.getElementById('assessment-modal-model-used').textContent = results.provider || results.model || results.model_used || 'Unknown';
    
    // Calculate and display processing time
    const processingTime = results.statistics?.processing_time || results.processing_time || 0;
    document.getElementById('modal-processing-time').textContent = 
        processingTime ? `${processingTime.toFixed(2)}s` : '0s';
    
    // Calculate average confidence
    let totalConfidence = 0;
    let confidenceCount = 0;
    skills.forEach(skill => {
        const confidence = skill.confidence_score || skill.confidence || 0;
        if (confidence > 0) {
            totalConfidence += confidence;
            confidenceCount++;
        }
    });
    const avgConfidence = confidenceCount > 0 ? (totalConfidence / confidenceCount * 100).toFixed(1) : 0;
    document.getElementById('modal-avg-confidence').textContent = `${avgConfidence}%`;
    
    // Calculate proficiency distribution
    const proficiencyCount = {
        'Novice': 0,
        'Developing': 0,
        'Intermediate': 0,
        'Advanced': 0,
        'Expert': 0
    };
    
    skills.forEach(skill => {
        const level = skill.level || skill.proficiency_level || skill.proficiency || 'Unknown';
        if (proficiencyCount.hasOwnProperty(level)) {
            proficiencyCount[level]++;
        }
    });
    
    // Update proficiency chart
    const chartContainer = document.getElementById('modal-proficiency-chart');
    if (chartContainer) {
        chartContainer.innerHTML = '';
        
        const colors = {
            'Novice': 'bg-blue-500',
            'Developing': 'bg-cyan-500',
            'Intermediate': 'bg-yellow-500',
            'Advanced': 'bg-green-500',
            'Expert': 'bg-purple-500'
        };
        
        Object.entries(proficiencyCount).forEach(([level, count]) => {
            const percentage = skills.length > 0 ? (count / skills.length * 100).toFixed(1) : 0;
            chartContainer.innerHTML += `
                <div class="text-center">
                    <div class="text-2xl font-bold text-gray-900 dark:text-white">${count}</div>
                    <div class="text-sm text-gray-600 dark:text-gray-400">${level}</div>
                    <div class="mt-2 h-2 bg-gray-200 dark:bg-gray-600 rounded-full overflow-hidden">
                        <div class="${colors[level]} h-full" style="width: ${percentage}%"></div>
                    </div>
                    <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">${percentage}%</div>
                </div>
            `;
        });
    }
    
    // Store skills data globally for pagination
    window.currentSkillsData = skills;
    window.currentPage = 1;
    window.skillsPerPage = 50;

    // Initialize paginated skills table with smaller page size for performance
    window.skillsPerPage = 25; // Reduced from 50 for faster rendering
    renderSkillsPage(skills, 1, window.skillsPerPage);

    // Show the modal
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden'; // Prevent background scrolling

    console.log(`✅ Displaying ${skills.length} assessment results`);
}

// Efficient pagination rendering function
function renderSkillsPage(skills, page, pageSize) {
    const tbody = document.getElementById('modal-skills-tbody');
    if (!tbody || !skills || skills.length === 0) return;

    const startIndex = (page - 1) * pageSize;
    const endIndex = Math.min(startIndex + pageSize, skills.length);
    const pageSkills = skills.slice(startIndex, endIndex);

    // Build all rows in one string to minimize DOM manipulation
    let htmlContent = '';

    pageSkills.forEach((skill, index) => {
        const skillName = skill.skill_name || skill.name || skill.skill || '-';
        const proficiency = skill.proficiency || skill.proficiency_level || '-';
        const level = skill.level || skill.proficiency_level || skill.proficiency || '-';
        const confidence = skill.confidence_score || skill.confidence || 0;
        const reasoning = skill.reasoning || skill.explanation || skill.reason || '';

        const levelColors = {
            'Novice': 'text-blue-600 bg-blue-100 dark:bg-blue-900/30 dark:text-blue-400',
            'Developing': 'text-cyan-600 bg-cyan-100 dark:bg-cyan-900/30 dark:text-cyan-400',
            'Intermediate': 'text-yellow-600 bg-yellow-100 dark:bg-yellow-900/30 dark:text-yellow-400',
            'Advanced': 'text-green-600 bg-green-100 dark:bg-green-900/30 dark:text-green-400',
            'Expert': 'text-purple-600 bg-purple-100 dark:bg-purple-900/30 dark:text-purple-400'
        };

        const levelClass = levelColors[level] || 'text-gray-600 bg-gray-100 dark:bg-gray-700 dark:text-gray-400';
        const actualIndex = startIndex + index;

        htmlContent += `
            <tr class="${actualIndex % 2 === 0 ? 'bg-gray-50 dark:bg-gray-700/50' : ''}">
                <td class="px-4 py-3 text-sm font-medium text-gray-900 dark:text-white">
                    ${skillName}
                </td>
                <td class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300 text-center">
                    ${proficiency}
                </td>
                <td class="px-4 py-3 text-center">
                    <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full ${levelClass}">
                        ${level}
                    </span>
                </td>
                <td class="px-4 py-3 text-sm">
                    <div class="flex items-center">
                        <div class="w-16 bg-gray-200 dark:bg-gray-600 rounded-full h-2 mr-2">
                            <div class="bg-blue-600 h-2 rounded-full" style="width: ${confidence * 100}%"></div>
                        </div>
                        <span class="text-gray-700 dark:text-gray-300">${(confidence * 100).toFixed(0)}%</span>
                    </div>
                </td>
                <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-400">
                    <div class="max-w-md">
                        ${reasoning ? `
                            <div class="cursor-help" title="${reasoning.replace(/"/g, '&quot;')}">
                                ${reasoning.length > 150 ? reasoning.substring(0, 150) + '...' : reasoning}
                            </div>
                        ` : '<span class="text-gray-400 italic">No reasoning provided</span>'}
                    </div>
                </td>
            </tr>
        `;
    });

    // Set innerHTML once instead of appending in loop - MUCH faster
    tbody.innerHTML = htmlContent;

    // Update pagination controls
    updatePaginationControls(skills.length, page, pageSize);
}

// Update pagination controls
function updatePaginationControls(totalItems, currentPage, pageSize) {
    const totalPages = Math.ceil(totalItems / pageSize);
    const startItem = ((currentPage - 1) * pageSize) + 1;
    const endItem = Math.min(currentPage * pageSize, totalItems);

    // Update pagination info
    const paginationInfo = document.getElementById('pagination-info');
    if (paginationInfo) {
        paginationInfo.textContent = `Showing ${startItem}-${endItem} of ${totalItems} skills`;
    }

    // Update pagination buttons and page display
    const prevBtn = document.getElementById('prev-page-btn');
    const nextBtn = document.getElementById('next-page-btn');
    const currentPageDisplay = document.getElementById('current-page-display');
    const totalPagesDisplay = document.getElementById('total-pages-display');

    if (prevBtn) prevBtn.disabled = currentPage <= 1;
    if (nextBtn) nextBtn.disabled = currentPage >= totalPages;
    if (currentPageDisplay) currentPageDisplay.textContent = currentPage;
    if (totalPagesDisplay) totalPagesDisplay.textContent = totalPages;
}

// Navigation functions
function goToPreviousPage() {
    if (window.currentPage > 1) {
        window.currentPage--;
        renderSkillsPage(window.currentSkillsData, window.currentPage, window.skillsPerPage);
    }
}

function goToNextPage() {
    const totalPages = Math.ceil(window.currentSkillsData.length / window.skillsPerPage);
    if (window.currentPage < totalPages) {
        window.currentPage++;
        renderSkillsPage(window.currentSkillsData, window.currentPage, window.skillsPerPage);
    }
}

// Export pagination functions to global scope
window.goToPreviousPage = goToPreviousPage;
window.goToNextPage = goToNextPage;

// Function to close the assessment modal
function closeAssessmentModal() {
    const modal = document.getElementById('assessment-results-modal');
    if (modal) {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        modal.style.display = '';
    }
}

// Function to export assessment results
function exportAssessmentResults() {
    const data = workflowState.step6Data || workflowState.assessmentResults;
    if (!data) {
        showNotification('No assessment results to export', 'warning');
        return;
    }
    
    const exportData = {
        timestamp: new Date().toISOString(),
        ...data
    };
    
    const blob = new Blob([JSON.stringify(exportData, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `assessment_results_${Date.now()}.json`;
    a.click();
    URL.revokeObjectURL(url);
    
    showNotification('Assessment results exported successfully', 'success');
}

