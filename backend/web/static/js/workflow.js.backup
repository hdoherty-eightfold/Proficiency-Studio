// Save prompt template
window.savePromptTemplate = function() {
    const promptField = document.getElementById('assessment-prompt');
    if (!promptField) return;
    
    const promptContent = promptField.value.trim();
    if (!promptContent) {
        showNotification('Prompt template is empty', 'warning');
        return;
    }
    
    // Store the prompt template for use by LLM and LangChain
    workflowState.savedPromptTemplate = promptContent;
    localStorage.setItem('langchain_prompt_template', promptContent);
    
    showNotification('Prompt template saved successfully', 'success');
};

// Reset prompt template
async function resetPromptTemplate() {
    try {
        const response = await fetch('/api/settings/assessment');
        const settings = await response.json();
        
        const promptField = document.getElementById('assessment-prompt');
        if (promptField && settings.proficiency_prompt) {
            promptField.value = settings.proficiency_prompt;
            showNotification('Prompt template reset to default version', 'info');
        }
    } catch (error) {
        console.error('Error resetting prompt template:', error);
        showNotification('Error resetting prompt template', 'error');
    }
}

// Test selected LLM with model discovery
async function testSelectedLLM() {
    const provider = document.getElementById('llm-provider').value;
    const apiKey = document.getElementById('llm-api-key').value;
    
    if (!apiKey) {
        showNotification('Please enter an API key', 'error');
        return;
    }
    
    const startTime = Date.now();
    showNotification(`Testing ${provider} API...`, 'info');
    
    try {
        // First save the key
        const saveResponse = await fetch('/api/keys/update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ [provider]: apiKey })
        });
        
        if (!saveResponse.ok) {
            throw new Error('Failed to save API key');
        }
        
        // Then test it and get models
        const response = await fetch('/api/keys/test-with-models', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ provider: provider })
        });
        
        const result = await response.json();
        const responseTime = Date.now() - startTime;
        
        // Show API test modal
        showApiTestModal(provider, result, responseTime);
        
        if (result.status === 'success' && result.models) {
            // Update available models
            availableModels[provider] = result.models;
            updateModelSelection();
            
            workflowState.llmConfigured = true;
            showNotification(`${provider} configured successfully with ${result.models.length} models`, 'success');
        } else {
            showNotification(`${provider} test failed: ${result.message}`, 'error');
        }
    } catch (error) {
        showNotification(`Error testing ${provider}: ${error.message}`, 'error');
    }
}

// Show API test modal
// Helper function to check if model supports JSON response format
function supportsJsonFormat(model) {
    const supportedModels = [
        'gpt-4', 'gpt-4-turbo', 'gpt-4-turbo-preview', 
        'gpt-4-0613', 'gpt-4-32k', 'gpt-4-32k-0613',
        'gpt-3.5-turbo', 'gpt-3.5-turbo-16k', 'gpt-3.5-turbo-0125',
        'gpt-3.5-turbo-1106'
    ];
    return supportedModels.some(supported => model.includes(supported));
}

function showApiTestModal(provider, result, responseTime) {
    const modal = document.getElementById('api-test-modal');
    
    // Update provider info
    document.getElementById('test-provider').textContent = provider.toUpperCase();
    document.getElementById('test-endpoint').textContent = result.endpoint || 'N/A';
    document.getElementById('test-response-time').textContent = `${responseTime}ms`;
    
    // Update status with color
    const statusEl = document.getElementById('test-status');
    if (result.status === 'success') {
        statusEl.innerHTML = '<span class="text-green-600">✅ Success</span>';
    } else {
        statusEl.innerHTML = '<span class="text-red-600">❌ Failed</span>';
    }
    
    // Update models list with JSON format support indication
    const modelsList = document.getElementById('test-models-list');
    if (result.models && result.models.length > 0) {
        const jsonSupportedCount = result.models.filter(model => supportsJsonFormat(model)).length;
        
        // Add summary info
        let summaryHtml = '';
        if (provider === 'openai' && jsonSupportedCount > 0) {
            summaryHtml = `<div class="mb-3 p-2 bg-blue-50 rounded text-xs">
                <i class="fas fa-info-circle text-blue-500 mr-1"></i>
                ${jsonSupportedCount} of ${result.models.length} models support structured JSON output
            </div>`;
        }
        
        modelsList.innerHTML = summaryHtml + result.models.map(model => {
            const jsonSupported = supportsJsonFormat(model);
            const jsonIcon = jsonSupported ? 
                '<i class="fas fa-code text-green-500 ml-2" title="Supports JSON response format"></i>' : 
                '<i class="fas fa-times text-gray-300 ml-2" title="Does not support JSON response format"></i>';
            
            return `<div class="flex items-center justify-between">
                <div class="flex items-center">
                    <i class="fas fa-robot text-gray-400 mr-2"></i>
                    <span>${model}</span>
                </div>
                ${provider === 'openai' ? jsonIcon : ''}
            </div>`;
        }).join('');
    } else {
        modelsList.innerHTML = '<div class="text-gray-500">No models available</div>';
    }
    
    // Initialize JSON viewer for response
    if (!workflowState.apiTestViewer) {
        workflowState.apiTestViewer = new JsonViewer('api-test-response-viewer', {
            theme: 'dark',
            searchable: true,
            copyable: true,
            maxHeight: '300px'
        });
    }
    workflowState.apiTestViewer.setJson(result, { filename: 'api_test_response' });
    
    modal.classList.remove('hidden');
}

// Close API test modal
function closeApiTestModal() {
    document.getElementById('api-test-modal').classList.add('hidden');
}

// ===============================================
// Step 6: Update JIE Roles Functions
// ===============================================

// Handle role selection change
window.onRoleSelectionChange = function() {
    const roleSelect = document.getElementById('update-role-select');
    const selectedRole = roleSelect.value;
    
    if (!selectedRole) {
        document.getElementById('update-preview-json').textContent = 'Select a role to preview update payload';
        return;
    }
    
    // Find the selected role in our stored roles
    const role = workflowState.jieRoles?.find(r => r.id === selectedRole || r.title === selectedRole);
    
    if (role) {
        // Store selected role for update
        workflowState.selectedRoleForUpdate = role;
        
        // Update preview with current assessment results
        updatePreviewJson();
    }
};

// Authenticate for role update
window.authenticateForUpdate = async function() {
    const statusText = document.getElementById('update-auth-status-text');
    const authenticateBtn = document.getElementById('authenticate-update-btn');
    
    try {
        authenticateBtn.disabled = true;
        statusText.textContent = 'Authenticating...';
        statusText.className = 'text-blue-600';
        
        // Use existing authentication or request new token
        if (workflowState.eightfoldToken) {
            statusText.textContent = 'Authenticated';
            statusText.className = 'text-green-600';
            showNotification('Already authenticated', 'success');
            return;
        }
        
        // Get credentials
        const clientId = document.getElementById('eightfold-client-id').value;
        const clientSecret = document.getElementById('eightfold-client-secret').value;
        
        if (!clientId || !clientSecret) {
            throw new Error('Please enter Eightfold credentials first');
        }
        
        // Authenticate with Eightfold - this looks like it's using different parameters
        // Need to update this to match the expected format
        const response = await fetch('/api/eightfold/authenticate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                username: clientId,  // Map client_id to username
                password: clientSecret,  // Map client_secret to password
                api_url: 'https://apiv2.eightfold.ai'
            })
        });
        
        const result = await response.json();
        
        if (result.success && result.auth_response?.bearer_token) {
            workflowState.eightfoldToken = result.auth_response.bearer_token;
            // Also store in sessionStorage for persistence
            sessionStorage.setItem('eightfold_token', result.auth_response.bearer_token);
            window.eightfoldAuthToken = result.auth_response.bearer_token;  // Global fallback
            statusText.textContent = 'Authenticated';
            statusText.className = 'text-green-600';
            showNotification('Authentication successful', 'success');
        } else {
            throw new Error(result.detail || result.message || 'Authentication failed');
        }
        
    } catch (error) {
        statusText.textContent = 'Authentication failed';
        statusText.className = 'text-red-600';
        showNotification('Authentication failed: ' + error.message, 'error');
    } finally {
        authenticateBtn.disabled = false;
    }
};

// Update preview JSON based on options
window.updatePreviewJson = function() {
    const previewElement = document.getElementById('update-preview-json');
    const selectedRole = workflowState.selectedRoleForUpdate;
    
    if (!selectedRole) {
        previewElement.textContent = 'Select a role first';
        return;
    }
    
    // Get update options
    const updateProficiencies = document.getElementById('update-proficiencies-check').checked;
    const useAssessmentResults = document.getElementById('use-assessment-results-check').checked;
    
    // Build update payload
    const updatePayload = {
        role_id: selectedRole.id || selectedRole.title,
        title: selectedRole.title,
        updates: {}
    };
    
    // Get skills with proficiencies from assessment results or UI
    const skills = [];
    
    if (useAssessmentResults && workflowState.lastAssessmentResults) {
        // Use assessment results from LangChain
        const assessments = workflowState.lastAssessmentResults.assessments || [];
        assessments.forEach(assessment => {
            const skill = {
                name: assessment.skill_name
            };
            
            if (updateProficiencies && assessment.proficiency_numeric) {
                skill.proficiency = assessment.proficiency_numeric;
            }
            
            if (updateLevels && assessment.proficiency_level) {
                skill.level = assessment.proficiency_level;
            }
            
            skills.push(skill);
        });
    } else {
        // Use configured proficiencies from UI
        const proficiencyValues = Array.from(document.querySelectorAll('.proficiency-value-input')).map(input => ({
            level: parseInt(input.dataset.level),
            label: input.value
        }));
        
        const levelValues = Array.from(document.querySelectorAll('.level-value-input')).map(input => input.value);
        
        // Sample skills for preview (would use actual role skills in production)
        const sampleSkills = selectedRole.skillProficiencies?.slice(0, 5) || [
            { name: 'Python' },
            { name: 'Machine Learning' },
            { name: 'Data Analysis' }
        ];
        
        sampleSkills.forEach(skill => {
            const updatedSkill = {
                name: skill.name
            };
            
            if (updateProficiencies) {
                // Assign random proficiency for demo
                updatedSkill.proficiency = Math.floor(Math.random() * 5) + 1;
            }
            
            if (updateLevels) {
                // Assign random level for demo
                const randomLevel = levelValues[Math.floor(Math.random() * levelValues.length)];
                updatedSkill.level = randomLevel || 'Intermediate';
            }
            
            skills.push(updatedSkill);
        });
    }
    
    updatePayload.updates.skillProficiencies = skills;
    
    // Add metadata
    updatePayload.metadata = {
        updated_at: new Date().toISOString(),
        update_source: 'skills_proficiency_generator',
        assessment_method: useAssessmentResults ? 'langchain_assessment' : 'manual_configuration'
    };
    
    // Display formatted JSON
    previewElement.textContent = JSON.stringify(updatePayload, null, 2);
    
    // Store for later use
    workflowState.roleUpdatePayload = updatePayload;
};

// Execute role update
window.executeRoleUpdate = async function() {
    const executeBtn = document.getElementById('execute-update-btn');
    const statusText = document.getElementById('update-status-text');
    const progressBar = document.getElementById('update-progress-bar');
    const progressContainer = document.getElementById('update-progress-container');
    
    try {
        // Validate authentication
        if (!workflowState.eightfoldToken) {
            throw new Error('Please authenticate first');
        }
        
        // Validate payload
        if (!workflowState.roleUpdatePayload) {
            throw new Error('Please select a role and configure update options');
        }
        
        executeBtn.disabled = true;
        statusText.textContent = 'Updating role...';
        statusText.className = 'text-blue-600';
        progressContainer.classList.remove('hidden');
        progressBar.style.width = '30%';
        
        // Make API call to update role
        const response = await fetch('/api/eightfold/update-role', {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${workflowState.eightfoldToken}`
            },
            body: JSON.stringify(workflowState.roleUpdatePayload)
        });
        
        progressBar.style.width = '70%';
        
        const result = await response.json();
        
        progressBar.style.width = '100%';
        
        if (response.ok && result.success) {
            statusText.textContent = 'Role updated successfully';
            statusText.className = 'text-green-600';
            showNotification('Role updated successfully', 'success');
            
            // Store update result
            workflowState.lastRoleUpdateResult = result;
            
            // Log the update
            // Role update successful
            
        } else {
            throw new Error(result.detail || result.error || 'Update failed');
        }
        
    } catch (error) {
        statusText.textContent = 'Update failed: ' + error.message;
        statusText.className = 'text-red-600';
        showNotification('Role update failed: ' + error.message, 'error');
        // Role update error
    } finally {
        executeBtn.disabled = false;
        
        // Hide progress after 3 seconds
        setTimeout(() => {
            progressContainer.classList.add('hidden');
            progressBar.style.width = '0%';
        }, 3000);
    }
};

// Preview update payload (opens modal)
window.previewUpdatePayload = function() {
    // First update the preview
    updatePreviewJson();
    
    // Create and show modal with the payload
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50';
    modal.innerHTML = `
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-xl max-w-4xl w-full mx-4 max-h-[80vh] overflow-hidden">
            <div class="p-6 border-b border-gray-200 dark:border-gray-700">
                <div class="flex justify-between items-center">
                    <h3 class="text-xl font-bold text-gray-900 dark:text-white">
                        <i class="fas fa-code text-blue-600 mr-2"></i>
                        Update Payload Preview
                    </h3>
                    <button onclick="this.closest('.fixed').remove()" class="text-gray-500 hover:text-gray-700">
                        <i class="fas fa-times text-xl"></i>
                    </button>
                </div>
            </div>
            <div class="p-6 overflow-y-auto" style="max-height: calc(80vh - 200px);">
                <pre class="bg-gray-100 dark:bg-gray-900 p-4 rounded-lg overflow-x-auto text-sm">
                    <code class="language-json">${escapeHtml(JSON.stringify(workflowState.roleUpdatePayload || {}, null, 2))}</code>
                </pre>
                <div class="mt-4 p-4 bg-blue-50 dark:bg-blue-900 rounded-lg">
                    <h4 class="font-semibold text-blue-900 dark:text-blue-100 mb-2">
                        <i class="fas fa-info-circle mr-2"></i>Payload Details
                    </h4>
                    <ul class="text-sm text-blue-800 dark:text-blue-200 space-y-1">
                        <li>• Role: ${workflowState.selectedRoleForUpdate?.title || 'Not selected'}</li>
                        <li>• Skills to update: ${workflowState.roleUpdatePayload?.updates?.skillProficiencies?.length || 0}</li>
                        <li>• Update proficiencies: ${document.getElementById('update-proficiencies-check')?.checked ? 'Yes' : 'No'}</li>
                        <li>• Using assessment results: ${document.getElementById('use-assessment-results-check')?.checked ? 'Yes' : 'No'}</li>
                    </ul>
                </div>
            </div>
            <div class="p-6 border-t border-gray-200 dark:border-gray-700 flex justify-end gap-2">
                <button onclick="this.closest('.fixed').remove()" 
                        class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300">
                    Close
                </button>
                <button onclick="navigator.clipboard.writeText(JSON.stringify(${JSON.stringify(workflowState.roleUpdatePayload || {})}, null, 2)); showNotification('Copied to clipboard', 'success'); this.closest('.fixed').remove();" 
                        class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
                    <i class="fas fa-copy mr-2"></i>Copy JSON
                </button>
            </div>
        </div>
    `;
    document.body.appendChild(modal);
};

// Helper function to escape HTML
function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

// Populate role dropdown for Step 6
function populateRoleDropdown(roles) {
    const roleSelect = document.getElementById('update-role-select');
    if (!roleSelect) return;
    
    // Clear existing options except the first one
    roleSelect.innerHTML = '<option value="">Select a role to update</option>';
    
    // Add roles to dropdown
    roles.forEach(role => {
        const option = document.createElement('option');
        option.value = role.id || role.title;
        option.textContent = role.title || 'Unnamed Role';
        
        // Add skill count to the option text
        const skillCount = role.skillProficiencies?.length || 0;
        if (skillCount > 0) {
            option.textContent += ` (${skillCount} skills)`;
        }
        
        roleSelect.appendChild(option);
    });
    
    // Enable the dropdown
    roleSelect.disabled = false;
    
    // Populated role dropdown
}

// ===============================================
// Advanced Role Management Functions
// ===============================================

// Copy prompt to clipboard function
function copyPromptToClipboard() {
    const promptTextarea = document.getElementById('assessment-prompt');
    if (promptTextarea && promptTextarea.value) {
        navigator.clipboard.writeText(promptTextarea.value).then(() => {
            showNotification('Prompt copied to clipboard', 'success');
        }).catch(() => {
            // Fallback for older browsers
            promptTextarea.select();
            document.execCommand('copy');
            showNotification('Prompt copied to clipboard', 'success');
        });
    } else {
        showNotification('No prompt text to copy', 'warning');
    }
}

// Global state for role management
let roleManagementState = {
    sourceEnvironment: null,
    destEnvironment: null,
    sourceAuth: null,
    destAuth: null,
    sourceRoles: [],
    currentOperation: null,
    selectedRole: null
};

// Environment change handlers
window.onSourceEnvironmentChange = function() {
    const env = document.getElementById('source-environment').value;
    roleManagementState.sourceEnvironment = env;
    
    if (env && sandboxConfigs[env]) {
        // Auto-load credentials if available
        const config = sandboxConfigs[env];
        // Source environment set
    }
    
    updateAuthStatus();
    clearSourceRoles();
};

window.onDestEnvironmentChange = function() {
    const env = document.getElementById('dest-environment').value;
    roleManagementState.destEnvironment = env;
    
    if (env && sandboxConfigs[env]) {
        const config = sandboxConfigs[env];
        // Destination environment set
    }
    
    updateAuthStatus();
};

// Operation change handler
window.onOperationChange = function() {
    const operation = document.getElementById('role-operation').value;
    roleManagementState.currentOperation = operation;
    
    // Show/hide sections based on operation
    const roleSelectionSection = document.getElementById('role-selection-section');
    const newRoleSection = document.getElementById('new-role-section');
    const transferMatrix = document.getElementById('transfer-matrix');
    const executeBtn = document.getElementById('execute-operation-btn');
    
    // Reset visibility
    roleSelectionSection.classList.add('hidden');
    newRoleSection.classList.add('hidden');
    transferMatrix.classList.add('hidden');
    executeBtn.disabled = true;
    
    switch (operation) {
        case 'create':
            newRoleSection.classList.remove('hidden');
            updateOperationPreview();
            break;
        case 'update':
        case 'delete':
            roleSelectionSection.classList.remove('hidden');
            updateOperationPreview();
            break;
        case 'transfer':
            roleSelectionSection.classList.remove('hidden');
            newRoleSection.classList.remove('hidden');
            transferMatrix.classList.remove('hidden');
            updateOperationPreview();
            break;
    }
    
    // Enable execute button if operation is selected
    if (operation) {
        executeBtn.disabled = false;
    }
};

// Authentication functions
window.authenticateSource = async function() {
    const env = roleManagementState.sourceEnvironment;
    if (!env || !sandboxConfigs[env]) {
        showNotification('Please select a valid source environment first', 'error');
        return;
    }
    
    try {
        const config = sandboxConfigs[env];
        const authPayload = {
            username: config.username,
            password: config.password,
            api_url: config.apiUrl
        };
        
        // Add custom grant type and auth header for specific environments
        if (config.grantType) {
            authPayload.grant_type = config.grantType;
        }
        if (config.authHeader) {
            authPayload.auth_header = config.authHeader;
        }
        
        const response = await fetch('/api/eightfold/authenticate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(authPayload)
        });
        
        const result = await response.json();
        
        if (result.success && result.auth_response?.bearer_token) {
            roleManagementState.sourceAuth = result.auth_response.bearer_token;
            updateAuthStatus();
            showNotification(`Source authentication successful: ${config.name}`, 'success');
        } else {
            throw new Error(result.detail || 'Authentication failed');
        }
    } catch (error) {
        showNotification(`Source authentication failed: ${error.message}`, 'error');
    }
};

window.authenticateDest = async function() {
    const env = roleManagementState.destEnvironment;
    if (!env || !sandboxConfigs[env]) {
        showNotification('Please select a valid destination environment first', 'error');
        return;
    }
    
    try {
        const config = sandboxConfigs[env];
        const authPayload = {
            username: config.username,
            password: config.password,
            api_url: config.apiUrl
        };
        
        // Add custom grant type and auth header for specific environments
        if (config.grantType) {
            authPayload.grant_type = config.grantType;
        }
        if (config.authHeader) {
            authPayload.auth_header = config.authHeader;
        }
        
        const response = await fetch('/api/eightfold/authenticate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(authPayload)
        });
        
        const result = await response.json();
        
        if (result.success && result.auth_response?.bearer_token) {
            roleManagementState.destAuth = result.auth_response.bearer_token;
            updateAuthStatus();
            showNotification(`Destination authentication successful: ${config.name}`, 'success');
        } else {
            throw new Error(result.detail || 'Authentication failed');
        }
    } catch (error) {
        showNotification(`Destination authentication failed: ${error.message}`, 'error');
    }
};

// Update authentication status display
function updateAuthStatus() {
    const sourceStatus = document.getElementById('source-auth-status');
    const destStatus = document.getElementById('dest-auth-status');
    
    if (sourceStatus) {
        sourceStatus.textContent = roleManagementState.sourceAuth ? 'Authenticated' : 'Not authenticated';
        sourceStatus.className = roleManagementState.sourceAuth ? 'text-green-600' : 'text-red-600';
    }
    
    if (destStatus) {
        destStatus.textContent = roleManagementState.destAuth ? 'Authenticated' : 'Not authenticated';
        destStatus.className = roleManagementState.destAuth ? 'text-green-600' : 'text-red-600';
    }
}

// Load roles from source environment
window.loadSourceRoles = async function() {
    if (!roleManagementState.sourceAuth) {
        showNotification('Please authenticate source environment first', 'error');
        return;
    }
    
    try {
        const apiBaseUrl = getEightfoldApiUrl();
        
        // Use proxy to avoid CORS issues
        const proxyRequest = {
            endpoint: '/api/v2/JIE/roles?limit=100',
            method: 'GET',
            headers: {
                'Authorization': `Bearer ${roleManagementState.sourceAuth}`,
                'Content-Type': 'application/json',
                'Accept': 'application/json'
            },
            base_url: apiBaseUrl
        };
        
        const response = await fetch('/api/eightfold/proxy', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(proxyRequest)
        });
        
        const result = await response.json();
        
        // Direct API response - data is at root level
        if (response.ok && result.data) {
            roleManagementState.sourceRoles = result.data;
            populateOperationRoleDropdown(result.data);
            showNotification(`Loaded ${result.data.length} roles from source environment`, 'success');
        } else {
            throw new Error(result.message || 'Failed to load roles');
        }
    } catch (error) {
        showNotification(`Failed to load source roles: ${error.message}`, 'error');
    }
};

// Populate the operation role dropdown
function populateOperationRoleDropdown(roles) {
    const roleSelect = document.getElementById('operation-role-select');
    if (!roleSelect) return;
    
    roleSelect.innerHTML = '<option value="">Select a role...</option>';
    
    roles.forEach(role => {
        const option = document.createElement('option');
        option.value = role.id || role.title;
        option.textContent = role.title || 'Unnamed Role';
        
        const skillCount = role.skillProficiencies?.length || 0;
        if (skillCount > 0) {
            option.textContent += ` (${skillCount} skills)`;
        }
        
        roleSelect.appendChild(option);
    });
}

// Clear source roles
function clearSourceRoles() {
    roleManagementState.sourceRoles = [];
    const roleSelect = document.getElementById('operation-role-select');
    if (roleSelect) {
        roleSelect.innerHTML = '<option value="">No roles loaded...</option>';
    }
}

// Update operation preview
function updateOperationPreview() {
    const operation = roleManagementState.currentOperation;
    const endpointSpan = document.getElementById('operation-endpoint');
    const payloadPre = document.getElementById('operation-payload-preview');
    
    if (!operation || !endpointSpan || !payloadPre) return;
    
    let endpoint = '';
    let payload = {};
    
    switch (operation) {
        case 'create':
            endpoint = 'POST /api/v2/JIE/roles';
            payload = {
                title: document.getElementById('new-role-title')?.value || 'New Role Title',
                skillProficiencies: []
            };
            break;
        case 'update':
            endpoint = 'PUT /api/v2/JIE/roles/{role_id}';
            payload = {
                title: 'Updated Role Title',
                skillProficiencies: []
            };
            break;
        case 'delete':
            endpoint = 'DELETE /api/v2/JIE/roles/{role_id}';
            payload = { message: 'Delete operation - no payload needed' };
            break;
        case 'transfer':
            endpoint = 'POST /api/v2/JIE/roles (destination)';
            payload = {
                title: document.getElementById('new-role-title')?.value || 'Transferred Role',
                skillProficiencies: [],
                metadata: {
                    transferredFrom: 'source_environment',
                    originalId: 'source_role_id'
                }
            };
            break;
    }
    
    endpointSpan.textContent = `Endpoint: ${endpoint}`;
    payloadPre.textContent = JSON.stringify(payload, null, 2);
}

// Execute the selected operation
window.executeRoleOperation = async function() {
    const operation = roleManagementState.currentOperation;
    if (!operation) {
        showNotification('Please select an operation first', 'error');
        return;
    }
    
    setOperationStatus('running', 'Executing operation...');
    
    try {
        switch (operation) {
            case 'create':
                await executeCreateRole();
                break;
            case 'update':
                await executeUpdateRole();
                break;
            case 'delete':
                await executeDeleteRole();
                break;
            case 'transfer':
                await executeTransferRole();
                break;
        }
    } catch (error) {
        setOperationStatus('error', `Operation failed: ${error.message}`);
    }
};

// Set operation status
function setOperationStatus(status, message) {
    const statusDiv = document.getElementById('operation-status');
    const statusIcon = document.getElementById('operation-status-icon');
    const statusText = document.getElementById('operation-status-text');
    const progressDiv = document.getElementById('operation-progress');
    const progressBar = document.getElementById('operation-progress-bar');
    
    if (!statusDiv || !statusIcon || !statusText) return;
    
    statusDiv.classList.remove('hidden');
    statusText.textContent = message;
    
    const icons = {
        running: '<i class="fas fa-spinner fa-spin text-blue-600"></i>',
        success: '<i class="fas fa-check-circle text-green-600"></i>',
        error: '<i class="fas fa-exclamation-circle text-red-600"></i>'
    };
    
    statusIcon.innerHTML = icons[status] || '';
    
    if (status === 'running' && progressDiv && progressBar) {
        progressDiv.classList.remove('hidden');
        progressBar.style.width = '50%';
    } else if (progressDiv) {
        progressDiv.classList.add('hidden');
    }
}

// Copy operation payload
window.copyOperationPayload = function() {
    const payload = document.getElementById('operation-payload-preview').textContent;
    navigator.clipboard.writeText(payload).then(() => {
        showNotification('Payload copied to clipboard', 'success');
    });
};

// Individual operation implementations
async function executeCreateRole() {
    const title = document.getElementById('new-role-title')?.value;
    if (!title) {
        throw new Error('Please enter a role title');
    }
    
    if (!roleManagementState.destAuth) {
        throw new Error('Please authenticate destination environment first');
    }
    
    try {
        const response = await fetch('/api/eightfold/create-role', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${roleManagementState.destAuth}`
            },
            body: JSON.stringify({
                title: title,
                skillProficiencies: [],
                headers: {
                    'Authorization': `Bearer ${roleManagementState.destAuth}`
                }
            })
        });
        
        const result = await response.json();
        
        if (result.success) {
            setOperationStatus('success', `Role "${title}" created successfully`);
            showNotification(`Role "${title}" created successfully`, 'success');
        } else {
            throw new Error(result.detail || result.error || 'Create failed');
        }
    } catch (error) {
        throw new Error(`Create role failed: ${error.message}`);
    }
}

async function executeUpdateRole() {
    const roleId = document.getElementById('operation-role-select')?.value;
    if (!roleId) {
        throw new Error('Please select a role to update');
    }
    
    if (!roleManagementState.destAuth) {
        throw new Error('Please authenticate destination environment first');
    }
    
    // Find the selected role
    const selectedRole = roleManagementState.sourceRoles.find(r => 
        (r.id || r.title) === roleId
    );
    
    if (!selectedRole) {
        throw new Error('Selected role not found');
    }
    
    try {
        const response = await fetch('/api/eightfold/update-role', {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${roleManagementState.destAuth}`
            },
            body: JSON.stringify({
                role_id: roleId,
                title: selectedRole.title,
                updates: {
                    skillProficiencies: selectedRole.skillProficiencies || []
                },
                headers: {
                    'Authorization': `Bearer ${roleManagementState.destAuth}`
                }
            })
        });
        
        const result = await response.json();
        
        if (result.success) {
            setOperationStatus('success', `Role "${selectedRole.title}" updated successfully`);
            showNotification(`Role "${selectedRole.title}" updated successfully`, 'success');
        } else {
            throw new Error(result.detail || result.error || 'Update failed');
        }
    } catch (error) {
        throw new Error(`Update role failed: ${error.message}`);
    }
}

async function executeDeleteRole() {
    const roleId = document.getElementById('operation-role-select')?.value;
    if (!roleId) {
        throw new Error('Please select a role to delete');
    }
    
    if (!roleManagementState.sourceAuth) {
        throw new Error('Please authenticate source environment first');
    }
    
    // Find the selected role for confirmation
    const selectedRole = roleManagementState.sourceRoles.find(r => 
        (r.id || r.title) === roleId
    );
    
    const roleName = selectedRole?.title || roleId;
    
    // Confirm deletion
    if (!confirm(`Are you sure you want to delete the role "${roleName}"? This action cannot be undone.`)) {
        setOperationStatus('error', 'Operation cancelled by user');
        return;
    }
    
    try {
        const response = await fetch('/api/eightfold/delete-role', {
            method: 'DELETE',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${roleManagementState.sourceAuth}`
            },
            body: JSON.stringify({
                role_id: roleId,
                headers: {
                    'Authorization': `Bearer ${roleManagementState.sourceAuth}`
                }
            })
        });
        
        const result = await response.json();
        
        if (result.success) {
            setOperationStatus('success', `Role "${roleName}" deleted successfully`);
            showNotification(`Role "${roleName}" deleted successfully`, 'success');
            
            // Reload source roles to reflect the deletion
            loadSourceRoles();
        } else {
            throw new Error(result.detail || result.error || 'Delete failed');
        }
    } catch (error) {
        throw new Error(`Delete role failed: ${error.message}`);
    }
}

async function executeTransferRole() {
    const roleId = document.getElementById('operation-role-select')?.value;
    const newTitle = document.getElementById('new-role-title')?.value;
    
    if (!roleId || !newTitle) {
        throw new Error('Please select a source role and enter a new title');
    }
    
    if (!roleManagementState.sourceAuth || !roleManagementState.destAuth) {
        throw new Error('Please authenticate both source and destination environments');
    }
    
    // Find the source role
    const sourceRole = roleManagementState.sourceRoles.find(r => 
        (r.id || r.title) === roleId
    );
    
    if (!sourceRole) {
        throw new Error('Source role not found');
    }
    
    try {
        // Step 1: Create the role in destination environment
        const createResponse = await fetch('/api/eightfold/create-role', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${roleManagementState.destAuth}`
            },
            body: JSON.stringify({
                title: newTitle,
                skillProficiencies: sourceRole.skillProficiencies || [],
                metadata: {
                    transferredFrom: roleManagementState.sourceEnvironment,
                    originalId: sourceRole.id || sourceRole.title,
                    originalTitle: sourceRole.title,
                    transferDate: new Date().toISOString()
                },
                headers: {
                    'Authorization': `Bearer ${roleManagementState.destAuth}`
                }
            })
        });
        
        const createResult = await createResponse.json();
        
        if (createResult.success) {
            const skillCount = sourceRole.skillProficiencies?.length || 0;
            setOperationStatus('success', 
                `Role "${sourceRole.title}" transferred as "${newTitle}" with ${skillCount} skills`);
            showNotification(
                `Role transferred successfully: "${sourceRole.title}" → "${newTitle}" (${skillCount} skills)`, 
                'success'
            );
            
            // Update transfer matrix preview
            updateTransferPreview(sourceRole, newTitle);
        } else {
            throw new Error(createResult.detail || createResult.error || 'Transfer failed');
        }
    } catch (error) {
        throw new Error(`Transfer role failed: ${error.message}`);
    }
}

// Update transfer preview
function updateTransferPreview(sourceRole, newTitle) {
    const sourcePreview = document.getElementById('source-role-preview');
    const destPreview = document.getElementById('dest-role-preview');
    
    if (sourcePreview && sourceRole) {
        const skillCount = sourceRole.skillProficiencies?.length || 0;
        sourcePreview.innerHTML = `
            <div class="font-medium">${sourceRole.title}</div>
            <div class="text-xs text-gray-500 mt-1">
                ID: ${sourceRole.id || 'N/A'}<br>
                Skills: ${skillCount}<br>
                Environment: ${roleManagementState.sourceEnvironment}
            </div>
        `;
    }
    
    if (destPreview && newTitle) {
        destPreview.innerHTML = `
            <div class="font-medium text-green-700">${newTitle}</div>
            <div class="text-xs text-gray-500 mt-1">
                Status: Ready to create<br>
                Skills: Will copy ${sourceRole?.skillProficiencies?.length || 0}<br>
                Environment: ${roleManagementState.destEnvironment}
            </div>
        `;
    }
}

// Python Script Functions
window.togglePythonScript = function() {
    const content = document.getElementById('python-script-content');
    const toggle = document.getElementById('python-script-toggle');
    
    if (content.classList.contains('hidden')) {
        content.classList.remove('hidden');
        toggle.classList.add('rotate-180');
    } else {
        content.classList.add('hidden');
        toggle.classList.remove('rotate-180');
    }
};

window.copyPythonScript = function() {
    const scriptCode = document.getElementById('python-script-code');
    const textContent = scriptCode.textContent;
    
    navigator.clipboard.writeText(textContent).then(() => {
        showNotification('Python script copied to clipboard!', 'success');
    }).catch(err => {
        // Failed to copy script
        showNotification('Failed to copy script', 'error');
    });
};

// Skill Limit Slider Functions
window.updateSkillLimitDisplay = function(value) {
    const limitValueElement = document.getElementById('skill-limit-value');
    if (limitValueElement) {
        limitValueElement.textContent = value;
    }
    
    const limitDisplayElement = document.getElementById('skill-limit-display');
    if (limitDisplayElement) {
        limitDisplayElement.innerHTML = `<i class="fas fa-list mr-1"></i>${value} skills`;
    }
    
    // Update workflow state
    workflowState.skillLimit = parseInt(value);
    
    // Update the skill count display to reflect the new limit
    updateSkillCountDisplay();
};

window.onSkillLimitChange = function(value) {
    workflowState.skillLimit = parseInt(value);
    showNotification(`Skill limit set to ${value}`, 'info');
    // Update the display
    updateSkillCountDisplay();
};

// LLM Provider Change Functions
window.onProviderChange = function() {
    const provider = document.getElementById('llm-provider').value;
    const modelSelect = document.getElementById('llm-model-select');  // Fixed: correct ID
    
    if (!modelSelect) {
        console.warn('Model select element not found');
        return;
    }
    
    // Update models based on provider - currently only Google is supported
    const models = {
        google: ['gemini-2.5-pro', 'gemini-2.5-flash'],
        // Other providers disabled for now
        openai: [],
        anthropic: [],
        grok: []
    };
    
    modelSelect.innerHTML = '<option value="">Select a model...</option>';
    if (models[provider] && models[provider].length > 0) {
        models[provider].forEach((model, index) => {
            const option = document.createElement('option');
            option.value = model;
            option.textContent = model;
            // Set gemini-2.5-pro as default for Google
            if (provider === 'google' && model === 'gemini-2.5-pro') {
                option.selected = true;
            }
            modelSelect.appendChild(option);
        });
    } else if (provider !== 'google') {
        const option = document.createElement('option');
        option.value = '';
        option.textContent = 'Coming Soon - Only Google supported currently';
        option.disabled = true;
        modelSelect.appendChild(option);
    }
    
    // Update summary
    updateLLMSummary();
};

window.onModelChange = function() {
    updateLLMSummary();
};

// Initialize default provider and model on page load
document.addEventListener('DOMContentLoaded', function() {
    // Set default Google provider and model
    const providerSelect = document.getElementById('llm-provider');
    const modelSelect = document.getElementById('llm-model-select');
    const batchSizeInput = document.getElementById('batch-size-input');
    const concurrentBatchesInput = document.getElementById('concurrent-batches-input');
    const processingModeSelect = document.getElementById('processing-mode-select');

    if (providerSelect && modelSelect) {
        providerSelect.value = 'google';
        onProviderChange(); // This will populate the model dropdown

        // Set Google-optimized batch configuration
        if (batchSizeInput) {
            // Match backend: split skills in half
            const skillCount = workflowState.extractedSkills?.length || 1223;
            batchSizeInput.value = Math.ceil((skillCount + 1) / 2);
        }
        if (concurrentBatchesInput) {
            concurrentBatchesInput.value = 1;  // Sequential for Google
        }
        if (processingModeSelect) {
            processingModeSelect.value = 'sequential';
        }

        // Update batch calculations
        updateBatchCalculations();

        // Set default model to gemini-2.5-pro (recommended)
        setTimeout(() => {
            if (modelSelect.querySelector('option[value="gemini-2.5-pro"]')) {
                modelSelect.value = 'gemini-2.5-pro';
                onModelChange();
            }
        }, 100);
    }
    
    // Also load the preset Google key automatically
    loadPresetKey('google');
});

// Update LLM Configuration Summary
function updateLLMSummary() {
    const providerElement = document.getElementById('llm-provider');
    const modelElement = document.getElementById('llm-model-select');  // Fixed: correct ID
    const keySourceElement = document.getElementById('key-source') || document.getElementById('key-method');
    const customKeyElement = document.getElementById('llm-api-key');
    
    // Check if elements exist before accessing
    if (!providerElement || !modelElement) {
        return;
    }
    
    const provider = providerElement.value;
    const model = modelElement.value;
    const keySource = keySourceElement ? keySourceElement.value : '';
    const customKey = customKeyElement ? customKeyElement.value : '';
    
    // Update summary fields if they exist
    const summaryProvider = document.getElementById('llm-summary-provider');
    const summaryModel = document.getElementById('llm-summary-model');
    
    if (summaryProvider) {
        summaryProvider.textContent = provider || 'Not configured';
    }
    if (summaryModel) {
        summaryModel.textContent = model || 'Not selected';
    }
    
    let keyStatus = 'Not provided';
    if (keySource === 'preset') {
        keyStatus = 'Using preset key';
    } else if (customKey) {
        keyStatus = 'Custom key provided';
    }
    
    const summaryKey = document.getElementById('llm-summary-key');
    if (summaryKey) {
        summaryKey.textContent = keyStatus;
    }
    
    // Update status
    const statusElement = document.getElementById('llm-summary-status');
    if (statusElement) {
        if (provider && model && (keySource === 'preset' || customKey)) {
            statusElement.innerHTML = '<span class="text-green-600"><i class="fas fa-check-circle mr-1"></i>Ready</span>';
        } else {
            statusElement.innerHTML = '<span class="text-red-600"><i class="fas fa-times-circle mr-1"></i>Not ready</span>';
        }
    }
}

