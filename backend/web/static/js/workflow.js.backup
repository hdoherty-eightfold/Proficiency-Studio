// Function to update Step 6 with assessment results
function updateStep6WithAssessmentResults() {
    // Updating Step 6 with assessment results
    
    // Check if we have assessment results
    if (!workflowState.assessmentResults) {
        // No assessment results available
        return;
    }
    
    const results = workflowState.assessmentResults;
    const summaryDiv = document.getElementById('step-6-results-summary');
    const statsDiv = document.getElementById('step-6-assessment-stats');
    
    if (summaryDiv && results) {
        // Calculate statistics
        const totalRoles = results.roles?.length || 0;
        const assessedSkills = results.skills?.length || 0;
        const totalSkillsSent = results.total_skills_sent || assessedSkills;
        const proficiencyLevels = results.proficiency_levels || {};
        const uniqueLevels = new Set(Object.values(proficiencyLevels)).size;
        
        // Update summary text
        summaryDiv.innerHTML = `
            <div class="text-green-600 dark:text-green-400">
                <i class="fas fa-check-circle mr-2"></i>
                <strong>Assessment Complete!</strong>
            </div>
            <p class="mt-2">LLM has generated proficiency values for ${assessedSkills} of ${totalSkillsSent} skills across ${totalRoles} roles.</p>
            <p class="mt-2">You can now:</p>
            <ul class="list-disc list-inside mt-2 space-y-1">
                <li><strong>Update to Source:</strong> Apply proficiencies to the same environment</li>
                <li><strong>Create to New Environment:</strong> Create roles with proficiencies in a different environment</li>
                <li><strong>Wipe Proficiencies:</strong> Remove all proficiency data from selected roles</li>
            </ul>
        `;
        
        // Update statistics
        if (statsDiv) {
            statsDiv.classList.remove('hidden');
            document.getElementById('total-roles-count').textContent = totalRoles;
            document.getElementById('total-skills-count').textContent = `${assessedSkills} of ${totalSkillsSent}`;
            document.getElementById('proficiency-levels-count').textContent = uniqueLevels;
        }
        
        // Store results for Step 6 operations
        workflowState.step6Data = {
            roles: results.roles,
            skills: results.skills,
            total_skills_sent: results.total_skills_sent || results.skills?.length || 0,
            proficiencyLevels: proficiencyLevels,
            timestamp: new Date().toISOString()
        };
    }
}

// JIE Roles History Management Functions
function saveJIERolesToHistory(isAutoSave = false) {
    if (!workflowState.jieRoles || workflowState.jieRoles.length === 0) {
        if (!isAutoSave) {
            showNotification('No JIE roles to save. Please fetch roles first.', 'warning');
        }
        return;
    }
    
    // Get existing history from localStorage with error handling
    let history = [];
    try {
        history = JSON.parse(localStorage.getItem('jieRolesHistory') || '[]');
    } catch (e) {
        localStorage.removeItem('jieRolesHistory');
    }
    
    // Get environment name for display
    const envSelect = document.getElementById('sandbox-selector');
    const envName = envSelect?.options[envSelect.selectedIndex]?.text || envSelect?.value || 'unknown';
    const environment = document.getElementById('sandbox-selector')?.value || 'unknown';
    
    // Create a content hash for duplicate detection
    const createContentHash = () => {
        const roleSignature = workflowState.jieRoles
            .slice(0, 10)
            .map(r => r.title || r.name || '')
            .sort()
            .join('|');
        const skillSignature = (workflowState.extractedSkills || [])
            .slice(0, 20)
            .map(s => s.name)
            .sort()
            .join('|');
        return `${environment}_${workflowState.jieRoles.length}_${workflowState.extractedSkills?.length || 0}_${roleSignature}_${skillSignature}`;
    };
    
    const contentHash = createContentHash();
    
    // Check for duplicate entries using content hash
    const isDuplicate = history.some(entry => {
        // Quick check: same environment and same content hash
        if (entry.contentHash && entry.contentHash === contentHash) {
            // Update the timestamp of the existing entry instead of creating duplicate
            entry.timestamp = new Date().toISOString();
            const timestamp = new Date();
            const dateStr = timestamp.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
            const timeStr = timestamp.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
            entry.displayName = `JIE Roles - ${envName} - ${dateStr} ${timeStr} - ${workflowState.jieRoles.length} roles, ${workflowState.extractedSkills?.length || 0} skills`;
            
            // Also update the data in case there were minor changes
            entry.roles = workflowState.jieRoles;
            entry.extractedSkills = workflowState.extractedSkills;
            entry.metadata = {
                totalRoles: workflowState.jieRoles.length,
                totalSkills: workflowState.extractedSkills?.length || 0,
                uniqueSkills: workflowState.extractedSkills?.length || 0,
                rolesWithSkills: workflowState.jieRoles.filter(r => r.skillProficiencies?.length > 0).length,
                autoSaved: isAutoSave
            };
            return true;
        }
        return false;
    });
    
    if (isDuplicate) {
        // Save the updated history with new timestamp
        try {
            localStorage.setItem('jieRolesHistory', JSON.stringify(history));
            if (!isAutoSave) {
                showNotification('Updated existing history entry with new timestamp', 'info');
            }
        } catch (e) {
            console.error('Failed to update history:', e);
        }
        return; // Don't add a new entry
    }
    
    // Create timestamp for display
    const timestamp = new Date();
    const dateStr = timestamp.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
    const timeStr = timestamp.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
    
    // Create display name with better formatting like LangChain responses
    const displayName = `JIE Roles - ${envName} - ${dateStr} ${timeStr} - ${workflowState.jieRoles.length} roles, ${workflowState.extractedSkills?.length || 0} skills`;
    
    // Create history entry with FULL API response data to avoid repeated API calls
    const historyEntry = {
        id: Date.now().toString(),
        displayName: displayName,
        timestamp: new Date().toISOString(),
        environment: environment,
        environmentName: envName,
        contentHash: contentHash, // Store hash for future duplicate detection
        // Store FULL data from API to avoid re-fetching
        roles: workflowState.jieRoles, // Full roles data from API
        extractedSkills: workflowState.extractedSkills, // Full extracted skills
        metadata: {
            totalRoles: workflowState.jieRoles.length,
            totalSkills: workflowState.extractedSkills?.length || 0,
            uniqueSkills: workflowState.extractedSkills?.length || 0,
            rolesWithSkills: workflowState.jieRoles.filter(r => r.skillProficiencies?.length > 0).length,
            autoSaved: isAutoSave
        }
    };
    
    // Smart history management - keep fewer entries but with full data
    history.unshift(historyEntry);
    
    // Calculate total size and manage entries intelligently
    let totalSize = JSON.stringify(history).length;
    const maxSize = 4 * 1024 * 1024; // 4MB limit (safe under 5MB localStorage limit)
    
    // If too large, remove oldest entries until within limit
    while (totalSize > maxSize && history.length > 1) {
        history.pop(); // Remove oldest entry
        totalSize = JSON.stringify(history).length;
    }
    
    // Keep maximum 3 full entries to balance storage vs functionality
    if (history.length > 3) {
        history = history.slice(0, 3);
    }
    
    // Save to localStorage with error handling
    try {
        localStorage.setItem('jieRolesHistory', JSON.stringify(history));
    } catch (e) {
        // If quota exceeded, clear history and try to save just current entry
        if (e.name === 'QuotaExceededError') {
            localStorage.removeItem('jieRolesHistory');
            try {
                localStorage.setItem('jieRolesHistory', JSON.stringify([historyEntry]));
            } catch (e2) {
                // Silently fail if we can't save even a single entry
            }
        }
    }
    
    // Auto-save completed
    
    // Only show notification for manual saves (not auto-saves)
    if (!isAutoSave) {
        showNotification(`Saved ${historyEntry.metadata.totalRoles} roles with ${historyEntry.metadata.totalSkills} skills to history`, 'success');
    }
}

function exportJIERoles() {
    if (!workflowState.jieRoles || workflowState.jieRoles.length === 0) {
        showNotification('No JIE roles to export. Please fetch roles first.', 'warning');
        return;
    }
    
    const exportData = {
        timestamp: new Date().toISOString(),
        environment: document.getElementById('sandbox-selector')?.value || 'unknown',
        roles: workflowState.jieRoles,
        extractedSkills: workflowState.extractedSkills,
        metadata: {
            totalRoles: workflowState.jieRoles.length,
            totalSkills: workflowState.extractedSkills?.length || 0,
            exportedBy: 'Skills Proficiency Generator',
            version: '1.0'
        }
    };
    
    // Create formatted filename with environment and timestamp
    const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, -5);
    const envName = (document.getElementById('sandbox-selector')?.value || 'unknown').replace(/\s+/g, '_');
    const filename = `jie_roles_${envName}_${exportData.metadata.totalRoles}roles_${exportData.metadata.totalSkills}skills_${timestamp}.json`;
    
    // Create download
    const blob = new Blob([JSON.stringify(exportData, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
    
    showNotification(`Exported ${exportData.metadata.totalRoles} roles to JSON file`, 'success');
}

function showJIERolesHistory() {
    
    const modal = document.getElementById('jie-roles-history-modal');
    const historyList = document.getElementById('jie-roles-history-list');
    const emptyState = document.getElementById('jie-roles-history-empty');
    
    if (!modal) {
        // JIE roles history modal not found
        showNotification('History modal not found. Please refresh the page.', 'error');
        return;
    }
    
    // Get history from localStorage
    const history = JSON.parse(localStorage.getItem('jieRolesHistory') || '[]');
    
    if (history.length === 0) {
        // Show empty state
        historyList.style.display = 'none';
        emptyState.style.display = 'block';
    } else {
        // Hide empty state
        historyList.style.display = 'block';
        emptyState.style.display = 'none';
        
        // Populate history list
        historyList.innerHTML = history.map(entry => {
            const date = new Date(entry.timestamp);
            const dateStr = date.toLocaleDateString() + ' ' + date.toLocaleTimeString();
            
            return `
                <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-4 hover:shadow-md transition-shadow">
                    <div class="flex justify-between items-start">
                        <div class="flex-1">
                            <div class="mb-2">
                                <div class="text-base font-semibold text-gray-800 dark:text-gray-200 mb-1">
                                    ${entry.displayName || `${entry.environmentName || entry.environment} - ${entry.metadata.totalRoles} roles`}
                                </div>
                                <div class="flex items-center gap-2">
                                    ${entry.metadata?.autoSaved ? '<span class="px-2 py-1 bg-green-100 text-green-700 rounded text-xs"><i class="fas fa-robot mr-1"></i>Auto-saved</span>' : ''}
                                </div>
                            </div>
                            <div class="grid grid-cols-4 gap-4 text-sm">
                                <div>
                                    <span class="text-gray-500">Roles:</span>
                                    <span class="ml-1 font-semibold">${entry.metadata.totalRoles}</span>
                                </div>
                                <div>
                                    <span class="text-gray-500">Skills:</span>
                                    <span class="ml-1 font-semibold">${entry.metadata.totalSkills}</span>
                                </div>
                                <div>
                                    <span class="text-gray-500">Unique:</span>
                                    <span class="ml-1 font-semibold">${entry.metadata.uniqueSkills}</span>
                                </div>
                                <div>
                                    <span class="text-gray-500">With Skills:</span>
                                    <span class="ml-1 font-semibold">${entry.metadata.rolesWithSkills}</span>
                                </div>
                            </div>
                        </div>
                        <div class="flex gap-2">
                            <button onclick="loadJIERolesFromHistory('${entry.id}')" 
                                    class="bg-green-600 text-white px-3 py-1 rounded text-sm hover:bg-green-700">
                                <i class="fas fa-upload mr-1"></i>Load
                            </button>
                            <button onclick="exportJIERolesFromHistory('${entry.id}')" 
                                    class="bg-blue-600 text-white px-3 py-1 rounded text-sm hover:bg-blue-700">
                                <i class="fas fa-download mr-1"></i>Export
                            </button>
                            <button onclick="deleteJIERolesFromHistory('${entry.id}')" 
                                    class="bg-red-600 text-white px-3 py-1 rounded text-sm hover:bg-red-700">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
            `;
        }).join('');
    }
    
    // Show modal - remove hidden and add flex to display it
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    modal.style.display = 'flex'; // Ensure it's visible
}

function closeJIERolesHistory() {
    const modal = document.getElementById('jie-roles-history-modal');
    if (modal) {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        modal.style.display = 'none';
    }
}

function loadJIERolesFromHistory(entryId) {
    const history = JSON.parse(localStorage.getItem('jieRolesHistory') || '[]');
    const entry = history.find(h => h.id === entryId);
    
    if (!entry) {
        showNotification('History entry not found', 'error');
        return;
    }
    
    // Load the full API response data from history (avoiding new API call)
    workflowState.jieRoles = entry.roles || [];
    workflowState.extractedSkills = entry.extractedSkills || [];
    workflowState.skillsLoaded = true;

    // Update skills count and batch calculations
    updateSkillsCount();

    // Update UI
    updateSkillCountDisplay();
    
    // Update skill limit slider
    const skillLimitSlider = document.getElementById('skill-limit-slider');
    if (skillLimitSlider && entry.extractedSkills?.length > 0) {
        skillLimitSlider.max = entry.extractedSkills.length;
        skillLimitSlider.value = entry.extractedSkills.length;
        updateSkillLimitDisplay(entry.extractedSkills.length);
        workflowState.skillLimit = entry.extractedSkills.length;
    }
    
    // Update JIE Roles Summary
    const rolesSummary = document.getElementById('jie-roles-summary');
    if (rolesSummary && entry.roles) {
        // Get top 5 roles with most skills
        const sortedRoles = [...entry.roles]
            .sort((a, b) => (b.skillProficiencies?.length || 0) - (a.skillProficiencies?.length || 0))
            .slice(0, 5);
        
        let summaryHTML = `
            <div class="grid grid-cols-2 gap-3 mb-3">
                <div class="bg-white dark:bg-gray-800 rounded p-2">
                    <div class="text-2xl font-bold text-blue-600 dark:text-blue-400">${entry.roles.length}</div>
                    <div class="text-xs text-gray-600 dark:text-gray-400">Total Roles</div>
                </div>
                <div class="bg-white dark:bg-gray-800 rounded p-2">
                    <div class="text-2xl font-bold text-green-600 dark:text-green-400">${entry.extractedSkills?.length || 0}</div>
                    <div class="text-xs text-gray-600 dark:text-gray-400">Unique Skills</div>
                </div>
            </div>
            <div class="space-y-1">
                <div class="text-xs font-semibold text-gray-700 dark:text-gray-300 mb-1">Top Roles by Skill Count:</div>
        `;
        
        sortedRoles.forEach(role => {
            const skillCount = role.skillProficiencies?.length || 0;
            summaryHTML += `
                <div class="flex justify-between items-center text-xs py-1 border-b border-gray-200 dark:border-gray-600">
                    <span class="text-gray-700 dark:text-gray-300 truncate flex-1 mr-2" title="${role.title}">${role.title}</span>
                    <span class="text-gray-500 dark:text-gray-400 font-semibold">${skillCount} skills</span>
                </div>
            `;
        });
        
        if (entry.roles.length > 5) {
            summaryHTML += `
                <div class="text-xs text-gray-500 dark:text-gray-400 italic mt-2">
                    ... and ${entry.roles.length - 5} more roles
                </div>
            `;
        }
        
        summaryHTML += '</div>';
        rolesSummary.innerHTML = summaryHTML;
    }
    
    // Update total skills count
    const totalSkillsCount = document.getElementById('total-skills-count');
    if (totalSkillsCount) {
        totalSkillsCount.textContent = entry.extractedSkills?.length || 0;
    }
    
    // Show export button
    const exportBtn = document.getElementById('export-jie-roles-btn');
    if (exportBtn) exportBtn.style.display = 'block';
    
    // Populate role dropdowns for Step 6
    if (entry.roles) {
        populateRoleDropdown(entry.roles);
        populateRoleManagementDropdown(entry.roles);
    }
    
    // Close modal
    closeJIERolesHistory();
    
    showNotification(`Loaded ${entry.metadata.totalRoles} roles with ${entry.metadata.totalSkills} skills from history`, 'success');
}

function exportJIERolesFromHistory(entryId) {
    const history = JSON.parse(localStorage.getItem('jieRolesHistory') || '[]');
    const entry = history.find(h => h.id === entryId);
    
    if (!entry) {
        showNotification('History entry not found', 'error');
        return;
    }
    
    // Export the full API response data
    const exportData = {
        id: entry.id,
        displayName: entry.displayName,
        timestamp: entry.timestamp,
        environment: entry.environment,
        environmentName: entry.environmentName,
        roles: entry.roles || [],
        extractedSkills: entry.extractedSkills || [],
        metadata: entry.metadata,
        source: 'JIE Roles History Export'
    };
    
    // Create formatted filename from entry data
    const timestamp = new Date(entry.timestamp).toISOString().replace(/[:.]/g, '-').slice(0, -5);
    const envName = (entry.environment || 'unknown').replace(/\s+/g, '_');
    const filename = `jie_roles_${envName}_${entry.metadata?.totalRoles || 0}roles_${entry.metadata?.totalSkills || 0}skills_${timestamp}.json`;
    
    // Create download
    const blob = new Blob([JSON.stringify(exportData, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
    
    showNotification(`Exported ${entry.metadata?.totalRoles || 0} roles with ${entry.metadata?.totalSkills || 0} skills to JSON file`, 'success');
}

function deleteJIERolesFromHistory(entryId) {
    if (!confirm('Are you sure you want to delete this history entry?')) {
        return;
    }
    
    let history = JSON.parse(localStorage.getItem('jieRolesHistory') || '[]');
    history = history.filter(h => h.id !== entryId);
    localStorage.setItem('jieRolesHistory', JSON.stringify(history));
    
    // Refresh the modal
    showJIERolesHistory();
    
    showNotification('History entry deleted', 'success');
}

function clearJIERolesHistory() {
    if (!confirm('Are you sure you want to clear all JIE roles history? This cannot be undone.')) {
        return;
    }
    
    try {
        localStorage.removeItem('jieRolesHistory');
        
        // Refresh the modal
        showJIERolesHistory();
        
        showNotification('JIE roles history cleared', 'success');
    } catch (e) {
        showNotification('Failed to clear history', 'error');
    }
}

// Helper function to check and fix localStorage quota issues
function checkAndFixLocalStorageQuota() {
    try {
        // Try to get the current size of jieRolesHistory
        const historyStr = localStorage.getItem('jieRolesHistory');
        if (historyStr) {
            const sizeInKB = (historyStr.length * 2) / 1024; // Approximate size in KB (2 bytes per character)
            
            // Clean up if over 4MB (we're storing full API data now)
            if (sizeInKB > 4096) { // 4MB threshold for full data
                try {
                    const history = JSON.parse(historyStr);
                    // Keep only the most recent entry with full data
                    const cleanedHistory = history.slice(0, 1);
                    localStorage.setItem('jieRolesHistory', JSON.stringify(cleanedHistory));
                } catch (e) {
                    localStorage.removeItem('jieRolesHistory');
                }
            }
        }
    } catch (e) {
        // If there's any error, just clear the problematic data
        localStorage.removeItem('jieRolesHistory');
    }
}

