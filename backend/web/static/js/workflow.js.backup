// Workflow JavaScript for Skills Proficiency Generator
// This handles the streamlined workflow: Auth -> Skills -> Prompt -> LLM

// Google API Keys Management
window.googleApiKeys = {
    keys: [],
    activeKeyIndex: null,

    // Initialize with some default keys
    init() {
        const savedKeys = localStorage.getItem('googleApiKeys');
        if (savedKeys) {
            try {
                const parsed = JSON.parse(savedKeys);
                this.keys = parsed.keys || [];
                this.activeKeyIndex = parsed.activeKeyIndex || null;
            } catch (e) {
                console.error('Failed to parse saved Google API keys:', e);
            }
        }

        // Don't add default keys for security - require manual configuration
        if (this.keys.length === 0) {
            console.warn('No Google API keys configured. Please add keys manually via the UI.');
            // Don't initialize with hardcoded keys for security
            this.activeKeyIndex = null;
        }

        this.updateUI();
        // Also update the Google key selector dropdown after init
        setTimeout(() => {
            if (typeof updateGoogleKeySelector === 'function') {
                updateGoogleKeySelector();
            }
        }, 100);
    },

    add(name, key) {
        console.log('googleApiKeys.add called with:', { name, key });
        this.keys.push({ name, key, failCount: 0, addedAt: Date.now() });
        console.log('Keys after push:', this.keys);
        this.save();
        this.updateUI();
        // Update the Google key selector dropdown
        if (typeof updateGoogleKeySelector === 'function') {
            updateGoogleKeySelector();
        }
        // Update modal if it's open
        if (typeof updateModalKeysList === 'function') {
            console.log('Calling updateModalKeysList from add');
            updateModalKeysList();
        }
    },

    remove(index) {
        this.keys.splice(index, 1);
        if (this.activeKeyIndex >= this.keys.length) {
            this.activeKeyIndex = this.keys.length > 0 ? 0 : null;
        }
        this.save();
        this.updateUI();
        // Update the Google key selector dropdown
        if (typeof updateGoogleKeySelector === 'function') {
            updateGoogleKeySelector();
        }
    },

    setActive(index) {
        this.activeKeyIndex = index;
        this.save();
        this.updateUI();
        // Update the Google key selector dropdown
        if (typeof updateGoogleKeySelector === 'function') {
            updateGoogleKeySelector();
        }

        // Update the main API key input
        if (index !== null && this.keys[index]) {
            const keyInput = document.getElementById('llm-api-key');
            if (keyInput) {
                keyInput.value = this.keys[index].key;
            }
        }
    },

    getActiveKey() {
        if (this.activeKeyIndex !== null && this.keys[this.activeKeyIndex]) {
            return this.keys[this.activeKeyIndex].key;
        }
        return null;
    },

    markFailed(key) {
        const keyObj = this.keys.find(k => k.key === key);
        if (keyObj) {
            keyObj.failCount++;
            keyObj.lastFailed = new Date().toISOString();
            this.save();

            // Auto-switch to next available key
            const nextKey = this.getNextAvailableKey();
            if (nextKey !== null) {
                this.setActive(nextKey);
                showNotification(`Switched to ${this.keys[nextKey].name} API key due to rate limit`, 'info');
            }
        }
    },

    getNextAvailableKey() {
        // Find a key that hasn't failed recently
        const now = Date.now();
        const cooldownPeriod = 60000; // 1 minute cooldown

        for (let i = 0; i < this.keys.length; i++) {
            const key = this.keys[i];
            if (!key.lastFailed || (now - new Date(key.lastFailed).getTime()) > cooldownPeriod) {
                return i;
            }
        }
        return null;
    },

    save() {
        localStorage.setItem('googleApiKeys', JSON.stringify({
            keys: this.keys,
            activeKeyIndex: this.activeKeyIndex
        }));
    },

    updateUI() {
        const selectElement = document.getElementById('google-active-key');

        // Update the dropdown in Step 4
        if (selectElement) {
            selectElement.innerHTML = '<option value="">Select a Google API key...</option>';
            this.keys.forEach((keyObj, index) => {
                const option = document.createElement('option');
                option.value = index;
                option.textContent = `${keyObj.name} ${keyObj.failCount > 0 ? `(${keyObj.failCount} fails)` : ''}`;
                option.selected = index === this.activeKeyIndex;
                selectElement.appendChild(option);
            });

            // Update selected key info if it exists
            const keyInfo = document.getElementById('selected-key-info');
            const keyName = document.getElementById('active-key-name');
            const statusIndicator = document.getElementById('key-status-indicator');

            if (this.activeKeyIndex !== null && this.activeKeyIndex < this.keys.length) {
                const activeKey = this.keys[this.activeKeyIndex];

                if (keyInfo) {
                    keyInfo.classList.remove('hidden');
                }

                if (keyName) {
                    keyName.textContent = activeKey.name;
                }

                if (statusIndicator) {
                    if (activeKey.failCount > 0) {
                        statusIndicator.innerHTML = `
                            <div class="w-2 h-2 bg-red-500 rounded-full mr-2"></div>
                            <span class="text-sm text-red-600 dark:text-red-400">Failed (${activeKey.failCount} times)</span>
                        `;
                    } else {
                        statusIndicator.innerHTML = `
                            <div class="w-2 h-2 bg-green-500 rounded-full mr-2"></div>
                            <span class="text-sm text-green-600 dark:text-green-400">Ready</span>
                        `;
                    }
                }
            } else if (keyInfo) {
                keyInfo.classList.add('hidden');
            }
        }

        // Also update modal list if it's open
        if (document.getElementById('modal-keys-list') && window.updateModalKeysList) {
            window.updateModalKeysList();
        }
    },

    updateName(index, name) {
        if (this.keys[index]) {
            this.keys[index].name = name;
            this.save();
            this.updateUI();
        }
    },

    updateKey(index, key) {
        if (this.keys[index]) {
            this.keys[index].key = key;
            this.keys[index].failCount = 0; // Reset fail count for new key
            delete this.keys[index].lastFailed;
            this.save();
        }
    }
};

// Initialize Google API keys on page load
document.addEventListener('DOMContentLoaded', () => {
    window.googleApiKeys.init();
});

// Helper functions for Google API key management
function addGoogleApiKey() {
    const name = prompt('Enter a name for this API key:');
    const key = prompt('Enter the Google API key:');

    if (name && key) {
        window.googleApiKeys.add(name, key);
        showNotification(`Added Google API key: ${name}`, 'success');
    }
}

function selectGoogleKey() {
    const selectElement = document.getElementById('google-active-key');
    if (selectElement && selectElement.value !== '') {
        window.googleApiKeys.setActive(parseInt(selectElement.value));
        showNotification(`Switched to ${window.googleApiKeys.keys[selectElement.value].name} API key`, 'success');
    }
}

// Modal functions for Google API Key Management
window.showManageKeysModal = function() {
    const modal = document.getElementById('manage-keys-modal');
    if (modal) {
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        updateModalKeysList();
    }
}

window.closeManageKeysModal = function() {
    const modal = document.getElementById('manage-keys-modal');
    if (modal) {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
    }
}

window.showAddKeyModal = function() {
    // Clear the input fields
    const nameInput = document.getElementById('new-key-name');
    const valueInput = document.getElementById('new-key-value');

    if (nameInput) nameInput.value = '';
    if (valueInput) valueInput.value = '';

    // Show the manage keys modal with focus on add section
    showManageKeysModal();

    // Focus on the name input
    setTimeout(() => {
        if (nameInput) nameInput.focus();
    }, 100);
}

window.addNewKeyFromModal = function() {
    console.log('addNewKeyFromModal called');

    const nameInput = document.getElementById('new-key-name');
    const valueInput = document.getElementById('new-key-value');

    console.log('Input elements:', { nameInput, valueInput });

    if (!nameInput || !valueInput) {
        console.error('Input elements not found');
        return;
    }

    const name = nameInput.value.trim();
    const key = valueInput.value.trim();

    console.log('Values:', { name, key });

    if (!name) {
        alert('Please enter a name for the API key');
        nameInput.focus();
        return;
    }

    if (!key) {
        alert('Please enter the API key');
        valueInput.focus();
        return;
    }

    console.log('Before add - keys:', window.googleApiKeys.keys);

    // Add the key - this will trigger updateUI and updateModalKeysList
    window.googleApiKeys.add(name, key);

    console.log('After add - keys:', window.googleApiKeys.keys);

    // Clear inputs
    nameInput.value = '';
    valueInput.value = '';

    // Force update the modal list
    if (typeof updateModalKeysList === 'function') {
        console.log('Calling updateModalKeysList');
        updateModalKeysList();
    } else {
        console.error('updateModalKeysList not found!');
    }

    // Show success
    if (typeof showNotification === 'function') {
        showNotification(`Added Google API key: ${name}`, 'success');
    }
}

function updateModalKeysList() {
    const listContainer = document.getElementById('modal-keys-list');
    const noKeysMessage = document.getElementById('no-keys-message');

    if (!listContainer) {
        return;
    }

    if (window.googleApiKeys.keys.length === 0) {
        listContainer.innerHTML = '';
        if (noKeysMessage) {
            noKeysMessage.classList.remove('hidden');
        }
        return;
    }

    if (noKeysMessage) {
        noKeysMessage.classList.add('hidden');
    }

    listContainer.innerHTML = window.googleApiKeys.keys.map((key, index) => {
        const isActive = index === window.googleApiKeys.activeKeyIndex;
        const isFailed = key.failedAt && (Date.now() - key.failedAt < 3600000); // Failed within last hour

        return `
            <div class="flex items-center justify-between p-3 bg-white dark:bg-gray-700 rounded-lg border ${
                isActive ? 'border-green-500 bg-green-50 dark:bg-green-900/20' : 'border-gray-200 dark:border-gray-600'
            }">
                <div class="flex items-center space-x-3">
                    <div>
                        <div class="font-medium ${isActive ? 'text-green-700 dark:text-green-300' : 'text-gray-900 dark:text-white'}">
                            ${key.name}
                            ${isActive ? '<span class="ml-2 text-xs bg-green-100 dark:bg-green-900 text-green-600 dark:text-green-400 px-2 py-1 rounded">Active</span>' : ''}
                            ${isFailed ? '<span class="ml-2 text-xs bg-red-100 dark:bg-red-900 text-red-600 dark:text-red-400 px-2 py-1 rounded">Rate Limited</span>' : ''}
                        </div>
                        <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                            ${key.key.substring(0, 20)}...
                            ${key.addedAt ? `• Added ${new Date(key.addedAt).toLocaleDateString()}` : ''}
                        </div>
                    </div>
                </div>
                <div class="flex items-center space-x-2">
                    ${!isActive ? `
                        <button onclick="setActiveKeyFromModal(${index})" class="text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300">
                            <i class="fas fa-check-circle"></i>
                        </button>
                    ` : ''}
                    <button onclick="removeKeyFromModal(${index})" class="text-red-600 hover:text-red-800 dark:text-red-400 dark:hover:text-red-300">
                        <i class="fas fa-trash"></i>
                    </button>
                </div>
            </div>
        `;
    }).join('');
}

window.setActiveKeyFromModal = function(index) {
    window.googleApiKeys.setActive(index);
    showNotification(`Switched to ${window.googleApiKeys.keys[index].name} API key`, 'success');
    updateModalKeysList();
    updateGoogleKeySelector();
}

window.removeKeyFromModal = function(index) {
    const key = window.googleApiKeys.keys[index];
    if (confirm(`Are you sure you want to remove the API key "${key.name}"?`)) {
        window.googleApiKeys.remove(index);
        showNotification(`Removed API key: ${key.name}`, 'success');
        updateModalKeysList();
        updateGoogleKeySelector();
    }
}

function updateGoogleKeySelector() {
    const selector = document.getElementById('google-key-selector');
    if (!selector) return;

    selector.innerHTML = '<option value="">Select a Google API key...</option>';

    window.googleApiKeys.keys.forEach((key, index) => {
        const option = document.createElement('option');
        option.value = index;
        option.textContent = key.name;
        if (index === window.googleApiKeys.activeKeyIndex) {
            option.selected = true;
        }
        selector.appendChild(option);
    });
}

// Helper function to get the correct Eightfold API base URL
function getEightfoldApiUrl(environment) {
    // Default to production if no environment specified
    if (!environment) {
        environment = document.getElementById('environment-select')?.value || 'production';
    }
    
    // All environments use the same API URL
    // Sandbox vs production is determined by credentials, not URL
    return 'https://apiv2.eightfold.ai';
}

// Tab switching functionality
function switchTab(tabName) {
    // console.log('switchTab called with:', tabName);
    
    // First, ensure no modals are interfering
    document.querySelectorAll('.fixed.inset-0').forEach(modal => {
        if (!modal.classList.contains('tab-content')) {
            // console.log('Found modal, ensuring it is hidden:', modal.id || modal.className);
            modal.style.display = 'none';
        }
    });
    
    // Hide all tab contents using both methods for safety
    document.querySelectorAll('.tab-content').forEach(content => {
        // console.log('Hiding tab:', content.id);
        content.style.display = 'none';
        content.classList.add('hidden');
    });
    
    // Remove active state from all tabs
    document.querySelectorAll('.tab-button').forEach(button => {
        button.classList.remove('border-blue-500', 'text-blue-600', 'dark:border-blue-400', 'dark:text-blue-400');
        button.classList.add('border-transparent', 'text-gray-500', 'dark:text-gray-400');
    });
    
    // Show selected tab content with force
    const selectedContent = document.getElementById(`tab-content-${tabName}`);
    // console.log('Looking for tab:', `tab-content-${tabName}`);
    // console.log('Found element:', selectedContent);
    
    if (selectedContent) {
        // Remove hidden class and force display
        selectedContent.classList.remove('hidden');
        selectedContent.style.display = 'block';
        selectedContent.style.visibility = 'visible';
        selectedContent.style.opacity = '1';
        
        // Force browser reflow
        void selectedContent.offsetHeight;
        
        // Double-check it's visible
        const computed = window.getComputedStyle(selectedContent);
        // console.log(`Tab ${tabName} - Display: ${computed.display}, Visibility: ${computed.visibility}, Opacity: ${computed.opacity}`);
        
        // If still not visible, try more aggressive approach
        if (computed.display === 'none') {
            // console.warn('Tab still hidden, applying override styles');
            selectedContent.style.setProperty('display', 'block', 'important');
        }
    } else {
        // console.error(`Tab content not found: tab-content-${tabName}`);
    }
    
    // Set active state on selected tab
    const selectedTab = document.getElementById(`tab-${tabName}`);
    if (selectedTab) {
        selectedTab.classList.remove('border-transparent', 'text-gray-500', 'dark:text-gray-400');
        selectedTab.classList.add('border-blue-500', 'text-blue-600', 'dark:border-blue-400', 'dark:text-blue-400');
    }
    
    // Initialize API Explorer when switching to it
    if (tabName === 'api-explorer' && window.initializeApiExplorer) {
        // Small delay to ensure DOM is ready
        setTimeout(() => {
            window.initializeApiExplorer();
        }, 100);
    }
}

// Make switchTab globally available
window.switchTab = switchTab;

// Debug function to check tab states
function debugTabs() {
    // Tab debug information
    
    // Check all tab contents
    document.querySelectorAll('.tab-content').forEach((tab, index) => {
        const computed = window.getComputedStyle(tab);
        const rect = tab.getBoundingClientRect();
        
        // Tab details logged
        
        // Check if any parent is hiding it
        let parent = tab.parentElement;
        let level = 1;
        while (parent && level <= 5) {
            const parentComputed = window.getComputedStyle(parent);
            if (parentComputed.display === 'none' || parentComputed.visibility === 'hidden') {
                // Parent visibility issue detected
            }
            parent = parent.parentElement;
            level++;
        }
    });
    
    // Check for any interfering modals
    document.querySelectorAll('.fixed.inset-0').forEach((modal, index) => {
        const computed = window.getComputedStyle(modal);
        // Modal state checked
    });
    
    // console.log('=== END DEBUG ===');
    
    // Show alert with summary
    const apiExplorer = document.getElementById('tab-content-api-explorer');
    if (apiExplorer) {
        const computed = window.getComputedStyle(apiExplorer);
        showNotification('API Explorer debug info logged to console', 'info');
        // console.log(`API Explorer Tab:\nHidden class: ${apiExplorer.classList.contains('hidden')}\nDisplay: ${computed.display}`);
    }
}

// Make debugTabs globally available
window.debugTabs = debugTabs;

